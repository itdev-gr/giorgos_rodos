---
import { resolveLocale } from '../../i18n/context';
import { getMessages } from '../../i18n';
import { buildFooterLinks } from '../../i18n/nav-links';

const locale = resolveLocale(Astro.locals, Astro.url.pathname);
const messages = getMessages(locale);
const links = buildFooterLinks(messages.nav, messages.footer, locale);
---

<footer class="site-footer">
  <div class="container">
    <div style="display: grid; grid-template-columns: 1.2fr 2fr 1fr; gap: 48px; padding-bottom: 48px; border-bottom: 1px solid rgba(255,255,255,0.08);" class="ft-main">
      <!-- Brand -->
      <div class="ft-brand">
        <a href={links.homeHref}>
          <img src="/assets/img/brand/logos/logo-traced.svg" alt={messages.brand} style="height: 100px; margin-bottom: 16px; filter: brightness(0) invert(1);" />
        </a>
        <p class="ft-tagline">{messages.footer.tagline}</p>
        <div class="ft-social">
          <a href="https://www.instagram.com/" aria-label="Instagram"><i class="fab fa-instagram"></i></a>
          <a href="https://www.facebook.com/" aria-label="Facebook"><i class="fab fa-facebook-f"></i></a>
          <a href="https://www.whatsapp.com/" aria-label="WhatsApp"><i class="fab fa-whatsapp"></i></a>
        </div>
        <a href="https://rhodesthingstodo.com" class="ft-badge" target="_blank" rel="noopener noreferrer">
          <img src="https://rhodesthingstodo.com/badge.svg" alt="Featured on Rhodes Things To Do" width="210" height="54" loading="lazy" style="border:0" />
        </a>
      </div>

      <!-- Links -->
      <div style="display: flex; gap: 48px;" class="ft-links">
        <div class="ft-col">
          <h3 class="ft-heading">{messages.footer.company}</h3>
          <ul class="ft-list">
            {links.company.map((item) => (
              <li><a href={item.href}>{item.label}</a></li>
            ))}
          </ul>
        </div>
        <div class="ft-col">
          <h3 class="ft-heading">{messages.footer.services}</h3>
          <ul class="ft-list">
            {links.services.map((item) => (
              <li>
                <a
                  href={item.href}
                  target={'external' in item && item.external ? '_blank' : undefined}
                  rel={'external' in item && item.external ? 'noopener noreferrer' : undefined}
                >
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Contact -->
      <div class="ft-contact">
        <h3 class="ft-heading">{messages.footer.getInTouch}</h3>
        <a href="mailto:rhodessailingtours2023@gmail.com" class="ft-contact-link">rhodessailingtours2023@gmail.com</a>
        <a href="tel:+306951666454" class="ft-contact-link">+30 695 166 6454</a>
        <p class="ft-contact-link ft-address">Ionos Dragoumi 39, Rhodes 851 00</p>
      </div>
    </div>

    <!-- Bottom -->
    <div class="ft-bottom">
      <p class="ft-bottom-text ft-bottom-left">{messages.footer.copyright}</p>
      <p class="ft-bottom-text ft-bottom-center">{messages.footer.developedBy} <a href="https://itdev.gr" class="ft-bottom-link">IT DEV</a></p>
      <div class="ft-bottom-links ft-bottom-right">
        {links.legal.map((item) => (
          <a href={item.href}>{item.label}</a>
        ))}
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: #0e2f38;
    color: #fff;
    padding: 64px 0 0;
  }

  .site-footer a,
  .site-footer p,
  .site-footer li {
    color: #fff;
  }

  /* Tagline */
  .ft-tagline {
    font-size: 1.05rem;
    line-height: 1.6;
    opacity: 0.85;
    margin-bottom: 20px;
  }

  .ft-social {
    display: flex;
    gap: 12px;
  }

  .ft-badge {
    display: inline-block;
    margin-top: 20px;
  }

  .ft-badge img {
    display: block;
    height: auto;
  }

  .ft-social a {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s ease;
  }

  .ft-social a:hover {
    background: rgba(255,255,255,0.1);
  }

  .ft-heading {
    color: #fff;
    font-size: 1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 20px;
  }

  .ft-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .ft-list li {
    margin-bottom: 10px;
  }

  .ft-list a {
    opacity: 0.85;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .ft-list a:hover {
    opacity: 1;
    color: #1CA8CB;
  }

  .ft-contact-link {
    display: block;
    margin-bottom: 10px;
    text-decoration: none;
    opacity: 0.85;
  }

  .ft-contact-link:hover {
    opacity: 1;
    color: #1CA8CB;
  }

  .ft-address {
    margin-top: 8px;
  }

  .ft-bottom {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    align-items: center;
    padding: 24px 0;
    gap: 16px;
  }

  .ft-bottom-text {
    margin: 0;
    font-size: 0.875rem;
    opacity: 0.7;
  }

  .ft-bottom-center {
    text-align: center;
  }

  .ft-bottom-left {
    text-align: left;
  }

  .ft-bottom-link {
    color: #1CA8CB;
    text-decoration: none;
  }

  .ft-bottom-links {
    display: flex;
    gap: 20px;
    justify-content: flex-end;
  }

  .ft-bottom-links a {
    font-size: 0.875rem;
    opacity: 0.7;
    text-decoration: none;
  }

  .ft-bottom-links a:hover {
    opacity: 1;
    color: #1CA8CB;
  }

  @media (max-width: 991px) {
    .ft-main {
      grid-template-columns: 1fr !important;
      gap: 32px !important;
    }

    .ft-links {
      flex-direction: column !important;
      gap: 32px !important;
    }

    .ft-bottom {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .ft-bottom-left {
      text-align: center;
    }

    .ft-bottom-links {
      justify-content: center;
    }
  }
</style>
