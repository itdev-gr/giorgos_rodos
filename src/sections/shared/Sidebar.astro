---
// Shared sidebar for inner pages
---

<aside class="sidebar-area style2">
  <div class="widget widget_categories">
    <h3 class="widget_title">Categories</h3>
    <ul>
      <li><a href="/blog"><img src="/assets/img/ui/theme/map.svg" alt="" aria-hidden="true" />City Tour</a><span>(8)</span></li>
      <li><a href="/blog"><img src="/assets/img/ui/theme/map.svg" alt="" aria-hidden="true" />Beach Tours</a><span>(6)</span></li>
      <li><a href="/blog"><img src="/assets/img/ui/theme/map.svg" alt="" aria-hidden="true" />Wildlife Tours</a><span>(2)</span></li>
      <li><a href="/blog"><img src="/assets/img/ui/theme/map.svg" alt="" aria-hidden="true" />News &amp; Tips</a><span>(7)</span></li>
      <li><a href="/blog"><img src="/assets/img/ui/theme/map.svg" alt="" aria-hidden="true" />Adventure Tours</a><span>(9)</span></li>
      <li><a href="/blog"><img src="/assets/img/ui/theme/map.svg" alt="" aria-hidden="true" />Mountain Tours</a><span>(10)</span></li>
    </ul>
  </div>
  <div class="widget">
    <h3 class="widget_title">Recent Posts</h3>
    <div class="recent-post-wrap">
      {[
        { img: 'recent-post-1-1.jpg', title: 'Exploring The Green Spaces Of the island maldives', date: '22/6/ 2025' },
        { img: 'recent-post-1-2.jpg', title: 'Harmony With Nature Of Belgium Tour and travle', date: '25/6/ 2025' },
        { img: 'recent-post-1-3.jpg', title: 'Exploring The Green Spaces Of Realar Residence', date: '27/6/ 2025' },
      ].map((post) => (
        <div class="recent-post">
          <div class="media-img">
            <a href="/blog"><img src={`/assets/img/pages/blog/${post.img}`} alt="Blog" /></a>
          </div>
          <div class="media-body">
            <h4 class="post-title">
              <a class="text-inherit" href="/blog">{post.title}</a>
            </h4>
            <div class="recent-post-meta">
              <a href="/blog"><i class="fa-regular fa-calendar"></i>{post.date}</a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
  <div class="widget widget_tag_cloud">
    <h3 class="widget_title">Popular Tags</h3>
    <div class="tagcloud">
      {['Tour', 'Adventure', 'Rent', 'Innovate', 'Hotel', 'Modern', 'Luxury', 'Travel'].map((tag) => (
        <a href="/blog">{tag}</a>
      ))}
    </div>
  </div>
  <div class="widget widget_offer" style="background-image: url(/assets/img/ui/backgrounds/widget_bg_1.jpg);">
    <div class="offer-banner">
      <div class="offer">
        <h6 class="box-title">Need Help? We Are Here To Help You</h6>
        <div class="banner-logo">
          <img src="/assets/img/brand/logos/logo2.svg" alt="Rhodes Rent a Boat" />
        </div>
        <div class="offer">
          <h6 class="offer-title">You Get Online support</h6>
          <a class="offter-num" href="tel:+306951666454">+30 695 166 6454</a>
        </div>
        <a href="/contact" class="th-btn style2 th-icon">Read More</a>
      </div>
    </div>
  </div>
</aside>
