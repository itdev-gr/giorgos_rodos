---
import CountUpSection from '../../components/interactive/CountUpSection';

const counters = [
  { value: 15, suffix: '', title: 'Years at Sea' },
  { value: 97, suffix: '%', title: 'Guest Return Rate' },
  { value: 500, suffix: '+', title: 'Charters Completed' },
  { value: 30, suffix: '+', title: 'Islands in Our Routes' },
];
---

<div class="counter-area space">
  <div class="container shape-mockup-wrap">
    <CountUpSection client:visible counters={counters} />
  </div>
</div>
