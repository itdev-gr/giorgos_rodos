<section class="intro-statement space">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-8 offset-lg-0 text-center">
        <p class="intro-accent" data-ani="fadein"><em>Since 2009</em></p>
        <h2 class="intro-heading" data-ani="slideinup" data-ani-delay="0.1">Where the Aegean Becomes Yours</h2>
        <p class="intro-body" data-ani="fadein" data-ani-delay="0.25">
          We do not simply charter yachts. We craft private voyages across the most beautiful waters in the world — tailored to your pace, your passions, and the rhythm of the Greek sea.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .intro-statement {
    background: #fff;
  }

  .intro-accent {
    font-family: var(--style-font, 'Cormorant Garamond', serif);
    font-style: italic;
    font-size: 1.35rem;
    color: var(--theme-color, #1CA8CB);
    margin-bottom: 16px;
    letter-spacing: 0.02em;
  }

  .intro-heading {
    font-family: var(--title-font, 'Manrope', sans-serif);
    font-size: 42px;
    font-weight: 700;
    color: var(--title-color, #1a1a2b);
    margin-bottom: 24px;
    line-height: 1.2;
    letter-spacing: -0.01em;
  }

  .intro-body {
    font-family: var(--body-font, 'Inter', sans-serif);
    font-size: 1.125rem;
    line-height: 1.8;
    color: #6e7070;
    max-width: 640px;
    margin: 0 auto;
  }

  @media (max-width: 991px) {
    .intro-heading {
      font-size: 32px;
    }
  }

  @media (max-width: 575px) {
    .intro-heading {
      font-size: 26px;
    }

    .intro-body {
      font-size: 1rem;
    }
  }
</style>
