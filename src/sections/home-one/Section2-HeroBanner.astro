---
import { DEFAULT_HERO_MP4 } from '../../lib/hero-video';

const heroPoster = '/assets/img/heroes/hero-poster-padded.jpg';
const mp4Src = DEFAULT_HERO_MP4;
---
<div class="th-hero-wrapper hero-1 hero-fullscreen" id="hero">
  <div class="hero-inner">
    <div class="th-hero-bg hero-bg-video">
      <!--
        The poster image is the LCP element: it's preloaded with high priority
        and paints as soon as it decodes, anchoring LCP to a fast image.
        The video is NOT downloaded up front (preload="none"); it is loaded
        and faded in only after the page has loaded, so on slow connections it
        never paints inside the LCP window and never resets LCP. On fast
        connections it appears within a moment of load — effectively direct.
      -->
      <img
        class="hero-poster"
        src={heroPoster}
        alt=""
        aria-hidden="true"
        width="1920"
        height="1080"
        decoding="sync"
        fetchpriority="high"
      />
      <video
        class="hero-video"
        muted
        loop
        playsinline
        preload="none"
        poster={heroPoster}
        width="1920"
        height="1080"
        aria-hidden="true"
      >
        <source src={mp4Src} type="video/mp4" />
      </video>
      <div class="hero-overlay"></div>
    </div>
    <div class="container">
      <div class="hero-style1">
        <div class="hero-content">
          <h1 class="hero-heading">Rhodes Rent a Boat</h1>
          <p class="hero-lead">
            Explore the east coast at your own pace. License-free options for couples and families,
            plus skippered boats when you prefer to sit back and enjoy the day.
          </p>
          <a href="/contact" class="hero-cta-btn">Book Now</a>
        </div>
      </div>
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    var FALLBACK = '/assets/img/heroes/hero-video.mp4';

    function ensureHeroVideo() {
      var video = document.querySelector('.hero-video');
      if (!video || window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      // On phones the video is hidden (poster only) to keep LCP fast and avoid
      // downloading the clip on mobile data — don't fetch/play it there.
      if (window.matchMedia('(max-width: 767px)').matches) return;
      if (video.dataset.heroReady) return;
      video.dataset.heroReady = '1';

      // Fade the video in only once it is actually rendering frames, so it
      // replaces the poster seamlessly with no flash.
      video.addEventListener('playing', function () {
        video.classList.add('is-playing');
      }, { once: true });

      video.addEventListener('error', function onError() {
        var source = video.querySelector('source');
        if (source && source.getAttribute('src') !== FALLBACK) {
          source.setAttribute('src', FALLBACK);
        }
        video.load();
        video.play().catch(function () {});
      }, { once: true });

      // Kick off loading + playback. preload="none" means nothing was fetched
      // until now, keeping the video out of the LCP/critical path; we start it
      // as soon as the page is otherwise loaded so it appears promptly.
      video.load();
      var p = video.play();
      if (p && p.catch) p.catch(function () {});
    }

    function schedule() {
      if ('requestIdleCallback' in window) {
        requestIdleCallback(ensureHeroVideo, { timeout: 1500 });
      } else {
        setTimeout(ensureHeroVideo, 200);
      }
    }

    // Wait until the page has loaded so the hero video never competes with the
    // LCP poster or extends the LCP window on slow connections.
    if (document.readyState === 'complete') {
      schedule();
    } else {
      window.addEventListener('load', schedule, { once: true });
    }
    document.addEventListener('astro:page-load', schedule);
  })();
</script>

<style>
  .hero-fullscreen {
    height: 100vh;
    min-height: 600px;
  }

  .hero-fullscreen .hero-inner {
    position: relative;
    height: 100%;
  }

  .hero-1.hero-fullscreen .th-hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    height: 100%;
    background-color: #0b2f38;
  }

  .hero-poster,
  .hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .hero-poster {
    z-index: 0;
  }

  .hero-video {
    z-index: 1;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .hero-video.is-playing {
    opacity: 1;
  }

  /* Phones: show the poster only. A full-bleed autoplay video would become the
     LCP element and load ~0.8MB on mobile data; the poster keeps LCP fast. */
  @media (max-width: 767px) {
    .hero-video {
      display: none !important;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-bg-video {
      background: url('/assets/img/heroes/hero-poster-padded.jpg') center / cover no-repeat;
    }

    .hero-video {
      display: none !important;
    }
  }

  .hero-cta-btn {
    display: inline-block;
    background-color: #1CA8CB;
    color: #fff;
    padding: 14px 32px;
    font-size: 16px;
    font-weight: 600;border-radius: 4px;
    text-decoration: none;
    margin-top: 24px;
    transition: background-color 0.2s;
  }
  .hero-cta-btn:hover {
    background-color: #178fa8;
    color: #fff;
  }

  .hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0.35) 0%,
      rgba(0, 0, 0, 0.15) 40%,
      rgba(0, 0, 0, 0.3) 100%
    );
    z-index: 1;
    pointer-events: none;
  }

  @media (max-width: 991px) {
    .hero-overlay {
      background: none;
    }
    .hero-fullscreen {
      height: 75vh;
      min-height: 380px;
    }

    .hero-lead {
      color: #fff;
      font-weight: 500;
    }
  }

  .hero-fullscreen .container {
    position: relative;
    z-index: 2;
    height: 100%;
    pointer-events: none;
  }

  .hero-fullscreen .hero-style1 {
    padding: 0 0 0 3%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    position: relative;
    pointer-events: auto;
  }

  .hero-content {
    text-align: left;
    color: #fff;
    max-width: 700px;
    position: relative;
    z-index: 1;
  }

  .hero-accent {
    display: block;font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
    color: #fff;
    line-height: 1.3;
  }

  .hero-heading {font-size: clamp(1.75rem, 3.5vw, 3rem);
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 1rem;
    color: #fff;
    letter-spacing: -0.5px;
  }

  .hero-lead {font-size: clamp(0.95rem, 1.6vw, 1.1rem);
    font-weight: 400;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.92);
    margin: 0 0 1.75rem;
    max-width: 540px;
  }

  .hero-subtitle {font-size: clamp(1rem, 2vw, 1.25rem);
    font-weight: 300;
    margin-bottom: 2.5rem;
    opacity: 0.85;
    letter-spacing: 0.5px;
    color: #fff;
  }

  .hero-cta {
    display: inline-block;
    padding: 16px 40px;font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: #fff;
    background: transparent;
    border: 1.5px solid rgba(255, 255, 255, 0.7);
    border-radius: 4px;
    text-decoration: none;
    transition: all 0.4s ease;
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }

  .hero-cta:hover {
    background: #fff;
    color: #113D48;
    border-color: #fff;
  }

  /* Scroll indicator */
  .scroll-indicator {
    position: absolute;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    color: rgba(255, 255, 255, 0.7);
  }

  .scroll-text {font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 2px;
  }

  .scroll-arrow {
    animation: bounce 2s ease infinite;
  }

  @keyframes bounce {
    0%, 20%, 50%, 80%, 100% {
      transform: translateY(0);
    }
    40% {
      transform: translateY(8px);
    }
    60% {
      transform: translateY(4px);
    }
  }

  @media (max-width: 767px) {
    .hero-fullscreen {
      height: 75vh;
      min-height: 360px;
    }

    .hero-fullscreen .hero-style1 {
      justify-content: flex-end;
      padding: 0 0 5vh 5%;
      align-items: flex-start;
    }

    .hero-content {
      text-align: left;
    }

    .hero-accent {
      font-size: 0.85rem;
      letter-spacing: 0.1em;
      color: #fff;
      font-weight: 700;
    }

    .hero-heading {
      font-size: 32px;
      color: #fff;
      font-weight: 700;
    }

    .hero-lead {
      font-size: 0.92rem;
      line-height: 1.6;
      margin-bottom: 1.25rem;
      max-width: 100%;
    }

    .hero-cta {
      padding: 14px 32px;
    }

    .scroll-indicator {
      bottom: 24px;
    }
  }
</style>
