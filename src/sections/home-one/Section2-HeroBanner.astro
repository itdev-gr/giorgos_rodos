---
import { getMediaSlot } from '../../lib/media';
import { heroVideoSources } from '../../lib/hero-video';
const heroVideo = await getMediaSlot('home.hero.video', '/assets/img/hero/hero-video.webm');
const sources = heroVideoSources(heroVideo);
---
<div class="th-hero-wrapper hero-1 hero-fullscreen" id="hero">
  <div class="hero-inner">
    <div class="th-hero-bg">
      <video
        autoplay
        muted
        loop
        playsinline
        width="1920"
        height="1080"
        style="width: 100%; height: 100%; object-fit: cover; position: absolute; top: 0; left: 0;"
      >
        {sources.webm && <source src={sources.webm} type="video/webm" />}
        <source src={sources.mp4} type="video/mp4" />
      </video>
      <div class="hero-overlay"></div>
    </div>
    <div class="container">
      <div class="hero-style1">
        <div class="hero-content">
          <span class="hero-accent">Boat Experiences in Rhodes</span>
          <h1 class="hero-heading">Rhodes Rent a Boat & Boat Tours Handpicked Trips, Cruises and Private Experiences</h1>
          <a href="/contact" class="hero-cta-btn">Enquire Now</a>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .hero-fullscreen {
    height: 100vh;
    min-height: 600px;
  }

  .hero-cta-btn {
    display: inline-block;
    background-color: #1CA8CB;
    color: #fff;
    padding: 14px 32px;
    font-size: 16px;
    font-weight: 600;
    font-family: 'Inter', sans-serif;
    border-radius: 4px;
    text-decoration: none;
    margin-top: 24px;
    transition: background-color 0.2s;
  }
  .hero-cta-btn:hover {
    background-color: #178fa8;
    color: #fff;
  }

  .hero-fullscreen .hero-inner {
    height: 100%;
  }

  .hero-fullscreen .th-hero-bg {
    height: 100%;
  }

  .hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0.35) 0%,
      rgba(0, 0, 0, 0.15) 40%,
      rgba(0, 0, 0, 0.3) 100%
    );
    z-index: 1;
  }

  @media (max-width: 991px) {
    .hero-overlay {
      background: none;
    }
    .hero-fullscreen {
      height: 75vh;
      min-height: 380px;
    }
  }

  .hero-fullscreen .container {
    height: 100%;
  }

  .hero-fullscreen .hero-style1 {
    padding: 0 0 0 3%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    position: relative;
    z-index: 2;
  }

  .hero-content {
    text-align: left;
    color: #fff;
    max-width: 700px;
  }

  .hero-accent {
    display: block;
    font-family: 'Allura', cursive;
    font-size: 2.25rem;
    font-weight: 400;
    letter-spacing: 0;
    margin-bottom: 0.5rem;
    opacity: 0.95;
    line-height: 1;
  }

  .hero-heading {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.4rem, 2.5vw, 2.25rem);
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 1.25rem;
    color: #fff;
    letter-spacing: -0.5px;
  }

  .hero-subtitle {
    font-family: 'Inter', sans-serif;
    font-size: clamp(1rem, 2vw, 1.25rem);
    font-weight: 300;
    margin-bottom: 2.5rem;
    opacity: 0.85;
    letter-spacing: 0.5px;
    color: #fff;
  }

  .hero-cta {
    display: inline-block;
    padding: 16px 40px;
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: #fff;
    background: transparent;
    border: 1.5px solid rgba(255, 255, 255, 0.7);
    border-radius: 4px;
    text-decoration: none;
    transition: all 0.4s ease;
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }

  .hero-cta:hover {
    background: #fff;
    color: #113D48;
    border-color: #fff;
  }

  /* Scroll indicator */
  .scroll-indicator {
    position: absolute;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    color: rgba(255, 255, 255, 0.7);
  }

  .scroll-text {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 2px;
  }

  .scroll-arrow {
    animation: bounce 2s ease infinite;
  }

  @keyframes bounce {
    0%, 20%, 50%, 80%, 100% {
      transform: translateY(0);
    }
    40% {
      transform: translateY(8px);
    }
    60% {
      transform: translateY(4px);
    }
  }

  @media (max-width: 767px) {
    .hero-fullscreen {
      height: 75vh;
      min-height: 360px;
    }

    .hero-fullscreen .hero-style1 {
      justify-content: flex-end;
      padding-bottom: 5vh;
      align-items: center;
    }

    .hero-content {
      text-align: center;
    }

    .hero-accent {
      font-size: 1.75rem;
      letter-spacing: 0;
    }

    .hero-cta {
      padding: 14px 32px;
    }

    .scroll-indicator {
      bottom: 24px;
    }
  }
</style>
