---
const features = [
  {
    icon: 'fas fa-compass',
    title: 'Local Skippers Who Know Every Cove',
    description: 'Our captains grew up on these waters. They know where the sea is calmest, where the fish are biting, and which beaches have no footprints.',
  },
  {
    icon: 'fas fa-check-circle',
    title: 'Everything Included, Nothing Hidden',
    description: 'Fuel, safety equipment, snorkeling gear, and refreshments — the price you see is the price you pay. No surprises.',
  },
  {
    icon: 'fas fa-comments',
    title: 'Speak with Us Before You Decide',
    description: 'We would rather have a conversation than push a booking. Call us, message us, ask anything — we are here to help you choose the right experience.',
  },
];
---

<!-- Full-width image with overlaid text -->
<div style="position: relative; min-height: 540px; display: flex; align-items: flex-end; overflow: hidden; width: 100%;">
  <img
    src="/assets/img/gallery/yacht/yacht-luxury-1.jpg"
    alt="Luxury yacht charter in Rhodes"
    loading="lazy"
    class="bs-hero-bg"
    style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; object-position: center 30%; display: block;"
  />
  <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: linear-gradient(180deg, rgba(17,61,72,0.05) 0%, rgba(17,61,72,0.6) 55%, rgba(17,61,72,0.9) 100%); z-index: 1;"></div>
  <div style="position: relative; z-index: 2; width: 100%; padding: 0 0 60px;">
    <div class="container">
      <span style="display: inline-block; font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 1.2rem; color: rgba(255,255,255,0.85); letter-spacing: 0.04em; margin-bottom: 14px;" data-ani="fadein">Why People Trust Us</span>
      <h2 style="font-family: 'Manrope', sans-serif; font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; color: #fff; line-height: 1.15; margin-bottom: 20px; letter-spacing: -0.01em;" data-ani="slideinup" data-ani-delay="0.1">We Handle Everything<br />So You Do Not Have To</h2>
    </div>
  </div>
</div>

<!-- Feature cards on light background -->
<div style="background-color: #E9F6F9; padding: 80px 0 70px;">
  <div class="container">
    <div class="row gy-4">
      {features.map((feature, i) => (
        <div class="col-lg-4" data-ani="slideinup" data-ani-delay={String(i * 0.12)}>
          <div style="background: #ffffff; border-radius: 12px; padding: 36px 30px; height: 100%; box-shadow: 0 4px 24px rgba(0,0,0,0.05); transition: transform 0.3s ease, box-shadow 0.3s ease;">
            <div style="width: 56px; height: 56px; display: flex; align-items: center; justify-content: center; background: #E9F6F9; border-radius: 14px; margin-bottom: 20px; font-size: 1.3rem; color: #1CA8CB;">
              <i class={feature.icon}></i>
            </div>
            <h5 style="font-family: 'Manrope', sans-serif; font-size: 1.1rem; font-weight: 700; color: #113D48; margin-bottom: 10px; line-height: 1.3;">{feature.title}</h5>
            <p style="font-size: 0.95rem; line-height: 1.7; color: #6e7070; margin-bottom: 0;">{feature.description}</p>
          </div>
        </div>
      ))}
    </div>
    <div class="text-center" style="margin-top: 50px;" data-ani="fadein" data-ani-delay="0.35">
      <a href="/about" class="th-btn style3 th-icon">Get to Know Us</a>
    </div>
  </div>
</div>

<style is:global>
  @media (max-width: 768px) {
    .bs-hero-bg {
      object-position: center center !important;
    }
  }
</style>
