---
const mapSrc =
  'https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3231.5!2d28.2197904!3d36.4497769!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x1495612e417eb653%3A0x90a1e588da06a420!2sRhodes+Rent+a+Boat!5e0!3m2!1sen!2sgr!4v1715072400000!5m2!1sen!2sgr';
---

<section class="gmap-section">
  <div class="container">
    <div class="title-area text-center gmap-section__header">
      <h2 class="sec-title" data-ani="slideinup">Find Us in Rhodes Town</h2>
    </div>
    <div class="gmap-wrap" data-ani="fadein" data-ani-delay="0.2">
      <iframe
        class="gmap-iframe"
        src={mapSrc}
        width="100%"
        height="450"
        style="border:0;"
        allowfullscreen=""
        loading="eager"
        referrerpolicy="no-referrer-when-downgrade"
        title="Rhodes Rent a Boat, Ionos Dragoumi 39, Rhodes"
      ></iframe>
    </div>
  </div>
</section>

<style>
  .gmap-section {
    padding: 80px 0;
  }

  .gmap-section__header {
    margin-bottom: 40px;
  }

  .gmap-wrap {
    border-radius: 12px;
    overflow: hidden;
  }

  .gmap-iframe {
    display: block;
    width: 100%;
    min-height: 320px;
    aspect-ratio: 16 / 10;
    height: auto;
  }

  @media (min-width: 768px) {
    .gmap-iframe {
      min-height: 450px;
      aspect-ratio: auto;
      height: 450px;
    }
  }
</style>
