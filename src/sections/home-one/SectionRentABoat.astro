---
import { imgUrl, imgSrcset } from '../../lib/media';
import { resolveLocale } from '../../i18n/context';
import { getPageContent } from '../../i18n/page-content';
import { localizedPath } from '../../i18n/routing';

const locale = resolveLocale(Astro.locals, Astro.url.pathname);
const rent = getPageContent(locale).home.rentABoat;
const contactHref = localizedPath('/contact', locale);
const thingsHref = localizedPath('/things-to-do', locale);

const heroImage = '/assets/img/home/sections/rhodes-customers.png';
const heroSrc = imgUrl(heroImage, 800, { quality: 80 }) || heroImage;
const heroSrcset = imgSrcset(heroImage, [480, 640, 800, 1000]) || '';
---

<section class="rab-section" id="rent-a-boat">
  <div class="container">
    <div class="rab-grid">
      <div class="rab-visual" data-ani="slideinleft">
        <div class="rab-visual__frame">
          <img
            src={heroSrc}
            srcset={heroSrcset || undefined}
            sizes="(max-width: 991px) 100vw, 42vw"
            alt={rent.imageAlt}
            loading="lazy"
            width="800"
            height="1000"
            decoding="async"
          />
          <div class="rab-visual__overlay"></div>
        </div>
      </div>

      <div class="rab-content">
        <article class="rab-card" data-ani="fadein">
          <h2 class="rab-subheading">{rent.heading}</h2>

          <div class="rab-copy">
            <p>{rent.paragraphs[0]}</p>
            <p>{rent.paragraphs[1]}</p>
          </div>

          <div class="rab-actions">
            <a href={contactHref} class="rab-btn rab-btn--primary">{rent.ctaPrimary}</a>
            <a href={thingsHref} class="rab-btn rab-btn--outline">{rent.ctaSecondary}</a>
          </div>
        </article>
      </div>
    </div>
  </div>
</section>

<style>
  .rab-section {
    padding: 88px 0;
    background: linear-gradient(180deg, #f4fafc 0%, #fff 45%, #fff 100%);
    overflow: hidden;
  }

  .rab-grid {
    display: grid;
    grid-template-columns: minmax(280px, 0.95fr) minmax(0, 1.05fr);
    gap: 56px;
    align-items: center;
  }

  .rab-visual {
    position: relative;
  }

  .rab-visual__frame {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    aspect-ratio: 4 / 5;
    box-shadow: 0 24px 60px rgba(17, 61, 72, 0.14);
  }

  .rab-visual__frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .rab-visual__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(17, 61, 72, 0) 55%,
      rgba(17, 61, 72, 0.35) 100%
    );
    pointer-events: none;
  }

  .rab-card {
    background: #fff;
    border: 1px solid rgba(17, 61, 72, 0.08);
    border-radius: 20px;
    padding: 32px 34px;
    box-shadow: 0 10px 40px rgba(17, 61, 72, 0.06);
  }

  .rab-subheading {font-size: clamp(1.15rem, 2vw, 1.45rem);
    font-weight: 700;
    color: #113D48;
    line-height: 1.35;
    margin: 0 0 18px;
  }

  .rab-copy {font-size: 1.1rem;
    line-height: 1.85;
    color: #000;
  }

  .rab-copy p {
    margin: 0 0 16px;
    color: #000;
  }

  .rab-copy p:last-child {
    margin-bottom: 0;
  }

  .rab-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 28px;
  }

  .rab-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 13px 24px;
    border-radius: 6px;font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease;
  }

  .rab-btn--primary {
    background: #1CA8CB;
    color: #fff;
    border: 1px solid #1CA8CB;
  }

  .rab-btn--primary:hover {
    background: #178fa8;
    border-color: #178fa8;
    color: #fff;
  }

  .rab-btn--outline {
    background: transparent;
    color: #113D48;
    border: 1px solid rgba(17, 61, 72, 0.2);
  }

  .rab-btn--outline:hover {
    border-color: #1CA8CB;
    color: #1CA8CB;
  }

  @media (max-width: 991px) {
    .rab-section {
      padding: 64px 0;
    }

    .rab-grid {
      grid-template-columns: 1fr;
      gap: 36px;
    }

    .rab-visual__frame {
      aspect-ratio: 16 / 10;
      max-height: 360px;
    }

    .rab-card {
      padding: 24px 20px;
    }

    .rab-copy {
      font-size: 1.05rem;
    }
  }

  @media (max-width: 575px) {
    .rab-actions {
      flex-direction: column;
    }

    .rab-btn {
      width: 100%;
    }
  }
</style>
