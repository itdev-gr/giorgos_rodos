---
import { createAdminClient, createPublicClient } from '../../lib/supabase';
import ExperienceCard from '../../components/ExperienceCard.astro';
import { normalizeServiceHref } from '../../lib/internal-links';
import { resolveLocale } from '../../i18n/context';
import { getPageContent } from '../../i18n/page-content';
import { localizedPath } from '../../i18n/routing';

const locale = resolveLocale(Astro.locals, Astro.url.pathname);
const home = getPageContent(locale).home;
const cardBySlug = Object.fromEntries(home.categoryCards.map((c) => [c.slug, c]));

const fallbackCategories = home.categoryCards.map((c) => ({
  title: c.title,
  description: c.description,
  image: {
    'rhodes-boat-tours': '/assets/img/cruises/greco_sunset3.jpg',
    'rhodes-boat-trips': '/assets/img/locations/private-sailing.jpg',
    'rhodes-boat-cruises': '/assets/img/cruises/greco_home1.jpg',
    'rhodes-rent-a-boat': '/assets/img/locations/tsambika-beach.jpg',
    'rhodes-catamaran-tours': '/assets/img/fleet/lagoon-42-aenaos.webp',
    'rhodes-charter': '/assets/img/fleet/oceanis-461-nailah.jpg',
    'rhodes-tender-boat': '/assets/img/operations/tender/tender-service.jpg',
    'rhodes-mice-events': '/assets/img/gallery/yacht/yacht-luxury-1.jpg',
  }[c.slug] || '/assets/img/gallery/yacht/crystal-water-1.jpg',
  href: localizedPath(`/service/${c.slug}`, locale),
}));

let categories = fallbackCategories;
try {
  const supabase = createAdminClient() || createPublicClient();
  if (supabase) {
    const { data: urlData } = supabase.storage.from('site-config').getPublicUrl('service-categories.json');
    if (urlData?.publicUrl) {
      const res = await fetch(urlData.publicUrl + '?t=' + Date.now());
      if (res.ok) {
        const data = await res.json();
        if (Array.isArray(data) && data.length > 0) {
          categories = data
            .sort((a: any, b: any) => (a.sort_order || 0) - (b.sort_order || 0))
            .map((cat: any) => {
              const href = localizedPath(normalizeServiceHref(cat.href), locale);
              const slug = cat.href?.replace(/^\/service\//, '').replace(/^\//, '');
              const localized = slug && cardBySlug[slug];
              return {
                ...cat,
                href,
                title: localized?.title ?? cat.title,
                description: localized?.description ?? cat.description,
              };
            });
        }
      }
    }
  }
} catch {
  // Silently fall back to hardcoded categories
}
---

<section class="services-categories">
  <div class="container">
    <div class="title-area text-center services-categories__header">
      <h2 class="sec-title services-categories__title" data-ani="slideinup">{home.categoriesTitle}</h2>
    </div>
    <div class="exp-grid exp-grid--4 services-categories__grid">
      {categories.map((cat, i) => (
        <div class="services-categories__cell" data-ani="slideinup" data-ani-delay={`${0.08 + i * 0.04}`}>
          <ExperienceCard
            href={cat.href}
            title={cat.title}
            description={cat.description}
            image={cat.image}
            showStars={false}
            showButton={true}
            sizes="(max-width: 575px) 100vw, (max-width: 991px) 50vw, 25vw"
          />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .services-categories {
    padding: 88px 0;
    overflow: hidden;
    background: #fff;
  }

  .services-categories__header {
    margin-bottom: 48px;
  }

  .services-categories__title {font-size: clamp(1.75rem, 3vw, 2.35rem);
    font-weight: 700;
    color: #113D48;
    text-align: center;
    width: 100%;
    margin: 0;
    line-height: 1.2;
  }

  @media (max-width: 991px) {
    .services-categories {
      padding: 64px 0;
      width: 100%;
      overflow: visible;
    }

    .services-categories .container {
      width: 100%;
      max-width: 100%;
      padding-inline: 20px;
      box-sizing: border-box;
    }

    .services-categories__header {
      margin-bottom: 36px;
    }

    .services-categories__cell {
      width: 100%;
      min-width: 0;
    }

    .services-categories__cell :global(.exp-card) {
      width: 100%;
    }
  }

  @media (max-width: 575px) {
    .services-categories .container {
      padding-inline: 16px;
    }
  }
</style>

<style is:global>
  .services-categories .services-categories__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 40px;
  }

  @media (max-width: 1199px) {
    .services-categories .services-categories__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 32px;
    }
  }

  @media (max-width: 991px) {
    .services-categories .services-categories__grid {
      grid-template-columns: 1fr;
      gap: 28px;
    }
  }
</style>
