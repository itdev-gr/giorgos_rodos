---
import { createAdminClient, createPublicClient } from '../../lib/supabase';
import ExperienceCard from '../../components/ExperienceCard.astro';

const fallbackCategories = [
  { title: 'Rhodes Boat Tours', description: 'Guided sailing tours along the stunning Rhodes coastline and nearby islands.', image: '/assets/img/cruises/greco_sunset3.jpg', href: '/service/rhodes-boat-tours' },
  { title: 'Rhodes Boat Trips', description: 'Private sailing yacht trips with experienced crews across the Dodecanese.', image: '/assets/img/locations/private-sailing.jpg', href: '/service/rhodes-boat-trips' },
  { title: 'Rhodes Boat Cruises', description: 'All-inclusive day and sunset cruises with swimming, dining, and music.', image: '/assets/img/cruises/greco_home1.jpg', href: '/service/rhodes-boat-cruises' },
  { title: 'Rhodes Rent a Boat', description: 'Drive your own boat along the coast, no licence needed, full freedom.', image: '/assets/img/locations/tsambika-beach.jpg', href: '/#rent-a-boat' },
  { title: 'Rhodes Catamaran Cruises', description: 'Spacious catamarans for group cruises, events, and island-hopping adventures.', image: '/assets/img/fleet/lagoon-42-aenaos.webp', href: '/service/rhodes-catamaran-tours' },
  { title: 'Rhodes Yacht Charter', description: 'Over 80 sailing yachts and catamarans. Bareboat or crewed, the Dodecanese is yours.', image: '/assets/img/fleet/oceanis-461-nailah.jpg', href: '/service/rhodes-charter' },
  { title: 'Rhodes Tender Boat Services', description: 'Fast and reliable shore-to-ship transfers across Rhodes harbours and bays.', image: '/assets/img/operations/tender/tender-service.jpg', href: '/service/rhodes-tender-boat' },
  { title: 'Rhodes MICE & Incentive Events', description: 'Corporate events, incentive trips, and team-building experiences on the water.', image: '/assets/img/gallery/yacht/yacht-luxury-1.jpg', href: '/service/rhodes-mice-events' },
];

let categories = fallbackCategories;
try {
  const supabase = createAdminClient() || createPublicClient();
  if (supabase) {
    const { data: urlData } = supabase.storage.from('site-config').getPublicUrl('service-categories.json');
    if (urlData?.publicUrl) {
      const res = await fetch(urlData.publicUrl + '?t=' + Date.now());
      if (res.ok) {
        const data = await res.json();
        if (Array.isArray(data) && data.length > 0) {
          categories = data.sort((a: any, b: any) => (a.sort_order || 0) - (b.sort_order || 0));
        }
      }
    }
  }
} catch {
  // Silently fall back to hardcoded categories
}
---

<section class="services-categories">
  <div class="container">
    <div class="title-area text-center services-categories__header">
      <h2 class="sec-title services-categories__title" data-ani="slideinup">Our Services</h2>
    </div>
    <div class="exp-grid exp-grid--4 services-categories__grid">
      {categories.map((cat, i) => (
        <div class="services-categories__cell" data-ani="slideinup" data-ani-delay={`${0.08 + i * 0.04}`}>
          <ExperienceCard
            href={cat.href}
            title={cat.title}
            description={cat.description}
            image={cat.image}
            showStars={false}
            showButton={true}
            sizes="(max-width: 575px) 100vw, (max-width: 991px) 50vw, 25vw"
          />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .services-categories {
    padding: 88px 0;
    overflow: hidden;
    background: #fff;
  }

  .services-categories__header {
    margin-bottom: 48px;
  }

  .services-categories__title {font-size: clamp(1.75rem, 3vw, 2.35rem);
    font-weight: 700;
    color: #113D48;
    text-align: center;
    width: 100%;
    margin: 0;
    line-height: 1.2;
  }

  @media (max-width: 991px) {
    .services-categories {
      padding: 64px 0;
      width: 100%;
      overflow: visible;
    }

    .services-categories .container {
      width: 100%;
      max-width: 100%;
      padding-inline: 20px;
      box-sizing: border-box;
    }

    .services-categories__header {
      margin-bottom: 36px;
    }

    .services-categories__grid {
      width: 100%;
    }

    .services-categories__cell {
      width: 100%;
      min-width: 0;
    }

    .services-categories__cell :global(.exp-card) {
      width: 100%;
    }
  }

  @media (max-width: 575px) {
    .services-categories .container {
      padding-inline: 16px;
    }
  }
</style>
