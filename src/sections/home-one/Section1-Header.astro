---
import MobileMenu from '../../components/interactive/MobileMenu';
---

<header class="th-header header-layout1" id="header-one">
  <div class="sticky-wrapper" id="sticky-wrapper">
    <div class="menu-area">
      <div class="container th-container">
        <div class="row align-items-center justify-content-between">
          <div class="col-auto">
            <div class="header-logo">
              <a href="/">
                <img src="/assets/img/logo.svg" alt="Rhodes Boat Tours" />
              </a>
            </div>
          </div>
          <div class="col-auto me-xl-auto">
            <nav class="main-menu d-none d-xl-inline-block">
              <ul>
                <li>
                  <a class="active" href="/">Home</a>
                </li>
                <li><a href="/about">About Us</a></li>
                <li class="menu-item-has-children">
                  <a href="/service">Service</a>
                  <ul class="sub-menu">
                    <li><a href="/service/rhodes-rent-a-boat">Rhodes Rent a Boat</a></li>
                    <li><a href="/service/rodos-boat-tours">Rhodes Boat Tours</a></li>
                    <li><a href="/service/rhodes-boat-trips">Rhodes Boat Trips</a></li>
                    <li><a href="/service/rodos-boat-cruises">Rhodes Boat Cruises</a></li>
                    <li><a href="/service/rhodes-catamaran-tours">Rhodes Catamaran Tours</a></li>
                    <li><a href="/service/rhodes-sailing-trips">Rhodes Sailing Trips</a></li>
                    <li><a href="/service/rodos-charter">Rhodes Yacht Charter</a></li>
                    <li><a href="/service/rodos-mise">Rhodes Mise</a></li>
                    <li><a href="/service/rodos-tender-boat">Rhodes Tender Boat</a></li>
                  </ul>
                </li>
                <li><a href="/gallery">Gallery</a></li>
              </ul>
            </nav>
            <button type="button" class="th-menu-toggle d-block d-xl-none" id="mobile-menu-trigger">
              <i class="far fa-bars"></i>
            </button>
          </div>
          <div class="col-auto d-none d-xl-block">
            <div class="header-button">
              <a href="/contact" class="luxury-cta">Enquire</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</header>

<div id="mobile-menu-container">
  <MobileMenu client:load isOpen={false} onClose={() => {}} />
</div>

<style>
  /* ===== Luxury Navbar Base ===== */
  #header-one {
    position: relative;
    z-index: 99;
  }

  /* Transparent mode — only active when .header-transparent is on the header AND not scrolled */
  #header-one.header-transparent .sticky-wrapper:not(.sticky) {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    z-index: 99;
    background: linear-gradient(180deg, rgba(0,0,0,0.3) 0%, transparent 100%);
  }

  #header-one.header-transparent .sticky-wrapper:not(.sticky) .header-logo img {
    filter: brightness(0) invert(1);
  }

  #header-one.header-transparent .sticky-wrapper:not(.sticky) .main-menu > ul > li > a {
    color: #fff;
  }

  #header-one.header-transparent .sticky-wrapper:not(.sticky) .main-menu ul li.menu-item-has-children > a:after {
    color: #fff;
  }

  #header-one.header-transparent .sticky-wrapper:not(.sticky) .luxury-cta {
    background: transparent;
    color: #fff;
    border: 1.5px solid rgba(255,255,255,0.6);
    backdrop-filter: blur(5px);
    -webkit-backdrop-filter: blur(5px);
  }

  #header-one.header-transparent .sticky-wrapper:not(.sticky) .luxury-cta:hover {
    background: var(--theme-color, #1CA8CB);
    border-color: var(--theme-color, #1CA8CB);
    color: #fff;
  }

  #header-one.header-transparent .sticky-wrapper:not(.sticky) .th-menu-toggle {
    background: transparent;
    color: #fff;
    border: 1.5px solid rgba(255,255,255,0.6);
  }

  /* ===== Solid State (default & scrolled) ===== */
  .sticky-wrapper {
    transition: all 0.4s ease;
  }

  .sticky-wrapper.sticky {
    background-color: #fff;
    box-shadow: 0 2px 20px rgba(0,0,0,0.06);
  }

  /* Logo transition — black in solid state */
  .header-logo img {
    transition: filter 0.4s ease;
    max-height: 50px;
    filter: brightness(0);
  }

  /* ===== Nav Links — Luxury Typography ===== */
  #header-one .main-menu > ul > li > a {
    font-family: var(--body-font, 'Inter', sans-serif);
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--title-color, #113D48);
    padding: 32px 0;
    position: relative;
    transition: color 0.3s ease;
  }

  /* Underline hover — slides in from left */
  #header-one .main-menu > ul > li > a::before {
    content: '';
    position: absolute;
    bottom: 24px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--theme-color, #1CA8CB);
    transition: width 0.3s ease;
  }

  #header-one .main-menu > ul > li > a:hover::before,
  #header-one .main-menu > ul > li > a.active::before {
    width: 100%;
  }

  #header-one .main-menu > ul > li > a:hover {
    color: var(--theme-color, #1CA8CB);
  }

  /* Dropdown arrow — smaller, matches text color */
  #header-one .main-menu ul li.menu-item-has-children > a:after {
    font-size: 0.7em;
    margin-left: 5px;
    transition: color 0.3s ease;
  }

  /* ===== Sub-menu / Dropdown Refinement ===== */
  #header-one .main-menu ul.sub-menu {
    border-bottom: 2px solid var(--theme-color, #1CA8CB);
    box-shadow: 0 8px 32px rgba(0,0,0,0.08);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-radius: 4px;
  }

  #header-one .main-menu ul.sub-menu a {
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.5px;
    text-transform: none;
  }

  /* ===== CTA Button — Solid State ===== */
  .luxury-cta {
    display: inline-block;
    padding: 12px 28px;
    font-family: var(--body-font, 'Inter', sans-serif);
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    background: var(--title-color, #113D48);
    color: #fff;
    border: 1.5px solid var(--title-color, #113D48);
    border-radius: 4px;
    transition: all 0.3s ease;
    text-decoration: none;
  }

  .luxury-cta:hover {
    background: var(--theme-color, #1CA8CB);
    border-color: var(--theme-color, #1CA8CB);
    color: #fff;
  }

  /* ===== Mobile Toggle — Luxury ===== */
  #header-one .th-menu-toggle {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--theme-color, #1CA8CB);
    color: #fff;
    border: none;
    font-size: 18px;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #header-one .th-menu-toggle:hover {
    background: var(--title-color, #113D48);
  }

  /* ===== Transparent state mobile toggle override (already handled above) ===== */

  /* ===== Responsive ===== */
  @media (max-width: 1199px) {
    .luxury-cta {
      padding: 10px 20px;
      font-size: 12px;
    }
  }
</style>

<script>
  // Sticky header — triggers at 80px for quick transition
  const stickyWrapper = document.getElementById('sticky-wrapper');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 80) {
      stickyWrapper?.classList.add('sticky');
    } else {
      stickyWrapper?.classList.remove('sticky');
    }
  });

  // Mobile menu trigger
  document.getElementById('mobile-menu-trigger')?.addEventListener('click', () => {
    const wrapper = document.querySelector('.th-menu-wrapper');
    if (wrapper) {
      wrapper.classList.add('th-body-visible');
      wrapper.style.visibility = 'visible';
    }
  });
</script>
