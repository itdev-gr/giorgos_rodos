---
import MobileMenu from '../../components/interactive/MobileMenu';

interface Props {
  /**
   * Transparent-over-hero rendering (white text, absolute positioning).
   * Defaults to true because every page that uses this component sits over
   * a full-bleed hero. Set false for layouts without a dark backdrop.
   * Server-side rendering avoids the CLS 1.0 caused by the previous JS
   * class-toggle approach.
   */
  transparent?: boolean;
}

const { transparent = true } = Astro.props;
---

<header class:list={['th-header header-layout1', transparent && 'header-transparent']} id="header-one">
  <div class="sticky-wrapper" id="sticky-wrapper">
    <div class="menu-area">
      <div class="container th-container">
        <div class="row align-items-center">
          <!-- Logo -->
          <div class="col-auto">
            <div class="header-logo">
              <a href="/">
                <img src="/assets/img/brand/logos/logo-traced.svg" alt="Rhodes Rent a Boat" width="200" height="60" decoding="async" fetchpriority="high" />
              </a>
            </div>
          </div>
          <!-- Nav, centered on desktop -->
          <div class="col d-none d-lg-flex justify-content-center">
            <nav class="main-menu">
              <ul>
                <li>
                  <a href="/">Home</a>
                </li>
                <li><a href="/about">About Us</a></li>
                <li class="menu-item-has-children">
                  <a href="/service">Service</a>
                  <ul class="sub-menu">
                    <li><a href="/service/rhodes-boat-tours">Rhodes Boat Tours</a></li>
                    <li><a href="/service/rhodes-boat-trips">Rhodes Boat Trips</a></li>
                    <li><a href="/service/rhodes-boat-cruises">Rhodes Boat Cruises</a></li>
                    <li><a href="/service/rhodes-catamaran-tours">Rhodes Catamaran Tours</a></li>
                    <li><a href="/service/rhodes-sailing-trips">Rhodes Sailing Trips</a></li>
                    <li><a href="/service/rhodes-charter">Rhodes Yacht Charter</a></li>
                    <li><a href="/service/rhodes-mice-events">MICE & Incentive</a></li>
                    <li><a href="/service/rhodes-tender-boat">Rhodes Tender Boat</a></li>
                    <li><a href="https://www.rhodestransfer24.com/" target="_blank" rel="noopener noreferrer">Rhodes Transfers</a></li>
                    <li><a href="https://rhodessidecartours.com/" target="_blank" rel="noopener noreferrer">Rhodes Sidecar Tours</a></li>
                    <li><a href="https://siech-rentacar.com/" target="_blank" rel="noopener noreferrer">Rhodes Rent a Car</a></li>
                  </ul>
                </li>
                <li><a href="/things-to-do">All Experiences</a></li>
                <li><a href="/blog">Blog</a></li>
                <li><a href="/faq">FAQ</a></li>
                <li><a href="/contact">Contact Us</a></li>
              </ul>
            </nav>
          </div>
          <!-- CTA + mobile toggle -->
          <div class="col-auto ms-auto">
            <div class="d-none d-lg-block">
              <a href="/contact" class="luxury-cta">Book Now</a>
            </div>
            <button type="button" class="th-menu-toggle d-block d-lg-none" id="mobile-menu-trigger" aria-label="Open menu">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
                <line x1="3" y1="6" x2="21" y2="6"></line>
                <line x1="3" y1="12" x2="21" y2="12"></line>
                <line x1="3" y1="18" x2="21" y2="18"></line>
              </svg>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</header>

<div id="mobile-menu-container">
  <MobileMenu client:idle />
</div>

<style>
  /* ===== Luxury Navbar Base ===== */
  #header-one {
    position: relative;
    z-index: 99;
  }

  .main-menu ul.sub-menu li a:before {
    display: none !important;
  }

  /* Transparent mode, only active when .header-transparent is on the header AND not scrolled */
  #header-one.header-transparent .sticky-wrapper:not(.sticky) {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    z-index: 99;
    background: linear-gradient(180deg, rgba(0,0,0,0.3) 0%, transparent 100%);
  }

  #header-one.header-transparent .sticky-wrapper:not(.sticky) .header-logo img {
    filter: brightness(0) invert(1);
  }

  #header-one.header-transparent .sticky-wrapper:not(.sticky) .main-menu > ul > li > a {
    color: #fff;
  }

  #header-one.header-transparent .sticky-wrapper:not(.sticky) .main-menu ul li.menu-item-has-children > a:after {
    color: #fff;
  }

  #header-one.header-transparent .sticky-wrapper:not(.sticky) .luxury-cta {
    background: rgba(28, 168, 203, 0.85);
    color: #fff;
    border: none;
    backdrop-filter: blur(5px);
    -webkit-backdrop-filter: blur(5px);
  }

  #header-one.header-transparent .sticky-wrapper:not(.sticky) .luxury-cta:hover {
    background: #1CA8CB;
    color: #fff;
  }

  #header-one.header-transparent .sticky-wrapper:not(.sticky) .th-menu-toggle {
    background: transparent;
    color: #fff;
    border: none;
  }

  /* ===== Solid State (default & scrolled) ===== */
  .sticky-wrapper {
    transition: all 0.4s ease;
  }

  .sticky-wrapper.sticky {
    background-color: #fff;
    box-shadow: 0 2px 20px rgba(0,0,0,0.06);
  }

  .header-logo img {
    transition: filter 0.4s ease;
    max-height: 140px;
    width: auto;
    filter: none;
  }

  @media (max-width: 991px) {
    .header-logo img {
      max-height: 100px;
    }
  }

  /* Nav links, ensure flex layout inside centered col */
  #header-one .main-menu > ul {
    display: flex;
    align-items: center;
  }

  /* ===== Nav Links, Luxury Typography ===== */
  #header-one .main-menu > ul > li > a {
    font-family: var(--body-font);
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--title-color, #113D48);
    padding: 32px 0;
    position: relative;
    transition: color 0.3s ease;
  }

  /* Underline hover, slides in from left */
  #header-one .main-menu > ul > li > a::before {
    content: '';
    position: absolute;
    bottom: 24px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--theme-color, #1CA8CB);
    transition: width 0.3s ease;
  }

  #header-one .main-menu > ul > li > a:hover::before,
  #header-one .main-menu > ul > li > a.active::before {
    width: 100%;
  }

  #header-one .main-menu > ul > li > a:hover {
    color: var(--theme-color, #1CA8CB);
  }

  /* Dropdown arrow, smaller, matches text color */
  #header-one .main-menu ul li.menu-item-has-children > a:after {
    font-size: 0.7em;
    margin-left: 5px;
    transition: color 0.3s ease;
  }

  /* ===== Sub-menu / Dropdown Refinement ===== */
  #header-one .main-menu ul.sub-menu {
    display: none !important;
    visibility: hidden !important;
    opacity: 0 !important;
    pointer-events: none !important;
    transform: scaleY(0) !important;
    border-bottom: 2px solid var(--theme-color, #1CA8CB);
    box-shadow: 0 8px 32px rgba(0,0,0,0.08);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-radius: 4px;
  }

  @media (min-width: 992px) {
    html.nav-hover-ready #header-one .main-menu li.menu-item-has-children:hover > ul.sub-menu,
    #header-one .main-menu li.menu-item-has-children:focus-within > ul.sub-menu {
      display: block !important;
      visibility: visible !important;
      opacity: 1 !important;
      pointer-events: auto !important;
      transform: scaleY(1) !important;
    }
  }

  #header-one .main-menu ul.sub-menu a {
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.5px;
    text-transform: none;
  }

  /* ===== CTA Button, Solid State ===== */
  .luxury-cta {
    display: inline-block;
    padding: 10px 24px;
    font-family: var(--body-font);
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    background: #1CA8CB;
    color: #fff;
    border: none;
    border-radius: 4px;
    transition: background-color 0.2s ease;
    text-decoration: none;
  }

  .luxury-cta:hover {
    background: #178fa8;
    color: #fff;
  }

  /* ===== Mobile Toggle, Luxury ===== */
  #header-one .th-menu-toggle {
    width: auto;
    height: auto;
    min-width: 44px;
    min-height: 44px;
    border-radius: 0;
    background: transparent;
    color: var(--title-color, #113D48);
    border: none;
    transition: color 0.3s ease, opacity 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
  }

  #header-one .th-menu-toggle svg {
    display: block;
    width: 28px;
    height: 28px;
  }

  #header-one .th-menu-toggle:hover {
    background: transparent;
    color: var(--theme-color, #1CA8CB);
  }

  #header-one.header-transparent .sticky-wrapper:not(.sticky) .th-menu-toggle:hover {
    color: #fff;
    opacity: 0.75;
  }

  /* ===== Full-screen mobile drawer ===== */
  :global(.th-menu-wrapper) {
    background-color: #fff;
  }

  :global(.th-menu-wrapper .th-menu-area) {
    width: 100%;
    max-width: 100%;
    border-right: none;
    left: -100%;
  }

  :global(.th-menu-wrapper.th-body-visible .th-menu-area) {
    left: 0;
    opacity: 1;
    visibility: visible;
  }

  :global(.th-menu-wrapper .mobile-menu-close) {
    position: fixed;
    top: 20px;
    right: 20px;
    left: auto;
    width: 44px;
    height: 44px;
    border-radius: 8px;
    background: transparent;
    border: 2px solid var(--title-color, #113D48);
    color: var(--title-color, #113D48);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    z-index: 1000000;
    line-height: 1;
  }

  :global(.th-menu-wrapper .mobile-menu-close:hover) {
    background: var(--title-color, #113D48);
    color: #fff;
  }

  :global(.th-menu-wrapper .th-mobile-menu) {
    margin-top: 0;
    padding-top: 72px;
    max-height: calc(100vh - 40px);
    padding-bottom: 40px;
    overflow-y: auto;
    text-align: left;
  }

  :global(.th-menu-wrapper .th-mobile-menu > ul) {
    padding: 0 24px;
  }

  :global(.th-menu-wrapper .th-mobile-menu ul li a) {
    font-weight: 600;
    font-size: 17px;
    padding: 16px 0;
    line-height: 1.3;
  }

  :global(.th-menu-wrapper .th-mobile-menu ul li) {
    border-bottom-color: #e8e8e8;
  }

  :global(.th-menu-wrapper .th-mobile-menu ul .menu-item-has-children > a:after) {
    background: transparent;
    border-radius: 0;
    width: auto;
    height: auto;
    line-height: 1;
    margin-top: 4px;
    font-size: 14px;
    color: var(--title-color, #113D48);
  }

  /* ===== Responsive ===== */
  @media (max-width: 991px) {
    a[href^="tel:"] {
      display: inline-flex;
      align-items: center;
      min-height: 44px;
      padding: 4px 8px;
      font-size: 15px;
    }
  }

  /* Tighten nav at small-desktop / landscape-tablet so 7 items + CTA fit */
  @media (min-width: 992px) and (max-width: 1199px) {
    #header-one .main-menu > ul > li > a {
      font-size: 11.5px;
      letter-spacing: 0.6px;
      padding: 28px 0;
    }
    #header-one .main-menu > ul {
      gap: 14px;
    }
    .luxury-cta {
      padding: 10px 18px;
      font-size: 11.5px;
      letter-spacing: 1px;
    }
  }
</style>

<script>
  // Block desktop dropdown hover until the user actually moves the mouse.
  // Fixes refresh flash when the cursor is already over "Service".
  function enableNavHover() {
    document.documentElement.classList.add('nav-hover-ready');
  }
  document.documentElement.classList.remove('nav-hover-ready');
  window.addEventListener('mousemove', enableNavHover, { once: true, passive: true });
  window.addEventListener('touchstart', enableNavHover, { once: true, passive: true });
  window.addEventListener('keydown', enableNavHover, { once: true });

  document.addEventListener('astro:page-load', () => {
    document.documentElement.classList.remove('nav-hover-ready');
  });

  // Sticky header, triggers at 80px for quick transition
  const stickyWrapper = document.getElementById('sticky-wrapper');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 80) {
      stickyWrapper?.classList.add('sticky');
    } else {
      stickyWrapper?.classList.remove('sticky');
    }
  });
</script>
