---
import MobileMenu from '../../components/interactive/MobileMenu';
import LanguageSwitcher from '../../components/LanguageSwitcher.astro';
import { resolveLocale } from '../../i18n/context';
import { getMessages } from '../../i18n';
import { buildNavItems } from '../../i18n/nav-links';
import { localizedPath } from '../../i18n/routing';

interface Props {
  /**
   * Transparent-over-hero rendering (white text, absolute positioning).
   * Defaults to true because every page that uses this component sits over
   * a full-bleed hero. Set false for layouts without a dark backdrop.
   * Server-side rendering avoids the CLS 1.0 caused by the previous JS
   * class-toggle approach.
   */
  transparent?: boolean;
}

const { transparent = true } = Astro.props;
const locale = resolveLocale(Astro.locals, Astro.url.pathname);
const messages = getMessages(locale);
const navItems = buildNavItems(messages.nav, locale);
const homeHref = localizedPath('/', locale);
const contactHref = localizedPath('/contact', locale);
---

<header class:list={['th-header header-layout1', transparent && 'header-transparent']} id="header-one">
  <div class="sticky-wrapper" id="sticky-wrapper">
    <div class="menu-area">
      <div class="container th-container">
        <div class="header-grid">
          <!-- Nav, left on desktop -->
          <nav class="main-menu header-nav-left d-none d-lg-block" aria-label="Main navigation">
            <ul>
              {navItems.map((item) => (
                item.children ? (
                  <li class="menu-item-has-children">
                    <a href={item.href}>{item.label}</a>
                    <ul class="sub-menu">
                      {item.children.map((child) => (
                        <li>
                          <a
                            href={child.href}
                            target={child.external ? '_blank' : undefined}
                            rel={child.external ? 'noopener noreferrer' : undefined}
                          >
                            {child.label}
                          </a>
                        </li>
                      ))}
                    </ul>
                  </li>
                ) : (
                  <li>
                    <a href={item.href}>{item.label}</a>
                  </li>
                )
              ))}
            </ul>
          </nav>
          <!-- Logo, centered on desktop -->
          <div class="header-logo">
            <a href={homeHref}>
              <img src="/assets/img/brand/logos/logo-traced.svg" alt={messages.brand} width="200" height="60" decoding="async" />
            </a>
          </div>
          <!-- CTA + language + mobile toggle, right -->
          <div class="header-actions d-flex align-items-center">
            <LanguageSwitcher />
            <div class="d-none d-lg-block">
              <a href={contactHref} class="luxury-cta">{messages.nav.bookNow}</a>
            </div>
            <button type="button" class="th-menu-toggle d-block d-lg-none" id="mobile-menu-trigger" aria-label={messages.nav.openMenu}>
              <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" aria-hidden="true">
                <line x1="3" y1="6" x2="21" y2="6"></line>
                <line x1="3" y1="12" x2="21" y2="12"></line>
                <line x1="3" y1="18" x2="21" y2="18"></line>
              </svg>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</header>

<div id="mobile-menu-container">
  <MobileMenu client:idle menuItems={navItems} />
</div>

<style>
  .header-actions {
    gap: 18px;
  }

  /* ===== Header layout: logo centered, nav left, actions right (desktop) ===== */
  .header-grid {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  @media (min-width: 992px) {
    /* Header spans (almost) the full viewport so the pages have room to sit
       far left with space before the centered logo — the narrow Bootstrap
       container was cramping all seven links into a third of the width. */
    #header-one .th-container {
      max-width: none;
      width: 100%;
      padding-left: clamp(28px, 3vw, 60px);
      padding-right: clamp(28px, 3vw, 60px);
    }

    .header-grid {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
      column-gap: 24px;
    }

    .header-nav-left {
      justify-self: stretch;
      min-width: 0;
      /* Theme's .main-menu adds 150px left padding — kill it so pages sit
         flush-left under the container edge. */
      padding-left: 0;
      padding-right: 0;
    }

    /* Pages sit flush-left with even spacing; empty space is left before the
       centered logo so they never crowd it (Archon-style). Fluid font + gap
       keep all links on one line inside the left third at any width. */
    #header-one .header-nav-left > ul {
      width: 100%;
      justify-content: flex-start;
      flex-wrap: nowrap;
      gap: clamp(4px, 0.5vw, 14px);
    }

    /* The theme sets `margin: 0 14px` on every nav <li>, which stacks ~28px
       per item on top of the intended `gap` and pushes the last links under
       the centered logo. Zero it so `gap` is the sole spacer. */
    #header-one .header-nav-left > ul > li {
      margin: 0;
    }

    /* Two classes (.main-menu.header-nav-left) so this out-specifies the base
       `#header-one .main-menu > ul > li > a` rule below (and the duplicate in
       BaseLayout), both of which otherwise force a fixed 13px/1.5px that
       overflows the left grid track. */
    #header-one .main-menu.header-nav-left > ul > li > a {
      font-size: clamp(10.5px, 0.62vw, 12.5px);
      letter-spacing: clamp(0.2px, 0.05vw, 1.2px);
    }

    /* Compact, Archon-style centered logo */
    .header-grid .header-logo img {
      max-height: 90px;
    }

    .header-grid .header-logo {
      justify-self: center;
    }

    .header-grid .header-actions {
      justify-self: end;
    }
  }

  /* ===== Luxury Navbar Base ===== */
  #header-one {
    position: relative;
    z-index: 99;
  }

  .main-menu ul.sub-menu li a:before {
    display: none !important;
  }

  /* Transparent mode, only active when .header-transparent is on the header AND not scrolled */
  #header-one.header-transparent .sticky-wrapper:not(.sticky) {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    z-index: 99;
    background: linear-gradient(180deg, rgba(0,0,0,0.3) 0%, transparent 100%);
  }

  /* Lighter top darkening on mobile so the hero video stays bright */
  @media (max-width: 991px) {
    #header-one.header-transparent .sticky-wrapper:not(.sticky) {
      background: linear-gradient(180deg, rgba(0,0,0,0.15) 0%, transparent 100%);
    }
  }

  #header-one.header-transparent .sticky-wrapper:not(.sticky) .header-logo img {
    filter: brightness(0) invert(1);
  }

  #header-one.header-transparent .sticky-wrapper:not(.sticky) .main-menu > ul > li > a {
    color: #fff;
  }

  #header-one.header-transparent .sticky-wrapper:not(.sticky) .main-menu ul li.menu-item-has-children > a:after {
    color: #fff;
  }

  #header-one.header-transparent .sticky-wrapper:not(.sticky) .luxury-cta {
    background: rgba(28, 168, 203, 0.85);
    color: #fff;
    border: none;
    backdrop-filter: blur(5px);
    -webkit-backdrop-filter: blur(5px);
  }

  #header-one.header-transparent .sticky-wrapper:not(.sticky) .luxury-cta:hover {
    background: #1CA8CB;
    color: #fff;
  }

  #header-one.header-transparent .sticky-wrapper:not(.sticky) .th-menu-toggle {
    background: transparent;
    color: #fff;
    border: none;
  }

  /* ===== Solid State (default & scrolled) ===== */
  .sticky-wrapper {
    transition: all 0.4s ease;
  }

  .sticky-wrapper.sticky {
    background-color: #fff;
    box-shadow: 0 2px 20px rgba(0,0,0,0.06);
  }

  .header-logo img {
    transition: filter 0.4s ease;
    max-height: 140px;
    width: auto;
    filter: none;
  }

  @media (max-width: 991px) {
    .header-logo img {
      max-height: 100px;
    }
  }

  /* Nav links, ensure flex layout inside centered col */
  #header-one .main-menu > ul {
    display: flex;
    align-items: center;
  }

  /* Never wrap a page label onto a second line */
  #header-one .main-menu > ul > li {
    flex: 0 0 auto;
  }

  #header-one .main-menu > ul > li > a {
    white-space: nowrap;
  }

  /* ===== Nav Links, Luxury Typography ===== */
  #header-one .main-menu > ul > li > a {
    font-family: var(--body-font);
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--title-color, #113D48);
    padding: 32px 0;
    position: relative;
    transition: color 0.3s ease;
  }

  #header-one .main-menu > ul > li > a::before {
    content: '';
    position: absolute;
    bottom: 24px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--theme-color, #1CA8CB);
    transition: width 0.3s ease;
  }

  #header-one .main-menu > ul > li > a:hover::before,
  #header-one .main-menu > ul > li > a.active::before {
    width: 100%;
  }

  #header-one .main-menu > ul > li > a:hover {
    color: var(--theme-color, #1CA8CB);
  }

  #header-one .main-menu ul li.menu-item-has-children > a:after {
    font-size: 0.7em;
    margin-left: 5px;
    transition: color 0.3s ease;
  }

  #header-one .main-menu ul.sub-menu {
    display: none !important;
    visibility: hidden !important;
    opacity: 0 !important;
    pointer-events: none !important;
    transform: scaleY(0) !important;
    border-bottom: 2px solid var(--theme-color, #1CA8CB);
    box-shadow: 0 8px 32px rgba(0,0,0,0.08);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-radius: 4px;
  }

  @media (min-width: 992px) {
    html.nav-hover-ready #header-one .main-menu li.menu-item-has-children:hover > ul.sub-menu,
    #header-one .main-menu li.menu-item-has-children:focus-within > ul.sub-menu {
      display: block !important;
      visibility: visible !important;
      opacity: 1 !important;
      pointer-events: auto !important;
      transform: scaleY(1) !important;
    }
  }

  #header-one .main-menu ul.sub-menu a {
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.5px;
    text-transform: none;
  }

  .luxury-cta {
    display: inline-block;
    padding: 10px 24px;
    font-family: var(--body-font);
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    background: #1CA8CB;
    color: #fff;
    border: none;
    border-radius: 4px;
    transition: background-color 0.2s ease;
    text-decoration: none;
  }

  .luxury-cta:hover {
    background: #178fa8;
    color: #fff;
  }

  #header-one .th-menu-toggle {
    width: auto;
    height: auto;
    min-width: 48px;
    min-height: 48px;
    border-radius: 0;
    background: transparent;
    color: var(--title-color, #113D48);
    border: none;
    transition: color 0.3s ease, opacity 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
  }

  #header-one .th-menu-toggle svg {
    display: block;
    width: 36px;
    height: 36px;
  }

  #header-one .th-menu-toggle:hover {
    background: transparent;
    color: var(--theme-color, #1CA8CB);
  }

  #header-one.header-transparent .sticky-wrapper:not(.sticky) .th-menu-toggle:hover {
    color: #fff;
    opacity: 0.75;
  }

  :global(.th-menu-wrapper) {
    background-color: #fff;
  }

  :global(.th-menu-wrapper .th-menu-area) {
    width: 100%;
    max-width: 100%;
    border-right: none;
    left: -100%;
  }

  :global(.th-menu-wrapper.th-body-visible .th-menu-area) {
    left: 0;
    opacity: 1;
    visibility: visible;
  }

  :global(.th-menu-wrapper .mobile-menu-close) {
    position: fixed;
    top: 20px;
    right: 20px;
    left: auto;
    width: 44px;
    height: 44px;
    border-radius: 8px;
    background: transparent;
    border: 2px solid var(--title-color, #113D48);
    color: var(--title-color, #113D48);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    z-index: 1000000;
    line-height: 1;
  }

  :global(.th-menu-wrapper .mobile-menu-close:hover) {
    background: var(--title-color, #113D48);
    color: #fff;
  }

  :global(.th-menu-wrapper .th-mobile-menu) {
    margin-top: 0;
    padding-top: 72px;
    max-height: calc(100vh - 40px);
    padding-bottom: 40px;
    overflow-y: auto;
    text-align: left;
  }

  :global(.th-menu-wrapper .th-mobile-menu > ul) {
    padding: 0 24px;
  }

  :global(.th-menu-wrapper .th-mobile-menu ul li a) {
    font-weight: 600;
    font-size: 17px;
    padding: 16px 0;
    line-height: 1.3;
  }

  :global(.th-menu-wrapper .th-mobile-menu ul li) {
    border-bottom-color: #e8e8e8;
  }

  :global(.th-menu-wrapper .th-mobile-menu ul .menu-item-has-children > a:after) {
    background: transparent;
    border-radius: 0;
    width: auto;
    height: auto;
    line-height: 1;
    margin-top: 4px;
    font-size: 14px;
    color: var(--title-color, #113D48);
  }

  @media (max-width: 991px) {
    a[href^="tel:"] {
      display: inline-flex;
      align-items: center;
      min-height: 44px;
      padding: 4px 8px;
      font-size: 15px;
    }
  }

  @media (min-width: 992px) and (max-width: 1399px) {
    #header-one .main-menu > ul > li > a {
      padding: 28px 0;
    }
    .luxury-cta {
      padding: 10px 18px;
      font-size: 11.5px;
      letter-spacing: 1px;
    }
  }
</style>

<script>
  function enableNavHover() {
    document.documentElement.classList.add('nav-hover-ready');
  }
  document.documentElement.classList.remove('nav-hover-ready');
  window.addEventListener('mousemove', enableNavHover, { once: true, passive: true });
  window.addEventListener('touchstart', enableNavHover, { once: true, passive: true });
  window.addEventListener('keydown', enableNavHover, { once: true });

  document.addEventListener('astro:page-load', () => {
    document.documentElement.classList.remove('nav-hover-ready');
  });

  const stickyWrapper = document.getElementById('sticky-wrapper');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 80) {
      stickyWrapper?.classList.add('sticky');
    } else {
      stickyWrapper?.classList.remove('sticky');
    }
  });
</script>
