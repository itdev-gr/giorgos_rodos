---
import posts from '../../data/data-post.json';
import { imgUrl, imgSrcset } from '../../lib/media';

const featured = posts.slice(0, 3);
---

<section class="home-news">
  <div class="container">
    <div class="home-news__header text-center">
      <h2 class="home-news__title" data-ani="slideinup">Our Boating News</h2>
    </div>

    <div class="home-news__grid">
      {featured.map((post, i) => {
        const imagePath = `/assets/img/pages/blog/${post.bannerImg || post.image}`;
        const tag = post.tags?.[0];
        return (
          <article class="home-news__card" data-ani="slideinup" data-ani-delay={`${0.05 + i * 0.08}`}>
            <a href={`/blog/${post.slug}`} class="home-news__link">
              <div class="home-news__media">
                <img
                  src={imgUrl(imagePath, 640, { quality: 80 }) || imagePath}
                  srcset={imgSrcset(imagePath, [400, 640, 800]) || undefined}
                  sizes="(max-width: 575px) 100vw, (max-width: 991px) 50vw, 33vw"
                  alt={post.title}
                  loading="lazy"
                  width="640"
                  height="400"
                  decoding="async"
                />
                {tag && <span class="home-news__tag">{tag}</span>}
              </div>
              <div class="home-news__body">
                <p class="home-news__meta">
                  <time datetime={post.publishedDate || undefined}>{post.date}</time>
                </p>
                <h3 class="home-news__card-title">{post.title}</h3>
                <p class="home-news__excerpt">{post.excerpt}</p>
                <span class="home-news__cta">Read article <span aria-hidden="true">→</span></span>
              </div>
            </a>
          </article>
        );
      })}
    </div>

    <div class="home-news__cta-wrap">
      <a href="/blog" class="th-btn style3 home-news__btn" data-ani="fadein" data-ani-delay="0.3">See All Articles</a>
    </div>
  </div>
</section>

<style>
  .home-news {
    padding: 80px 0;
    background: #f8fafb;
  }

  .home-news__header {
    margin-bottom: 44px;
  }

  .home-news__title {
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    font-weight: 700;
    color: #113D48;
    margin: 0;
    line-height: 1.2;
  }

  .home-news__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }

  .home-news__card {
    background: #fff;
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid #e8eef2;
    box-shadow: 0 4px 20px rgba(17, 61, 72, 0.05);
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
  }

  .home-news__card:hover {
    transform: translateY(-6px);
    box-shadow: 0 16px 40px rgba(28, 168, 203, 0.12);
    border-color: rgba(28, 168, 203, 0.35);
  }

  .home-news__link {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }

  .home-news__media {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: #dce8ec;
  }

  .home-news__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .home-news__card:hover .home-news__media img {
    transform: scale(1.05);
  }

  .home-news__tag {
    position: absolute;
    top: 14px;
    left: 14px;
    background: rgba(17, 61, 72, 0.88);
    color: #fff;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 6px 12px;
    border-radius: 6px;
  }

  .home-news__body {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: 22px 22px 24px;
  }

  .home-news__meta {
    font-size: 0.8rem;
    color: #64748b;
    margin: 0 0 10px;
  }

  .home-news__card-title {
    font-size: 1.1rem;
    font-weight: 700;
    line-height: 1.35;
    color: #113D48;
    margin: 0 0 10px;
    transition: color 0.2s ease;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .home-news__card:hover .home-news__card-title {
    color: #1CA8CB;
  }

  .home-news__excerpt {
    font-size: 0.9rem;
    line-height: 1.6;
    color: #5a6a72;
    margin: 0 0 16px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .home-news__cta {
    margin-top: auto;
    font-size: 0.85rem;
    font-weight: 600;
    color: #1CA8CB;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: gap 0.2s ease;
  }

  .home-news__card:hover .home-news__cta {
    gap: 10px;
  }

  .home-news__cta-wrap {
    display: flex;
    justify-content: center;
    margin-top: 44px;
  }

  .home-news__btn {
    display: inline-flex;
    justify-content: center;
  }

  @media (max-width: 991px) {
    .home-news {
      padding: 64px 0;
    }

    .home-news__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 22px;
    }
  }

  @media (max-width: 575px) {
    .home-news {
      padding: 52px 0;
    }

    .home-news__header {
      margin-bottom: 32px;
    }

    .home-news__grid {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .home-news__body {
      padding: 18px 18px 20px;
    }

    .home-news__cta-wrap {
      margin-top: 32px;
    }
  }
</style>
