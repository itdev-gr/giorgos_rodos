---
interface Season {
  name: string;
  months: string;
  description: string;
  recommended?: boolean;
}

interface Props {
  title: string;
  subtitle?: string;
  image: string;
  seasons: Season[];
}

const {
  title,
  subtitle = 'Best Time to Visit',
  image,
  seasons,
} = Astro.props;

---

<section class="szn-section" style={`background-image: url(${image});`}>
  <div class="szn-overlay"></div>
  <div class="container" style="position: relative; z-index: 2;">
    <div class="szn-header">
      <span class="szn-label" data-ani="fadein">{subtitle}</span>
      <h2 class="szn-title" data-ani="slideinup" data-ani-delay="0.1">{title}</h2>
    </div>
    <div class="szn-grid" style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px;">
      {seasons.map((season, i) => (
        <div class={`szn-card ${season.recommended ? 'szn-card--rec' : ''}`} style={`padding: 36px 28px; background: ${season.recommended ? 'rgba(28,168,203,0.2)' : 'rgba(255,255,255,0.08)'}; border: 1px solid ${season.recommended ? 'rgba(28,168,203,0.4)' : 'rgba(255,255,255,0.12)'}; border-radius: 16px; text-align: center; backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);`} data-ani="slideinup" data-ani-delay={`${0.15 + i * 0.1}`}>
          {season.recommended && <div class="szn-badge">Best Time</div>}
          <h4 class="szn-name">{season.name}</h4>
          <span class="szn-months">{season.months}</span>
          <p class="szn-desc">{season.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .szn-section {
    position: relative;
    padding: 100px 0;
    overflow: hidden;
    background-size: cover;
    background-position: center;
  }

  .szn-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(17, 61, 72, 0.92) 0%,
      rgba(17, 61, 72, 0.85) 100%
    );
    z-index: 1;
  }

  .szn-header {
    text-align: center;
    margin-bottom: 56px;
  }

  .szn-label {
    display: inline-block;font-style: italic;
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.6);
    margin-bottom: 12px;
  }

  .szn-title {font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 700;
    color: #fff;
    margin-bottom: 0;
  }

  .szn-grid {
    display: grid !important;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }

  .szn-card {
    position: relative;
    padding: 36px 28px;
    background: rgba(255,255,255,0.07);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,0.1);
    border-left: 1px solid rgba(255,255,255,0.1);
    border-radius: 16px;
    text-align: center;
    box-shadow: none;
    transition: transform 0.3s ease, background 0.3s ease;
  }

  .szn-card:hover {
    transform: translateY(-5px);
    background: rgba(255,255,255,0.12);
  }

  .szn-card--rec {
    background: rgba(28, 168, 203, 0.15);
    border-color: rgba(28, 168, 203, 0.35);
  }

  .szn-card--rec:hover {
    background: rgba(28, 168, 203, 0.22);
  }

  .szn-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    padding: 4px 16px;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: #fff;
    background: var(--theme-color, #1CA8CB);
    border-radius: 20px;
    white-space: nowrap;
  }

  .szn-icon {
    font-size: 2.2rem;
    margin-bottom: 16px;
    line-height: 1;
  }

  .szn-name {font-size: 1.15rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 6px;
  }

  .szn-months {
    display: block;font-size: 0.85rem;
    font-weight: 600;
    color: var(--theme-color, #1CA8CB);
    margin-bottom: 14px;
    letter-spacing: 0.5px;
  }

  .szn-desc {
    font-size: 0.9rem;
    line-height: 1.65;
    color: rgba(255,255,255,0.7);
    margin-bottom: 0;
  }

  @media (max-width: 991px) {
    .szn-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 575px) {
    .szn-section {
      padding: 60px 0;
    }

    .szn-grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .szn-card {
      padding: 24px 18px;
    }
  }
</style>
