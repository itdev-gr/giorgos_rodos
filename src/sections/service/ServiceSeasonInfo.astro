---
interface Season {
  name: string;
  months: string;
  description: string;
  recommended?: boolean;
}

interface Props {
  title: string;
  subtitle?: string;
  image: string;
  seasons: Season[];
}

const {
  title,
  subtitle = 'Best Time to Visit',
  image,
  seasons,
} = Astro.props;
---

<div class="space overflow-hidden">
  <div class="container">
    <div class="row align-items-center">
      <div class="col-xl-6">
        <div class="title-area mb-25">
          <span class="sub-title style1" data-ani="slideinup">{subtitle}</span>
          <h2 class="sec-title" data-ani="slideinup" data-ani-delay="0.1">{title}</h2>
        </div>
        <div class="season-cards">
          {seasons.map((season, i) => (
            <div class="season-card" data-ani="slideinleft" data-ani-delay={`${0.1 + i * 0.1}`}>
              <div class="season-card_header">
                <h5 class="season-card_name">{season.name}</h5>
                {season.recommended && (
                  <span class="season-card_badge">Recommended</span>
                )}
              </div>
              <p class="season-card_months">{season.months}</p>
              <p class="season-card_desc">{season.description}</p>
            </div>
          ))}
        </div>
      </div>
      <div class="col-xl-6">
        <div class="season-img" data-ani="slideinright">
          <img src={image} alt={title} class="w-100" style="border-radius: 16px; object-fit: cover; max-height: 600px;" loading="lazy" />
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .season-cards {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-bottom: 30px;
  }
  .season-card {
    padding: 24px;
    border-radius: 12px;
    background: #fff;
    box-shadow: 0 2px 20px rgba(0,0,0,0.06);
    border-left: 4px solid var(--theme-color, #1CA8CB);
  }
  .season-card_header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 6px;
  }
  .season-card_name {
    margin-bottom: 0;
  }
  .season-card_badge {
    display: inline-block;
    padding: 3px 12px;
    font-size: 0.75rem;
    font-weight: 600;
    color: #fff;
    background: var(--theme-color, #1CA8CB);
    border-radius: 20px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .season-card_months {
    font-size: 0.9rem;
    color: var(--theme-color, #1CA8CB);
    font-weight: 600;
    margin-bottom: 6px;
  }
  .season-card_desc {
    margin-bottom: 0;
    font-size: 0.93rem;
  }
  .season-img {
    margin-top: 30px;
  }
  @media (min-width: 1200px) {
    .season-img {
      margin-top: 0;
    }
  }
</style>
