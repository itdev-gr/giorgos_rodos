---
interface Step {
  title: string;
  description: string;
  icon: string;
}

interface Props {
  title: string;
  subtitle?: string;
  steps?: Step[];
}

const {
  title,
  subtitle = 'How It Works',
  steps = [
    { title: 'Inquiry', description: 'Tell us your vessel details, arrival dates, and specific requirements.', icon: 'fas fa-envelope-open-text' },
    { title: 'Assessment', description: 'Our team evaluates your needs and prepares a tailored service plan.', icon: 'fas fa-clipboard-check' },
    { title: 'Provisioning', description: 'We source and organize all supplies, fuel, and logistics ahead of your arrival.', icon: 'fas fa-boxes-stacked' },
    { title: 'Delivery', description: 'Everything is delivered dockside, on time and to specification.', icon: 'fas fa-truck-fast' },
    { title: 'Support', description: 'Ongoing 24/7 concierge support throughout your stay in Rhodes.', icon: 'fas fa-headset' },
  ],
} = Astro.props;
---

<div class="space overflow-hidden">
  <div class="container">
    <div class="title-area text-center mb-60">
      <span class="sub-title style1" data-ani="slideinup">{subtitle}</span>
      <h2 class="sec-title" data-ani="slideinup" data-ani-delay="0.1">{title}</h2>
    </div>
    <div class="mise-timeline position-relative">
      <div class="mise-timeline-line"></div>
      <div class="row g-0 justify-content-between">
        {steps.map((step, i) => (
          <div class="mise-timeline-step text-center" data-ani="slideinup" data-ani-delay={`${i * 0.15}`}>
            <div class="mise-timeline-icon">
              <i class={step.icon}></i>
            </div>
            <div class="mise-timeline-number">{String(i + 1).padStart(2, '0')}</div>
            <h6 class="mise-timeline-title">{step.title}</h6>
            <p class="mise-timeline-desc">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</div>

<style>
  .mise-timeline {
    padding: 0 20px;
  }
  .mise-timeline-line {
    position: absolute;
    top: 42px;
    left: 10%;
    right: 10%;
    height: 3px;
    background: #e0e0e0;
    z-index: 0;
  }
  .mise-timeline-line::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    width: 0;
    background: var(--theme-color, #1CA8CB);
    transition: width 1s ease;
  }
  .mise-timeline .row {
    display: flex;
    flex-wrap: wrap;
  }
  .mise-timeline-step {
    flex: 1;
    min-width: 160px;
    position: relative;
    z-index: 1;
    padding: 0 10px;
  }
  .mise-timeline-icon {
    width: 84px;
    height: 84px;
    border-radius: 50%;
    background: #fff;
    border: 3px solid var(--theme-color, #1CA8CB);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 16px;
    font-size: 1.6rem;
    color: var(--theme-color, #1CA8CB);
    box-shadow: 0 4px 20px rgba(28, 168, 203, 0.15);
  }
  .mise-timeline-number {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--theme-color, #1CA8CB);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 8px;
  }
  .mise-timeline-title {
    margin-bottom: 8px;
  }
  .mise-timeline-desc {
    font-size: 0.85rem;
    margin-bottom: 0;
    color: #6e7070;
  }
  @media (max-width: 991px) {
    .mise-timeline .row {
      flex-direction: column;
      gap: 30px;
    }
    .mise-timeline-line {
      display: none;
    }
    .mise-timeline-step {
      min-width: auto;
      max-width: 300px;
      margin: 0 auto;
    }
  }
</style>

<script>
  function initTimelineLine() {
    if (typeof window.gsap === 'undefined' || typeof window.ScrollTrigger === 'undefined') return;
    const line = document.querySelector('.mise-timeline-line');
    if (!line || line.dataset.lineInit) return;
    line.dataset.lineInit = 'true';
    window.gsap.to(line, {
      '--line-width': '100%',
      ease: 'none',
      scrollTrigger: {
        trigger: '.mise-timeline',
        start: 'top 80%',
        end: 'top 30%',
        scrub: true,
        onUpdate: (self) => {
          const after = line.querySelector
          ? line
          : null;
          if (after) {
            (after as HTMLElement).style.setProperty('--tw', `${self.progress * 100}%`);
          }
        },
      },
    });
    /* Note: pseudo-elements cannot be animated directly with GSAP */
    /* Direct approach: animate a real child */
    const lineEl = document.querySelector('.mise-timeline-line') as HTMLElement;
    if (lineEl) {
      lineEl.style.overflow = 'hidden';
      const fill = document.createElement('div');
      fill.style.cssText = 'height:100%;width:0;background:var(--theme-color,#1CA8CB);';
      lineEl.appendChild(fill);
      window.gsap.to(fill, {
        width: '100%',
        ease: 'none',
        scrollTrigger: {
          trigger: '.mise-timeline',
          start: 'top 80%',
          end: 'top 30%',
          scrub: true,
        },
      });
    }
  }
  document.addEventListener('DOMContentLoaded', initTimelineLine);
  document.addEventListener('astro:page-load', initTimelineLine);
</script>
