---
interface Props {
  title: string;
  images: string[];
}

const { title, images } = Astro.props;
const swiperId = `gallery-carousel-${Math.random().toString(36).slice(2, 8)}`;
---

<div class="sidebar-gallery-area space">
  <div class="container-fluid">
    <div class="title-area mb-30 text-center">
      <span class="sub-title">Explore</span>
      <h2 class="sec-title">{title}</h2>
    </div>
    <div class="slider-area">
      <div class="swiper th-slider has-shadow" id={swiperId}>
        <div class="swiper-wrapper">
          {images.map((img) => (
            <div class="swiper-slide">
              <div class="gallery-thumb style2 global-img">
                <img src={img} alt="Gallery" />
                <a href={img} class="gallery-btn popup-image">
                  <i class="fas fa-search-plus" aria-hidden="true"></i>
                </a>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</div>

<script define:vars={{ swiperId }}>
  function initGalleryCarousel() {
    if (typeof Swiper === 'undefined') {
      const script = document.createElement('script');
      script.src = 'https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js';
      script.onload = () => createSwiper();
      document.head.appendChild(script);
    } else {
      createSwiper();
    }
  }

  function createSwiper() {
    const el = document.getElementById(swiperId);
    if (!el || el.dataset.initialized) return;
    el.dataset.initialized = 'true';
    new Swiper('#' + swiperId, {
      slidesPerView: 1,
      spaceBetween: 20,
      centeredSlides: true,
      loop: true,
      autoplay: { delay: 3000, disableOnInteraction: false },
      breakpoints: {
        0: { slidesPerView: 1 },
        576: { slidesPerView: 2 },
        768: { slidesPerView: 2 },
        992: { slidesPerView: 3 },
        1200: { slidesPerView: 3 },
        1300: { slidesPerView: 4 },
      },
    });
  }

  document.addEventListener('DOMContentLoaded', initGalleryCarousel);
  document.addEventListener('astro:page-load', initGalleryCarousel);
</script>
