---
interface Feature {
  icon: string;
  title: string;
  text: string;
}

interface Props {
  title: string;
  description: string;
  image1: string;
  image2: string;
  features: Feature[];
}

const { title, description, image1, image2, features } = Astro.props;
---

<div class="about-area position-relative overflow-hidden space" id="about-sec">
  <div class="container">
    <div class="row">
      <div class="col-xl-5 order-xl-1">
        <div>
          <div class="title-area mb-20">
            <span class="sub-title style1">About This Service</span>
            <h2 class="sec-title mb-20">{title}</h2>
          </div>
          <p class="sec-text mb-30">{description}</p>
          <div class="about-item-wrap">
            {features.map((feature) => (
              <div class="about-item style2">
                <div class="about-item_img">
                  <img src={feature.icon} alt="" />
                </div>
                <div class="about-item_centent">
                  <h5 class="box-title">{feature.title}</h5>
                  <p class="about-item_text">{feature.text}</p>
                </div>
              </div>
            ))}
          </div>
          <div class="mt-35">
            <a href="/contact" class="th-btn style3 th-icon">Book Now</a>
          </div>
        </div>
      </div>
      <div class="col-xl-7 order-xl-2">
        <div class="img-box2">
          <div class="img1">
            <img src={image1} alt="About" />
          </div>
          <div class="img2">
            <img src={image2} alt="About" />
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
