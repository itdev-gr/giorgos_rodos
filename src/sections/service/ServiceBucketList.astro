---
interface BucketItem {
  title: string;
  description: string;
}

interface Props {
  title: string;
  subtitle?: string;
  items: BucketItem[];
}

const {
  title,
  subtitle = 'Must-Do Experiences',
  items,
} = Astro.props;
---

<div class="bucket-list-section space overflow-hidden">
  <div class="container">
    <div class="title-area text-center mb-50">
      <span class="sub-title style1 text-white" data-ani="slideinup">{subtitle}</span>
      <h2 class="sec-title text-white" data-ani="slideinup" data-ani-delay="0.1">{title}</h2>
    </div>
    <div class="row gy-30">
      {items.map((item, i) => (
        <div class="col-lg-6">
          <div class="bucket-item" data-ani="zoomIn" data-ani-delay={`${i * 0.1}`}>
            <span class="bucket-item_number">{String(i + 1).padStart(2, '0')}</span>
            <div class="bucket-item_content">
              <h5 class="bucket-item_title">{item.title}</h5>
              <p class="bucket-item_desc">{item.description}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</div>

<style>
  .bucket-list-section {
    background: #113D48;
  }
  .bucket-item {
    display: flex;
    gap: 20px;
    padding: 30px;
    border-radius: 12px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    transition: background 0.3s;
    height: 100%;
  }
  .bucket-item:hover {
    background: rgba(255,255,255,0.1);
  }
  .bucket-item_number {
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--theme-color, #1CA8CB);
    line-height: 1;
    flex-shrink: 0;
    opacity: 0.7;
  }
  .bucket-item_content {
    flex: 1;
  }
  .bucket-item_title {
    color: #fff;
    margin-bottom: 8px;
  }
  .bucket-item_desc {
    color: rgba(255,255,255,0.7);
    margin-bottom: 0;
    font-size: 0.93rem;
  }
</style>
