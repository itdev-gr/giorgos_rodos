---
interface Feature {
  icon: string;
  title: string;
  text: string;
}

interface Props {
  title: string;
  description: string;
  image1: string;
  image2: string;
  image3: string;
  features: Feature[];
}

const { title, description, image1, image2, image3, features } = Astro.props;
---

<div class="about-area position-relative overflow-hidden space" id="about-sec">
  <div class="container shape-mockup-wrap">
    <div class="row">
      <div class="col-xl-7">
        <div class="img-box3">
          <div class="img1">
            <img src={image1} alt="About" />
          </div>
          <div class="img2">
            <img src={image2} alt="About" />
          </div>
          <div class="img3 movingX">
            <img src={image3} alt="About" />
          </div>
        </div>
      </div>
      <div class="col-xl-5">
        <div class="ps-xl-4">
          <div class="title-area mb-20">
            <span class="sub-title style1">About This Service</span>
            <h2 class="sec-title mb-20 pe-xl-5 me-xl-5">{title}</h2>
          </div>
          <p class="pe-xl-5">{description}</p>
          <p class="mb-30 pe-xl-5"></p>
          <div class="about-item-wrap">
            {features.map((feature) => (
              <div class="about-item style2">
                <div class="about-item_img">
                  <img src={feature.icon} alt="" />
                </div>
                <div class="about-item_centent">
                  <h5 class="box-title">{feature.title}</h5>
                  <p class="about-item_text">{feature.text}</p>
                </div>
              </div>
            ))}
          </div>
          <div class="mt-35">
            <a href="/contact" class="th-btn style3 th-icon">Book Now</a>
          </div>
        </div>
      </div>
    </div>
    <div class="shape-mockup movingX d-none d-xxl-block" style="top: 0%; left: -18%;">
      <img src="/assets/img/shape/shape_2_1.png" alt="shape" />
    </div>
    <div class="shape-mockup spin d-none d-xxl-block" style="top: 18%; left: -112%;">
      <img src="/assets/img/shape/shape_2_3.png" alt="shape" />
    </div>
    <div class="shape-mockup d-none d-xxl-block" style="bottom: 18%; right: -12%;">
      <img src="/assets/img/shape/shape_2_4.png" alt="shape" />
    </div>
  </div>
</div>
