---
interface Feature {
  icon: string;
  title: string;
  text: string;
}

interface Props {
  title: string;
  subtitle?: string;
  description: string;
  image: string;
  layout?: 'left' | 'right';
  features: Feature[];
}

const {
  title,
  subtitle = 'Why Choose Us',
  description,
  image,
  layout = 'left',
  features,
} = Astro.props;

const imageAni = layout === 'left' ? 'slideinleft' : 'slideinright';
const imageOrder = layout === 'left' ? '' : 'order-xl-2';
const textOrder = layout === 'left' ? '' : 'order-xl-1';
---

<div class="bg-smoke space overflow-hidden">
  <div class="container">
    <div class="row align-items-center">
      <div class={`col-xl-6 ${imageOrder}`}>
        <div class="service-why-img" data-ani={imageAni}>
          <img src={image} alt={title} class="w-100" style="border-radius: 16px; object-fit: cover; max-height: 550px;" loading="lazy" />
        </div>
      </div>
      <div class={`col-xl-6 ${textOrder}`}>
        <div class={layout === 'left' ? 'ps-xl-5' : 'pe-xl-5'}>
          <div class="title-area mb-25">
            <span class="sub-title style1" data-ani="slideinup">{subtitle}</span>
            <h2 class="sec-title" data-ani="slideinup" data-ani-delay="0.1">{title}</h2>
          </div>
          <p class="mb-30" data-ani="fadein" data-ani-delay="0.2">{description}</p>
          <div class="about-item-wrap">
            {features.map((feature, i) => (
              <div class="about-item style2" data-ani="slideinup" data-ani-delay={`${0.2 + i * 0.1}`}>
                <div class="about-item_img">
                  <img src={feature.icon} alt="" />
                </div>
                <div class="about-item_centent">
                  <h5 class="box-title">{feature.title}</h5>
                  <p class="about-item_text">{feature.text}</p>
                </div>
              </div>
            ))}
          </div>
          <div class="mt-35" data-ani="slideinup" data-ani-delay="0.5">
            <a href="/contact" class="th-btn style3 th-icon">Learn More</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .service-why-img {
    position: relative;
    margin-bottom: 30px;
  }
  @media (min-width: 1200px) {
    .service-why-img {
      margin-bottom: 0;
    }
  }
</style>
