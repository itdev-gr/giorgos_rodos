---
interface Feature {
  icon: string;
  title: string;
  text: string;
}

interface Props {
  title: string;
  subtitle?: string;
  description: string;
  image: string;
  layout?: 'left' | 'right';
  features: Feature[];
}

const {
  title,
  subtitle = 'Why Choose Us',
  description,
  image,
  layout = 'left',
  features,
} = Astro.props;

const reversed = layout === 'right';
---

<section class="why-section">
  <div class="container">
    <div class={`why-grid ${reversed ? 'why-grid--reversed' : ''}`}>
      <div class="why-image-col">
        <div class="why-image-wrapper" data-ani="fadein">
          <img src={image} alt={title} loading="lazy" />
          <div class="why-image-accent"></div>
        </div>
      </div>
      <div class="why-text-col">
        <span class="why-label" data-ani="slideinup">{subtitle}</span>
        <h2 class="why-title" data-ani="slideinup" data-ani-delay="0.1">{title}</h2>
        <p class="why-desc" data-ani="fadein" data-ani-delay="0.2">{description}</p>
        <div class="why-features">
          {features.map((feature, i) => (
            <div class="why-feature" data-ani="slideinup" data-ani-delay={`${0.2 + i * 0.1}`}>
              <div class="why-feature-icon">
                <img src={feature.icon} alt="" />
              </div>
              <div class="why-feature-body">
                <h4 class="why-feature-title">{feature.title}</h4>
                <p class="why-feature-text">{feature.text}</p>
              </div>
            </div>
          ))}
        </div>
        <div class="why-cta" data-ani="slideinup" data-ani-delay="0.5">
          <a href="/contact" class="why-btn">Get in Touch</a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .why-section {
    padding: 100px 0;
    background: #f8fafb;
    overflow: hidden;
  }

  .why-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }

  .why-grid--reversed .why-image-col {
    order: 2;
  }
  .why-grid--reversed .why-text-col {
    order: 1;
  }

  /* Image */
  .why-image-col {
    min-width: 0;
  }

  .why-image-wrapper {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
  }

  .why-image-wrapper img {
    width: 100%;
    height: 520px;
    object-fit: cover;
    display: block;
    border-radius: 20px;
  }

  .why-image-accent {
    position: absolute;
    bottom: -20px;
    right: -20px;
    width: 160px;
    height: 160px;
    border-radius: 20px;
    background: var(--theme-color, #1CA8CB);
    opacity: 0.15;
    z-index: -1;
  }

  /* Text */
  .why-text-col {
    min-width: 0;
  }

  .why-label {
    display: inline-block;
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--theme-color, #1CA8CB);
    margin-bottom: 12px;
  }

  .why-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 700;
    line-height: 1.15;
    color: #113D48;
    margin-bottom: 20px;
  }

  .why-desc {
    font-size: 1.05rem;
    line-height: 1.75;
    color: #5a6a72;
    margin-bottom: 36px;
  }

  /* Features */
  .why-features {
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin-bottom: 36px;
  }

  .why-feature {
    display: flex;
    gap: 18px;
    align-items: flex-start;
    padding: 20px 24px;
    background: #fff;
    border-radius: 14px;
    box-shadow: 0 2px 16px rgba(0,0,0,0.04);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .why-feature:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 30px rgba(0,0,0,0.08);
  }

  .why-feature-icon {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(28, 168, 203, 0.1);
    border-radius: 12px;
  }

  .why-feature-icon img {
    width: 24px;
    height: 24px;
  }

  .why-feature-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.05rem;
    font-weight: 700;
    color: #113D48;
    margin-bottom: 4px;
  }

  .why-feature-text {
    font-size: 0.92rem;
    line-height: 1.6;
    color: #6b7c85;
    margin-bottom: 0;
  }

  /* CTA */
  .why-btn {
    display: inline-block;
    padding: 14px 36px;
    font-family: 'Inter', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: #fff;
    background: var(--theme-color, #1CA8CB);
    border: none;
    border-radius: 8px;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .why-btn:hover {
    background: #113D48;
    color: #fff;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(17, 61, 72, 0.25);
  }

  /* Responsive */
  @media (max-width: 991px) {
    .why-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .why-grid--reversed .why-image-col,
    .why-grid--reversed .why-text-col {
      order: unset;
    }

    .why-image-wrapper img {
      height: 400px;
    }
  }

  @media (max-width: 575px) {
    .why-section {
      padding: 60px 0;
    }

    .why-image-wrapper img {
      height: 280px;
    }

    .why-feature {
      padding: 16px 18px;
    }

    .why-image-accent {
      display: none;
    }
  }
</style>
