---
interface Props {
  title: string;
  subtitle: string;
  backgroundImage: string;
  heroVideo?: string;
  cta1Text?: string;
  cta1Link?: string;
  cta2Text?: string;
  cta2Link?: string;
}

const {
  title,
  subtitle,
  backgroundImage,
  heroVideo = '',
  cta1Text = 'Book Now',
  cta1Link = '/contact',
  cta2Text = 'Contact Us',
  cta2Link = '/contact',
} = Astro.props;
---

<div class="service-hero-fullwidth position-relative overflow-hidden" id="service-hero">
  <div class="service-hero-bg" style={`background-image: url(${backgroundImage});`}></div>
  {heroVideo && (
    <video class="service-hero-video" autoplay muted loop playsinline preload="metadata">
      <source src={heroVideo} type="video/mp4" />
    </video>
  )}
  <div class="service-hero-overlay"></div>
  <div class="container position-relative" style="z-index: 2;">
    <div class="service-hero-content text-center">
      <h1 class="service-hero-title">{title}</h1>
      <a href="/contact" class="hero-cta-btn">Enquire Now</a>
    </div>
  </div>
</div>

<style>
  .service-hero-fullwidth {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .service-hero-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    will-change: transform;
  }
  @supports (-webkit-touch-callout: none) {
    .service-hero-bg {
      background-attachment: scroll !important;
    }
  }
  .service-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0,0,0,0.25) 0%, rgba(0,0,0,0.45) 100%);
    z-index: 1;
  }
  .service-hero-content {
    padding: 160px 0 120px;
  }
  .service-hero-title {
    font-size: clamp(2.5rem, 6vw, 5rem);
    color: #fff;
    font-weight: 800;
    margin-bottom: 20px;
    line-height: 1.15;
  }
  .hero-cta-btn {
    display: inline-block;
    background-color: #1CA8CB;
    color: #fff;
    padding: 14px 32px;
    font-size: 16px;
    font-weight: 600;
    font-family: 'Inter', sans-serif;
    border-radius: 4px;
    text-decoration: none;
    margin-top: 24px;
    transition: background-color 0.2s;
  }
  .hero-cta-btn:hover {
    background-color: #178fa8;
    color: #fff;
  }

  .service-hero-subtitle {
    font-size: clamp(1rem, 2vw, 1.35rem);
    color: rgba(255,255,255,0.85);
    max-width: 650px;
    margin: 0 auto 40px;
    line-height: 1.7;
  }
  .scroll-indicator {
    margin-top: 50px;
  }
  .scroll-indicator span {
    display: block;
    width: 24px;
    height: 40px;
    border: 2px solid rgba(255,255,255,0.5);
    border-radius: 12px;
    margin: 0 auto;
    position: relative;
  }
  .scroll-indicator span::after {
    content: '';
    display: block;
    width: 4px;
    height: 8px;
    background: #fff;
    border-radius: 2px;
    position: absolute;
    top: 6px;
    left: 50%;
    transform: translateX(-50%);
    animation: scrollBounce 1.8s ease-in-out infinite;
  }
  @keyframes scrollBounce {
    0%, 100% { transform: translateX(-50%) translateY(0); opacity: 1; }
    50% { transform: translateX(-50%) translateY(12px); opacity: 0.3; }
  }

  /* Video hero — mobile only */
  .service-hero-video {
    display: none;
  }

  @media (max-width: 991px) {
    .service-hero-video {
      display: block;
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      z-index: 0;
    }

    .service-hero-fullwidth:has(.service-hero-video) .service-hero-bg {
      display: none;
    }

    .service-hero-overlay {
      background: linear-gradient(180deg, rgba(0,0,0,0.2) 0%, rgba(0,0,0,0.5) 100%);
    }

    .service-hero-fullwidth {
      min-height: 380px;
      height: 75vh;
      max-height: none;
      align-items: flex-end;
    }
    .service-hero-content {
      padding: 0 0 5vh;
    }
  }

  @media (max-width: 767px) {
    .service-hero-fullwidth {
      min-height: 360px;
    }
    .service-hero-content {
      padding: 0 0 5vh;
    }
  }
</style>

<script>
  function initHeroParallax() {
    if (typeof window.gsap === 'undefined' || typeof window.ScrollTrigger === 'undefined') return;
    const bg = document.querySelector('.service-hero-bg');
    if (!bg || bg.dataset.parallaxInit) return;
    bg.dataset.parallaxInit = 'true';
    window.gsap.to(bg, {
      yPercent: 30,
      ease: 'none',
      scrollTrigger: {
        trigger: '#service-hero',
        start: 'top top',
        end: 'bottom top',
        scrub: true,
      },
    });
  }
  document.addEventListener('DOMContentLoaded', initHeroParallax);
  document.addEventListener('astro:page-load', initHeroParallax);
</script>
