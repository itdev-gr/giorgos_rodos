---
import { imgUrl, imgSrcset } from '../../lib/media';

interface Props {
  title: string;
  subtitle: string;
  backgroundImage: string;
  heroVideo?: string;
  imageAlt?: string;
  cta1Text?: string;
  cta1Link?: string;
  cta2Text?: string;
  cta2Link?: string;
}

const {
  title,
  subtitle,
  backgroundImage,
  heroVideo = '',
  imageAlt = 'Boat tour departing from Rhodes harbour',
  cta1Text = 'Book Now',
  cta1Link = '/contact',
  cta2Text = 'Contact Us',
  cta2Link = '/contact',
} = Astro.props;

const heroSrc = imgUrl(backgroundImage, 1200) || backgroundImage;
const heroSrcset = imgSrcset(backgroundImage, [640, 960, 1200, 1920]) || '';
const videoType = heroVideo.toLowerCase().endsWith('.mov') ? 'video/quicktime' : 'video/mp4';
---

<div class="service-hero-fullwidth position-relative overflow-hidden" id="service-hero">
  <div class="service-hero-bg" aria-hidden="true">
    <img
      src={heroSrc}
      srcset={heroSrcset || undefined}
      sizes="100vw"
      width="1920"
      height="1080"
      alt={imageAlt}
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
  </div>
  {heroVideo && (
    <video
      class="service-hero-video"
      autoplay
      muted
      loop
      playsinline
      preload="none"
      poster={heroSrc}
      data-src={heroVideo}
      data-type={videoType}
      width="1920"
      height="1080"
    ></video>
  )}
  <div class="service-hero-overlay"></div>
  <div class="container position-relative" style="z-index: 2;">
    <div class="service-hero-content text-center">
      <h1 class="service-hero-title">{title}</h1>
      <a href="/contact" class="hero-cta-btn">Enquire Now</a>
    </div>
  </div>
</div>

<style>
  .service-hero-fullwidth {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #0e2f38;
  }
  .service-hero-bg {
    position: absolute;
    inset: 0;
    will-change: transform;
    z-index: 0;
  }
  .service-hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }
  @supports (-webkit-touch-callout: none) {
    .service-hero-bg {
      background-attachment: scroll !important;
    }
  }
  .service-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(rgba(0, 0, 0, 0.4), rgba(0, 0, 0, 0.4)),
      linear-gradient(180deg, rgba(0, 0, 0, 0.15) 0%, rgba(0, 0, 0, 0.35) 100%);
    z-index: 1;
  }
  .service-hero-content {
    padding: 160px 0 120px;
  }
  .service-hero-title {
    font-size: clamp(2.5rem, 6vw, 5rem);
    color: #fff;
    font-weight: 800;
    margin-bottom: 20px;
    line-height: 1.15;
  }
  .hero-cta-btn {
    display: inline-block;
    background-color: #1CA8CB;
    color: #fff;
    padding: 14px 32px;
    font-size: 16px;
    font-weight: 600;
    font-family: 'Inter', sans-serif;
    border-radius: 4px;
    text-decoration: none;
    margin-top: 24px;
    transition: background-color 0.2s;
  }
  .hero-cta-btn:hover {
    background-color: #178fa8;
    color: #fff;
  }

  .service-hero-subtitle {
    font-size: clamp(1rem, 2vw, 1.35rem);
    color: rgba(255,255,255,0.85);
    max-width: 650px;
    margin: 0 auto 40px;
    line-height: 1.7;
  }
  .scroll-indicator {
    margin-top: 50px;
  }
  .scroll-indicator span {
    display: block;
    width: 24px;
    height: 40px;
    border: 2px solid rgba(255,255,255,0.5);
    border-radius: 12px;
    margin: 0 auto;
    position: relative;
  }
  .scroll-indicator span::after {
    content: '';
    display: block;
    width: 4px;
    height: 8px;
    background: #fff;
    border-radius: 2px;
    position: absolute;
    top: 6px;
    left: 50%;
    transform: translateX(-50%);
    animation: scrollBounce 1.8s ease-in-out infinite;
  }
  @keyframes scrollBounce {
    0%, 100% { transform: translateX(-50%) translateY(0); opacity: 1; }
    50% { transform: translateX(-50%) translateY(12px); opacity: 0.3; }
  }

  /* Video hero — mobile only; image stays visible as fallback/poster */
  .service-hero-video {
    display: none;
  }

  @media (max-width: 991px) {
    .service-hero-video {
      display: block;
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      z-index: 1;
    }

    .service-hero-bg {
      z-index: 0;
    }

    .service-hero-video.is-hidden {
      display: none !important;
    }

    .service-hero-overlay {
      background: linear-gradient(rgba(0, 0, 0, 0.4), rgba(0, 0, 0, 0.4)),
        linear-gradient(180deg, rgba(0, 0, 0, 0.2) 0%, rgba(0, 0, 0, 0.5) 100%);
    }

    .service-hero-fullwidth {
      min-height: 380px;
      height: 75vh;
      max-height: none;
      align-items: flex-end;
    }
    .service-hero-content {
      padding: 0 0 5vh;
    }
  }

  @media (max-width: 767px) {
    .service-hero-fullwidth {
      min-height: 360px;
    }
    .service-hero-content {
      padding: 0 0 5vh;
    }
  }
</style>

<script>
  function loadServiceHeroVideo() {
    const video = document.querySelector('#service-hero .service-hero-video') as HTMLVideoElement | null;
    if (!video || video.dataset.loaded) return;
    if (window.matchMedia('(min-width: 992px)').matches) return;

    video.dataset.loaded = 'true';
    const src = video.dataset.src;
    const type = video.dataset.type;
    if (!src) return;

    const source = document.createElement('source');
    source.src = src;
    if (type) source.type = type;
    video.appendChild(source);
    video.load();
    video.play().catch(() => {});
  }

  function initHeroVideoFallback() {
    const video = document.querySelector('#service-hero .service-hero-video') as HTMLVideoElement | null;
    if (!video || video.dataset.fallbackInit) return;
    video.dataset.fallbackInit = 'true';

    const showImage = () => video.classList.add('is-hidden');

    video.addEventListener('error', showImage);
    video.addEventListener('emptied', showImage);

    window.setTimeout(() => {
      if (video.querySelector('source') && video.readyState < 2) showImage();
    }, 2500);
  }

  async function initHeroParallax() {
    const bg = document.querySelector('.service-hero-bg') as HTMLElement | null;
    if (!bg || bg.dataset.parallaxInit) return;

    const boot = () => new Promise<void>((resolve) => {
      const tick = () => {
        if (window.gsap && window.ScrollTrigger) return resolve();
        setTimeout(tick, 50);
      };
      tick();
    });

    if ('requestIdleCallback' in window) {
      requestIdleCallback(() => { void boot().then(() => runParallax(bg)); }, { timeout: 3000 });
    } else {
      window.addEventListener('load', () => { void boot().then(() => runParallax(bg)); }, { once: true });
    }
  }

  function runParallax(bg: HTMLElement) {
    if (bg.dataset.parallaxInit || !window.gsap || !window.ScrollTrigger) return;
    bg.dataset.parallaxInit = 'true';
    window.gsap.to(bg, {
      yPercent: 30,
      ease: 'none',
      scrollTrigger: {
        trigger: '#service-hero',
        start: 'top top',
        end: 'bottom top',
        scrub: true,
      },
    });
  }

  function initServiceHero() {
    if ('requestIdleCallback' in window) {
      requestIdleCallback(loadServiceHeroVideo, { timeout: 4000 });
    } else {
      window.addEventListener('load', loadServiceHeroVideo, { once: true });
    }
    initHeroVideoFallback();
    initHeroParallax();
  }

  document.addEventListener('DOMContentLoaded', initServiceHero);
  document.addEventListener('astro:page-load', initServiceHero);
</script>
