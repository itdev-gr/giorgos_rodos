---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../sections/home-one/Section1-Header.astro';
import FooterFour from '../../sections/shared/FooterFour.astro';
import BreadcrumbSchema from '../../components/seo/BreadcrumbSchema.astro';
import TouristTripSchema from '../../components/seo/TouristTripSchema.astro';
import { createPublicClient } from '../../lib/supabase';
import { SITE_URL, looksLikeUuid } from '../../lib/seo';
import { imgUrl, imgSrcset } from '../../lib/media';
import { tourCardAlt } from '../../lib/tour-alt';
import { charterCardDescription } from '../../lib/charter-description';
import TourDetailGallery from '../../components/tour/TourDetailGallery.astro';
import TourServiceLink from '../../components/tour/TourServiceLink.astro';
import FAQSection from '../../components/FAQSection.astro';
import { enrichTourDetailContent } from '../../lib/tour-detail-content';
import { resolveTourSlugRedirect } from '../../lib/tour-slug-redirects';

const { slug } = Astro.params;

const redirectSlug = resolveTourSlugRedirect(slug);
if (redirectSlug) {
  return Astro.redirect(`/tour-detail/${redirectSlug}`, 301);
}
let tour: any = null;
let isPublished = false;
let relatedTours: any[] = [];

try {
  const supabase = createPublicClient();
  if (supabase && slug) {
    // Try slug lookup first; fall back to UUID lookup for legacy URLs.
    let { data } = await supabase
      .from('tours')
      .select('*, profiles(full_name, company_name, phone)')
      .eq('slug', slug)
      .maybeSingle();

    if (!data && looksLikeUuid(slug)) {
      const { data: byId } = await supabase
        .from('tours')
        .select('*, profiles(full_name, company_name, phone)')
        .eq('id', slug)
        .maybeSingle();
      data = byId;

      // 301 to canonical slug URL when this tour has a slug
      if (data && data.slug && data.slug !== slug) {
        return Astro.redirect(`/tour-detail/${data.slug}`, 301);
      }
    }

    tour = data;

    // Related tours: same service_page first, fallback to global; exclude current; limit 3
    if (tour) {
      const sp = tour.service_page;
      let q = supabase
        .from('tours')
        .select('id, slug, title, description, image_url, images, duration, guests, price, badge_label')
        .eq('status', 'approved')
        .neq('id', tour.id)
        .limit(3);
      if (sp) q = q.eq('service_page', sp);
      const { data: related } = await q;
      relatedTours = related || [];
      if (relatedTours.length < 3) {
        const fillCount = 3 - relatedTours.length;
        const exclude = [tour.id, ...relatedTours.map((r: any) => r.id)];
        const { data: globals } = await supabase
          .from('tours')
          .select('id, slug, title, description, image_url, images, duration, guests, price, badge_label')
          .eq('status', 'approved')
          .eq('is_global', true)
          .not('id', 'in', `(${exclude.join(',')})`)
          .limit(fillCount);
        relatedTours = [...relatedTours, ...(globals || [])];
      }
    }
  }
} catch (e) {
  console.error('Failed to fetch tour:', e);
}

if (!tour) {
  return Astro.redirect('/404');
}

isPublished = tour.status === 'approved';

const images = tour.images?.length ? tour.images : (tour.image_url ? [tour.image_url] : ['/assets/img/gallery/yacht/crystal-water-1.jpg']);
const isCharterTour =
  tour.service_page === 'rhodes-charter' || tour.service_page === 'rodos-charter';
const displayDescription = isCharterTour
  ? charterCardDescription(tour)
  : tour.description;
const highlights = tour.highlights || [];
const detail = enrichTourDetailContent(tour);
const { inclusions, exclusions, inclusionsIntro, exclusionsIntro, itineraryIntro, itinerarySteps, meetingPoint, meetingNotes, experienceNotes, practicalTips, faq } = detail;

const tourPathSegment = tour.slug || tour.id;
const tourCanonical = `${SITE_URL}/tour-detail/${tourPathSegment}`;
const heroOgImage = images[0]?.startsWith('http') ? images[0] : `${SITE_URL}${images[0] || ''}`;

const bookingWaText = `Hi! I'd like to book: ${tour.title}. Please send me availability and price.`;
const bookingWhatsappHref = `https://wa.me/306951666454?text=${encodeURIComponent(bookingWaText)}`;

const metaDescription =
  displayDescription?.trim() ||
  `${tour.title} in Rhodes, ${tour.duration ? `${tour.duration}, ` : ''}${tour.price ? `from ${tour.price}. ` : ''}Enquire with local experts at Rhodes Rent a Boat.`;
---

<BaseLayout
  title={`${tour.title}: Rhodes Rent a Boat`}
  description={metaDescription}
  canonical={tourCanonical}
  ogImage={heroOgImage}
  noindex={!isPublished}
>
  <Fragment slot="head">
    <link rel="preload" as="image" href={imgUrl(images[0], 1200, { quality: 80 })} imagesrcset={imgSrcset(images[0])} imagesizes="(max-width: 991px) 100vw, 1200px" fetchpriority="high" />
  </Fragment>
  <BreadcrumbSchema items={[
    { name: 'Home', url: '/' },
    { name: 'Things to Do', url: '/things-to-do' },
    { name: tour.title, url: `/tour-detail/${tourPathSegment}` },
  ]} />
  {isPublished && (
    <TouristTripSchema tour={{ ...tour, meeting_point: meetingPoint }} displayDescription={displayDescription} isPublished={isPublished} />
  )}
  <Header transparent={false} />

  {!isPublished && (
    <div style={`position: fixed; top: 0; left: 0; right: 0; z-index: 9999; padding: 10px 20px; text-align: center; font-size: 0.82rem; font-weight: 600; font-family: Helvetica, "Helvetica Neue", Arial, sans-serif; ${tour.status === 'pending' ? 'background: #FEF3C7; color: #92400E;' : tour.status === 'rejected' ? 'background: #FEE2E2; color: #991B1B;' : 'background: #E5E7EB; color: #374151;'}`}>
      <i class={`fas ${tour.status === 'pending' ? 'fa-clock' : tour.status === 'rejected' ? 'fa-times-circle' : 'fa-file'}`} style="margin-right: 6px;"></i>
      {tour.status === 'pending' ? 'This tour is pending review and not yet visible to the public.' : tour.status === 'rejected' ? 'This tour has been rejected and is not visible to the public.' : 'This tour is a draft and not yet published.'}
    </div>
  )}

  <TourDetailGallery tourTitle={tour.title} images={images} />

  <!-- Content -->
  <section style="padding: 40px 0 80px; background: #f8fafc;">
    <div class="container" style="max-width: 1200px; margin: 0 auto; padding: 0 16px;">
      <div style="display: grid; grid-template-columns: 1fr 380px; gap: 40px; align-items: start;" class="td-layout">

        <!-- Left Column -->
        <div>
          <!-- Title + Badge -->
          <div style="margin-bottom: 24px;">
            {tour.badge_label && (
              <span style="display: inline-block; padding: 4px 12px; background: #113D48; color: #fff; border-radius: 6px; font-size: 0.72rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 12px;">{tour.badge_label}</span>
            )}
            <h1 class="td-page__title" style="font-size: 1.8rem; font-weight: 800; color: #113D48; margin: 0 0 8px; line-height: 1.25;">{tour.title}</h1>
          </div>

          <!-- Specs Strip -->
          <div style="display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 32px; padding-bottom: 24px; border-bottom: 1px solid #e2e8f0;">
            {tour.duration && (
              <div style="display: inline-flex; align-items: center; gap: 8px; padding: 8px 16px; background: #fff; border-radius: 10px; border: 1px solid #e2e8f0;">
                <i class="far fa-clock" style="color: #1CA8CB; font-size: 0.85rem;"></i>
                <span style="font-size: 0.85rem; font-weight: 600; color: #334155;">{tour.duration}</span>
              </div>
            )}
            {tour.guests && (
              <div style="display: inline-flex; align-items: center; gap: 8px; padding: 8px 16px; background: #fff; border-radius: 10px; border: 1px solid #e2e8f0;">
                <i class="far fa-user" style="color: #1CA8CB; font-size: 0.85rem;"></i>
                <span style="font-size: 0.85rem; font-weight: 600; color: #334155;">{tour.guests}</span>
              </div>
            )}
            {tour.badge_label && (
              <div style="display: inline-flex; align-items: center; gap: 8px; padding: 8px 16px; background: #fff; border-radius: 10px; border: 1px solid #e2e8f0;">
                <i class="fas fa-ship" style="color: #1CA8CB; font-size: 0.85rem;"></i>
                <span style="font-size: 0.85rem; font-weight: 600; color: #334155;">{tour.badge_label}</span>
              </div>
            )}
            {tour.departure_time && (
              <div style="display: inline-flex; align-items: center; gap: 8px; padding: 8px 16px; background: #fff; border-radius: 10px; border: 1px solid #e2e8f0;">
                <i class="fas fa-map-marker-alt" style="color: #1CA8CB; font-size: 0.85rem;"></i>
                <span style="font-size: 0.85rem; font-weight: 600; color: #334155;">Departs {tour.departure_time}</span>
              </div>
            )}
          </div>

          <!-- Description -->
          <div style="margin-bottom: 36px;">
            <TourServiceLink servicePage={tour.service_page} />
            <h2 style="font-size: 1.2rem; font-weight: 700; color: #113D48; margin: 0 0 14px;">About This Experience</h2>
            <p style="font-size: 0.95rem; line-height: 1.8; color: #475569;">{displayDescription}</p>
            <p style="font-size: 0.95rem; line-height: 1.8; color: #475569; margin-top: 14px;">{experienceNotes}</p>
            <p style="font-size: 0.95rem; line-height: 1.8; color: #475569; margin-top: 14px;">{practicalTips}</p>
          </div>

          <!-- Highlights -->
          {highlights.length > 0 && (
            <div style="margin-bottom: 36px;">
              <h2 style="font-size: 1.2rem; font-weight: 700; color: #113D48; margin: 0 0 14px;">Highlights</h2>
              <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
                {highlights.map((h: string) => (
                  <div style="display: flex; align-items: flex-start; gap: 10px; padding: 10px 14px; background: #fff; border-radius: 8px; border: 1px solid #f1f5f9;">
                    <i class="fas fa-star" style="color: #F59E0B; font-size: 0.75rem; margin-top: 3px; flex-shrink: 0;"></i>
                    <span style="font-size: 0.88rem; color: #334155;">{h}</span>
                  </div>
                ))}
              </div>
            </div>
          )}

          <!-- What's Included / Not Included -->
          <div style="margin-bottom: 36px; display: grid; grid-template-columns: 1fr 1fr; gap: 24px;" class="td-inclusions">
            <div>
              <h2 style="font-size: 1.2rem; font-weight: 700; color: #113D48; margin: 0 0 14px;">What's Included</h2>
              <p style="font-size: 0.88rem; line-height: 1.65; color: #64748b; margin: 0 0 12px;">{inclusionsIntro}</p>
              <div style="display: flex; flex-direction: column; gap: 8px;">
                {inclusions.map((item: string) => (
                  <div style="display: flex; align-items: center; gap: 10px;">
                    <i class="fas fa-check-circle" style="color: #10B981; font-size: 0.85rem; flex-shrink: 0;"></i>
                    <span style="font-size: 0.88rem; color: #334155;">{item}</span>
                  </div>
                ))}
              </div>
            </div>
            <div>
              <h2 style="font-size: 1.2rem; font-weight: 700; color: #113D48; margin: 0 0 14px;">Not Included</h2>
              <p style="font-size: 0.88rem; line-height: 1.65; color: #64748b; margin: 0 0 12px;">{exclusionsIntro}</p>
              <div style="display: flex; flex-direction: column; gap: 8px;">
                {exclusions.map((item: string) => (
                  <div style="display: flex; align-items: center; gap: 10px;">
                    <i class="fas fa-times-circle" style="color: #EF4444; font-size: 0.85rem; flex-shrink: 0;"></i>
                    <span style="font-size: 0.88rem; color: #334155;">{item}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>

          <!-- Itinerary -->
          <div style="margin-bottom: 36px;">
            <h2 style="font-size: 1.2rem; font-weight: 700; color: #113D48; margin: 0 0 14px;">Route & Itinerary</h2>
            <p style="font-size: 0.95rem; line-height: 1.8; color: #475569; margin: 0 0 18px;">{itineraryIntro}</p>
            <ol class="td-itinerary">
              {itinerarySteps.map((step, i) => (
                <li class="td-itinerary__item">
                  <span class="td-itinerary__dot" aria-hidden="true">{i + 1}</span>
                  <div class="td-itinerary__card">
                    {step.time && (
                      <span class="td-itinerary__time">
                        <i class="far fa-clock" aria-hidden="true"></i>
                        {step.time}
                      </span>
                    )}
                    <strong class="td-itinerary__title">{step.title}</strong>
                    {step.detail && step.detail !== step.title && (
                      <p class="td-itinerary__detail">{step.detail}</p>
                    )}
                  </div>
                </li>
              ))}
            </ol>
          </div>

          <!-- Meeting Point -->
          <div style="margin-bottom: 36px; padding: 20px; background: #fff; border-radius: 12px; border: 1px solid #e2e8f0;">
            <h2 style="font-size: 1.2rem; font-weight: 700; color: #113D48; margin: 0 0 10px;">
              <i class="fas fa-map-marker-alt" style="color: #1CA8CB; margin-right: 8px;"></i>Meeting Point
            </h2>
            <p style="font-size: 0.92rem; color: #475569; margin: 0 0 10px;">{meetingPoint}</p>
            <p style="font-size: 0.88rem; line-height: 1.65; color: #64748b; margin: 0;">{meetingNotes}</p>
            {tour.departure_time && tour.return_time && (
              <p style="font-size: 0.85rem; color: #94a3b8; margin: 12px 0 0;">
                <i class="far fa-clock" style="margin-right: 6px;"></i>
                Typical hours: {tour.departure_time} – {tour.return_time}
              </p>
            )}
          </div>
        </div>

        <!-- Right Column, Sticky Sidebar -->
        <div class="td-sidebar" style="position: sticky; top: 100px;">
          <div style="background: #fff; border-radius: 16px; padding: 28px; box-shadow: 0 4px 20px rgba(0,0,0,0.08); border: 1px solid #e2e8f0;">
            <!-- Price -->
            {tour.price && (
              <div style="margin-bottom: 20px; padding-bottom: 18px; border-bottom: 1px solid #f1f5f9;">
                <p style="font-size: 0.75rem; color: #94a3b8; margin: 0 0 4px; text-transform: uppercase; letter-spacing: 0.5px;">From</p>
                <p style="font-size: 1.8rem; font-weight: 800; color: #113D48; margin: 0;">{tour.price}</p>
              </div>
            )}

            <!-- Book via WhatsApp -->
            <a
              href={bookingWhatsappHref}
              target="_blank"
              rel="noopener noreferrer"
              style="display: flex; align-items: center; justify-content: center; gap: 10px; width: 100%; padding: 15px; background: #25D366; color: #fff; border-radius: 10px; font-size: 0.98rem; font-weight: 700; cursor: pointer; text-decoration: none; box-sizing: border-box; transition: background 0.2s;"
            >
              <i class="fab fa-whatsapp" style="font-size: 1.25rem;"></i>
              Book on WhatsApp
            </a>
            <p style="margin-top: 12px; text-align: center; font-size: 0.8rem; color: #94a3b8;">
              Send us your dates and we'll confirm availability &amp; price — fast reply.
            </p>

          </div>
        </div>
      </div>
    </div>
  </section>

  <FAQSection
    items={faq}
    title="Frequently Asked Questions"
    intro="Quick answers about this experience. For booking, weather and general boat questions see the <a href='/faq'>full FAQ</a>."
    background="white"
  />

  <!-- Related tours, internal linking + crawl flow -->
  {relatedTours.length > 0 && (
    <section class="td-related" aria-labelledby="td-related-title">
      <div class="container" style="max-width: 1200px; margin: 0 auto; padding: 0 16px;">
        <div class="td-related__header">
          <h2 id="td-related-title" class="td-related__title">You May Also Like</h2>
          <a href="/things-to-do" class="td-related__link">Browse all boat experiences in Rhodes →</a>
        </div>
        <div class="td-related__grid">
          {relatedTours.map((rt: any) => {
            const img = (Array.isArray(rt.images) && rt.images[0]) || rt.image_url || '/assets/img/gallery/yacht/crystal-water-1.jpg';
            const rtDescription =
              rt.service_page === 'rhodes-charter' || rt.service_page === 'rodos-charter'
                ? charterCardDescription(rt)
                : rt.description;
            return (
              <a href={`/tour-detail/${rt.slug || rt.id}`} class="td-related__card">
                <div class="td-related__img">
                  <img src={imgUrl(img, 600, { quality: 75 })} srcset={imgSrcset(img, [400, 600, 800])} sizes="(max-width: 991px) 50vw, 380px" alt={tourCardAlt(rt.title, rt.badge_label)} loading="lazy" width="600" height="450" />
                  {rt.badge_label && <span class="td-related__badge">{rt.badge_label}</span>}
                </div>
                <div class="td-related__body">
                  <h3 class="td-related__card-title">{rt.title}</h3>
                  <p class="td-related__excerpt">{rtDescription}</p>
                  <div class="td-related__meta">
                    {rt.duration && <span><i class="far fa-clock" aria-hidden="true"></i> {rt.duration}</span>}
                    {rt.guests && <span><i class="far fa-user" aria-hidden="true"></i> {rt.guests}</span>}
                    {rt.price && <span class="td-related__price">{rt.price}</span>}
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <FooterFour />
</BaseLayout>


<style is:global>
  .td-page__title {
    text-transform: none !important;
  }

  @media (max-width: 991px) {
    .td-layout { grid-template-columns: 1fr !important; }
    .td-sidebar { position: static !important; }
    .td-inclusions { grid-template-columns: 1fr !important; }
  }
  .td-gallery img { transition: transform 0.3s; }
  .td-thumb:hover { opacity: 1 !important; }

  .td-itinerary {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .td-itinerary__item {
    position: relative;
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding-bottom: 14px;
  }
  .td-itinerary__item:last-child { padding-bottom: 0; }
  /* connector line between step markers */
  .td-itinerary__item:not(:last-child)::before {
    content: '';
    position: absolute;
    left: 16px;
    top: 42px;
    bottom: 2px;
    width: 2px;
    border-radius: 1px;
    background: linear-gradient(180deg, rgba(28, 168, 203, 0.35), rgba(28, 168, 203, 0.1));
  }
  .td-itinerary__dot {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 34px;
    height: 34px;
    margin-top: 8px;
    border-radius: 50%;
    background: #113D48;
    color: #fff;
    font-size: 0.82rem;
    font-weight: 700;
    box-shadow: 0 0 0 4px rgba(28, 168, 203, 0.14);
  }
  .td-itinerary__card {
    flex: 1;
    min-width: 0;
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    padding: 14px 18px;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .td-itinerary__item:hover .td-itinerary__card {
    border-color: rgba(28, 168, 203, 0.45);
    box-shadow: 0 4px 14px rgba(17, 61, 72, 0.07);
  }
  .td-itinerary__time {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.3px;
    color: #0c6478;
    background: rgba(28, 168, 203, 0.12);
    padding: 3px 11px;
    border-radius: 999px;
    margin-bottom: 8px;
  }
  .td-itinerary__time i { font-size: 0.7rem; }
  .td-itinerary__title {
    display: block;
    font-size: 0.95rem;
    line-height: 1.55;
    color: #113D48;
  }
  .td-itinerary__detail {
    font-size: 0.88rem;
    line-height: 1.65;
    color: #475569;
    margin: 6px 0 0;
  }
  @media (max-width: 575px) {
    .td-itinerary__item { gap: 12px; }
    .td-itinerary__dot { width: 30px; height: 30px; font-size: 0.78rem; }
    .td-itinerary__item:not(:last-child)::before { left: 14px; top: 40px; }
    .td-itinerary__card { padding: 12px 14px; }
  }

  /* Related tours */
  .td-related {
    padding: 60px 0 80px;
    background: #fff;
  }
  .td-related__header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 28px;
  }
  .td-related__title {font-size: clamp(1.5rem, 2.5vw, 1.9rem);
    font-weight: 700;
    color: #113D48;
    margin: 0;
    text-transform: none;
  }
  .td-related__link {font-size: 0.88rem;
    font-weight: 600;
    color: #1CA8CB;
    text-decoration: none;
  }
  .td-related__link:hover { text-decoration: underline; }
  .td-related__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 22px;
  }
  .td-related__card {
    display: flex;
    flex-direction: column;
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .td-related__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 26px rgba(0,0,0,0.08);
  }
  .td-related__img {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }
  .td-related__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .td-related__card:hover .td-related__img img {
    transform: scale(1.05);
  }
  .td-related__badge {
    position: absolute;
    top: 12px;
    right: 12px;
    background: rgba(17,61,72,0.85);
    color: #fff;font-size: 0.7rem;
    font-weight: 600;
    padding: 4px 10px;
    border-radius: 6px;
    backdrop-filter: blur(4px);
  }
  .td-related__body {
    padding: 18px 18px 20px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .td-related__card-title {font-size: 1.05rem;
    font-weight: 700;
    color: #113D48;
    margin: 0 0 10px;
    line-height: 1.35;
  }
  .td-related__excerpt {font-size: 0.86rem;
    line-height: 1.55;
    color: #5a6a72;
    margin: 0 0 14px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .td-related__meta {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;font-size: 0.78rem;
    color: #5a6a72;
