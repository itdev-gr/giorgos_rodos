---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../sections/home-one/Section1-Header.astro';
import FooterFour from '../sections/shared/FooterFour.astro';
import FAQSchema from '../components/seo/FAQSchema.astro';
import BreadcrumbSchema from '../components/seo/BreadcrumbSchema.astro';
import { mainFaq as faqs } from '../lib/faq';
---

<BaseLayout
  title="FAQ: Boat Tours, Rentals & Charters in Rhodes | Rhodes Rent a Boat"
  description="Answers to 70+ questions about Rhodes boat trips, tours, license-free rentals, yacht charters, pricing, Symi day trips and booking—from local experts since 1998."
>
  <FAQSchema items={faqs} id="https://rhodesrentaboat.com/faq#faqpage" />
  <BreadcrumbSchema items={[
    { name: 'Home', url: '/' },
    { name: 'FAQ', url: '/faq' },
  ]} />
  <Header />

  <section class="faq-hero">
    <div class="container">
      <div class="faq-hero__content text-center">
        <h1 class="faq-hero__title">Frequently Asked Questions</h1>
      </div>
    </div>
  </section>

  <!-- FaqInner -->
  <div class="faq-body space-extra-bottom">
    <div class="container">
      <div class="row">
        <div class="col-lg-10 offset-lg-1">
          <div class="faq-list mb-30">
            {faqs.map((faq, index) => (
              <details class="faq-item">
                <summary class="faq-item__q">
                  <span class="faq-item__num">Q{index + 1}.</span>
                  <span class="faq-item__text">{faq.question}</span>
                  <span class="faq-item__icon" aria-hidden="true"></span>
                </summary>
                <div class="faq-item__a">
                  <p class="faq-text" set:html={faq.answer}></p>
                </div>
              </details>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>

  <FooterFour />
</BaseLayout>

<style>
  .faq-hero {
    min-height: 320px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 140px 0 64px;
    background: linear-gradient(135deg, #1CA8CB 0%, #1489a8 35%, #113D48 100%);
  }

  .faq-hero__content {
    max-width: 720px;
    margin: 0 auto;
  }

  .faq-hero__title {font-size: clamp(2rem, 4.5vw, 3.25rem);
    font-weight: 800;
    color: #fff;
    margin: 0;
    line-height: 1.15;
  }

  .faq-body {
    padding-top: 64px;
    background: #fff;
  }

  @media (max-width: 991px) {
    .faq-hero {
      min-height: 280px;
      padding: 120px 0 52px;
    }

    .faq-body {
      padding-top: 48px;
    }
  }

  @media (max-width: 575px) {
    .faq-hero {
      padding: 108px 0 44px;
    }

    .faq-body {
      padding-top: 40px;
    }
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .faq-item {
    background: #fff;
    border: 1px solid #e6eef0;
    border-radius: 12px;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.04);
    overflow: hidden;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .faq-item[open] {
    border-color: #1CA8CB;
    box-shadow: 0 4px 20px rgba(28, 168, 203, 0.08);
  }

  .faq-item__q {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 22px 26px;font-size: 1.05rem;
    font-weight: 600;
    color: #113D48;
    line-height: 1.4;
    user-select: none;
  }

  .faq-item__q::-webkit-details-marker { display: none; }
  .faq-item__q::marker { content: ''; }

  .faq-item__q:hover .faq-item__text {
    color: #1CA8CB;
  }

  .faq-item__num {
    flex-shrink: 0;
    color: #1CA8CB;
    font-weight: 700;
  }

  .faq-item__text {
    flex: 1;
    transition: color 0.2s ease;
  }

  .faq-item__icon {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: rgba(28, 168, 203, 0.12);
    color: #1CA8CB;
    position: relative;
    transition: transform 0.25s ease, background 0.2s ease;
  }

  .faq-item__icon::before,
  .faq-item__icon::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    background: #1CA8CB;
    border-radius: 1px;
  }
  .faq-item__icon::before {
    width: 12px;
    height: 2px;
    transform: translate(-50%, -50%);
  }
  .faq-item__icon::after {
    width: 2px;
    height: 12px;
    transform: translate(-50%, -50%);
    transition: transform 0.25s ease, opacity 0.25s ease;
  }

  .faq-item[open] .faq-item__icon::after {
    transform: translate(-50%, -50%) scaleY(0);
    opacity: 0;
  }

  .faq-item[open] .faq-item__icon {
    background: #1CA8CB;
  }
  .faq-item[open] .faq-item__icon::before,
  .faq-item[open] .faq-item__icon::after {
    background: #fff;
  }

  .faq-item__a {
    padding: 0 26px 24px 68px;
  }
  .faq-item__a .faq-text {font-size: 0.98rem;
    line-height: 1.65;
    color: #5a6a72;
    margin: 0;
  }

  @media (max-width: 767px) {
    .faq-item__q {
      padding: 18px 20px;
      font-size: 0.98rem;
      gap: 12px;
    }
    .faq-item__a {
      padding: 0 20px 20px 20px;
    }
  }
</style>
