---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../sections/home-one/Section1-Header.astro';
import Breadcrumb from '../components/ui/Breadcrumb.astro';
import FooterFour from '../sections/shared/FooterFour.astro';
import FAQSchema from '../components/seo/FAQSchema.astro';
import BreadcrumbSchema from '../components/seo/BreadcrumbSchema.astro';
import { getMediaSlot } from '../lib/media';

const contactBg = await getMediaSlot('faq.contact.bg', '/assets/img/bg/tour_bg_3.jpg');

// Answers may include inline HTML; Google FAQPage schema supports anchors.
// Internal links route readers from FAQ to the relevant money/service pages.
const faqs = [
  { question: 'Do I need a boat licence to rent a boat in Rhodes?', answer: 'Not necessarily. We offer <a href="/service/rhodes-rent-a-boat">license-free boats</a> that anyone can drive — no experience required. You get a full safety briefing before departure, and GPS tracking means our team can assist you at any time. If you want a larger vessel or prefer to relax while someone else drives, we also offer boats with a professional skipper included.' },
  { question: 'What is included in the price of a boat tour or cruise?', answer: 'That depends on the experience you choose. Our <a href="/service/rodos-boat-cruises">all-inclusive cruises</a> cover food, drinks, music, and snorkeling gear — there are no hidden extras. For <a href="/service/rodos-charter">yacht charters</a> and speedboat tours, fuel, safety equipment, and skipper services are typically included, and we will always tell you exactly what is covered before you book. We believe in transparent pricing with no surprises at the dock.' },
  { question: 'How far in advance should I book?', answer: 'During peak season (June through August), we recommend booking at least one to two weeks in advance, especially for <a href="/service/rodos-charter">private yacht charters</a> and weekend speedboat tours. For spring and autumn trips, a few days notice is usually enough. That said, it never hurts to <a href="/contact">reach out early</a> — even if you are just exploring ideas, we are happy to chat.' },
  { question: 'What happens if the weather is bad on the day of my trip?', answer: 'Safety always comes first. If sea conditions are unsuitable for your booking, we will contact you to reschedule for another day at no extra cost. Our skippers monitor weather and wind conditions daily, and they will never take a boat out if it is not safe to do so. If rescheduling is not possible during your stay, we offer a full refund. <a href="/contact">Get in touch</a> if you have specific concerns about your dates.' },
  { question: 'Can I bring children on board?', answer: 'Absolutely. Many of our experiences are family-friendly, and we carry child-size life jackets on all our boats. Our skippers are experienced with families and will adjust the pace and stops accordingly — calmer bays, shallower water, and plenty of swimming time. <a href="/service/rodos-boat-cruises">Group day cruises</a> work especially well for families with younger kids. Just let us know the ages of your children when you book so we can recommend the best option.' },
  { question: 'What is the difference between a boat tour, a cruise, and a charter?', answer: 'A <a href="/service/rodos-boat-tours">boat tour</a> is typically a private or semi-private day trip on a smaller vessel with a skipper, visiting specific spots along the coast. A <a href="/service/rodos-boat-cruises">cruise</a> is a larger group experience aboard a bigger boat with all-inclusive food, drinks, and entertainment. A <a href="/service/rodos-charter">charter</a> means you hire an entire yacht — either with a skipper or bareboat if you hold a valid sailing licence — and you set your own route and schedule. If you are not sure which one is right for you, <a href="/contact">just ask us</a> and we will help you decide.' },
  { question: 'Do your skippers speak English?', answer: 'Yes. All of our skippers and crew members speak fluent English, and many also speak German, Italian, or French. Communication is never a problem — our team is friendly, approachable, and always happy to share local tips and recommendations.' },
  { question: 'What should I bring on a boat trip?', answer: 'We recommend sunscreen, a hat, sunglasses, a towel, and a light layer for the wind. Wear comfortable clothes and shoes that can get wet. Snorkeling gear is provided on most of our <a href="/things-to-do">tours and cruises</a>. If you have any dietary requirements for onboard meals, just let us know in advance and we will take care of it.' },
  { question: 'Can I book a private experience for a special occasion?', answer: 'Of course. We regularly arrange <a href="/service/rodos-charter">private charters</a> and tours for birthdays, proposals, anniversaries and honeymoons, plus <a href="/service/rhodes-mice-events">corporate events</a> and team-building days. Tell us what you are celebrating and what kind of atmosphere you are looking for, and we will put together something memorable. From champagne at sunset to a private beach barbecue — we can make it happen.' },
  { question: 'How do I get in touch with you?', answer: 'You can reach us by phone, email, WhatsApp, or through the <a href="/contact">contact form</a> on our website. We respond to every message personally — usually within a few hours. When you contact us, you are speaking with real people who live here in Rhodes and know the sea firsthand. We would rather have a conversation than push a booking, so do not hesitate to reach out with questions — even if you are just thinking about it.' },
];
---

<BaseLayout
  title="FAQ — Boat Tours, Rentals and Sailing Trips in Rhodes"
  description="Answers to the most common questions about boat tours, license-free rentals, catamaran trips and yacht charters in Rhodes."
>
  <FAQSchema items={faqs} />
  <BreadcrumbSchema items={[
    { name: 'Home', url: '/' },
    { name: 'FAQ', url: '/faq' },
  ]} />
  <Header />
  <Breadcrumb title="FAQs" />

  <!-- FaqInner -->
  <div class="space-top space-extra-bottom">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-xl-7">
          <div class="title-area text-center">
            <span class="sub-title">FAQ</span>
            <h2 class="sec-title">Frequently Asked Questions</h2>
            <p>We believe in honest answers. If you do not find what you need here, just reach out — we are always happy to help.</p>
          </div>
        </div>
      </div>
      <div class="row">
        <div class="col-lg-10 offset-lg-1">
          <div class="faq-list mb-30">
            {faqs.map((faq, index) => (
              <details class="faq-item" open={index === 0}>
                <summary class="faq-item__q">
                  <span class="faq-item__num">Q{index + 1}.</span>
                  <span class="faq-item__text">{faq.question}</span>
                  <span class="faq-item__icon" aria-hidden="true"></span>
                </summary>
                <div class="faq-item__a">
                  <p class="faq-text" set:html={faq.answer}></p>
                </div>
              </details>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ElementSection placeholder -->
  <section class="elements-sec">
    <div class="container-fluid border-0 p-0">
      <div class="tags-container relative border-0"></div>
    </div>
  </section>

  <!-- FaqContact -->
  <div
    class="bg-top-center space overflow-hidden"
    style={`background: url(${contactBg}); background-repeat: no-repeat; position: relative; z-index: 1;`}
  >
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-lg-11">
          <div>
            <div class="title-area text-center mb-30">
              <span class="sub-title style1">Still Have Questions?</span>
              <h2 class="sec-title">We Are Happy to Help</h2>
            </div>
            <form class="contact-form ajax-contact">
              <h3 class="sec-title mb-30">Send Us a Message</h3>
              <div class="row">
                <div class="col-md-6 form-group">
                  <input type="text" class="form-control" name="name" id="name3" placeholder="First Name" />
                  <img src="/assets/img/icon/user.svg" alt="name field icon" />
                </div>
                <div class="col-md-6 form-group">
                  <input type="email" class="form-control" name="email3" id="email3" placeholder="Your Mail" />
                  <img src="/assets/img/icon/mail.svg" alt="email field icon" />
                </div>
                <div class="form-group col-12">
                  <select name="subject" id="subject" class="form-select nice-select" aria-label="What you are interested in">
                    <option value="" disabled selected>What are you interested in?</option>
                    <option value="Yacht Charter">Yacht Charter</option>
                    <option value="Boat Tour or Cruise">Boat Tour or Cruise</option>
                    <option value="Speedboat with Skipper">Speedboat with Skipper</option>
                    <option value="License-Free Boat Rental">License-Free Boat Rental</option>
                    <option value="Special Event or Celebration">Special Event or Celebration</option>
                    <option value="Something Else">Something Else</option>
                  </select>
                </div>
                <div class="form-group col-12">
                  <textarea name="message" id="message" cols="30" rows="3" class="form-control" placeholder="Your Message"></textarea>
                  <img src="/assets/img/icon/chat.svg" alt="message field icon" />
                </div>
                <div class="form-btn col-12 mt-24">
                  <button type="submit" class="th-btn style3">
                    Send message <img src="/assets/img/icon/plane.svg" alt="send icon" />
                  </button>
                </div>
              </div>
              <p class="form-messages mb-0 mt-3"></p>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map(({ question, answer }) => ({
      '@type': 'Question',
      name: question,
      acceptedAnswer: { '@type': 'Answer', text: answer }
    }))
  })} />

  <FooterFour />
</BaseLayout>

<style>
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .faq-item {
    background: #fff;
    border: 1px solid #e6eef0;
    border-radius: 12px;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.04);
    overflow: hidden;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .faq-item[open] {
    border-color: #1CA8CB;
    box-shadow: 0 4px 20px rgba(28, 168, 203, 0.08);
  }

  .faq-item__q {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 22px 26px;
    font-family: 'Playfair Display', serif;
    font-size: 1.05rem;
    font-weight: 600;
    color: #113D48;
    line-height: 1.4;
    user-select: none;
  }

  .faq-item__q::-webkit-details-marker { display: none; }
  .faq-item__q::marker { content: ''; }

  .faq-item__q:hover .faq-item__text {
    color: #1CA8CB;
  }

  .faq-item__num {
    flex-shrink: 0;
    color: #1CA8CB;
    font-weight: 700;
  }

  .faq-item__text {
    flex: 1;
    transition: color 0.2s ease;
  }

  .faq-item__icon {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: rgba(28, 168, 203, 0.12);
    color: #1CA8CB;
    position: relative;
    transition: transform 0.25s ease, background 0.2s ease;
  }

  .faq-item__icon::before,
  .faq-item__icon::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    background: #1CA8CB;
    border-radius: 1px;
  }
  .faq-item__icon::before {
    width: 12px;
    height: 2px;
    transform: translate(-50%, -50%);
  }
  .faq-item__icon::after {
    width: 2px;
    height: 12px;
    transform: translate(-50%, -50%);
    transition: transform 0.25s ease, opacity 0.25s ease;
  }

  .faq-item[open] .faq-item__icon::after {
    transform: translate(-50%, -50%) scaleY(0);
    opacity: 0;
  }

  .faq-item[open] .faq-item__icon {
    background: #1CA8CB;
  }
  .faq-item[open] .faq-item__icon::before,
  .faq-item[open] .faq-item__icon::after {
    background: #fff;
  }

  .faq-item__a {
    padding: 0 26px 24px 68px;
  }
  .faq-item__a .faq-text {
    font-family: 'Inter', sans-serif;
    font-size: 0.98rem;
    line-height: 1.75;
    color: #5a6a72;
    margin: 0;
  }

  @media (max-width: 767px) {
    .faq-item__q {
      padding: 18px 20px;
      font-size: 0.98rem;
      gap: 12px;
    }
    .faq-item__a {
      padding: 0 20px 20px 20px;
    }
  }
</style>
