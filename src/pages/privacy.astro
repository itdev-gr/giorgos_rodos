---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../sections/home-one/Section1-Header.astro';
import FooterFour from '../sections/shared/FooterFour.astro';
import BreadcrumbSchema from '../components/seo/BreadcrumbSchema.astro';
import LegalDocument from '../components/LegalDocument.astro';
import { SITE_URL } from '../lib/seo';
import { resolveLocale } from '../i18n/context';
import { getMessages } from '../i18n';
import { localizedPath } from '../i18n/routing';
import { SCHEMA_LANGUAGE } from '../i18n/locales';
import { getLegalContent } from '../i18n/legal-content';

const locale = resolveLocale(Astro.locals, Astro.url.pathname);
const messages = getMessages(locale);
const { privacy } = getLegalContent(locale);
const pagePath = localizedPath('/privacy', locale);

const privacyPageJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': `${SITE_URL}${pagePath}#webpage`,
  url: `${SITE_URL}${pagePath}`,
  name: messages.meta.privacy.title,
  description: messages.meta.privacy.description,
  inLanguage: SCHEMA_LANGUAGE[locale],
  isPartOf: { '@id': `${SITE_URL}#website` },
};
---

<BaseLayout
  title={messages.meta.privacy.title}
  description={messages.meta.privacy.description}
  canonical={`${SITE_URL}${pagePath}`}
  noindexFollow={true}
>
  <BreadcrumbSchema items={[
    { name: messages.breadcrumbs.home, url: localizedPath('/', locale) },
    { name: messages.footer.privacy, url: pagePath },
  ]} />
  <script type="application/ld+json" set:html={JSON.stringify(privacyPageJsonLd)} />
  <Header />

  <LegalDocument document={privacy} />

  <FooterFour />
</BaseLayout>
