---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../sections/home-one/Section1-Header.astro';
import HeroBanner from '../sections/home-one/Section2-HeroBanner.astro';
import Intro from '../sections/home-one/Section3-Intro.astro';
import BoatCategories from '../sections/home-one/Section4-BoatCategories.astro';
import RentABoat from '../sections/home-one/SectionRentABoat.astro';
import GoogleMap from '../sections/home-one/Section5-GoogleMap.astro';
import WhyChooseUs from '../sections/home-one/Section6-WhyChooseUs.astro';
import Reviews from '../sections/home-one/Section7-Reviews.astro';
import BlogPreview from '../sections/home-one/Section8-BlogPreview.astro';
import Contact from '../sections/home-one/Section9-Contact.astro';
import Footer from '../sections/shared/FooterFour.astro';
---

<BaseLayout
  title="Rhodes Boat Tours – Boat Trips, Cruises & Rent a Boat in Greece"
  description="Boat tours, private boat trips, cruises and rent a boat in Rhodes — handpicked by local experts since 2009. Discover the best coastal experiences in Greece."
  ogImage="https://rhodesrentaboat.com/rhodes-rent-aboat.jpg"
>

  <!-- JSON-LD Schema: LocalBusiness + TouristTrip -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "Rhodes Boat Tours",
    "description": "Local boat tour experts in Rhodes, Greece. Handpicked boat trips, cruises, yacht charters, and rent-a-boat experiences since 2009.",
    "url": "https://rhodosboattours.com",
    "telephone": "+306951666454",
    "email": "info@rhodesrentaboat.com",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Mandraki Harbour",
      "addressLocality": "Rhodes",
      "postalCode": "851 00",
      "addressCountry": "GR"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 36.4475,
      "longitude": 28.4275
    },
    "openingHoursSpecification": {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"],
      "opens": "09:00",
      "closes": "20:00"
    },
    "sameAs": [
      "https://www.instagram.com/rhodos_yachts",
      "https://www.facebook.com/rhodosyachts"
    ],
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Boat Experiences in Rhodes",
      "itemListElement": [
        { "@type": "Offer", "itemOffered": { "@type": "TouristTrip", "name": "Rhodes Boat Tours", "description": "Guided sailing tours along the Rhodes coastline" }},
        { "@type": "Offer", "itemOffered": { "@type": "TouristTrip", "name": "Rhodes Boat Cruises", "description": "All-inclusive day and sunset cruises" }},
        { "@type": "Offer", "itemOffered": { "@type": "TouristTrip", "name": "Rhodes Yacht Charter", "description": "Bareboat and crewed yacht charters in the Dodecanese" }},
        { "@type": "Offer", "itemOffered": { "@type": "TouristTrip", "name": "Rhodes Rent a Boat", "description": "License-free boat rentals along the Rhodes coast" }}
      ]
    }
  })} />

  <Header />
  <HeroBanner />
  <Intro />
  <BoatCategories />
  <RentABoat />
  <WhyChooseUs />
  <Reviews />
  <BlogPreview />
  <Contact />
  <GoogleMap />
  <Footer />

  <!-- Homepage-only: enable transparent header over hero -->
  <script>
    document.getElementById('header-one')?.classList.add('header-transparent');
  </script>
</BaseLayout>
