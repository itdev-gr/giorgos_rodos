---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../sections/home-one/Section1-Header.astro';
import HeroBanner from '../sections/home-one/Section2-HeroBanner.astro';
import Intro from '../sections/home-one/Section3-Intro.astro';
import BoatCategories from '../sections/home-one/Section4-BoatCategories.astro';
import RentABoat from '../sections/home-one/SectionRentABoat.astro';
import GoogleMap from '../sections/home-one/Section5-GoogleMap.astro';
import WhyChooseUs from '../sections/home-one/Section6-WhyChooseUs.astro';
import Reviews from '../sections/home-one/Section7-Reviews.astro';
import BlogPreview from '../sections/home-one/Section8-BlogPreview.astro';
import Contact from '../sections/home-one/Section9-Contact.astro';
import Footer from '../sections/shared/FooterFour.astro';
---

<BaseLayout
  title="Rhodes Rent a Boat — Boat Tours, Cruises & Yacht Charters in Rhodes Town"
  description="Boat tours, private boat trips, cruises and yacht charters in Rhodes — handpicked by local experts on Ionos Dragoumi 39, Rhodes Town, since 1998. Honest advice, no marketplace fees."
  ogImage="https://rhodesrentaboat.com/rhodes-rent-aboat.jpg"
>

  <!-- JSON-LD Schema: TravelAgency offer catalog (linked to base Organization) -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "TravelAgency",
    "@id": "https://rhodesrentaboat.com#travelagency",
    "name": "Rhodes Rent a Boat",
    "alternateName": "Rhodes Boat Tours",
    "description": "Local boat tour experts in Rhodes, Greece. Handpicked boat trips, cruises, yacht charters, and rent-a-boat experiences since 1998.",
    "url": "https://rhodesrentaboat.com",
    "telephone": "+306951666454",
    "email": "info@rhodesrentaboat.com",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Ionos Dragoumi 39",
      "addressLocality": "Rhodes",
      "postalCode": "85100",
      "addressCountry": "GR"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 36.4497769,
      "longitude": 28.2197904
    },
    "openingHoursSpecification": {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"],
      "opens": "00:00",
      "closes": "23:59"
    },
    "sameAs": [
      "https://www.instagram.com/rhodos_yachts",
      "https://www.facebook.com/rhodosyachts"
    ],
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Boat Experiences in Rhodes",
      "itemListElement": [
        { "@type": "Offer", "url": "https://rhodesrentaboat.com/service/rodos-boat-tours", "itemOffered": { "@type": "TouristTrip", "name": "Rhodes Boat Tours", "description": "Guided sailing tours along the Rhodes coastline" }},
        { "@type": "Offer", "url": "https://rhodesrentaboat.com/service/rodos-boat-cruises", "itemOffered": { "@type": "TouristTrip", "name": "Rhodes Boat Cruises", "description": "All-inclusive day and sunset cruises" }},
        { "@type": "Offer", "url": "https://rhodesrentaboat.com/service/rodos-charter", "itemOffered": { "@type": "TouristTrip", "name": "Rhodes Yacht Charter", "description": "Bareboat and crewed yacht charters in the Dodecanese" }},
        { "@type": "Offer", "url": "https://rhodesrentaboat.com/service/rhodes-rent-a-boat", "itemOffered": { "@type": "TouristTrip", "name": "Rhodes Rent a Boat", "description": "License-free boat rentals along the Rhodes coast" }},
        { "@type": "Offer", "url": "https://rhodesrentaboat.com/service/rhodes-catamaran-tours", "itemOffered": { "@type": "TouristTrip", "name": "Rhodes Catamaran Tours", "description": "Day and sunset catamaran experiences" }},
        { "@type": "Offer", "url": "https://rhodesrentaboat.com/service/rhodes-sailing-trips", "itemOffered": { "@type": "TouristTrip", "name": "Rhodes Sailing Trips", "description": "Shared and private sailing experiences" }}
      ]
    }
  })} />

  <Header />
  <HeroBanner />
  <Intro />
  <BoatCategories />
  <RentABoat />
  <WhyChooseUs />
  <Reviews />
  <BlogPreview />
  <Contact />
  <GoogleMap />
  <Footer />

  <!-- Homepage-only: enable transparent header over hero -->
  <script>
    document.getElementById('header-one')?.classList.add('header-transparent');
  </script>
</BaseLayout>
