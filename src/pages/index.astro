---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../sections/home-one/Section1-Header.astro';
import HeroBanner from '../sections/home-one/Section2-HeroBanner.astro';
import IntroStatement from '../sections/home-one/Section3-IntroStatement.astro';
import CharterDestinations from '../sections/home-one/Section3-CharterDestinations.astro';
import BrandStory from '../sections/home-one/Section5-BrandStory.astro';
import ServicesGrid from '../sections/home-one/Section6-ServicesGrid.astro';
import FleetShowcase from '../sections/home-one/Section7-FleetShowcase.astro';
import ServiceBucketList from '../sections/service/ServiceBucketList.astro';
import ServiceGalleryCarousel from '../sections/service/ServiceGalleryCarousel.astro';
import Stats from '../sections/home-one/Section10-Stats.astro';
import ServiceMiseChecklist from '../sections/service/ServiceMiseChecklist.astro';
import TestimonialOne from '../components/interactive/TestimonialOne';
import CTA from '../sections/home-one/Section-CTA.astro';
import Footer from '../sections/home-one/Section14-Footer.astro';
import ScrollToTop from '../components/interactive/ScrollToTop';
---

<BaseLayout title="Private Yacht Charters | Greek Islands">
  <Header />
  <HeroBanner />
  <IntroStatement />
  <CharterDestinations />
  <BrandStory />
  <ServicesGrid />
  <FleetShowcase />
  <ServiceBucketList
    title="Experiences That Define a Voyage"
    subtitle="Your Bucket List"
    items={[
      { title: 'Island Hopping the Cyclades', description: 'Drift between Santorini, Mykonos, Paros, and lesser-known gems at your own pace.' },
      { title: 'Sunset Dining at Secret Coves', description: 'Anchor in hidden bays where your crew prepares a candlelit dinner under the stars.' },
      { title: 'Snorkelling in Volcanic Waters', description: 'Explore the underwater world around volcanic islands with crystal-clear visibility.' },
      { title: 'Stargazing from the Open Sea', description: 'Far from city lights, the Aegean sky reveals a canopy of stars like nowhere else.' },
      { title: 'Private Beach Landings', description: 'Step ashore on secluded beaches accessible only by boat — your own slice of paradise.' },
      { title: 'Historic Harbour Walks', description: 'Wander through ancient ports, medieval towns, and timeless fishing villages.' },
    ]}
  />
  <ServiceGalleryCarousel
    title="A Glimpse of the Journey"
    images={[
      '/assets/img/gallery/yacht/yacht-sailing-1.jpg',
      '/assets/img/gallery/yacht/ocean-view-1.jpg',
      '/assets/img/gallery/yacht/sunset-cruise-1.jpg',
      '/assets/img/gallery/yacht/crystal-water-1.jpg',
      '/assets/img/gallery/yacht/yacht-deck-1.jpg',
      '/assets/img/gallery/yacht/greek-island-1.jpg',
      '/assets/img/gallery/yacht/yacht-exterior-1.jpg',
      '/assets/img/gallery/yacht/greek-coast-1.jpg',
      '/assets/img/gallery/yacht/aerial-yacht-1.jpg',
      '/assets/img/gallery/yacht/yacht-luxury-1.jpg',
      '/assets/img/gallery/yacht/yacht-interior-1.jpg',
      '/assets/img/gallery/yacht/sailing-sunset-1.jpg',
    ]}
  />
  <Stats />
  <ServiceMiseChecklist
    title="Your Journey in Four Steps"
    subtitle="How It Works"
    steps={[
      { title: 'Consultation', description: 'Share your vision — dates, destinations, and the pace of your ideal voyage.', icon: 'fas fa-comments' },
      { title: 'Itinerary Design', description: 'Our team crafts a bespoke route, selects the ideal vessel, and arranges every detail.', icon: 'fas fa-route' },
      { title: 'Embark', description: 'Step aboard, meet your crew, and set sail into the Aegean.', icon: 'fas fa-anchor' },
      { title: 'Experience', description: 'Each day unfolds at your rhythm — new islands, hidden coves, and memories that endure.', icon: 'fas fa-heart' },
    ]}
  />
  <TestimonialOne client:visible />
  <CTA />
  <Footer />
  <ScrollToTop client:load />

  <!-- Homepage-only: enable transparent header over hero -->
  <script>
    document.getElementById('header-one')?.classList.add('header-transparent');
  </script>
</BaseLayout>
