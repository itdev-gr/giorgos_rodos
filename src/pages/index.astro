---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../sections/home-one/Section1-Header.astro';
import HeroBanner from '../sections/home-one/Section2-HeroBanner.astro';
import Intro from '../sections/home-one/Section3-Intro.astro';
import BoatCategories from '../sections/home-one/Section4-BoatCategories.astro';
import RentABoat from '../sections/home-one/SectionRentABoat.astro';
import GoogleMap from '../sections/home-one/Section5-GoogleMap.astro';
import WhyChooseUs from '../sections/home-one/Section6-WhyChooseUs.astro';
import Reviews from '../sections/home-one/Section7-Reviews.astro';
import BlogPreview from '../sections/home-one/Section8-BlogPreview.astro';
import Contact from '../sections/home-one/Section9-Contact.astro';
import Footer from '../sections/shared/FooterFour.astro';
import FAQSection from '../components/FAQSection.astro';
import { homeFaq } from '../lib/faq';

// People-Also-Ask-aligned FAQ for the homepage's broad commercial intent
---

<BaseLayout
  title="Rhodes Rent a Boat — Boat Tours, Cruises & Yacht Charters in Rhodes Town"
  description="Boat tours, private boat trips, cruises and yacht charters in Rhodes — handpicked by local experts on Ionos Dragoumi 39, Rhodes Town, since 1998. Honest advice, no marketplace fees."
  ogImage="https://rhodesrentaboat.com/rhodes-rent-aboat.jpg"
>
  <link slot="head" rel="preload" as="image" href="/assets/img/hero/hero_bg_1_1.jpg" fetchpriority="high" />


  <Header />
  <HeroBanner />
  <Intro />
  <BoatCategories />
  <RentABoat />
  <WhyChooseUs />
  <Reviews />
  <BlogPreview />
  <Contact />
  <FAQSection
    items={homeFaq}
    title="Rhodes Boat Tours — Common Questions"
    intro="The questions visitors ask us most often. For more, see the <a href='/faq'>full FAQ</a>."
  />
  <GoogleMap />
  <Footer />

  <!-- Homepage-only: enable transparent header over hero -->
  <script>
  </script>
</BaseLayout>
