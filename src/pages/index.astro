---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../sections/home-one/Section1-Header.astro';
import HeroBanner from '../sections/home-one/Section2-HeroBanner.astro';
import BoatCategories from '../sections/home-one/Section4-BoatCategories.astro';
import RentABoat from '../sections/home-one/SectionRentABoat.astro';
import ExperiencesCarousel from '../sections/home-one/SectionExperiencesCarousel.astro';
import GoogleMap from '../sections/home-one/Section5-GoogleMap.astro';
import WhyChooseUs from '../sections/home-one/Section6-WhyChooseUs.astro';
import Reviews from '../sections/home-one/Section7-Reviews.astro';
import BlogPreview from '../sections/home-one/Section8-BlogPreview.astro';
import Footer from '../sections/shared/FooterFour.astro';
---

<BaseLayout
  title="Rhodes Rent a Boat | Boat Trips, Tours & Cruises Since 1998"
  description="Rhodes Rent a Boat local sailing expert since 1998. Boat trips, tours, cruises & rentals personally selected by owner."
  ogImage="https://rhodesrentaboat.com/assets/img/brand/social/rhodes-rent-aboat.jpg"
>
  <link slot="head" rel="preload" as="image" href="/assets/img/heroes/hero-poster-mobile.jpg" media="(max-width: 767px)" fetchpriority="high" />
  <link slot="head" rel="preload" as="image" href="/assets/img/heroes/hero-poster-padded.jpg" media="(min-width: 768px)" fetchpriority="high" />

  <Header />
  <HeroBanner />
  <BoatCategories />
  <RentABoat />
  <ExperiencesCarousel />
  <WhyChooseUs />
  <Reviews />
  <BlogPreview />
  <GoogleMap />
  <Footer />

  <!-- Homepage-only: enable transparent header over hero -->
  <script>
  </script>
</BaseLayout>
