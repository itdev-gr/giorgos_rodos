---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../sections/home-one/Section1-Header.astro';
import FooterFour from '../../sections/shared/FooterFour.astro';
import BreadcrumbSchema from '../../components/seo/BreadcrumbSchema.astro';
import posts from '../../data/data-post.json';
import { blogExpansions } from '../../data/blog-expansions';
import { SITE_URL } from '../../lib/seo';
import { blogImageAlt } from '../../lib/tour-alt';

const { slug } = Astro.params;
const post = posts.find((p: any) => p.slug === slug);

if (!post) {
  return new Response(null, { status: 404, statusText: 'Not Found' });
}

const articleImageAlt = blogImageAlt(post.title, post.tags?.[0]);
const canonical = `${SITE_URL}/blog/${post.slug}`;
const ogImage = `${SITE_URL}/assets/img/pages/blog/${post.bannerImg || post.image}`;

// Related posts: any tag overlap, exclude current, sort by publishedDate desc, max 3
const currentTags = new Set<string>(post.tags || []);
const relatedPosts = (posts as any[])
  .filter((p) => p.slug !== post.slug && (p.tags || []).some((t: string) => currentTags.has(t)))
  .sort((a, b) => String(b.publishedDate || '').localeCompare(String(a.publishedDate || '')))
  .slice(0, 3);

// Tag → service CTA map. Pick up to 2 distinct CTAs based on this post's tags.
interface BlogServiceCta {
  url: string;
  title: string;
  blurb: string;
  ctaLabel: string;
}

const TAG_TO_SERVICE: Record<string, BlogServiceCta> = {
  'Rent a Boat': { url: '/#rent-a-boat', title: 'Rent a Boat in Rhodes', blurb: 'License-free options or boats with skipper.', ctaLabel: 'Compare boat rental Rhodes no license' },
  'Boat Trips': { url: '/service/rhodes-boat-trips', title: 'Rhodes Boat Trips', blurb: 'Skippered boat trips with flexible routes.', ctaLabel: 'Book a private Rhodes boat trip' },
  'Cruises': { url: '/service/rhodes-boat-cruises', title: 'Rhodes Boat Cruises', blurb: 'Symi, Lindos and sunset day cruises.', ctaLabel: 'See Rhodes boat cruises' },
  'Symi': { url: '/things-to-do', title: 'Symi Day Trips from Rhodes', blurb: 'Compare approved Symi cruises and private boats.', ctaLabel: 'Browse Symi day trips from Rhodes' },
  'Day Trips': { url: '/service/rhodes-boat-cruises', title: 'Rhodes Day Cruises', blurb: 'Organised day trips with lunch and swimming stops.', ctaLabel: 'Explore Rhodes day cruises' },
  'Lindos': { url: '/things-to-do', title: 'Lindos Boat Trips from Rhodes', blurb: 'Coastal routes to St Paul\'s Bay and the Acropolis.', ctaLabel: 'Browse Lindos boat trips' },
  'Boat Tours': { url: '/service/rhodes-boat-tours', title: 'Rhodes Boat Tours', blurb: 'Local guides, hidden bays, handpicked experiences.', ctaLabel: 'See Rhodes boat tours' },
  'Private Tours': { url: '/service/rhodes-boat-trips', title: 'Private Boat Trip Rhodes', blurb: 'Your own boat, your own pace, with a local skipper.', ctaLabel: 'Book a private boat trip' },
  'Sunset': { url: '/service/rhodes-boat-cruises', title: 'Sunset Cruise in Rhodes', blurb: 'Magical sunset routes along the coastline.', ctaLabel: 'Find sunset cruises in Rhodes' },
  'Beaches': { url: '/things-to-do', title: 'Best Boat Tours in Rhodes', blurb: 'Browse the catalog of approved experiences.', ctaLabel: 'Browse boat experiences in Rhodes' },
  'Hidden Gems': { url: '/things-to-do', title: 'Hidden Bays by Boat in Rhodes', blurb: 'Hand-picked tours, no algorithms.', ctaLabel: 'Discover hidden boat routes' },
  'Activities': { url: '/things-to-do', title: 'Things to Do in Rhodes by Boat', blurb: 'Catalog of all approved experiences.', ctaLabel: 'Browse all boat experiences' },
  'Guide': { url: '/service', title: 'Boat Services in Rhodes', blurb: 'See all our services in one place.', ctaLabel: 'Explore boat services in Rhodes' },
  'Rhodes': { url: '/things-to-do', title: 'Best Boat Tours in Rhodes', blurb: 'Browse all approved boat experiences.', ctaLabel: 'Browse Rhodes boat experiences' },
};
const seenServiceUrls = new Set<string>();
const serviceCtas: BlogServiceCta[] = [];
for (const tag of (post.tags || []) as string[]) {
  const svc = TAG_TO_SERVICE[tag];
  if (svc && !seenServiceUrls.has(svc.url)) {
    seenServiceUrls.add(svc.url);
    serviceCtas.push(svc);
    if (serviceCtas.length === 2) break;
  }
}
// Always end with a contact fallback if we didn't fill 2 slots
if (serviceCtas.length < 2) {
  if (!seenServiceUrls.has('/contact')) {
    serviceCtas.push({ url: '/contact', title: 'Talk to a Local', blurb: 'Tell us your dates, we will recommend the right experience for your group.', ctaLabel: 'Get a local recommendation' });
  }
}
---

<BaseLayout
  title={`${post.title} | Rhodes Rent a Boat`}
  description={post.excerpt}
  canonical={canonical}
  ogImage={ogImage}
  ogImageAlt={articleImageAlt}
  ogType="article"
  articleAuthor={post.author}
  articlePublishedTime={post.publishedDate}
  articleModifiedTime={post.publishedDate}
  articleSection={Array.isArray(post.tags) ? post.tags[0] : undefined}
  articleTags={post.tags}
>
  <BreadcrumbSchema items={[
    { name: 'Home', url: '/' },
    { name: 'Blog', url: '/blog' },
    { name: post.title, url: `/blog/${post.slug}` },
  ]} />
  <Header />

  <!-- Hero -->
  <section class="rab-hero" style={`background-image: url(/assets/img/pages/blog/${post.bannerImg || post.image});`}>
    <div class="rab-hero__overlay"></div>
    <div class="container rab-hero__content">
      <h1 class="rab-hero__title" data-ani="slideinup">{post.title}</h1>
    </div>
  </section>

  <!-- Article -->
  <article class="rab-post">
    <div class="container">
      <div class="rab-post__layout">
        <div class="rab-article" data-ani="fadein">
          <div class="rab-article__meta">
            <span class="rab-article__meta-item">By {post.author}</span>
            <span class="rab-article__meta-sep" aria-hidden="true">&bull;</span>
            <span class="rab-article__meta-item">{post.date}</span>
            {post.tags?.length > 0 && (
              <>
                <span class="rab-article__meta-sep" aria-hidden="true">&bull;</span>
                <span class="rab-article__tags">
                  {post.tags.map((t: string) => <span class="rab-article__tag">{t}</span>)}
                </span>
              </>
            )}
          </div>

          {(post as any).content && (
            <div class="rab-article__body" set:html={(post as any).content + (blogExpansions[post.slug] || '')} />
          )}
        </div>
      </div>
    </div>
  </article>

  <!-- Service CTAs, connect blog readers to relevant money pages -->
  {serviceCtas.length > 0 && (
    <section class="rab-services" aria-labelledby="rab-services-title">
      <div class="container">
        <div class="rab-services__inner">
          <h2 id="rab-services-title" class="rab-services__title">Ready to Book Something?</h2>
          <p class="rab-services__intro">Based on what you just read, these services may be the right fit:</p>
          <div class="rab-services__grid">
            {serviceCtas.map((cta) => (
              <a href={cta.url} class="rab-services__card">
                <h3 class="rab-services__card-title">{cta.title}</h3>
                <p class="rab-services__card-blurb">{cta.blurb}</p>
                <span class="rab-services__card-cta">{cta.ctaLabel} →</span>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Related posts, internal linking + reader retention -->
  {relatedPosts.length > 0 && (
    <section class="rab-related" aria-labelledby="rab-related-title">
      <div class="container">
        <h2 id="rab-related-title" class="rab-related__title">Keep Reading</h2>
        <div class="rab-related__grid">
          {relatedPosts.map((rp) => (
            <a href={`/blog/${rp.slug}`} class="rab-related__card">
              <div class="rab-related__img">
                <img src={`/assets/img/pages/blog/${rp.image}`} alt={rp.title} loading="lazy" />
              </div>
              <div class="rab-related__body">
                <span class="rab-related__tag">{(rp.tags && rp.tags[0]) || 'Article'}</span>
                <h3 class="rab-related__card-title">{rp.title}</h3>
                <p class="rab-related__excerpt">{rp.excerpt}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BlogPosting',
    '@id': `${canonical}#article`,
    headline: post.title,
    name: post.title,
    image: [ogImage],
    datePublished: post.publishedDate || undefined,
    dateModified: post.publishedDate || undefined,
    author: {
      '@type': 'Person',
      name: 'Giorgos R.',
      jobTitle: 'Captain & Founder',
      url: `${SITE_URL}/about`,
    },
    publisher: {
      '@id': `${SITE_URL}#organization`,
      '@type': 'Organization',
      name: 'Rhodes Rent a Boat',
      logo: { '@type': 'ImageObject', url: `${SITE_URL}/assets/img/brand/logos/logo2.svg` },
    },
    mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
    url: canonical,
    description: post.excerpt,
    keywords: Array.isArray(post.tags) ? post.tags.join(', ') : undefined,
    articleSection: Array.isArray(post.tags) ? post.tags[0] : undefined,
    inLanguage: 'en-US',
    isPartOf: { '@id': `${SITE_URL}/blog#blog` },
  })} />

  <FooterFour />
</BaseLayout>

<script>
  function initRabHero() {
  }
  document.addEventListener('DOMContentLoaded', initRabHero);
  document.addEventListener('astro:page-load', initRabHero);
</script>

<style>
  .rab-hero {
    position: relative;
    min-height: 60vh;
    display: flex;
    align-items: flex-end;
    background-color: #0b2f38;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    overflow: hidden;
  }
  .rab-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0, 0, 0, 0.2) 0%, rgba(17, 61, 72, 0.75) 100%);
    z-index: 1;
  }
  .rab-hero__content {
    position: relative;
    z-index: 2;
    padding: 140px 0 70px;
    color: #fff;
  }

  .rab-hero__title {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 700;
    line-height: 1.15;
    margin: 0;
    color: #fff;
  }

  @media (max-width: 991px) {
    .rab-hero {
      min-height: 52vh;
    }
    .rab-hero__content {
      padding-top: 120px;
      padding-bottom: 48px;
    }
  }
  @media (max-width: 767px) {
    .rab-hero__title {
      font-size: 2rem;
    }
  }

  /* ===== Article reading experience ===== */
  .rab-post {
    padding: 64px 0 88px;
    background: #fff;
  }

  .rab-post__layout {
    max-width: 720px;
    margin: 0 auto;
  }

  .rab-article {
    color: #445963;
    font-size: 1.125rem;
    line-height: 1.8;
    letter-spacing: 0.01em;
    -webkit-font-smoothing: antialiased;
    text-wrap: pretty;
  }

  .rab-article__meta {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    font-size: 0.875rem;
    color: #6b7c85;
    margin-bottom: 40px;
    padding-bottom: 24px;
    border-bottom: 1px solid #e8eef0;
  }

  .rab-article__meta-item {
    font-weight: 500;
  }

  .rab-article__meta-sep {
    opacity: 0.45;
  }

  .rab-article__tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .rab-article__tag {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #1CA8CB;
    background: rgba(28, 168, 203, 0.1);
    border-radius: 999px;
    padding: 5px 12px;
  }

  .rab-article__body {
    font-size: inherit;
    line-height: inherit;
    color: inherit;
  }

  .rab-article__body :global(h2) {
    font-size: clamp(1.55rem, 3vw, 1.95rem);
    font-weight: 700;
    color: #113D48;
    line-height: 1.25;
    letter-spacing: -0.02em;
    margin: 3rem 0 1rem;
  }

  .rab-article__body :global(h2:first-child) {
    margin-top: 0;
  }

  .rab-article__body :global(h3) {
    font-size: clamp(1.2rem, 2.2vw, 1.4rem);
    font-weight: 700;
    color: #113D48;
    line-height: 1.35;
    margin: 2.25rem 0 0.75rem;
  }

  .rab-article__body :global(p) {
    margin: 0 0 1.35rem;
  }

  .rab-article__body :global(p:last-child) {
    margin-bottom: 0;
  }

  .rab-article__body :global(ul),
  .rab-article__body :global(ol) {
    margin: 0 0 1.5rem;
    padding-left: 0;
    list-style: none;
  }

  .rab-article__body :global(ul li),
  .rab-article__body :global(ol li) {
    position: relative;
    padding-left: 1.35rem;
    margin-bottom: 0.65rem;
    line-height: 1.75;
  }

  .rab-article__body :global(ul li::before) {
    content: '';
    position: absolute;
    left: 0;
    top: 0.72em;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #1CA8CB;
  }

  .rab-article__body :global(ol) {
    counter-reset: rab-ol;
  }

  .rab-article__body :global(ol li) {
    counter-increment: rab-ol;
  }

  .rab-article__body :global(ol li::before) {
    content: counter(rab-ol) '.';
    position: absolute;
    left: 0;
    top: 0;
    font-size: 0.9rem;
    font-weight: 700;
    color: #1CA8CB;
  }

  .rab-article__body :global(a) {
    color: #1489a8;
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    transition: color 0.2s ease;
  }

  .rab-article__body :global(a:hover) {
    color: #113D48;
  }

  .rab-article__body :global(strong) {
    color: #113D48;
    font-weight: 600;
  }

  .rab-article__body :global(em) {
    font-style: italic;
    color: #3a4f57;
  }

  @media (max-width: 767px) {
    .rab-post {
      padding: 48px 0 64px;
    }

    .rab-article {
      font-size: 1.0625rem;
      line-height: 1.75;
    }

    .rab-article__meta {
      margin-bottom: 32px;
      padding-bottom: 20px;
    }

    .rab-article__body :global(h2) {
      margin-top: 2.25rem;
    }
  }

  /* ===== Service CTAs ===== */
  .rab-services {
    padding: 48px 0 72px;
    background: #f4f8f9;
  }
  .rab-services__inner {
    max-width: 880px;
    margin: 0 auto;
    text-align: center;
  }
  .rab-services__title {font-size: clamp(1.5rem, 2.5vw, 1.9rem);
    font-weight: 700;
    color: #113D48;
    margin: 0 0 8px;
  }
  .rab-services__intro {
    font-size: 1rem;
    line-height: 1.65;
    color: #5a6a72;
    margin: 0 0 28px;
  }
  .rab-services__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
  }
  .rab-services__card {
    display: block;
    padding: 24px 22px 22px;
    background: #fff;
    border: 1px solid #e5eaee;
    border-radius: 12px;
    text-decoration: none;
    color: inherit;
    text-align: left;
    transition: border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }
  .rab-services__card:hover {
    border-color: #1CA8CB;
    transform: translateY(-2px);
    box-shadow: 0 6px 18px rgba(28,168,203,0.12);
  }
  .rab-services__card-title {font-size: 1.1rem;
    font-weight: 700;
    color: #113D48;
    margin: 0 0 8px;
  }
  .rab-services__card-blurb {font-size: 0.92rem;
    line-height: 1.6;
    color: #5a6a72;
    margin: 0 0 12px;
  }
  .rab-services__card-cta {font-size: 0.82rem;
    font-weight: 600;
    color: #1CA8CB;
    letter-spacing: 0.5px;
  }

  /* ===== Related posts ===== */
  .rab-related {
    padding: 72px 0 88px;
    background: #fff;
  }
  .rab-related__title {font-size: clamp(1.5rem, 2.5vw, 1.9rem);
    font-weight: 700;
    color: #113D48;
    text-align: center;
    margin: 0 0 32px;
  }
  .rab-related__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 22px;
  }
  .rab-related__card {
    display: flex;
    flex-direction: column;
    background: #fff;
    border: 1px solid #e5eaee;
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .rab-related__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.08);
  }
  .rab-related__img {
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }
  .rab-related__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .rab-related__card:hover .rab-related__img img {
    transform: scale(1.05);
  }
  .rab-related__body {
    padding: 18px 18px 20px;
  }
  .rab-related__tag {
    display: inline-block;font-size: 11px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: #1CA8CB;
    margin-bottom: 8px;
  }
  .rab-related__card-title {font-size: 1.05rem;
    font-weight: 700;
    line-height: 1.35;
    color: #113D48;
    margin: 0 0 10px;
  }
  .rab-related__excerpt {font-size: 0.88rem;
    line-height: 1.6;
    color: #5a6a72;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (max-width: 767px) {
    .rab-services__grid { grid-template-columns: 1fr; }
    .rab-related__grid { grid-template-columns: 1fr; }
  }
</style>
