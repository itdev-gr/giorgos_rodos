---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../sections/home-one/Section1-Header.astro';
import FooterFour from '../../sections/shared/FooterFour.astro';
import BreadcrumbSchema from '../../components/seo/BreadcrumbSchema.astro';
import posts from '../../data/data-post.json';
import { blogExpansions } from '../../data/blog-expansions';
import { SITE_URL } from '../../lib/seo';
import { blogImageAlt } from '../../lib/tour-alt';

const { slug } = Astro.params;
const post = posts.find((p: any) => p.slug === slug);

if (!post) {
  return new Response(null, { status: 404, statusText: 'Not Found' });
}

const articleImageAlt = blogImageAlt(post.title, post.tags?.[0]);
const canonical = `${SITE_URL}/blog/${post.slug}`;
const ogImage = `${SITE_URL}/assets/img/blog/${post.bannerImg || post.image}`;

// Related posts: any tag overlap, exclude current, sort by publishedDate desc, max 3
const currentTags = new Set<string>(post.tags || []);
const relatedPosts = (posts as any[])
  .filter((p) => p.slug !== post.slug && (p.tags || []).some((t: string) => currentTags.has(t)))
  .sort((a, b) => String(b.publishedDate || '').localeCompare(String(a.publishedDate || '')))
  .slice(0, 3);

// Tag → service CTA map. Pick up to 2 distinct service CTAs based on this post's tags.
const TAG_TO_SERVICE: Record<string, { url: string; title: string; blurb: string }> = {
  'Rent a Boat': { url: '/service/rhodes-rent-a-boat', title: 'Rent a Boat in Rhodes', blurb: 'License-free options or boats with skipper.' },
  'Boat Trips': { url: '/service/rhodes-boat-trips', title: 'Rhodes Boat Trips', blurb: 'Skippered boat trips with flexible routes.' },
  'Cruises': { url: '/service/rhodes-boat-cruises', title: 'Rhodes Boat Cruises', blurb: 'Symi, Lindos and sunset day cruises.' },
  'Symi': { url: '/service/rhodes-boat-tours', title: 'Symi Day Cruise', blurb: 'The most popular day trip from Rhodes.' },
  'Day Trips': { url: '/service/rhodes-boat-tours', title: 'Rhodes Day Cruises', blurb: 'Organised day trips with lunch and swimming stops.' },
  'Lindos': { url: '/service/rhodes-boat-tours', title: 'Lindos by Boat', blurb: 'See the Acropolis from the sea.' },
  'Boat Tours': { url: '/service/rhodes-boat-tours', title: 'Boat Tours in Rhodes', blurb: 'Local guides, hidden bays, handpicked experiences.' },
  'Private Tours': { url: '/service/rhodes-boat-trips', title: 'Private Boat Trip', blurb: 'Your own boat, your own pace, with a local skipper.' },
  'Sunset': { url: '/service/rhodes-boat-tours', title: 'Sunset Cruise in Rhodes', blurb: 'Magical sunset routes along the coastline.' },
  'Beaches': { url: '/things-to-do', title: 'Best Boat Tours in Rhodes', blurb: 'Browse the catalog of approved experiences.' },
  'Hidden Gems': { url: '/things-to-do', title: 'Best Boat Tours in Rhodes', blurb: 'Hand-picked tours, no algorithms.' },
  'Activities': { url: '/things-to-do', title: 'Things to Do in Rhodes', blurb: 'Catalog of all approved experiences.' },
  'Guide': { url: '/service', title: 'Boat Services in Rhodes', blurb: 'See all our services in one place.' },
  'Rhodes': { url: '/things-to-do', title: 'Best Boat Tours in Rhodes', blurb: 'Browse all approved boat experiences.' },
};
const seenServiceUrls = new Set<string>();
const serviceCtas: { url: string; title: string; blurb: string }[] = [];
for (const tag of (post.tags || []) as string[]) {
  const svc = TAG_TO_SERVICE[tag];
  if (svc && !seenServiceUrls.has(svc.url)) {
    seenServiceUrls.add(svc.url);
    serviceCtas.push(svc);
    if (serviceCtas.length === 2) break;
  }
}
// Always end with a contact fallback if we didn't fill 2 slots
if (serviceCtas.length < 2) {
  if (!seenServiceUrls.has('/contact')) {
    serviceCtas.push({ url: '/contact', title: 'Talk to a Local', blurb: 'Tell us your dates — we will recommend the right experience for your group.' });
  }
}
---

<BaseLayout
  title={`${post.title} | Rhodes Rent a Boat`}
  description={post.excerpt}
  canonical={canonical}
  ogImage={ogImage}
  ogImageAlt={articleImageAlt}
  ogType="article"
  articleAuthor={post.author}
  articlePublishedTime={post.publishedDate}
  articleModifiedTime={post.publishedDate}
  articleSection={Array.isArray(post.tags) ? post.tags[0] : undefined}
  articleTags={post.tags}
>
  <BreadcrumbSchema items={[
    { name: 'Home', url: '/' },
    { name: 'Blog', url: '/blog' },
    { name: post.title, url: `/blog/${post.slug}` },
  ]} />
  <Header />

  <!-- Hero -->
  <section class="rab-hero" style={`background-image: url(/assets/img/blog/${post.bannerImg || post.image});`}>
    <div class="rab-hero__overlay"></div>
    <div class="container rab-hero__content">
      <span class="rab-hero__breadcrumb">Blog &nbsp;|&nbsp; {post.tags[0]}</span>
      <h1 class="rab-hero__title" data-ani="slideinup">{post.title}</h1>
      <p class="rab-hero__tagline" data-ani="slideinup" data-ani-delay="0.1">
        {post.excerpt}
      </p>
    </div>
  </section>

  <!-- Article -->
  <article style="padding: 80px 0;">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-lg-8">
          <div class="rab-article" data-ani="fadein">
            <div class="rab-article__meta">
              <span>By {post.author}</span>
              <span class="rab-article__meta-sep">&bull;</span>
              <span>{post.date}</span>
              <span class="rab-article__meta-sep">&bull;</span>
              <span class="rab-article__tags">
                {post.tags.map((t: string) => <span class="blog-card_tag">{t.toUpperCase()}</span>)}
              </span>
            </div>

            <img
              src={`/assets/img/blog/${post.bannerImg || post.image}`}
              alt={articleImageAlt}
              class="rab-article__img"
            />

            <p class="rab-article__lead">{post.excerpt}</p>

            {(post as any).content && (
              <div class="rab-article__body" set:html={(post as any).content + (blogExpansions[post.slug] || '')} />
            )}
          </div>
        </div>
      </div>
    </div>
  </article>

  <!-- Service CTAs — connect blog readers to relevant money pages -->
  {serviceCtas.length > 0 && (
    <section class="rab-services" aria-labelledby="rab-services-title">
      <div class="container">
        <div class="rab-services__inner">
          <h2 id="rab-services-title" class="rab-services__title">Ready to Book Something?</h2>
          <p class="rab-services__intro">Based on what you just read, these services may be the right fit:</p>
          <div class="rab-services__grid">
            {serviceCtas.map((cta) => (
              <a href={cta.url} class="rab-services__card">
                <h3 class="rab-services__card-title">{cta.title}</h3>
                <p class="rab-services__card-blurb">{cta.blurb}</p>
                <span class="rab-services__card-cta">Learn more →</span>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Related posts — internal linking + reader retention -->
  {relatedPosts.length > 0 && (
    <section class="rab-related" aria-labelledby="rab-related-title">
      <div class="container">
        <h2 id="rab-related-title" class="rab-related__title">Keep Reading</h2>
        <div class="rab-related__grid">
          {relatedPosts.map((rp) => (
            <a href={`/blog/${rp.slug}`} class="rab-related__card">
              <div class="rab-related__img">
                <img src={`/assets/img/blog/${rp.image}`} alt={rp.title} loading="lazy" />
              </div>
              <div class="rab-related__body">
                <span class="rab-related__tag">{(rp.tags && rp.tags[0]) || 'Article'}</span>
                <h3 class="rab-related__card-title">{rp.title}</h3>
                <p class="rab-related__excerpt">{rp.excerpt}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BlogPosting',
    '@id': `${canonical}#article`,
    headline: post.title,
    name: post.title,
    image: [ogImage],
    datePublished: post.publishedDate || undefined,
    dateModified: post.publishedDate || undefined,
    author: {
      '@type': 'Person',
      name: 'Giorgos R.',
      jobTitle: 'Captain & Founder',
      url: `${SITE_URL}/about`,
    },
    publisher: {
      '@id': `${SITE_URL}#organization`,
      '@type': 'Organization',
      name: 'Rhodes Rent a Boat',
      logo: { '@type': 'ImageObject', url: `${SITE_URL}/assets/img/logo2.svg` },
    },
    mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
    url: canonical,
    description: post.excerpt,
    keywords: Array.isArray(post.tags) ? post.tags.join(', ') : undefined,
    articleSection: Array.isArray(post.tags) ? post.tags[0] : undefined,
    inLanguage: 'en-US',
    isPartOf: { '@id': `${SITE_URL}/blog#blog` },
  })} />

  <FooterFour />
</BaseLayout>

<script>
  function initRabHero() {
  }
  document.addEventListener('DOMContentLoaded', initRabHero);
  document.addEventListener('astro:page-load', initRabHero);
</script>

<style>
  .rab-hero {
    position: relative;
    min-height: 60vh;
    display: flex;
    align-items: flex-end;
    background-color: #0b2f38;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    overflow: hidden;
  }
  .rab-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0, 0, 0, 0.2) 0%, rgba(17, 61, 72, 0.75) 100%);
    z-index: 1;
  }
  .rab-hero__content {
    position: relative;
    z-index: 2;
    padding-bottom: 70px;
    color: #fff;
  }
  .rab-hero__breadcrumb {
    display: inline-block;
    text-transform: uppercase;
    font-size: 14px;
    letter-spacing: 3px;
    margin-bottom: 18px;
    opacity: 0.85;
  }
  .rab-hero__title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 700;
    line-height: 1.15;
    margin-bottom: 16px;
    color: #fff;
  }
  .rab-hero__tagline {
    font-family: 'Cormorant Garamond', 'Playfair Display', serif;
    font-style: italic;
    font-size: clamp(1rem, 1.8vw, 1.25rem);
    line-height: 1.6;
    max-width: 620px;
    opacity: 0.92;
    margin-bottom: 0;
  }

  @media (max-width: 991px) {
    .rab-hero {
      min-height: 75vh;
    }
    .rab-hero__content {
      padding-bottom: 5vh;
    }
  }
  @media (max-width: 767px) {
    .rab-hero__title {
      font-size: 2rem;
    }
  }

  .rab-article {
    font-family: 'Inter', sans-serif;
    font-size: 1.05rem;
    line-height: 1.85;
    color: #4a5568;
  }
  .rab-article p {
    margin-bottom: 18px;
  }
  .rab-article__meta {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    font-size: 14px;
    color: #737887;
    margin-bottom: 28px;
  }
  .rab-article__meta-sep {
    opacity: 0.5;
  }
  .rab-article__tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }
  .blog-card_tag {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1px;
    color: #113D48;
    background: rgba(17, 61, 72, 0.08);
    border-radius: 4px;
    padding: 2px 8px;
  }
  .rab-article__img {
    width: 100%;
    border-radius: 12px;
    margin-bottom: 32px;
    aspect-ratio: 16/9;
    object-fit: cover;
  }
  .rab-article__lead {
    font-size: 1.15rem;
    color: #2d3e46;
    margin-bottom: 28px !important;
  }
  .rab-article__body {
    font-size: 1.05rem;
    line-height: 1.85;
    color: #4a5568;
  }
  .rab-article__body h2 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.3rem, 2.5vw, 1.65rem);
    font-weight: 700;
    color: #113D48;
    margin: 40px 0 16px;
  }
  .rab-article__body h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.15rem;
    font-weight: 700;
    color: #113D48;
    margin: 28px 0 12px;
  }
  .rab-article__body p { margin-bottom: 18px; }
  .rab-article__body ul, .rab-article__body ol {
    padding-left: 22px;
    margin-bottom: 18px;
  }
  .rab-article__body li { margin-bottom: 8px; }
  .rab-article__body a { color: #1CA8CB; text-decoration: underline; }
  .rab-article__body strong { color: #113D48; }

  /* ===== Service CTAs ===== */
  .rab-services {
    padding: 30px 0 60px;
    background: #f8fafb;
  }
  .rab-services__inner {
    max-width: 880px;
    margin: 0 auto;
    text-align: center;
  }
  .rab-services__title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.5rem, 2.5vw, 1.9rem);
    font-weight: 700;
    color: #113D48;
    margin: 0 0 8px;
  }
  .rab-services__intro {
    font-family: 'Inter', sans-serif;
    font-size: 0.95rem;
    color: #5a6a72;
    margin: 0 0 28px;
  }
  .rab-services__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
  }
  .rab-services__card {
    display: block;
    padding: 24px 22px 22px;
    background: #fff;
    border: 1px solid #e5eaee;
    border-radius: 12px;
    text-decoration: none;
    color: inherit;
    text-align: left;
    transition: border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }
  .rab-services__card:hover {
    border-color: #1CA8CB;
    transform: translateY(-2px);
    box-shadow: 0 6px 18px rgba(28,168,203,0.12);
  }
  .rab-services__card-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: #113D48;
    margin: 0 0 8px;
  }
  .rab-services__card-blurb {
    font-family: 'Inter', sans-serif;
    font-size: 0.92rem;
    line-height: 1.6;
    color: #5a6a72;
    margin: 0 0 12px;
  }
  .rab-services__card-cta {
    font-family: 'Inter', sans-serif;
    font-size: 0.82rem;
    font-weight: 600;
    color: #1CA8CB;
    letter-spacing: 0.5px;
  }

  /* ===== Related posts ===== */
  .rab-related {
    padding: 60px 0 80px;
    background: #fff;
  }
  .rab-related__title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.5rem, 2.5vw, 1.9rem);
    font-weight: 700;
    color: #113D48;
    text-align: center;
    margin: 0 0 32px;
  }
  .rab-related__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 22px;
  }
  .rab-related__card {
    display: flex;
    flex-direction: column;
    background: #fff;
    border: 1px solid #e5eaee;
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .rab-related__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.08);
  }
  .rab-related__img {
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }
  .rab-related__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .rab-related__card:hover .rab-related__img img {
    transform: scale(1.05);
  }
  .rab-related__body {
    padding: 18px 18px 20px;
  }
  .rab-related__tag {
    display: inline-block;
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: #1CA8CB;
    margin-bottom: 8px;
  }
  .rab-related__card-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.05rem;
    font-weight: 700;
    line-height: 1.35;
    color: #113D48;
    margin: 0 0 10px;
  }
  .rab-related__excerpt {
    font-family: 'Inter', sans-serif;
    font-size: 0.88rem;
    line-height: 1.6;
    color: #5a6a72;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (max-width: 767px) {
    .rab-services__grid { grid-template-columns: 1fr; }
    .rab-related__grid { grid-template-columns: 1fr; }
  }
</style>
