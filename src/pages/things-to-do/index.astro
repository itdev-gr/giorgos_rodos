---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../sections/home-one/Section1-Header.astro';
import FooterFour from '../../sections/shared/FooterFour.astro';
import ServiceHeroFullwidth from '../../sections/service/ServiceHeroFullwidth.astro';
import TourSearchGrid from '../../components/dashboard/TourSearchGrid';
import BreadcrumbSchema from '../../components/seo/BreadcrumbSchema.astro';
import FAQSection from '../../components/FAQSection.astro';
import { createPublicClient } from '../../lib/supabase';
import { getMediaSlot } from '../../lib/media';
import { SITE_URL } from '../../lib/seo';

const thingsToDoFaq = [
  {
    question: 'What are the best things to do in Rhodes by boat?',
    answer: 'The biggest hits are the Symi day cruise, swimming and snorkeling at Anthony Quinn Bay and Kalithea Springs, the Lindos seaward approach to the Acropolis, and a sunset catamaran cruise. For a more independent day, a license-free boat lets you explore east-coast bays at your own pace.',
  },
  {
    question: 'Should I book a boat tour or a day cruise?',
    answer: 'A boat tour is usually private or semi-private on a smaller boat with a skipper — ideal for couples and small groups who want flexibility. A day cruise is a larger shared boat with all-inclusive food, drinks and a fixed route — ideal for first-time visitors who want everything organised. <a href="/contact">Tell us your group size and we will recommend the right one.</a>',
  },
  {
    question: 'Which Rhodes boat experience is best for families?',
    answer: 'Catamaran day cruises are the most family-friendly: stable in light chop, lots of deck space, shaded areas, lunch on board, and several swim stops in calm bays. Children of any age are welcome and child-size life jackets are provided. <a href="/service/rhodes-catamaran-tours">See catamaran tours</a>.',
  },
  {
    question: 'What is the most popular boat trip from Rhodes?',
    answer: 'The Symi day cruise is the single most-booked trip. The boat leaves Mandraki around 09:00, reaches Symi in about 80 minutes, gives you 4–5 hours on the island for lunch and exploring the pastel harbour, then a swim stop on the way back.',
  },
  {
    question: 'Do I need to book my Rhodes boat experience in advance?',
    answer: 'In high season (June–August) yes — popular shared cruises and most private boats sell out 1–2 weeks ahead, especially for weekends. In May, late September and October a few days notice is usually enough. For weekly yacht charters book 1–3 months ahead.',
  },
  {
    question: 'Can I see Symi or Lindos by boat from Rhodes?',
    answer: 'Yes — both are popular full-day trips. Symi is a 80-minute crossing each way; you spend most of the day on the island. Lindos is a coastal cruise along the east shore that lets you see the Acropolis from the sea, with a swim stop in St Paul\'s Bay below the citadel. Both are bookable as <a href="/service/rhodes-boat-cruises">shared cruises</a> or <a href="/service/rhodes-boat-trips">private trips</a>.',
  },
];

const heroImage = await getMediaSlot('things-to-do.hero.image', '/assets/img/gallery/yacht/greek-island-1.jpg');
const heroVideo = await getMediaSlot('things-to-do.hero.video', '/assets/img/hero/services/boat-tours.mp4');

// Fetch ALL approved tours from Supabase
let tours: any[] = [];
try {
  const supabase = createPublicClient();
  if (supabase) {
    const { data } = await supabase
      .from('tours')
      .select('*')
      .eq('status', 'approved')
      .neq('service_page', 'rhodes-charter')
      .order('is_global', { ascending: false })
      .order('created_at', { ascending: false });
    tours = data || [];
  }
} catch (e) {
  console.error('Failed to fetch tours:', e);
}
---

<BaseLayout title="Best Boat Tours in Rhodes — Experiences & Activities | Rhodes Rent a Boat" description="Best boat tours in Rhodes. All approved boat tours, trips, cruises, sailing, island hopping and local activities. Handpicked by locals." ogImage={heroImage}>
  <BreadcrumbSchema items={[
    { name: 'Home', url: '/' },
    { name: 'Things to Do', url: '/things-to-do' },
  ]} />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    '@id': `${SITE_URL}/things-to-do#collection`,
    url: `${SITE_URL}/things-to-do`,
    name: 'Best Boat Tours in Rhodes — Experiences & Activities',
    description: 'Best boat tours in Rhodes. All approved boat tours, trips, cruises, sailing, island hopping and local activities. Handpicked by locals.',
    inLanguage: 'en-US',
    isPartOf: { '@id': `${SITE_URL}#website` },
    mainEntity: {
      '@type': 'ItemList',
      numberOfItems: tours.length,
      itemListElement: tours.slice(0, 50).map((t: any, i: number) => ({
        '@type': 'ListItem',
        position: i + 1,
        url: `${SITE_URL}/tour-detail/${t.slug || t.id}`,
        name: t.title,
      })),
    },
  })} is:inline />
  <Header />

  <!-- 1. Hero -->
  <ServiceHeroFullwidth
    title="Best Boat Tours in Rhodes"
    subtitle="Experiences and Activities on the Island"
    backgroundImage={heroImage}
    heroVideo={heroVideo}
  />

  <!-- 2. Intro -->
  <section style="padding: 60px 0 40px;">
    <div class="container">
      <div style="max-width: 750px; margin: 0 auto; text-align: center;">
        <p style="font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 1.2rem; line-height: 1.7; color: #1CA8CB; margin-bottom: 24px;" data-ani="fadein">
          Discover all the best boat experiences in Rhodes — handpicked by locals and verified by our team.
        </p>
        <p style="font-size: 1rem; line-height: 1.8; color: #4a5568; margin-bottom: 0;" data-ani="fadein" data-ani-delay="0.1">
          Browse boat tours, sailing trips, catamaran cruises, yacht charters, rent-a-boat options and unique experiences. Use the search and filters to find exactly what you are looking for.
        </p>
      </div>
    </div>
  </section>

  <!-- 3. Tours Grid with Search -->
  <section aria-labelledby="all-tours-heading" style="padding: 40px 0 80px; background: #f8fafb;">
    <div class="container">
      <h2 id="all-tours-heading" style="position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0;">All Approved Boat Experiences in Rhodes</h2>
      {tours.length > 0 ? (
        <TourSearchGrid tours={tours} client:load />
      ) : (
        <div style="text-align: center; padding: 80px 20px;">
          <i class="fas fa-ship" style="font-size: 3rem; color: #cbd5e1; margin-bottom: 20px;"></i>
          <h2 style="font-family: 'Playfair Display', serif; font-size: 1.3rem; font-weight: 700; color: #113D48; margin-bottom: 12px;">No Tours Available Yet</h2>
          <p style="font-size: 0.95rem; color: #64748b; max-width: 500px; margin: 0 auto;">
            We are currently adding new boat experiences to this page. Check back soon or contact us for personal recommendations.
          </p>
        </div>
      )}
    </div>
  </section>

  <FAQSection
    items={thingsToDoFaq}
    title="Choosing the Right Boat Experience in Rhodes"
    intro="Quick answers for first-time visitors. For booking, weather and licence questions see the <a href='/faq'>full FAQ</a>."
  />

  <!-- 4. Contact -->
  <section style="padding: 80px 0; background: #113D48;">
    <div class="container">
      <div style="max-width: 700px; margin: 0 auto; text-align: center;">
        <h2 style="font-family: 'Playfair Display', serif; font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 700; color: #fff; margin-bottom: 20px;" data-ani="slideinup">Looking for Something Specific?</h2>
        <p style="font-size: 1rem; line-height: 1.75; color: rgba(255,255,255,0.7); margin-bottom: 36px;" data-ani="fadein" data-ani-delay="0.1">
          Can't find what you're looking for? Contact us and we will help you find the perfect boat experience in Rhodes.
        </p>
        <div style="display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;" data-ani="slideinup" data-ani-delay="0.2">
          <a href="/contact" class="th-btn style3 th-icon">Send Us a Message</a>
          <a href="https://wa.me/302241012345" style="display: inline-flex; align-items: center; gap: 8px; padding: 14px 28px; font-family: 'Inter', sans-serif; font-size: 0.85rem; font-weight: 600; color: #fff; border: 1.5px solid rgba(255,255,255,0.3); border-radius: 8px; text-decoration: none; transition: all 0.3s ease;"><i class="fab fa-whatsapp"></i> WhatsApp</a>
        </div>
      </div>
    </div>
  </section>

  <FooterFour />
</BaseLayout>

<script>
</script>
