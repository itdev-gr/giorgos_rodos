---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../sections/home-one/Section1-Header.astro';
import FooterFour from '../../sections/shared/FooterFour.astro';
import TourSearchGrid from '../../components/dashboard/TourSearchGrid';
import BreadcrumbSchema from '../../components/seo/BreadcrumbSchema.astro';
import FAQSection from '../../components/FAQSection.astro';
import ServiceExploreLinks from '../../components/things-to-do/ServiceExploreLinks.astro';
import { createPublicClient } from '../../lib/supabase';
import { SITE_URL } from '../../lib/seo';
import { thingsToDoFaq } from '../../lib/faq';

const ogImage = '/assets/img/gallery/yacht/greek-island-1.jpg';

// Fetch ALL approved tours from Supabase
let tours: any[] = [];
try {
  const supabase = createPublicClient();
  if (supabase) {
    const { data } = await supabase
      .from('tours')
      .select('*')
      .eq('status', 'approved')
      .neq('service_page', 'rhodes-charter')
      .order('is_global', { ascending: false })
      .order('created_at', { ascending: false });
    tours = data || [];
  }
} catch (e) {
  console.error('Failed to fetch tours:', e);
}
---

<BaseLayout title="All Boat Experiences in Rhodes: Browse & Filter | Rhodes Rent a Boat" description="Browse all approved boat experiences in Rhodes, sailing trips, day cruises, private boats, catamaran tours and self-drive rentals. Compare and choose." ogImage={ogImage}>
  <BreadcrumbSchema items={[
    { name: 'Home', url: '/' },
    { name: 'Things to Do', url: '/things-to-do' },
  ]} />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    '@id': `${SITE_URL}/things-to-do#collection`,
    url: `${SITE_URL}/things-to-do`,
    name: 'All Boat Experiences in Rhodes: Browse & Filter',
    description: 'Browse all approved boat experiences in Rhodes, sailing trips, day cruises, private boats, catamaran tours and self-drive rentals. Compare and choose.',
    inLanguage: 'en-US',
    isPartOf: { '@id': `${SITE_URL}#website` },
    mainEntity: {
      '@type': 'ItemList',
      numberOfItems: tours.length,
      itemListElement: tours.slice(0, 50).map((t: any, i: number) => ({
        '@type': 'ListItem',
        position: i + 1,
        url: `${SITE_URL}/tour-detail/${t.slug || t.id}`,
        name: t.title,
      })),
    },
  })} is:inline />
  <Header />

  <!-- 1. Hero -->
  <section class="things-hero">
    <div class="container">
      <div class="things-hero__content text-center">
        <h1 class="things-hero__title">All Boat Experiences in Rhodes</h1>
      </div>
    </div>
  </section>

  <!-- 2. Intro -->
  <section style="padding: 60px 0 40px;">
    <div class="container">
      <div style="max-width: 750px; margin: 0 auto; text-align: center;">
        <p style="font-style: italic; font-size: 1.2rem; line-height: 1.7; color: #1CA8CB; margin-bottom: 24px;" data-ani="fadein">
          Discover all the best boat experiences in Rhodes, handpicked by locals and verified by our team.
        </p>
        <p style="font-size: 1rem; line-height: 1.8; color: #4a5568; margin-bottom: 0;" data-ani="fadein" data-ani-delay="0.1">
          Browse <a href="/service/rhodes-boat-tours" style="color: #1CA8CB; font-weight: 600;">Rhodes boat tours</a>, <a href="/service/rhodes-boat-cruises" style="color: #1CA8CB; font-weight: 600;">Rhodes boat cruises</a>, <a href="/service/rhodes-boat-trips" style="color: #1CA8CB; font-weight: 600;">private boat trips</a>, catamaran sails, yacht charters and rent-a-boat options. Use the search and filters to find exactly what you are looking for.
        </p>
      </div>
    </div>
  </section>

  <ServiceExploreLinks />

  <!-- 3. Tours Grid with Search -->
  <section aria-labelledby="all-tours-heading" style="padding: 40px 0 80px; background: #f8fafb;">
    <div class="container">
      <h2 id="all-tours-heading" style="position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0;">All Approved Boat Experiences in Rhodes</h2>
      {tours.length > 0 ? (
        <TourSearchGrid tours={tours} client:load />
      ) : (
        <div style="text-align: center; padding: 80px 20px;">
          <i class="fas fa-ship" style="font-size: 3rem; color: #cbd5e1; margin-bottom: 20px;"></i>
          <h2 style="font-size: 1.3rem; font-weight: 700; color: #113D48; margin-bottom: 12px;">No Tours Available Yet</h2>
          <p style="font-size: 0.95rem; color: #64748b; max-width: 500px; margin: 0 auto;">
            We are currently adding new boat experiences to this page. Check back soon or contact us for personal recommendations.
          </p>
        </div>
      )}
    </div>
  </section>

  <FAQSection
    items={thingsToDoFaq}
    title="Choosing the Right Boat Experience in Rhodes"
    intro="Quick answers for first-time visitors. For booking, weather and licence questions see the <a href='/faq'>full FAQ</a>."
  />

  <FooterFour />
</BaseLayout>

<style>
  .things-hero {
    min-height: 420px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 140px 0 100px;
    background: linear-gradient(135deg, #1CA8CB 0%, #1489a8 35%, #113D48 100%);
  }

  .things-hero__title {
    font-family: Helvetica, "Helvetica Neue", Arial, sans-serif;
    font-size: clamp(2.25rem, 5vw, 4rem);
    font-weight: 800;
    color: #fff;
    margin-bottom: 0;
    line-height: 1.15;
  }

  @media (max-width: 991px) {
    .things-hero {
      min-height: 320px;
      padding: 120px 0 80px;
    }
  }
</style>
