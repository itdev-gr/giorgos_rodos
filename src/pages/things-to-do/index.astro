---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../sections/home-one/Section1-Header.astro';
import FooterFour from '../../sections/shared/FooterFour.astro';
import TourSearchGrid from '../../components/dashboard/TourSearchGrid';
import BreadcrumbSchema from '../../components/seo/BreadcrumbSchema.astro';
import FAQSection from '../../components/FAQSection.astro';
import { createPublicClient } from '../../lib/supabase';
import { resolveLocale } from '../../i18n/context';
import { getMessages } from '../../i18n';
import { getPageContent } from '../../i18n/page-content';
import { getThingsToDoFaq } from '../../i18n/faq-pages';
import { getFaqIntro, getFaqSectionTitle } from '../../i18n/faq-intros';
import { getThingsToDoSearchLabels, SERVICE_PAGE_LABEL_KEYS } from '../../i18n/ui-labels';
import { absoluteUrl, localizedPath } from '../../i18n/routing';
import { SCHEMA_LANGUAGE } from '../../i18n/locales';

const locale = resolveLocale(Astro.locals, Astro.url.pathname);
const messages = getMessages(locale);
const pc = getPageContent(locale).thingsToDo;
const faqs = getThingsToDoFaq(locale);
const thingsPath = localizedPath('/things-to-do', locale);
const searchLabels = getThingsToDoSearchLabels(locale);
const categoryLabels = Object.fromEntries(
  Object.entries(SERVICE_PAGE_LABEL_KEYS).map(([slug, key]) => [slug, messages.nav.services[key]]),
);

const ogImage = '/assets/img/gallery/yacht/greek-island-1.jpg';

let tours: any[] = [];
try {
  const supabase = createPublicClient();
  if (supabase) {
    const { data } = await supabase
      .from('tours')
      .select('*')
      .eq('status', 'approved')
      .neq('service_page', 'rhodes-charter')
      .order('is_global', { ascending: false })
      .order('created_at', { ascending: false });
    tours = data || [];
  }
} catch (e) {
  console.error('Failed to fetch tours:', e);
}
---

<BaseLayout title={messages.meta.thingsToDo.title} description={messages.meta.thingsToDo.description} ogImage={ogImage}>
  <BreadcrumbSchema items={[
    { name: messages.breadcrumbs.home, url: localizedPath('/', locale) },
    { name: messages.breadcrumbs.experiences, url: thingsPath },
  ]} />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    '@id': `${absoluteUrl(thingsPath)}#collection`,
    url: absoluteUrl(thingsPath),
    name: pc.schemaName,
    description: pc.schemaDescription,
    inLanguage: SCHEMA_LANGUAGE[locale],
    isPartOf: { '@id': `${absoluteUrl('/')}#website` },
    mainEntity: {
      '@type': 'ItemList',
      numberOfItems: Math.min(tours.length, 50),
      itemListElement: tours.slice(0, 50).map((t: any, i: number) => ({
        '@type': 'ListItem',
        position: i + 1,
        url: `${absoluteUrl('/tour-detail')}/${t.slug || t.id}`,
        name: t.title,
      })),
    },
  })} is:inline />
  <Header />

  <section class="things-hero">
    <div class="container">
      <div class="things-hero__content text-center">
        <h1 class="things-hero__title">{pc.h1}</h1>
      </div>
    </div>
  </section>

  <section aria-labelledby="all-tours-heading" style="padding: 40px 0 80px; background: #f8fafb;">
    <div class="container">
      <h2 id="all-tours-heading" style="position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0;">{pc.hiddenH2}</h2>
      {tours.length > 0 ? (
        <TourSearchGrid tours={tours} labels={searchLabels} categoryLabels={categoryLabels} client:load />
      ) : (
        <div style="text-align: center; padding: 80px 20px;">
          <i class="fas fa-ship" style="font-size: 3rem; color: #cbd5e1; margin-bottom: 20px;"></i>
          <h2 style="font-size: 1.3rem; font-weight: 700; color: #113D48; margin-bottom: 12px;">{pc.emptyTitle}</h2>
          <p style="font-size: 0.95rem; color: #64748b; max-width: 500px; margin: 0 auto;">
            {pc.emptyText}
          </p>
        </div>
      )}
    </div>
  </section>

  <FAQSection
    items={faqs}
    title={getFaqSectionTitle('thingsToDo', locale)}
    intro={getFaqIntro('thingsToDo', locale)}
  />

  <FooterFour />
</BaseLayout>

<style>
  .things-hero {
    min-height: 420px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 140px 0 100px;
    background: linear-gradient(135deg, #1CA8CB 0%, #1489a8 35%, #113D48 100%);
  }

  .things-hero__title {
    font-family: Helvetica, "Helvetica Neue", Arial, sans-serif;
    font-size: clamp(2.25rem, 5vw, 4rem);
    font-weight: 800;
    color: #fff;
    margin-bottom: 0;
    line-height: 1.15;
  }

  @media (max-width: 991px) {
    .things-hero {
      min-height: 320px;
      padding: 120px 0 80px;
    }
  }
</style>
