---
export const prerender = false;

import DashboardLayout from '../../../../layouts/DashboardLayout.astro';
import TourForm from '../../../../components/dashboard/TourForm';
import { createAdminClient } from '../../../../lib/supabase';

const { id } = Astro.params;
const userId = Astro.locals.user?.id;
const supabase = createAdminClient();

const { data: tour } = await supabase
  .from('tours')
  .select('*')
  .eq('id', id)
  .eq('owner_id', userId)
  .single();

if (!tour) {
  return Astro.redirect('/dashboard/user/tours');
}
---

<DashboardLayout title="Edit Tour">
  <div style="margin-bottom: 20px;">
    <a href="/dashboard/user/tours" style="display: inline-flex; align-items: center; gap: 6px; font-size: 0.85rem; color: #64748b; text-decoration: none;">
      <i class="fas fa-arrow-left" style="font-size: 0.75rem;"></i> Back to My Tours
    </a>
  </div>

  <TourForm mode="edit" tour={tour} client:load />
</DashboardLayout>
