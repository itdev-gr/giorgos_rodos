---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../sections/home-one/Section1-Header.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import FooterFour from '../../sections/shared/FooterFour.astro';
import tours from '../../data/data-tour.json';

const currentPosts = tours.slice(0, 8);
---

<BaseLayout title="Popular Tours - Rhodes Boat Tours">
  <Header />
  <Breadcrumb title="Popular Tours" />

  <section class="space">
    <div class="container shape-mockup-wrap">
      <div class="th-sort-bar">
        <div class="row justify-content-between align-items-center">
          <div class="col-md-4">
            <div class="search-form-area">
              <form class="search-form">
                <input type="text" placeholder="Search" />
                <button type="submit">
                  <i class="fa-light fa-magnifying-glass"></i>
                </button>
              </form>
            </div>
          </div>
          <div class="col-md-auto">
            <div class="sorting-filter-wrap">
              <div class="nav" role="tablist">
                <a
                  href="#"
                  id="tab-destination-grid"
                  data-bs-toggle="tab"
                  data-bs-target="#tab-grid"
                  role="tab"
                  aria-controls="tab-grid"
                  aria-selected="true"
                  class="active"
                >
                  <i class="fa-light fa-grid-2"></i>
                </a>
                <a
                  href="#"
                  id="tab-destination-list"
                  data-bs-toggle="tab"
                  data-bs-target="#tab-list"
                  role="tab"
                  aria-controls="tab-list"
                  aria-selected="false"
                >
                  <i class="fa-solid fa-list"></i>
                </a>
              </div>
              <form class="woocommerce-ordering" method="get">
                <select name="orderby" class="orderby" aria-label="destination order">
                  <option value="menu_order">Default Sorting</option>
                  <option value="popularity">Sort by popularity</option>
                  <option value="rating">Sort by average rating</option>
                  <option value="date">Sort by latest</option>
                  <option value="price">Sort by price: low to high</option>
                  <option value="price-desc">Sort by price: high to low</option>
                </select>
              </form>
            </div>
          </div>
        </div>
      </div>
      <div class="row">
        <div class="col-xxl-8 col-lg-7">
          <div class="tab-content" id="nav-tabContent">
            <!-- Grid View -->
            <div class="tab-pane fade show active" id="tab-grid" role="tabpanel">
              <div class="row gy-24 gx-24">
                {currentPosts.map((data) => (
                  <div class="col-md-6">
                    <div class="tour-box th-ani">
                      <div class="tour-box_img global-img">
                        <img src={`/assets/img/tour/${data.image}`} alt="" />
                      </div>
                      <div class="tour-content">
                        <h3 class="box-title">
                          <a href="/tour/details">{data.title}</a>
                        </h3>
                        <div class="tour-rating">
                          <div class="star-rating" role="img" aria-label="Rated 5.00 out of 5">
                            <span style="width: 100%;">
                              Rated <strong class="rating">5.00</strong> out of 5
                              based on <span class="rating">4.8</span>(4.8 Rating)
                            </span>
                          </div>
                          <a href="/tour/details" class="woocommerce-review-link">
                            (<span class="count">4.8</span> Rating)
                          </a>
                        </div>
                        <h4 class="tour-box_price">
                          <span class="currency">{data.price}</span>/Person
                        </h4>
                        <div class="tour-action">
                          <span><i class="fa-light fa-clock"></i>7 Days</span>
                          <a href="/tour/details" class="th-btn style4">Detail View</a>
                        </div>
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
            <!-- List View -->
            <div class="tab-pane fade" id="tab-list" role="tabpanel">
              <div class="row gy-30">
                {currentPosts.map((data) => (
                  <div class="col-12">
                    <div class="tour-box style-flex th-ani">
                      <div class="tour-box_img global-img">
                        <img src={`/assets/img/tour/${data.image}`} alt="" />
                      </div>
                      <div class="tour-content">
                        <h3 class="box-title">
                          <a href="/tour/details">{data.title}</a>
                        </h3>
                        <div class="tour-rating">
                          <div class="star-rating" role="img" aria-label="Rated 5.00 out of 5">
                            <span style="width: 100%;">
                              Rated <strong class="rating">5.00</strong> out of 5
                              based on <span class="rating">4.8</span>(4.8 Rating)
                            </span>
                          </div>
                          <a href="/tour/details" class="woocommerce-review-link">
                            (<span class="count">4.8</span> Rating)
                          </a>
                        </div>
                        <h4 class="tour-box_price">
                          <span class="currency">{data.price}</span>/Person
                        </h4>
                        <div class="tour-action">
                          <span><i class="fa-light fa-clock"></i>7 Days</span>
                          <a href="/tour/details" class="th-btn style4">Detail View</a>
                        </div>
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
            <!-- Pagination -->
            <div class="th-pagination text-center mt-60">
              <ul>
                <li><a class="active" href="#">1</a></li>
                <li><a href="#">2</a></li>
                <li><a href="#">3</a></li>
                <li>
                  <a class="next-page" href="#">
                    Next <img src="/assets/img/icon/arrow-right4.svg" alt="" />
                  </a>
                </li>
              </ul>
            </div>
          </div>
        </div>
        <div class="col-xxl-4 col-lg-5">
          <aside class="sidebar-area">
            <div class="widget widget_categories">
              <h3 class="widget_title">Categories</h3>
              <ul>
                <li><a href="/blog"><img src="/assets/img/theme-img/map.svg" alt="" />City Tour</a><span>(8)</span></li>
                <li><a href="/blog"><img src="/assets/img/theme-img/map.svg" alt="" />Beach Tours</a><span>(6)</span></li>
                <li><a href="/blog"><img src="/assets/img/theme-img/map.svg" alt="" />Wildlife Tours</a><span>(2)</span></li>
                <li><a href="/blog"><img src="/assets/img/theme-img/map.svg" alt="" />News &amp; Tips</a><span>(7)</span></li>
                <li><a href="/blog"><img src="/assets/img/theme-img/map.svg" alt="" />Adventure Tours</a><span>(9)</span></li>
                <li><a href="/blog"><img src="/assets/img/theme-img/map.svg" alt="" />Mountain Tours</a><span>(10)</span></li>
              </ul>
            </div>
            <div class="widget">
              <h3 class="widget_title">Recent Posts</h3>
              <div class="recent-post-wrap">
                <div class="recent-post">
                  <div class="media-img">
                    <a href="/blog/1"><img src="/assets/img/blog/recent-post-1-1.jpg" alt="Blog" /></a>
                  </div>
                  <div class="media-body">
                    <h4 class="post-title">
                      <a class="text-inherit" href="/blog/1">Exploring The Green Spaces Of the island maldives</a>
                    </h4>
                    <div class="recent-post-meta">
                      <a href="/blog"><i class="fa-regular fa-calendar"></i>22/6/ 2025</a>
                    </div>
                  </div>
                </div>
                <div class="recent-post">
                  <div class="media-img">
                    <a href="/blog/1"><img src="/assets/img/blog/recent-post-1-2.jpg" alt="Blog" /></a>
                  </div>
                  <div class="media-body">
                    <h4 class="post-title">
                      <a class="text-inherit" href="/blog/1">Harmony With Nature Of Belgium Tour and travle</a>
                    </h4>
                    <div class="recent-post-meta">
                      <a href="/blog"><i class="fa-regular fa-calendar"></i>25/6/ 2025</a>
                    </div>
                  </div>
                </div>
                <div class="recent-post">
                  <div class="media-img">
                    <a href="/blog/1"><img src="/assets/img/blog/recent-post-1-3.jpg" alt="Blog" /></a>
                  </div>
                  <div class="media-body">
                    <h4 class="post-title">
                      <a class="text-inherit" href="/blog/1">Exploring The Green Spaces Of Realar Residence</a>
                    </h4>
                    <div class="recent-post-meta">
                      <a href="/blog"><i class="fa-regular fa-calendar"></i>27/6/ 2025</a>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            <div class="widget widget_tag_cloud">
              <h3 class="widget_title">Popular Tags</h3>
              <div class="tagcloud">
                <a href="/blog">Tour</a>
                <a href="/blog">Adventure</a>
                <a href="/blog">Rent</a>
                <a href="/blog">Innovate</a>
                <a href="/blog">Hotel</a>
                <a href="/blog">Modern</a>
                <a href="/blog">Luxury</a>
                <a href="/blog">Travel</a>
              </div>
            </div>
            <div class="widget widget_offer" style="background-image: url(/assets/img/bg/widget_bg_1.jpg);">
              <div class="offer-banner">
                <div class="offer">
                  <h6 class="box-title">Need Help? We Are Here To Help You</h6>
                  <div class="banner-logo">
                    <img src="/assets/img/logo2.svg" alt="Rhodes Boat Tours" />
                  </div>
                  <div class="offer">
                    <h6 class="offer-title">You Get Online support</h6>
                    <a class="offter-num" href="tel:+302241012345">+30 22410 12345</a>
                  </div>
                  <a href="/contact" class="th-btn style2 th-icon">Read More</a>
                </div>
              </div>
            </div>
          </aside>
        </div>
      </div>
    </div>
  </section>

  <FooterFour />
</BaseLayout>
