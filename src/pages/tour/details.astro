<script>
  // Initialize tour detail sliders
  import Swiper from 'swiper';
  import { Navigation, Thumbs, EffectFade } from 'swiper/modules';

  function initTourSliders() {
    const thumbSlider = new Swiper('#tourThumbSlider', {
      modules: [Navigation, Thumbs],
      loop: true,
      spaceBetween: 25,
      slidesPerView: 3,
      watchSlidesProgress: true,
    });

    new Swiper('#tourSlider4', {
      modules: [Navigation, Thumbs, EffectFade],
      effect: 'fade',
      loop: true,
      spaceBetween: 10,
      navigation: {
        prevEl: '.slider-prev',
        nextEl: '.slider-next',
      },
      thumbs: {
        swiper: thumbSlider,
      },
    });
  }

  document.addEventListener('DOMContentLoaded', initTourSliders);
  document.addEventListener('astro:page-load', initTourSliders);
</script>
