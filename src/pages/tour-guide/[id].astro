---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../sections/home-one/Section1-Header.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import FooterFour from '../../sections/shared/FooterFour.astro';
import guides from '../../data/data-guide.json';

export function getStaticPaths() {
  return guides.map((g: any) => ({ params: { id: String(g.id) } }));
}

const { id } = Astro.params;
const guidePost = guides.find((g: any) => String(g.id) === id);

if (!guidePost) {
  return Astro.redirect('/tour-guide');
}

const counters = [
  { value: "2K+", title: "Total Guide" },
  { value: "65+", title: "Total Services" },
  { value: "79+", title: "Award Won" },
  { value: "120+", title: "Total Event" },
];

const teamSlides = [
  { thumb: "team_img_1.jpg", image: "team_1_1.jpg", name: "Michel Smith", link: "/tour-guide/1" },
  { thumb: "team_img_2.jpg", image: "team_1_2.jpg", name: "Janny Willson", link: "/tour-guide/2" },
  { thumb: "team_img_3.jpg", image: "team_1_3.jpg", name: "Jacob Jones", link: "/tour-guide/3" },
  { thumb: "team_img_1.jpg", image: "team_1_1.jpg", name: "Michel Smith", link: "/tour-guide/1" },
  { thumb: "team_img_2.jpg", image: "team_1_2.jpg", name: "Janny Willson", link: "/tour-guide/2" },
  { thumb: "team_img_3.jpg", image: "team_1_3.jpg", name: "Jacob Jones", link: "/tour-guide/3" },
];
---

<BaseLayout title={`${guidePost.title} - Tour Guide Details - Rhodes Boat Tours`}>
  <Header />
  <Breadcrumb title="Tour Guide Details" />

  <!-- TourGuiderDetailsMain -->
  <section class="space">
    <div class="container">
      <div class="team-details">
        <div class="row gy-5 mb-3 mb-xl-5 pb-xl-4">
          <div class="col-xl-4">
            <div class="th-team team-grid">
              <div class="team-img">
                <img src={`/assets/img/team/${guidePost.thumb}`} alt="Team" />
              </div>
              <div class="team-img2">
                <img src={`/assets/img/team/${guidePost.bannerImg}`} alt="Team" />
              </div>
              <div class="team-content">
                <div class="media-body">
                  <h3 class="box-title">
                    <a href="#">{guidePost.title}</a>
                  </h3>
                  <span class="team-desig">Tourist Guide</span>
                  <div class="th-social">
                    <a target="_blank" href="https://facebook.com/">
                      <i class="fab fa-facebook-f"></i>
                    </a>
                    <a target="_blank" href="https://twitter.com/">
                      <i class="fab fa-twitter"></i>
                    </a>
                    <a target="_blank" href="https://linkedin.com/">
                      <i class="fab fa-linkedin-in"></i>
                    </a>
                    <a target="_blank" href="https://youtube.com/">
                      <i class="fab fa-youtube"></i>
                    </a>
                    <a target="_blank" href="https://instagram.com/">
                      <i class="fab fa-instagram"></i>
                    </a>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div class="col-xl-8 ps-3 ps-xl-5 pe-xl-4">
            <div class="team-about">
              <h2 class="team-about_title">About Me</h2>
              <p class="team-about_text mb-25">
                Venenatis purus egestas lorem aenean enim bibendum. Ac pharetra
                egestas eget gravida turpis senectus. Sed blandit ipsum orci odio
                egestas egestas sed bibendum. Rhoncus est proin euismod
                condimentum eget a tristique integer viverra. Enim sed nunc magna
                consequat consectetur vestibulum odio posuere. Mattis nisl aenean
                auctor morbi suspendisse diam adipiscing. Tellus egestas amet
                tellus phasellus.
              </p>
              <p class="team-about_text mb-25">
                Ornare aliquam ac a pellentesque ante. Morbi maecenas odio integer
                adipiscing ridiculus mauris. Ornare in sit et tortor orci massa eu
                ultricies. Sit fermentum faucibu.
              </p>
              <h5 class="box-title">5 Years of Experiences</h5>
              <p class="team-about_text mb-25">
                Venenatis purus egestas lorem aenean enim bibendum. Ac pharetra
                egestas eget gravida turpis senectus. Sed blandit ipsum orci odio
                egestas egestas sed bibendum. Rhoncus est proin euismod
                condimentum eget a tristique integer viverra.
              </p>
              <div class="counter-box-wrap">
                {counters.map((counter) => (
                  <div class="counter-box">
                    <h2 class="counter-box_number">{counter.value}</h2>
                    <span class="counter-box_title">{counter.title}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
        <h2 class="box-title mb-30">Contact With Me</h2>
        <div class="row gy-4 justify-content-center">
          <div class="col-xl-4 col-lg-6">
            <div class="about-contact-grid style2">
              <div class="about-contact-icon">
                <img src="/assets/img/icon/location-dot2.svg" alt="" />
              </div>
              <div class="about-contact-details">
                <h6 class="box-title">Our Address</h6>
                <p class="about-contact-details-text">2690 Hiltona Street Victoria</p>
                <p class="about-contact-details-text">Road, New York, Canada</p>
              </div>
            </div>
          </div>
          <div class="col-xl-4 col-lg-6">
            <div class="about-contact-grid">
              <div class="about-contact-icon">
                <img src="/assets/img/icon/call.svg" alt="" />
              </div>
              <div class="about-contact-details">
                <h6 class="box-title">Phone Number</h6>
                <p class="about-contact-details-text">
                  <a href="tel:01234567890">+01 234 567 890</a>
                </p>
                <p class="about-contact-details-text">
                  <a href="tel:01234567890">+09 876 543 210</a>
                </p>
              </div>
            </div>
          </div>
          <div class="col-xl-4 col-lg-6">
            <div class="about-contact-grid">
              <div class="about-contact-icon">
                <img src="/assets/img/icon/mail.svg" alt="" />
              </div>
              <div class="about-contact-details">
                <h6 class="box-title">Email Address</h6>
                <p class="about-contact-details-text">
                  <a href="mailto:info@rodosyachts.gr">info@rodosyachts.gr</a>
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TourGuideTwo - Meet with Guide slider section -->
  <section
    class="team-area3 position-relative bg-top-center space"
    style="background-image: url(/assets/img/bg/team_bg_2.jpg); background-repeat: no-repeat; z-index: 1; padding-bottom: 0;"
  >
    <div class="container z-index-common">
      <div class="title-area text-center">
        <span class="sub-title">Meet with Guide</span>
        <h2 class="sec-title">Meet with Tour Guide</h2>
      </div>
      <div class="slider-area">
        <div class="swiper th-slider teamSlider3 has-shadow" id="teamSlider3">
          <div class="swiper-wrapper">
            {teamSlides.map((slide) => (
              <div class="swiper-slide">
                <div class="th-team team-grid">
                  <div class="team-img">
                    <img src={`/assets/img/team/${slide.thumb}`} alt="Team" />
                  </div>
                  <div class="team-img2">
                    <img src={`/assets/img/team/${slide.image}`} alt="Team" />
                  </div>
                  <div class="team-content">
                    <div class="media-body">
                      <h3 class="box-title">
                        <a href={slide.link}>{slide.name}</a>
                      </h3>
                      <span class="team-desig">Tourist Guide</span>
                      <div class="th-social">
                        <a target="_blank" href="https://facebook.com/">
                          <i class="fab fa-facebook-f"></i>
                        </a>
                        <a target="_blank" href="https://twitter.com/">
                          <i class="fab fa-twitter"></i>
                        </a>
                        <a target="_blank" href="https://linkedin.com/">
                          <i class="fab fa-linkedin-in"></i>
                        </a>
                        <a target="_blank" href="https://youtube.com/">
                          <i class="fab fa-youtube"></i>
                        </a>
                        <a target="_blank" href="https://instagram.com/">
                          <i class="fab fa-instagram"></i>
                        </a>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Slider Navigation -->
        <button class="slider-arrow slider-prev">
          <img src="/assets/img/icon/right-arrow2.svg" alt="" />
        </button>
        <button class="slider-arrow slider-next">
          <img src="/assets/img/icon/left-arrow2.svg" alt="" />
        </button>
      </div>
    </div>
  </section>

  <FooterFour />
</BaseLayout>

<script>
  // Initialize team slider
  import Swiper from 'swiper';
  import { Navigation, Pagination } from 'swiper/modules';

  function initTeamSlider() {
    new Swiper('#teamSlider3', {
      modules: [Navigation, Pagination],
      slidesPerView: 3,
      spaceBetween: 24,
      loop: true,
      breakpoints: {
        0: { slidesPerView: 1 },
        576: { slidesPerView: 1 },
        768: { slidesPerView: 2 },
        992: { slidesPerView: 3 },
        1200: { slidesPerView: 3 },
      },
      navigation: {
        prevEl: '.slider-prev',
        nextEl: '.slider-next',
      },
      pagination: { clickable: true },
    });
  }

  document.addEventListener('DOMContentLoaded', initTeamSlider);
  document.addEventListener('astro:page-load', initTeamSlider);
</script>
