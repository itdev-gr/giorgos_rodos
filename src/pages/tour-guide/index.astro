---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../sections/home-one/Section1-Header.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import FooterFour from '../../sections/shared/FooterFour.astro';
import ScrollToTop from '../../components/interactive/ScrollToTop';
import guides from '../../data/data-guide.json';

const currentPosts = guides.slice(0, 6);
---

<BaseLayout title="Tour Guide - Rodos Yachts">
  <Header />
  <Breadcrumb title="Tour Guide" />

  <section class="space" id="team-sec">
    <div class="container">
      <div class="row gy-4 gx-30">
        {currentPosts.map((data) => (
          <div class="col-xl-4 col-md-6">
            <div class="th-team team-grid">
              <div class="team-img">
                <img src={`/assets/img/team/${data.thumb}`} alt="Team" />
              </div>
              <div class="team-img2">
                <img src={`/assets/img/team/${data.image}`} alt="Team" />
              </div>
              <div class="team-content">
                <div class="media-body">
                  <h3 class="box-title">
                    <a href={`/tour-guide/${data.id}`}>{data.title}</a>
                  </h3>
                  <span class="team-desig">Tourist Guide</span>
                  <div class="th-social">
                    <a target="_blank" href="https://facebook.com/">
                      <i class="fab fa-facebook-f"></i>
                    </a>
                    <a target="_blank" href="https://twitter.com/">
                      <i class="fab fa-twitter"></i>
                    </a>
                    <a target="_blank" href="https://linkedin.com/">
                      <i class="fab fa-linkedin-in"></i>
                    </a>
                    <a target="_blank" href="https://youtube.com/">
                      <i class="fab fa-youtube"></i>
                    </a>
                    <a target="_blank" href="https://instagram.com/">
                      <i class="fab fa-instagram"></i>
                    </a>
                  </div>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <FooterFour />
  <ScrollToTop client:load />
</BaseLayout>
