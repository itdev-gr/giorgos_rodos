---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../sections/home-one/Section1-Header.astro';
import FooterFour from '../../sections/shared/FooterFour.astro';
import ServiceHeroFullwidth from '../../sections/service/ServiceHeroFullwidth.astro';
import ServiceSchema from '../../components/seo/ServiceSchema.astro';
import BreadcrumbSchema from '../../components/seo/BreadcrumbSchema.astro';
import FAQSection from '../../components/FAQSection.astro';
import { getMediaSlot, imgUrl, imgSrcset } from '../../lib/media';
import { tourCardAlt } from '../../lib/tour-alt';
import { charterCardDescription } from '../../lib/charter-description';
import { createPublicClient } from '../../lib/supabase';
import { charterFaq } from '../../lib/faq';

const heroVideo = await getMediaSlot('service.charter.hero.video', '/assets/img/hero/services/charter.mp4');
const heroImage = await getMediaSlot('service.charter.hero.image', '/assets/img/fleet/oceanis-511-lupo-di-mare.jpg');

// Fetch approved tours from Supabase
let dbCards: any[] = [];
try {
  const supabase = createPublicClient();
  if (supabase) {
    const { data } = await supabase
      .from('tours')
      .select('*')
      .or('service_page.eq.rhodes-charter,service_page.eq.rodos-charter')
      .eq('status', 'approved')
      .order('created_at', { ascending: false });
    dbCards = (data || []).map((t: any) => ({
      title: t.title,
      description: charterCardDescription(t),
      image: t.image_url || t.images?.[0] || '/assets/img/gallery/yacht/crystal-water-1.jpg',
      duration: t.duration || '',
      guests: t.guests || '',
      type: t.badge_label || '',
      price: t.price || '',
      href: `/tour-detail/${t.slug || t.id}`,
      imageAlt: tourCardAlt(t.title, t.badge_label),
    }));
  }
} catch (e) {
  console.error("Supabase error:", e); // Supabase unavailable — show demo data only
}

const charters = dbCards;
---

<BaseLayout title="Rhodes Yacht Charter — Bareboat & Skippered Sailing | Rhodes Rent a Boat" description="Bareboat & skippered yacht charters in Rhodes. Weekly sailing from Mandraki Harbour through the Dodecanese islands." ogImage={heroImage}>
  <ServiceSchema
    name="Rhodes Yacht Charter"
    description="Yacht charter in Rhodes — bareboat and skippered sailing yachts, catamarans and island-hopping holidays in the Dodecanese. Weekly charters from Rhodes."
    serviceType="Yacht Charter"
    image={heroImage}
    url="/service/rhodes-charter"
    areaServed="Dodecanese, Greece"
    lowPrice="1500"
    highPrice="15000"
    offerCount="80"
  />
  <BreadcrumbSchema items={[
    { name: 'Home', url: '/' },
    { name: 'Services', url: '/service' },
    { name: 'Rhodes Yacht Charter', url: '/service/rhodes-charter' },
  ]} />
  <Header />

  <!-- 1. Hero -->
  <ServiceHeroFullwidth
    title="Rhodes Yacht Charter"
    subtitle="Sailing Holidays in the Dodecanese"
    backgroundImage={heroImage}
    heroVideo={heroVideo}
  />

  <!-- 2. Intro -->
  <section style="padding: 60px 0 40px;">
    <div class="container">
      <div style="max-width: 700px; margin: 0 auto; text-align: center; margin-bottom: 40px;">
        <p style="font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 1.2rem; line-height: 1.7; color: #1CA8CB; margin-bottom: 0;" data-ani="fadein">
          Yacht charter is a completely different type of sea experience — multi-day sailing, island hopping and the freedom of the open sea.
        </p>
      </div>
      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px;" class="yc-intro-grid" data-ani="slideinup" data-ani-delay="0.1">
        <div style="text-align: center; padding: 32px 24px;">
          <div style="width: 56px; height: 56px; border-radius: 14px; background: rgba(28,168,203,0.1); color: #1CA8CB; display: inline-flex; align-items: center; justify-content: center; font-size: 1.3rem; margin-bottom: 18px;">
            <i class="fas fa-compass"></i>
          </div>
          <h2 style="font-family: 'Playfair Display', serif; font-size: 1rem; font-weight: 700; color: #113D48; margin-bottom: 10px;">Bareboat Charter</h2>
          <p style="font-size: 0.9rem; line-height: 1.65; color: #6b7c85; margin: 0;">Rent a sailing yacht without skipper. For experienced sailors with a valid license who want to plan their own route.</p>
        </div>
        <div style="text-align: center; padding: 32px 24px;">
          <div style="width: 56px; height: 56px; border-radius: 14px; background: rgba(28,168,203,0.1); color: #1CA8CB; display: inline-flex; align-items: center; justify-content: center; font-size: 1.3rem; margin-bottom: 18px;">
            <i class="fas fa-user-shield"></i>
          </div>
          <h2 style="font-family: 'Playfair Display', serif; font-size: 1rem; font-weight: 700; color: #113D48; margin-bottom: 10px;">Skippered Charter</h2>
          <p style="font-size: 0.9rem; line-height: 1.65; color: #6b7c85; margin: 0;">A sailing yacht with professional skipper on board. No sailing experience needed — the skipper handles everything.</p>
        </div>
        <div style="text-align: center; padding: 32px 24px;">
          <div style="width: 56px; height: 56px; border-radius: 14px; background: rgba(28,168,203,0.1); color: #1CA8CB; display: inline-flex; align-items: center; justify-content: center; font-size: 1.3rem; margin-bottom: 18px;">
            <i class="fas fa-map-marked-alt"></i>
          </div>
          <h2 style="font-family: 'Playfair Display', serif; font-size: 1rem; font-weight: 700; color: #113D48; margin-bottom: 10px;">Local Guidance</h2>
          <p style="font-size: 0.9rem; line-height: 1.65; color: #6b7c85; margin: 0;">We connect you with the right charter company and yacht class for your crew, dates and route — bareboat or skippered.</p>
        </div>
      </div>
      <div style="text-align: center; margin-top: 28px;" data-ani="fadein" data-ani-delay="0.2">
        <p style="font-family: 'Playfair Display', serif; font-weight: 600; font-size: 0.95rem; color: #113D48; margin: 0;">
          We don't charter yachts. We help you find the right sailing experience in Greece. For shorter trips, see our <a href="/service/rhodes-sailing-trips">sailing trips</a>.
        </p>
      </div>
    </div>
  </section>

  <!-- 3. Charter Grid -->
  <section style="padding: 80px 0; background: #f8fafb;">
    <div class="container">
      <div class="title-area text-center" style="margin-bottom: 50px;">
        <h2 class="sec-title" data-ani="slideinup">How Does Yacht Charter Work in Rhodes?</h2>
      </div>
      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px;" class="yc-charter-grid">
        {charters.map((charter, i) => (
          <a href={charter.href || '/contact'} class="yc-card" data-ani="slideinup" data-ani-delay={`${0.1 + i * 0.06}`} style="display: flex; flex-direction: column; text-decoration: none; color: inherit; background: #fff; border-radius: 14px; overflow: hidden; box-shadow: 0 4px 24px rgba(0,0,0,0.06); transition: transform 0.3s ease, box-shadow 0.3s ease;">
            <div style="height: 220px; overflow: hidden; position: relative;">
              <img src={imgUrl(charter.image, 600, { quality: 75 })} srcset={imgSrcset(charter.image, [400, 600, 800])} sizes="(max-width: 575px) 100vw, (max-width: 991px) 50vw, 33vw" width="600" height="450" alt={charter.imageAlt} loading="lazy" style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease;" />
              <span style="position: absolute; top: 14px; right: 14px; background: rgba(17,61,72,0.85); color: #fff; font-family: 'Inter', sans-serif; font-size: 0.75rem; font-weight: 600; padding: 5px 12px; border-radius: 6px; backdrop-filter: blur(4px);">{charter.type}</span>
            </div>
            <div style="padding: 24px; display: flex; flex-direction: column; flex: 1;">
              <h3 style="font-family: 'Playfair Display', serif; font-size: 1.1rem; font-weight: 700; color: #113D48; margin-bottom: 8px;">{charter.title}</h3>
              <p style="font-size: 0.88rem; line-height: 1.6; color: #6b7c85; margin-bottom: 14px;">{charter.description}</p>
              <div style="display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 16px;">
                <span style="display: inline-flex; align-items: center; gap: 4px; font-size: 0.75rem; color: #5a6a72; background: #f0f4f5; padding: 4px 10px; border-radius: 20px;"><i class="far fa-clock" style="font-size: 0.7rem; color: #1CA8CB;"></i> {charter.duration}</span>
                <span style="display: inline-flex; align-items: center; gap: 4px; font-size: 0.75rem; color: #5a6a72; background: #f0f4f5; padding: 4px 10px; border-radius: 20px;"><i class="far fa-user" style="font-size: 0.7rem; color: #1CA8CB;"></i> {charter.guests}</span>
              </div>
              <div style="display: flex; justify-content: space-between; align-items: center; margin-top: auto; padding-top: 14px; border-top: 1px solid #f0f0f0;">
                <span style="font-family: 'Playfair Display', serif; font-size: 1.05rem; font-weight: 700; color: #1CA8CB;">{charter.price}</span>
                <span style="font-size: 0.78rem; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; color: #113D48;">Enquire <i class="fa-regular fa-arrow-right" style="margin-left: 4px;"></i></span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <FAQSection
    items={charterFaq}
    title="Rhodes Yacht Charter — FAQ"
    intro="Common questions from charterers heading to the Dodecanese. For booking and weather see the <a href='/faq'>full FAQ</a>."
  />

  <!-- 4. Contact -->
  <section style="padding: 80px 0; background: #113D48;">
    <div class="container">
      <div style="max-width: 700px; margin: 0 auto; text-align: center;">
        <h2 style="font-family: 'Playfair Display', serif; font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 700; color: #fff; margin-bottom: 20px;" data-ani="slideinup">Planning a Sailing Holiday in Rhodes?</h2>
        <p style="font-size: 1rem; line-height: 1.75; color: rgba(255,255,255,0.7); margin-bottom: 36px;" data-ani="fadein" data-ani-delay="0.1">
          If you are planning a sailing holiday and you are not sure which type of yacht charter you need, contact us and we will connect you with the right charter company and help you plan your sailing route in the Dodecanese.
        </p>
        <div style="display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;" data-ani="slideinup" data-ani-delay="0.2">
          <a href="/contact" class="th-btn style3 th-icon">Send Us a Message</a>
          <a href="https://wa.me/306951666454" style="display: inline-flex; align-items: center; gap: 8px; padding: 14px 28px; font-family: 'Inter', sans-serif; font-size: 0.85rem; font-weight: 600; color: #fff; border: 1.5px solid rgba(255,255,255,0.3); border-radius: 8px; text-decoration: none; transition: all 0.3s ease;"><i class="fab fa-whatsapp"></i> WhatsApp</a>
          <a href="tel:+306951666454" style="display: inline-flex; align-items: center; gap: 8px; padding: 14px 28px; font-family: 'Inter', sans-serif; font-size: 0.85rem; font-weight: 600; color: #fff; border: 1.5px solid rgba(255,255,255,0.3); border-radius: 8px; text-decoration: none; transition: all 0.3s ease;"><i class="fas fa-phone"></i> +30 695 166 6454</a>
        </div>
      </div>
    </div>
  </section>

  <FooterFour />
</BaseLayout>

<script>
</script>

<style>
  .yc-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(0,0,0,0.1) !important;
  }

  .yc-card:hover img {
    transform: scale(1.05);
  }

  @media (max-width: 991px) {
    .yc-intro-grid {
      grid-template-columns: 1fr !important;
      gap: 0 !important;
    }
    .yc-charter-grid {
      grid-template-columns: repeat(2, 1fr) !important;
    }
  }

  @media (max-width: 575px) {
    .yc-charter-grid {
      grid-template-columns: 1fr !important;
    }
  }
</style>
