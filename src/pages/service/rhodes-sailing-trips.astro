---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../sections/home-one/Section1-Header.astro';
import FooterFour from '../../sections/shared/FooterFour.astro';
import ServiceHeroFullwidth from '../../sections/service/ServiceHeroFullwidth.astro';

const trips = [
  {
    title: 'Shared Sailing Day Trip',
    description: 'Join a small group on a sailing yacht for a day along the coast — swimming stops, lunch and a relaxed atmosphere.',
    image: '/assets/img/destinations/private-sailing.jpg',
    duration: '6 Hours',
    guests: '8–12 Guests',
    type: 'Shared',
    price: '€75/person',
  },
  {
    title: 'Private Sailing – Half Day',
    description: 'Your own sailing yacht for half a day. Choose your pace, your stops and enjoy the wind and the sea.',
    image: '/assets/img/gallery/yacht/yacht-sailing-1.jpg',
    duration: '4 Hours',
    guests: 'Up to 10 Guests',
    type: 'Private',
    price: 'From €400',
  },
  {
    title: 'Private Sailing – Full Day',
    description: 'A full day under sail. Visit hidden bays, swim in crystal-clear water and enjoy lunch on deck.',
    image: '/assets/img/gallery/yacht/sailing-sunset-1.jpg',
    duration: '7 Hours',
    guests: 'Up to 10 Guests',
    type: 'Private',
    price: 'From €650',
  },
  {
    title: 'Sunset Sailing Trip',
    description: 'An evening sail along the coast as the sun goes down. Drinks on deck, wind in the sails and golden light.',
    image: '/assets/img/cruises/greco_sunset3.jpg',
    duration: '3 Hours',
    guests: '8–12 Guests',
    type: 'Sunset',
    price: '€60/person',
  },
  {
    title: 'Private Sunset Sailing',
    description: 'Your own sailing boat for a sunset experience. Perfect for couples, celebrations and special evenings.',
    image: '/assets/img/destinations/symi-island.jpg',
    duration: '3 Hours',
    guests: 'Up to 8 Guests',
    type: 'Private',
    price: 'From €350',
  },
  {
    title: 'Sailing to Symi',
    description: 'A full day sailing trip to the colourful island of Symi. Explore the harbour, swim and sail back at sunset.',
    image: '/assets/img/destinations/symi-island.jpg',
    duration: 'Full Day',
    guests: 'Up to 10 Guests',
    type: 'Private',
    price: 'From €800',
  },
  {
    title: 'Romantic Sailing for Two',
    description: 'A sailing experience for couples — quiet bays, champagne on board and the sound of the wind on the sails.',
    image: '/assets/img/destinations/lindos-bay.jpg',
    duration: '4 Hours',
    guests: '2 Guests',
    type: 'Couples',
    price: '€300/couple',
  },
  {
    title: 'Sailing & Snorkeling',
    description: 'A sailing trip focused on swimming and snorkeling at the best spots along the east coast of Rhodes.',
    image: '/assets/img/destinations/anthony-quinn-bay.jpg',
    duration: '5 Hours',
    guests: '8–12 Guests',
    type: 'Shared',
    price: '€70/person',
  },
  {
    title: 'Multi-Day Sailing Trip',
    description: 'Two or three days of island hopping under sail — Rhodes, Symi, Halki and the Dodecanese at a slow pace.',
    image: '/assets/img/gallery/yacht/greek-island-1.jpg',
    duration: '2–3 Days',
    guests: 'Up to 8 Guests',
    type: 'Multi-Day',
    price: 'From €1,200',
  },
];
---

<BaseLayout title="Rhodes Sailing Boat Trips — Sailing Experiences in Rhodes | Rhodes Boat Tours" description="Sailing boat trips in Rhodes. Shared and private sailing experiences along the east coast. The wind, the sea and the most authentic way to explore Rhodes.">
  <Header />

  <!-- 1. Hero -->
  <ServiceHeroFullwidth
    title="Rhodes Sailing Boat Trips"
    subtitle="Experience the Sea Under Sail"
    backgroundImage="/assets/img/gallery/yacht/sailing-sunset-1.jpg"
    heroVideo="/assets/img/hero/services/charter.mp4"
  />

  <!-- 2. Intro -->
  <section style="padding: 60px 0 40px;">
    <div class="container">
      <div style="max-width: 700px; margin: 0 auto; text-align: center; margin-bottom: 40px;">
        <p style="font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 1.2rem; line-height: 1.7; color: #1CA8CB; margin-bottom: 0;" data-ani="fadein">
          Sailing is not about speed, it's about the journey. The wind decides the route.
        </p>
      </div>
      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px;" class="sl-intro-grid" data-ani="slideinup" data-ani-delay="0.1">
        <div style="text-align: center; padding: 32px 24px;">
          <div style="width: 56px; height: 56px; border-radius: 14px; background: rgba(28,168,203,0.1); color: #1CA8CB; display: inline-flex; align-items: center; justify-content: center; font-size: 1.3rem; margin-bottom: 18px;">
            <i class="fas fa-wind"></i>
          </div>
          <h3 style="font-family: 'Manrope', sans-serif; font-size: 1rem; font-weight: 700; color: #113D48; margin-bottom: 10px;">The Sailing Experience</h3>
          <p style="font-size: 0.9rem; line-height: 1.65; color: #6b7c85; margin: 0;">Sailing is slower, quieter and more connected to the sea. The wind on the sails, the boat moving through the water — a real sea experience.</p>
        </div>
        <div style="text-align: center; padding: 32px 24px;">
          <div style="width: 56px; height: 56px; border-radius: 14px; background: rgba(28,168,203,0.1); color: #1CA8CB; display: inline-flex; align-items: center; justify-content: center; font-size: 1.3rem; margin-bottom: 18px;">
            <i class="fas fa-users"></i>
          </div>
          <h3 style="font-family: 'Manrope', sans-serif; font-size: 1rem; font-weight: 700; color: #113D48; margin-bottom: 10px;">Shared & Private</h3>
          <p style="font-size: 0.9rem; line-height: 1.65; color: #6b7c85; margin: 0;">Join a small group sailing trip or rent a sailing yacht for your group. Day trips, sunset sails and multi-day adventures.</p>
        </div>
        <div style="text-align: center; padding: 32px 24px;">
          <div style="width: 56px; height: 56px; border-radius: 14px; background: rgba(28,168,203,0.1); color: #1CA8CB; display: inline-flex; align-items: center; justify-content: center; font-size: 1.3rem; margin-bottom: 18px;">
            <i class="fas fa-map-marked-alt"></i>
          </div>
          <h3 style="font-family: 'Manrope', sans-serif; font-size: 1rem; font-weight: 700; color: #113D48; margin-bottom: 10px;">Local Guidance</h3>
          <p style="font-size: 0.9rem; line-height: 1.65; color: #6b7c85; margin: 0;">We help you choose between shared trips, private sailing and multi-day routes. Real advice from people who know the waters.</p>
        </div>
      </div>
      <div style="text-align: center; margin-top: 28px;" data-ani="fadein" data-ani-delay="0.2">
        <p style="font-family: 'Manrope', sans-serif; font-weight: 600; font-size: 0.95rem; color: #113D48; margin: 0;">
          Sailing is not just a boat trip. It is a way to experience the sea.
        </p>
      </div>
    </div>
  </section>

  <!-- 3. Tours Grid -->
  <section style="padding: 80px 0; background: #f8fafb;">
    <div class="container">
      <div class="title-area text-center" style="margin-bottom: 50px;">
        <h2 class="sec-title" data-ani="slideinup">Explore Our Sailing Boat Trips in Rhodes</h2>
      </div>
      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px;" class="sl-trips-grid">
        {trips.map((trip, i) => (
          <a href="/contact" class="sl-card" data-ani="slideinup" data-ani-delay={`${0.1 + i * 0.06}`} style="display: flex; flex-direction: column; text-decoration: none; color: inherit; background: #fff; border-radius: 14px; overflow: hidden; box-shadow: 0 4px 24px rgba(0,0,0,0.06); transition: transform 0.3s ease, box-shadow 0.3s ease;">
            <div style="height: 220px; overflow: hidden; position: relative;">
              <img src={trip.image} alt={trip.title} loading="lazy" style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease;" />
              <span style="position: absolute; top: 14px; right: 14px; background: rgba(17,61,72,0.85); color: #fff; font-family: 'Inter', sans-serif; font-size: 0.75rem; font-weight: 600; padding: 5px 12px; border-radius: 6px; backdrop-filter: blur(4px);">{trip.type}</span>
            </div>
            <div style="padding: 24px; display: flex; flex-direction: column; flex: 1;">
              <h3 style="font-family: 'Manrope', sans-serif; font-size: 1.1rem; font-weight: 700; color: #113D48; margin-bottom: 8px;">{trip.title}</h3>
              <p style="font-size: 0.88rem; line-height: 1.6; color: #6b7c85; margin-bottom: 14px;">{trip.description}</p>
              <div style="display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 16px;">
                <span style="display: inline-flex; align-items: center; gap: 4px; font-size: 0.75rem; color: #5a6a72; background: #f0f4f5; padding: 4px 10px; border-radius: 20px;"><i class="far fa-clock" style="font-size: 0.7rem; color: #1CA8CB;"></i> {trip.duration}</span>
                <span style="display: inline-flex; align-items: center; gap: 4px; font-size: 0.75rem; color: #5a6a72; background: #f0f4f5; padding: 4px 10px; border-radius: 20px;"><i class="far fa-user" style="font-size: 0.7rem; color: #1CA8CB;"></i> {trip.guests}</span>
              </div>
              <div style="display: flex; justify-content: space-between; align-items: center; margin-top: auto; padding-top: 14px; border-top: 1px solid #f0f0f0;">
                <span style="font-family: 'Manrope', sans-serif; font-size: 1.05rem; font-weight: 700; color: #1CA8CB;">{trip.price}</span>
                <span style="font-size: 0.78rem; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; color: #113D48;">Enquire <i class="fa-regular fa-arrow-right" style="margin-left: 4px;"></i></span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- 4. Contact -->
  <section style="padding: 80px 0; background: #113D48;">
    <div class="container">
      <div style="max-width: 700px; margin: 0 auto; text-align: center;">
        <h2 style="font-family: 'Manrope', sans-serif; font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 700; color: #fff; margin-bottom: 20px;" data-ani="slideinup">Need Help Choosing the Right Sailing Trip?</h2>
        <p style="font-size: 1rem; line-height: 1.75; color: rgba(255,255,255,0.7); margin-bottom: 36px;" data-ani="fadein" data-ani-delay="0.1">
          If you are not sure whether a sailing boat trip, a catamaran tour or a boat trip is the best option for you, contact us and we will help you choose the experience that suits you best.
        </p>
        <div style="display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;" data-ani="slideinup" data-ani-delay="0.2">
          <a href="/contact" class="th-btn style3 th-icon">Send Us a Message</a>
          <a href="https://wa.me/302241012345" style="display: inline-flex; align-items: center; gap: 8px; padding: 14px 28px; font-family: 'Inter', sans-serif; font-size: 0.85rem; font-weight: 600; color: #fff; border: 1.5px solid rgba(255,255,255,0.3); border-radius: 8px; text-decoration: none; transition: all 0.3s ease;"><i class="fab fa-whatsapp"></i> WhatsApp</a>
          <a href="tel:+302241012345" style="display: inline-flex; align-items: center; gap: 8px; padding: 14px 28px; font-family: 'Inter', sans-serif; font-size: 0.85rem; font-weight: 600; color: #fff; border: 1.5px solid rgba(255,255,255,0.3); border-radius: 8px; text-decoration: none; transition: all 0.3s ease;"><i class="fas fa-phone"></i> +30 22410 12345</a>
        </div>
      </div>
    </div>
  </section>

  <FooterFour />
</BaseLayout>

<script>
  document.getElementById('header-one')?.classList.add('header-transparent');
</script>

<style>
  .sl-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(0,0,0,0.1) !important;
  }

  .sl-card:hover img {
    transform: scale(1.05);
  }

  @media (max-width: 991px) {
    .sl-intro-grid {
      grid-template-columns: 1fr !important;
      gap: 0 !important;
    }
    .sl-trips-grid {
      grid-template-columns: repeat(2, 1fr) !important;
    }
  }

  @media (max-width: 575px) {
    .sl-trips-grid {
      grid-template-columns: 1fr !important;
    }
  }
</style>
