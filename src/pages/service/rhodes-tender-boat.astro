---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../sections/home-one/Section1-Header.astro';
import FooterFour from '../../sections/shared/FooterFour.astro';
import ServiceHeroFullwidth from '../../sections/service/ServiceHeroFullwidth.astro';
import ServiceSchema from '../../components/seo/ServiceSchema.astro';
import BreadcrumbSchema from '../../components/seo/BreadcrumbSchema.astro';
import { getMediaSlot } from '../../lib/media';

const heroVideo = await getMediaSlot('service.tender.hero.video', '/assets/img/hero/services/tender.mp4');
const heroImage = await getMediaSlot('service.tender.hero.image', 'https://images.unsplash.com/photo-1605281317010-fe5ffe798166?w=1920&h=1080&fit=crop');
---

<BaseLayout title="Tender Boat Service in Rhodes — Shore-to-Ship Transfers | Rhodes Rent a Boat" description="Tender boat and shore-to-ship transfer services in Rhodes. Professional crew, reliable scheduling for cruise ship passengers and superyacht guests." ogImage={heroImage}>
  <ServiceSchema
    name="Tender Boat Service in Rhodes"
    description="Professional shore-to-ship tender boat transfers across Rhodes harbours and bays — rapid response, licensed operators, available around the clock during sailing season."
    serviceType="Tender Boat Transfer"
    image={heroImage}
    url="/service/rhodes-tender-boat"
  />
  <BreadcrumbSchema items={[
    { name: 'Home', url: '/' },
    { name: 'Services', url: '/service' },
    { name: 'Tender Boat Service in Rhodes', url: '/service/rhodes-tender-boat' },
  ]} />
  <Header />

  <!-- 1. Hero -->
  <ServiceHeroFullwidth
    title="Tender Boat Service in Rhodes"
    subtitle="Professional Shore-to-Ship Transfers"
    backgroundImage={heroImage}
    heroVideo={heroVideo}
  />

  <!-- 2. Intro -->
  <section style="padding: 60px 0 40px;">
    <div class="container">
      <div style="max-width: 700px; margin: 0 auto; text-align: center; margin-bottom: 40px;">
        <p style="font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 1.2rem; line-height: 1.7; color: #1CA8CB; margin-bottom: 0;" data-ani="fadein">
          Professional shore-to-ship transfers across Rhodes' harbours and bays. Reliable, punctual, and available around the clock during sailing season.
        </p>
      </div>
      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px;" class="tb-intro-grid" data-ani="slideinup" data-ani-delay="0.1">
        <div style="text-align: center; padding: 32px 24px;">
          <div style="width: 56px; height: 56px; border-radius: 14px; background: rgba(28,168,203,0.1); color: #1CA8CB; display: inline-flex; align-items: center; justify-content: center; font-size: 1.3rem; margin-bottom: 18px;">
            <i class="fas fa-bolt"></i>
          </div>
          <h2 style="font-family: 'Playfair Display', serif; font-size: 1rem; font-weight: 700; color: #113D48; margin-bottom: 10px;">Rapid Response</h2>
          <p style="font-size: 0.9rem; line-height: 1.65; color: #6b7c85; margin: 0;">On-demand transfers with typical response times under 15 minutes in peak zones.</p>
        </div>
        <div style="text-align: center; padding: 32px 24px;">
          <div style="width: 56px; height: 56px; border-radius: 14px; background: rgba(28,168,203,0.1); color: #1CA8CB; display: inline-flex; align-items: center; justify-content: center; font-size: 1.3rem; margin-bottom: 18px;">
            <i class="fas fa-shield-alt"></i>
          </div>
          <h2 style="font-family: 'Playfair Display', serif; font-size: 1rem; font-weight: 700; color: #113D48; margin-bottom: 10px;">Safe & Comfortable</h2>
          <p style="font-size: 0.9rem; line-height: 1.65; color: #6b7c85; margin: 0;">Well-maintained tenders with professional operators trained for all conditions.</p>
        </div>
        <div style="text-align: center; padding: 32px 24px;">
          <div style="width: 56px; height: 56px; border-radius: 14px; background: rgba(28,168,203,0.1); color: #1CA8CB; display: inline-flex; align-items: center; justify-content: center; font-size: 1.3rem; margin-bottom: 18px;">
            <i class="fas fa-calendar-check"></i>
          </div>
          <h2 style="font-family: 'Playfair Display', serif; font-size: 1rem; font-weight: 700; color: #113D48; margin-bottom: 10px;">Scheduled or On-Demand</h2>
          <p style="font-size: 0.9rem; line-height: 1.65; color: #6b7c85; margin: 0;">Pre-arrange regular transfers or call us anytime for immediate dispatch.</p>
        </div>
      </div>
      <div style="text-align: center; margin-top: 28px;" data-ani="fadein" data-ani-delay="0.2">
        <p style="font-family: 'Playfair Display', serif; font-weight: 600; font-size: 0.95rem; color: #113D48; margin: 0;">
          We provide reliable marine support — not just a boat ride.
        </p>
      </div>
    </div>
  </section>

  <!-- 3. Coverage Zones -->
  <section style="padding: 80px 0; background: #f8fafb;">
    <div class="container">
      <div class="title-area text-center" style="margin-bottom: 50px;">
        <span class="sub-title style1" data-ani="slideinup">Service Zones</span>
        <h2 class="sec-title" data-ani="slideinup" data-ani-delay="0.1">Our Coverage Area</h2>
      </div>
      <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px;" class="tb-zones-grid">
        <div class="tb-zone-card" data-ani="slideinup" data-ani-delay="0.1">
          <div class="tb-zone-card__icon"><i class="fas fa-anchor"></i></div>
          <div>
            <h3 class="tb-zone-card__title">Mandraki Harbour</h3>
            <p class="tb-zone-card__desc">Central Rhodes Town — the main commercial harbour and superyacht berths.</p>
            <span class="tb-zone-card__badge"><i class="fas fa-clock"></i> 10 min response</span>
          </div>
        </div>
        <div class="tb-zone-card" data-ani="slideinup" data-ani-delay="0.15">
          <div class="tb-zone-card__icon"><i class="fas fa-water"></i></div>
          <div>
            <h3 class="tb-zone-card__title">Elli Beach & North Coast</h3>
            <p class="tb-zone-card__desc">Covering anchorages along the northern coastline to Ixia Bay.</p>
            <span class="tb-zone-card__badge"><i class="fas fa-clock"></i> 15 min response</span>
          </div>
        </div>
        <div class="tb-zone-card" data-ani="slideinup" data-ani-delay="0.2">
          <div class="tb-zone-card__icon"><i class="fas fa-mountain"></i></div>
          <div>
            <h3 class="tb-zone-card__title">Lindos Bay</h3>
            <p class="tb-zone-card__desc">Transfers to vessels anchored in the scenic Lindos anchorage zone.</p>
            <span class="tb-zone-card__badge"><i class="fas fa-clock"></i> 25 min response</span>
          </div>
        </div>
        <div class="tb-zone-card" data-ani="slideinup" data-ani-delay="0.25">
          <div class="tb-zone-card__icon"><i class="fas fa-compass"></i></div>
          <div>
            <h3 class="tb-zone-card__title">South Coast & Prasonisi</h3>
            <p class="tb-zone-card__desc">Extended coverage for vessels exploring the southern shores.</p>
            <span class="tb-zone-card__badge"><i class="fas fa-clock"></i> 35 min response</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. Contact CTA -->
  <section style="padding: 80px 0; background: #113D48;">
    <div class="container">
      <div style="max-width: 700px; margin: 0 auto; text-align: center;">
        <h2 style="font-family: 'Playfair Display', serif; font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 700; color: #fff; margin-bottom: 20px;" data-ani="slideinup">Need a Tender Transfer?</h2>
        <p style="font-size: 1rem; line-height: 1.75; color: rgba(255,255,255,0.7); margin-bottom: 36px;" data-ani="fadein" data-ani-delay="0.1">
          Whether it is a VIP guest arrival, a late-night crew change, or a supply run — we make it seamless. Contact us and we will arrange your transfer.
        </p>
        <div style="display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;" data-ani="slideinup" data-ani-delay="0.2">
          <a href="/contact" class="th-btn style3 th-icon">Send Us a Message</a>
          <a href="https://wa.me/306951666454" style="display: inline-flex; align-items: center; gap: 8px; padding: 14px 28px; font-family: 'Inter', sans-serif; font-size: 0.85rem; font-weight: 600; color: #fff; border: 1.5px solid rgba(255,255,255,0.3); border-radius: 8px; text-decoration: none; transition: all 0.3s ease;"><i class="fab fa-whatsapp"></i> WhatsApp</a>
          <a href="tel:+306951666454" style="display: inline-flex; align-items: center; gap: 8px; padding: 14px 28px; font-family: 'Inter', sans-serif; font-size: 0.85rem; font-weight: 600; color: #fff; border: 1.5px solid rgba(255,255,255,0.3); border-radius: 8px; text-decoration: none; transition: all 0.3s ease;"><i class="fas fa-phone"></i> +30 695 166 6454</a>
        </div>
      </div>
    </div>
  </section>

  <FooterFour />
</BaseLayout>

<script>
</script>

<style>
  .tb-zone-card {
    display: flex;
    gap: 18px;
    padding: 28px 24px;
    background: #fff;
    border-radius: 14px;
    box-shadow: 0 4px 24px rgba(0,0,0,0.05);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .tb-zone-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
  }
  .tb-zone-card__icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: rgba(28,168,203,0.1);
    color: #1CA8CB;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    flex-shrink: 0;
  }
  .tb-zone-card__title {
    font-family: 'Playfair Display', serif;
    font-size: 1rem;
    font-weight: 700;
    color: #113D48;
    margin: 0 0 6px;
  }
  .tb-zone-card__desc {
    font-size: 0.88rem;
    line-height: 1.6;
    color: #6b7c85;
    margin: 0 0 10px;
  }
  .tb-zone-card__badge {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 0.72rem;
    font-weight: 600;
    color: #1CA8CB;
    background: rgba(28,168,203,0.08);
    padding: 4px 10px;
    border-radius: 20px;
  }
  .tb-zone-card__badge i {
    font-size: 0.65rem;
  }

  @media (max-width: 991px) {
    .tb-intro-grid {
      grid-template-columns: 1fr !important;
      gap: 0 !important;
    }
    .tb-zones-grid {
      grid-template-columns: 1fr !important;
    }
  }
</style>
