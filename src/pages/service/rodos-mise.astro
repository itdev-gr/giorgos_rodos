---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../sections/home-one/Section1-Header.astro';
import FooterFour from '../../sections/shared/FooterFour.astro';
import ServiceHeroFullwidth from '../../sections/service/ServiceHeroFullwidth.astro';
import ServiceWhySection from '../../sections/service/ServiceWhySection.astro';
import ServiceMiseChecklist from '../../sections/service/ServiceMiseChecklist.astro';
import ServiceBucketList from '../../sections/service/ServiceBucketList.astro';
import ServiceGalleryCarousel from '../../sections/service/ServiceGalleryCarousel.astro';
import ServicePlanningCTA from '../../sections/service/ServicePlanningCTA.astro';
import ServiceHighlights from '../../sections/service/ServiceHighlights.astro';
import ServiceOverview from '../../sections/service/ServiceOverview.astro';
import ServiceRelatedServices from '../../sections/service/ServiceRelatedServices.astro';
---

<BaseLayout title="Professional Marine Support in Rhodes - Rhodos Yachts">
  <Header />

  <ServiceHeroFullwidth
    title="Professional Marine Support"
    subtitle="Provisioning, logistics, port coordination, and crew support for yachts and vessels of all sizes — handled by a local team with over fifteen years of experience in Rhodes."
    backgroundImage="https://images.unsplash.com/photo-1544551763-46a013bb70d5?w=1920&h=1080&fit=crop"
    heroVideo="/assets/img/hero/services/mise.mp4"
    cta1Text="Request Service"
    cta2Text="Learn More"
  />

  <ServiceWhySection
    layout="right"
    title="Why Our Mise Services"
    subtitle="Trusted by Professionals"
    description="Operating a vessel in unfamiliar waters means dealing with local suppliers, customs, port authorities, and tight schedules. Our team has spent over fifteen years building the relationships and expertise to handle it all — so captains and owners can focus on their guests and their voyage."
    image="https://images.unsplash.com/photo-1586985289688-ca3cf47d3e6e?w=800&h=600&fit=crop"
    features={[
      { icon: '/assets/img/icon/about_1_1.svg', title: 'Full Provisioning', text: 'Premium food, beverages, and onboard supplies sourced from trusted local partners.' },
      { icon: '/assets/img/icon/about_1_2.svg', title: 'Port Coordination', text: 'Marina bookings, berth assignments, customs, and all necessary documentation.' },
      { icon: '/assets/img/icon/about_1_3.svg', title: 'Crew Support', text: 'Professional crew placement, rotation logistics, and shore-side accommodation.' },
    ]}
  />

  <ServiceMiseChecklist
    title="Our Seamless Process"
    subtitle="How It Works"
  />

  <ServiceBucketList
    title="Complete Mise Services"
    subtitle="What We Cover"
    items={[
      { title: 'Provisioning & Catering', description: 'Fresh produce, gourmet ingredients, beverages, and specialty items delivered dockside.' },
      { title: 'Fuel & Water Supply', description: 'Coordinated fuel bunkering and freshwater delivery at any marina in Rhodes.' },
      { title: 'Waste Management', description: 'Responsible disposal of grey water, sewage, and recyclable waste.' },
      { title: 'Technical Coordination', description: 'Connecting you with certified marine technicians, electricians, and engineers.' },
      { title: 'Concierge Services', description: 'Restaurant reservations, car hire, tours, and VIP transfers for crew and guests.' },
      { title: 'Emergency Response', description: '24/7 on-call support for urgent requests and unforeseen situations.' },
    ]}
  />

  <ServiceGalleryCarousel
    title="Our Operations"
    images={[
      'https://images.unsplash.com/photo-1540946485063-a40da27545f8?w=600&h=400&fit=crop',
      'https://images.unsplash.com/photo-1605281317010-fe5ffe798166?w=600&h=400&fit=crop',
      'https://images.unsplash.com/photo-1559827260-dc66d52bef19?w=600&h=400&fit=crop',
      'https://images.unsplash.com/photo-1586985289688-ca3cf47d3e6e?w=600&h=400&fit=crop',
      'https://images.unsplash.com/photo-1544551763-46a013bb70d5?w=600&h=400&fit=crop',
      'https://images.unsplash.com/photo-1599640842225-85d111c60e6b?w=600&h=400&fit=crop',
      'https://images.unsplash.com/photo-1507525428034-b723cf961d3e?w=600&h=400&fit=crop',
      'https://images.unsplash.com/photo-1586861635167-e5223aadc9fe?w=600&h=400&fit=crop',
    ]}
  />

  <ServicePlanningCTA
    title="Ready to Simplify Your Voyage?"
    description="Whether you're a captain arriving for the first time or a regular visitor to Rhodes, our mise team takes the complexity out of port operations. One call, one team, everything handled."
    image1="https://images.unsplash.com/photo-1586985289688-ca3cf47d3e6e?w=800&h=600&fit=crop"
    image2="https://images.unsplash.com/photo-1544551763-46a013bb70d5?w=800&h=600&fit=crop"
    cta1Text="Get a Quote"
    cta2Text="Call Us"
  />

  <ServiceHighlights
    title="Service Overview"
    subtitle="Complete Marine Support"
    highlights={[
      { label: 'Coverage', value: 'All Rhodes marinas' },
      { label: 'Availability', value: 'Year-round service' },
      { label: 'Response Time', value: 'Within 2 hours' },
      { label: 'Vessel Types', value: 'All sizes welcome' },
      { label: 'Languages', value: 'EN, GR, DE, IT, FR' },
      { label: 'Experience', value: '15+ years' },
    ]}
    included={['Provisioning service', 'Port arrangements', 'Fuel delivery coordination', 'Waste disposal service', 'Concierge support', '24/7 contact line']}
    excluded={['Fuel costs', 'Marina fees', 'Mechanical repairs', 'Customs clearance']}
  />

  <ServiceOverview
    title="Trusted by Captains & Owners"
    subtitle="Our Track Record"
    description="From superyachts to sailing boats, we've supported hundreds of vessels in Rhodes. Our team's local knowledge and supplier network is unmatched."
    features={[
      { icon: '/assets/img/icon/about_1_1.svg', title: 'Vetted Suppliers', text: 'Every supplier in our network is personally vetted for quality and reliability.' },
      { icon: '/assets/img/icon/about_1_2.svg', title: 'Multilingual Team', text: 'Our coordinators speak English, Greek, German, Italian, and French.' },
      { icon: '/assets/img/icon/about_1_3.svg', title: '24/7 Availability', text: 'Round-the-clock operations during peak season, on-call year-round.' },
    ]}
    stats={[
      { value: 500, suffix: '+', label: 'Vessels Served' },
      { value: 15, suffix: '+', label: 'Years Active' },
      { value: 50, suffix: '+', label: 'Local Partners' },
      { value: 24, suffix: '/7', label: 'Support' },
    ]}
  />

  <ServiceRelatedServices currentPage="mise" />

  <FooterFour />
</BaseLayout>
