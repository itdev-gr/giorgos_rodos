---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../sections/home-one/Section1-Header.astro';
import FooterFour from '../../sections/shared/FooterFour.astro';
import ServiceHeroFullwidth from '../../sections/service/ServiceHeroFullwidth.astro';
import ServiceOverview from '../../sections/service/ServiceOverview.astro';
import ServiceVesselsShowcase from '../../sections/service/ServiceVesselsShowcase.astro';
import ServiceWhySection from '../../sections/service/ServiceWhySection.astro';
import ServiceBucketList from '../../sections/service/ServiceBucketList.astro';
import ServiceMiseChecklist from '../../sections/service/ServiceMiseChecklist.astro';
---

<BaseLayout title="License-Free Boat Rental in Rhodes - Rhodes Boat Tours">
  <Header />

  <!-- 1. Hero -->
  <ServiceHeroFullwidth
    title="License-Free Boat Rental in Rhodes"
    subtitle="Take the helm yourself and explore the southeast coast of Rhodes at your own pace. No licence needed, no schedule to follow — just you and the sea."
    backgroundImage="/assets/img/license-free/hero-charaki-aerial.jpg"
    heroVideo="/assets/img/hero/services/license-free.mp4"
    cta1Text="Explore Our Fleet"
    cta2Text="Contact Us"
  />

  <!-- 2. Overview -->
  <ServiceOverview
    title="Freedom on the Water"
    subtitle="Overview"
    description="Self-drive boat exploration along the breathtaking southeast coast of Rhodes. Depart from Charaki beach and discover hidden coves, turquoise bays, and dramatic coastlines — all at your own pace, no licence required."
    features={[
      { icon: '/assets/img/icon/about_1_1.svg', title: 'No Licence Required', text: 'Our boats are classified for licence-free operation, making them accessible to everyone — no experience needed.' },
      { icon: '/assets/img/icon/about_1_2.svg', title: 'Your Own Itinerary', text: 'Explore at your own pace from Psaltos Beach to Kolymbia — stop wherever you want, stay as long as you like.' },
      { icon: '/assets/img/icon/about_1_3.svg', title: 'Fully Equipped', text: 'GPS tracking, safety gear, shade awning, cool box, life jackets — everything is included in your rental.' },
    ]}
    stats={[
      { value: 5, suffix: '', label: 'Boats Available' },
      { value: 7, suffix: '', label: 'Max Guests' },
      { value: 9, suffix: '', label: 'Hours Max Rental' },
      { value: 30, suffix: '', label: 'Horsepower' },
    ]}
  />

  <!-- 3. About Split 1 — Born from the Coastline (Image Left) -->
  <section class="about-split space">
    <div class="container">
      <div class="row align-items-center gy-40">
        <div class="col-lg-6" data-ani="slideinleft">
          <div class="about-split__img">
            <img class="global-img" src="/assets/img/license-free/charaki-bay.jpg" alt="Charaki Bay, Rhodes southeast coast" />
          </div>
        </div>
        <div class="col-lg-6" data-ani="slideinright">
          <div class="about-split__text ps-lg-4">
            <span class="about-split__accent"></span>
            <div class="title-area mb-20">
              <h2 class="sec-title">Born from the Coastline</h2>
            </div>
            <p class="about-split__subtitle"><em>Charaki — the perfect base for self-drive exploration</em></p>
            <p>
              Nestled on the southeast coast of Rhodes, Charaki is a small fishing village surrounded
              by some of the island's most dramatic scenery. Crystal-clear water, hidden coves, and
              golden beaches stretch in both directions — and most of them are only accessible by boat.
            </p>
            <p>
              This is where your adventure begins. From the calm, shallow waters of Charaki beach, you head out along a coastline that includes everything from the Acropolis of Lindos to secluded red sand beaches that most visitors on the island never even know exist.
            </p>
            <a href="#fleet" class="th-btn style3 th-icon mt-25">View Our Fleet</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. About Split 2 — Your Boat, Your Rules (Image Right, reversed) -->
  <section class="about-split bg-smoke space">
    <div class="container">
      <div class="row align-items-center flex-lg-row-reverse gy-40">
        <div class="col-lg-6" data-ani="slideinright">
          <div class="about-split__img">
            <img class="global-img" src="/assets/img/license-free/fleet-aerial-1.jpg" alt="Aerial view of license-free boats in Rhodes" />
          </div>
        </div>
        <div class="col-lg-6" data-ani="slideinleft">
          <div class="about-split__text pe-lg-4">
            <span class="about-split__accent"></span>
            <div class="title-area mb-20">
              <h2 class="sec-title">Your Boat, Your Rules</h2>
            </div>
            <p class="about-split__subtitle"><em>Complete freedom with full safety support</em></p>
            <p>
              Every rental begins with a thorough safety briefing — our team walks you through the
              controls, navigation, and recommended routes so you feel confident before you leave
              the shore. Each boat is equipped with GPS tracking, so our team can assist you at
              any time.
            </p>
            <p>
              Whether you want to anchor in a quiet cove for a long swim, explore the coastline at speed, or drift along and just take in the views — that is entirely up to you. No schedule, no group, no rush. Just the kind of freedom you came on holiday for.
            </p>
            <a href="/contact" class="th-btn style3 th-icon mt-25">Book Your Boat</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 5. Vessel Showcase -->
  <div id="fleet">
    <ServiceVesselsShowcase
      title="Our Fleet"
      subtitle="Choose Your Vessel"
      vessels={[
        {
          name: 'Nireus 490 Optima',
          image: '/assets/img/license-free/medium-boat-1.jpg',
          specs: ['Up to 4 Guests', '4.96m Length', 'Mercury 30 HP', 'Backup Engine Included', 'From €65/hr'],
          price: 'From €65/hr',
        },
        {
          name: 'Karel Paxos 170',
          image: '/assets/img/license-free/large-boat-1.jpg',
          specs: ['Up to 7 Guests', '4.99m Length', 'Tohatsu 30 HP', 'Backup Engine Included', 'From €90/hr'],
          price: 'From €90/hr',
        },
      ]}
    />
  </div>

  <!-- 6. About Split 3 — Explore the Southeast Coast (Image Left) -->
  <section class="about-split space">
    <div class="container">
      <div class="row align-items-center gy-40">
        <div class="col-lg-6" data-ani="slideinleft">
          <div class="about-split__img">
            <img class="global-img" src="/assets/img/license-free/coastline-aerial-1.jpg" alt="Southeast coast of Rhodes aerial view" />
          </div>
        </div>
        <div class="col-lg-6" data-ani="slideinright">
          <div class="about-split__text ps-lg-4">
            <span class="about-split__accent"></span>
            <div class="title-area mb-20">
              <h2 class="sec-title">Explore the Southeast Coast</h2>
            </div>
            <p class="about-split__subtitle"><em>From Psaltos Beach to Kolymbia — your route to discover</em></p>
            <p>
              Your permitted route covers one of the most spectacular stretches of coastline in the
              Mediterranean. Sail past the sheltered turquoise waters of St. Paul's Bay, gaze up at
              the ancient Acropolis of Lindos from the sea, and discover the golden sands of Vlicha
              Bay.
            </p>
            <p>
              Continue north to the dramatic Red Sand Beach at Kalathos — accessible only by boat —
              then on to the family-friendly Agathi Beach, the hidden coves of Stegna, and the calm
              waters of Kolymbia. Every stop is a new discovery.
            </p>
            <a href="/contact" class="th-btn style3 th-icon mt-25">Plan Your Route</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 7. About Split 4 — Everything Included (Image Right, reversed) -->
  <section class="about-split bg-smoke space">
    <div class="container">
      <div class="row align-items-center flex-lg-row-reverse gy-40">
        <div class="col-lg-6" data-ani="slideinright">
          <div class="about-split__img">
            <img class="global-img" src="/assets/img/license-free/red-sand-beach.jpg" alt="Red Sand Beach, Rhodes" />
          </div>
        </div>
        <div class="col-lg-6" data-ani="slideinleft">
          <div class="about-split__text pe-lg-4">
            <span class="about-split__accent"></span>
            <div class="title-area mb-20">
              <h2 class="sec-title">Everything Included, Nothing Hidden</h2>
            </div>
            <p class="about-split__subtitle"><em>Transparent pricing with no surprises</em></p>
            <p>
              Every rental includes fuel, a full safety briefing, GPS tracking, third-party insurance,
              life jackets, a cool box, shade awning, anchor, paddles, and all required safety
              equipment. There are no hidden fees — the price you see is the price you pay.
            </p>
            <p>
              Rent from 1 to 9 hours, departing any time between 09:00 and 18:00. Each boat carries
              a 25-litre tank plus 10 litres extra, giving you 3–4 hours of non-stop cruising range.
              Want a captain? An optional skipper is available for just +€10/hr.
            </p>
            <a href="/contact" class="th-btn style3 th-icon mt-25">Get in Touch</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 8. Why Book Through Rhodes Boat Tours -->
  <ServiceWhySection
    layout="right"
    title="Why Book Through Rhodes Boat Tours"
    subtitle="The Rhodes Boat Tours Difference"
    description="We partner directly with vetted local operators to bring you the best self-drive boat rental in Rhodes — no middlemen, no markups, and full concierge support from enquiry to departure."
    image="/assets/img/license-free/fleet-aerial-2.jpg"
    features={[
      { icon: '/assets/img/icon/about_1_1.svg', title: 'Vetted Local Operators', text: 'Every partner is hand-selected and regularly reviewed for quality, safety, and guest satisfaction.' },
      { icon: '/assets/img/icon/about_1_2.svg', title: 'Direct Partnerships', text: 'We work directly with trusted local operators — no middlemen, just seamless communication and a premium experience.' },
      { icon: '/assets/img/icon/about_1_3.svg', title: 'Concierge Support', text: 'From choosing the right boat to arranging transfers — we handle every detail for you.' },
    ]}
  />

  <!-- 9. Bucket List -->
  <ServiceBucketList
    title="Experiences That Await You"
    subtitle="Bucket List"
    items={[
      { title: 'Discover Red Sand Beach', description: 'A dramatic stretch of crimson coastline accessible only by boat, perfect for swimming and snorkeling.' },
      { title: 'Anchor at St. Paul\'s Bay', description: 'A sheltered turquoise cove beneath the Acropolis of Lindos, one of Rhodes\' most iconic spots.' },
      { title: 'Swim at Agathi Beach', description: 'A golden sandy beach with shallow, crystal-clear water ideal for families.' },
      { title: 'Cruise Past Lindos', description: 'See the ancient Acropolis perched on the clifftop from a perspective most visitors never experience.' },
      { title: 'Explore Stegna\'s Hidden Coves', description: 'Navigate into secluded rocky inlets where the water glows emerald green.' },
      { title: 'Snorkel in Vlicha Bay', description: 'Dive into calm, transparent waters teeming with marine life along the rocky shoreline.' },
    ]}
  />

  <!-- 10. How It Works -->
  <ServiceMiseChecklist
    title="Rent Your Boat in Four Easy Steps"
    subtitle="How It Works"
    steps={[
      { title: 'Choose Your Boat', description: 'Pick from our medium (4-guest) or large (7-guest) vessels based on your group size.', icon: 'fa-solid fa-ship' },
      { title: 'Select Your Duration', description: 'Rent from 1 to 9 hours, departing any time between 09:00 and 18:00.', icon: 'fa-regular fa-clock' },
      { title: 'Get Your Briefing', description: 'Our team walks you through the controls, safety equipment, and recommended routes.', icon: 'fa-solid fa-compass' },
      { title: 'Set Sail', description: 'Head out from Charaki beach and explore the coastline at your own pace.', icon: 'fa-solid fa-anchor' },
    ]}
  />

  <!-- 11. Related Services -->
  <div class="bg-smoke space overflow-hidden">
    <div class="container">
      <div class="title-area text-center mb-50">
        <span class="sub-title style1" data-ani="slideinup">Explore More</span>
        <h2 class="sec-title" data-ani="slideinup" data-ani-delay="0.1">Our Other Services</h2>
      </div>
      <div class="row gy-30 justify-content-center">
        <div class="col-lg-6">
          <a href="/service/rodos-rent-boats-with-skipper" class="related-service-card" data-ani="slideinup">
            <div class="related-service-card_img">
              <img src="/assets/img/skipper/mako-hero.jpg" alt="Speedboat Tours with Skipper" loading="lazy" />
              <div class="related-service-card_overlay"></div>
            </div>
            <div class="related-service-card_content">
              <h4 class="related-service-card_title">Speedboat Tours with Skipper</h4>
              <p class="related-service-card_text">Private speedboat experiences with a professional captain along the Rhodes coastline.</p>
              <span class="th-btn style3 th-icon">Explore <i class="fas fa-arrow-right ms-2"></i></span>
            </div>
          </a>
        </div>
        <div class="col-lg-6">
          <a href="/service/rodos-boat-tours" class="related-service-card" data-ani="slideinup" data-ani-delay="0.15">
            <div class="related-service-card_img">
              <img src="/assets/img/tours/hero-rhodes-coast.jpg" alt="Boat Tours in Rhodes" loading="lazy" />
              <div class="related-service-card_overlay"></div>
            </div>
            <div class="related-service-card_content">
              <h4 class="related-service-card_title">Boat Tours in Rhodes</h4>
              <p class="related-service-card_text">Guided day trips along the stunning Rhodes coastline and nearby islands.</p>
              <span class="th-btn style3 th-icon">Explore <i class="fas fa-arrow-right ms-2"></i></span>
            </div>
          </a>
        </div>
      </div>
    </div>
  </div>

  <FooterFour />
</BaseLayout>

<style>
  /* ===== About-style Split Sections ===== */
  .about-split__img {
    border-radius: 8px;
    overflow: hidden;
  }

  .about-split__img :global(img) {
    aspect-ratio: 4 / 3;
    object-fit: cover;
    width: 100%;
    display: block;
  }

  .about-split__accent {
    display: block;
    width: 30px;
    height: 4px;
    background: var(--theme-color);
    margin-bottom: 20px;
    border-radius: 2px;
  }

  .about-split__subtitle {
    color: var(--theme-color);
    font-size: 17px;
    margin-bottom: 15px;
  }

  /* ===== Related Services Cards ===== */
  .related-service-card {
    display: block;
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    height: 350px;
    text-decoration: none;
  }
  .related-service-card_img {
    position: absolute;
    inset: 0;
  }
  .related-service-card_img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s;
  }
  .related-service-card:hover .related-service-card_img img {
    transform: scale(1.05);
  }
  .related-service-card_overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(0deg, rgba(0,0,0,0.75) 0%, rgba(0,0,0,0.15) 60%);
  }
  .related-service-card_content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 30px;
    z-index: 1;
  }
  .related-service-card_title {
    color: #fff;
    margin-bottom: 8px;
    font-size: 1.5rem;
  }
  .related-service-card_text {
    color: rgba(255,255,255,0.85);
    margin-bottom: 15px;
    font-size: 0.95rem;
  }
</style>
