---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../sections/home-one/Section1-Header.astro';
import FooterFour from '../../sections/shared/FooterFour.astro';
import ServiceHeroFullwidth from '../../sections/service/ServiceHeroFullwidth.astro';
import ServiceSchema from '../../components/seo/ServiceSchema.astro';
import BreadcrumbSchema from '../../components/seo/BreadcrumbSchema.astro';
import { getMediaSlot } from '../../lib/media';

const heroImage = await getMediaSlot('service.sidecar.hero.image', '/assets/img/transfers/transfer-sidecar.jpg');
const heroVideo = await getMediaSlot('service.sidecar.hero.video', '/assets/img/hero/services/charter.mp4');
const splitImg1 = await getMediaSlot('service.sidecar.split.img-1', '/assets/img/transfers/transfer-rider.jpg');
const splitImg2 = await getMediaSlot('service.sidecar.split.img-2', '/assets/img/transfers/transfer-sidecar.jpg');
const splitImg3 = await getMediaSlot('service.sidecar.split.img-3', '/assets/img/transfers/rhodes-transfer-hero.jpg');
---

<BaseLayout title="Rhodes Sidecar Tours — Vintage Sidecar Experience in Rhodes | Rhodes Boat Tours" description="Rhodes Sidecar Tours — explore the island in a vintage sidecar motorcycle with a local driver. Panoramic views, hidden locations, sunset routes and unforgettable memories." ogImage={heroImage}>
  <ServiceSchema
    name="Rhodes Sidecar Tours"
    description="Vintage sidecar motorcycle tours in Rhodes with a local driver — panoramic views, hidden locations, sunset routes and unforgettable memories."
    serviceType="Sidecar Tour"
    image={heroImage}
    url="/service/rhodes-sidecar-tours"
  />
  <BreadcrumbSchema items={[
    { name: 'Home', url: '/' },
    { name: 'Services', url: '/service' },
    { name: 'Rhodes Sidecar Tours', url: '/service/rhodes-sidecar-tours' },
  ]} />
  <Header />

  <!-- 1. Hero -->
  <ServiceHeroFullwidth
    title="Rhodes Sidecar Tours"
    subtitle="Vintage Sidecar Experience in Rhodes"
    backgroundImage={heroImage}
    heroVideo={heroVideo}
  />

  <!-- 2. Intro -->
  <section style="padding: 60px 0 40px;">
    <div class="container">
      <div style="max-width: 700px; margin: 0 auto; text-align: center; margin-bottom: 40px;">
        <p style="font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 1.2rem; line-height: 1.7; color: #1CA8CB; margin-bottom: 0;" data-ani="fadein">
          Rhodes is an island you experience through its roads, landscapes and hidden places — and a sidecar is one of the most unique ways to live it.
        </p>
      </div>
      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px;" class="sc-intro-grid" data-ani="slideinup" data-ani-delay="0.1">
        <div style="text-align: center; padding: 32px 24px;">
          <div style="width: 56px; height: 56px; border-radius: 14px; background: rgba(28,168,203,0.1); color: #1CA8CB; display: inline-flex; align-items: center; justify-content: center; font-size: 1.3rem; margin-bottom: 18px;">
            <i class="fas fa-motorcycle"></i>
          </div>
          <h3 style="font-family: 'Playfair Display', serif; font-size: 1rem; font-weight: 700; color: #113D48; margin-bottom: 10px;">Vintage Sidecars</h3>
          <p style="font-size: 0.9rem; line-height: 1.65; color: #6b7c85; margin: 0;">Classic sidecar motorcycles restored with care — a one-of-a-kind way to experience the open road and the coastline of Rhodes.</p>
        </div>
        <div style="text-align: center; padding: 32px 24px;">
          <div style="width: 56px; height: 56px; border-radius: 14px; background: rgba(28,168,203,0.1); color: #1CA8CB; display: inline-flex; align-items: center; justify-content: center; font-size: 1.3rem; margin-bottom: 18px;">
            <i class="fas fa-user-tie"></i>
          </div>
          <h3 style="font-family: 'Playfair Display', serif; font-size: 1rem; font-weight: 700; color: #113D48; margin-bottom: 10px;">Local Driver</h3>
          <p style="font-size: 0.9rem; line-height: 1.65; color: #6b7c85; margin: 0;">Sit back and enjoy. Your driver knows every road, every viewpoint and every hidden corner of the island — no map needed.</p>
        </div>
        <div style="text-align: center; padding: 32px 24px;">
          <div style="width: 56px; height: 56px; border-radius: 14px; background: rgba(28,168,203,0.1); color: #1CA8CB; display: inline-flex; align-items: center; justify-content: center; font-size: 1.3rem; margin-bottom: 18px;">
            <i class="fas fa-camera"></i>
          </div>
          <h3 style="font-family: 'Playfair Display', serif; font-size: 1rem; font-weight: 700; color: #113D48; margin-bottom: 10px;">Personal & Slow</h3>
          <p style="font-size: 0.9rem; line-height: 1.65; color: #6b7c85; margin: 0;">Not a mass tour, not a typical excursion. A private, unhurried journey designed for memories, not check-lists.</p>
        </div>
      </div>
      <div style="text-align: center; margin-top: 28px;" data-ani="fadein" data-ani-delay="0.2">
        <p style="font-family: 'Playfair Display', serif; font-weight: 600; font-size: 0.95rem; color: #113D48; margin: 0 0 20px;">
          We recommend <a href="https://www.rhodessidecartours.com" target="_blank" style="color: #1CA8CB; text-decoration: underline;">RhodesSidecarTours</a> — a trusted local sidecar tour operator in Rhodes.
        </p>
        <a href="https://www.rhodessidecartours.com" target="_blank" rel="noopener noreferrer" class="th-btn style3 th-icon">Book Your Sidecar Tour <i class="fas fa-external-link-alt" style="margin-left: 6px; font-size: 0.8rem;"></i></a>
      </div>
    </div>
  </section>

  <!-- 3. Split Section — Image Left, Text Right -->
  <section style="padding: 60px 0;">
    <div class="container">
      <div class="row align-items-center gy-40">
        <div class="col-lg-6" data-ani="slideinleft">
          <div style="border-radius: 12px; overflow: hidden; aspect-ratio: 4/3;">
            <img src={splitImg1} alt="Rhodes sidecar tour rider" style="width: 100%; height: 100%; object-fit: cover; display: block;" />
          </div>
        </div>
        <div class="col-lg-6" data-ani="slideinright">
          <div style="padding-left: 20px;">
            <h2 style="font-family: 'Playfair Display', serif; font-size: 1.5rem; font-weight: 700; color: #113D48; margin-bottom: 16px;">Explore Rhodes Like Never Before</h2>
            <p style="font-size: 1rem; line-height: 1.8; color: #4a5568; margin-bottom: 16px;">
              Most people experience Rhodes by car, bus or boat. Few experience it the way a sidecar lets you — wind on your face, panoramic views unfolding around every bend, and complete freedom to stop wherever the moment asks for it.
            </p>
            <p style="font-size: 1rem; line-height: 1.8; color: #4a5568;">
              From the medieval streets of the Old Town to the coastal roads heading south, a vintage sidecar tour turns transportation into a story. It is one of the most photogenic, atmospheric and personal ways to discover the island.
            </p>
            <a href="https://www.rhodessidecartours.com" target="_blank" rel="noopener noreferrer" style="display: inline-flex; align-items: center; gap: 6px; margin-top: 16px; font-family: 'Inter', sans-serif; font-size: 0.85rem; font-weight: 600; color: #1CA8CB; text-decoration: none;">Book at RhodesSidecarTours.com <i class="fas fa-arrow-right" style="font-size: 0.75rem;"></i></a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. Split Section — Text Left, Image Right (reversed) -->
  <section style="padding: 60px 0; background: #f8fafb;">
    <div class="container">
      <div class="row align-items-center flex-lg-row-reverse gy-40">
        <div class="col-lg-6" data-ani="slideinright">
          <div style="border-radius: 12px; overflow: hidden; aspect-ratio: 4/3;">
            <img src={splitImg2} alt="Vintage sidecar motorcycle parked in Rhodes" style="width: 100%; height: 100%; object-fit: cover; display: block;" />
          </div>
        </div>
        <div class="col-lg-6" data-ani="slideinleft">
          <div style="padding-right: 20px;">
            <h2 style="font-family: 'Playfair Display', serif; font-size: 1.5rem; font-weight: 700; color: #113D48; margin-bottom: 16px;">What You Will See</h2>
            <p style="font-size: 1rem; line-height: 1.8; color: #4a5568; margin-bottom: 16px;">
              Sidecar tours weave through Rhodes Town, the Old Town walls, Mandraki Harbour and Monte Smith. They head out to hidden viewpoints, small villages and the scenic coastal roads that most visitors never find.
            </p>
            <p style="font-size: 1rem; line-height: 1.8; color: #4a5568;">
              Sunset routes follow the western coast for one of the most beautiful golden-hour rides on the island. Longer tours head into the countryside and the mountains of Rhodes — slow, scenic and very personal.
            </p>
            <a href="https://www.rhodessidecartours.com" target="_blank" rel="noopener noreferrer" style="display: inline-flex; align-items: center; gap: 6px; margin-top: 16px; font-family: 'Inter', sans-serif; font-size: 0.85rem; font-weight: 600; color: #1CA8CB; text-decoration: none;">Book at RhodesSidecarTours.com <i class="fas fa-arrow-right" style="font-size: 0.75rem;"></i></a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 5. Split Section — Sunset & Couples -->
  <section style="padding: 60px 0;">
    <div class="container">
      <div class="row align-items-center gy-40">
        <div class="col-lg-6" data-ani="slideinleft">
          <div style="border-radius: 12px; overflow: hidden; aspect-ratio: 4/3;">
            <img src={splitImg3} alt="Sunset sidecar tour in Rhodes" style="width: 100%; height: 100%; object-fit: cover; display: block;" />
          </div>
        </div>
        <div class="col-lg-6" data-ani="slideinright">
          <div style="padding-left: 20px;">
            <h2 style="font-family: 'Playfair Display', serif; font-size: 1.5rem; font-weight: 700; color: #113D48; margin-bottom: 16px;">Special Occasions and Sunset Rides</h2>
            <p style="font-size: 1rem; line-height: 1.8; color: #4a5568; margin-bottom: 16px;">
              Anniversaries, honeymoons, proposals, birthdays — a private sidecar tour turns a moment into a memory. It is unhurried, romantic and quietly cinematic.
            </p>
            <p style="font-size: 1rem; line-height: 1.8; color: #4a5568;">
              Tell your driver what you are celebrating and they will tailor the route — a quiet beach, a hilltop chapel, a sunset stop with the sea in front of you. No two tours are ever the same.
            </p>
            <a href="https://www.rhodessidecartours.com" target="_blank" rel="noopener noreferrer" style="display: inline-flex; align-items: center; gap: 6px; margin-top: 16px; font-family: 'Inter', sans-serif; font-size: 0.85rem; font-weight: 600; color: #1CA8CB; text-decoration: none;">Book at RhodesSidecarTours.com <i class="fas fa-arrow-right" style="font-size: 0.75rem;"></i></a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 6. Sidecar Info -->
  <section style="padding: 40px 0 60px; background: #f8fafb;">
    <div class="container">
      <div style="max-width: 800px; margin: 0 auto;">
        <div class="sc-flow" data-ani="fadein">
          <h2 style="font-family: 'Playfair Display', serif; font-size: 1.35rem; font-weight: 700; color: #113D48; margin: 0 0 16px;">Sidecar Tours in Rhodes</h2>
          <p>Rhodes Sidecar Tours is one of the most unique experiences you can book on the island. Instead of sitting in a bus or renting a car, you ride alongside a local driver in a restored vintage sidecar — completely open to the views, the sea air and the unmistakable feel of the road.</p>
          <p>The experience is slow, relaxed and very personal. It is not a mass excursion or a packaged tour. It is a private journey along coastal roads, mountain routes and hidden corners of Rhodes that many visitors would never find on their own.</p>

          <h2 style="font-family: 'Playfair Display', serif; font-size: 1.35rem; font-weight: 700; color: #113D48; margin: 32px 0 16px;">Routes Available</h2>
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 6px 24px; margin-bottom: 20px;" class="sc-list-grid">
            <p style="margin: 0; padding: 6px 0;"><i class="fas fa-check" style="color: #1CA8CB; margin-right: 8px; font-size: 0.8rem;"></i>Old Town and city tour</p>
            <p style="margin: 0; padding: 6px 0;"><i class="fas fa-check" style="color: #1CA8CB; margin-right: 8px; font-size: 0.8rem;"></i>Mandraki Harbour and Monte Smith</p>
            <p style="margin: 0; padding: 6px 0;"><i class="fas fa-check" style="color: #1CA8CB; margin-right: 8px; font-size: 0.8rem;"></i>East coast scenic ride</p>
            <p style="margin: 0; padding: 6px 0;"><i class="fas fa-check" style="color: #1CA8CB; margin-right: 8px; font-size: 0.8rem;"></i>West coast sunset ride</p>
            <p style="margin: 0; padding: 6px 0;"><i class="fas fa-check" style="color: #1CA8CB; margin-right: 8px; font-size: 0.8rem;"></i>Hidden village tour</p>
            <p style="margin: 0; padding: 6px 0;"><i class="fas fa-check" style="color: #1CA8CB; margin-right: 8px; font-size: 0.8rem;"></i>Mountain and countryside route</p>
            <p style="margin: 0; padding: 6px 0;"><i class="fas fa-check" style="color: #1CA8CB; margin-right: 8px; font-size: 0.8rem;"></i>Photo and storytelling tour</p>
            <p style="margin: 0; padding: 6px 0;"><i class="fas fa-check" style="color: #1CA8CB; margin-right: 8px; font-size: 0.8rem;"></i>Custom private route</p>
          </div>

          <h2 style="font-family: 'Playfair Display', serif; font-size: 1.35rem; font-weight: 700; color: #113D48; margin: 32px 0 16px;">Who Is This For?</h2>
          <p>Rhodes Sidecar Tours is ideal for:</p>
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 6px 24px; margin: 16px 0 24px;" class="sc-list-grid">
            <p style="margin: 0; padding: 6px 0;"><i class="fas fa-check" style="color: #1CA8CB; margin-right: 8px; font-size: 0.8rem;"></i>Couples and honeymooners</p>
            <p style="margin: 0; padding: 6px 0;"><i class="fas fa-check" style="color: #1CA8CB; margin-right: 8px; font-size: 0.8rem;"></i>Families looking for something different</p>
            <p style="margin: 0; padding: 6px 0;"><i class="fas fa-check" style="color: #1CA8CB; margin-right: 8px; font-size: 0.8rem;"></i>Photographers and creators</p>
            <p style="margin: 0; padding: 6px 0;"><i class="fas fa-check" style="color: #1CA8CB; margin-right: 8px; font-size: 0.8rem;"></i>Sunset seekers</p>
            <p style="margin: 0; padding: 6px 0;"><i class="fas fa-check" style="color: #1CA8CB; margin-right: 8px; font-size: 0.8rem;"></i>Travellers beyond typical tourism</p>
            <p style="margin: 0; padding: 6px 0;"><i class="fas fa-check" style="color: #1CA8CB; margin-right: 8px; font-size: 0.8rem;"></i>Special occasions and proposals</p>
          </div>

          <p style="font-family: 'Playfair Display', serif; font-weight: 600; font-size: 1.05rem; color: #113D48; text-align: center; padding: 24px 0; margin: 28px 0; border-top: 1px solid #eee; border-bottom: 1px solid #eee; line-height: 1.7;">
            If you are looking for something different, something memorable and something truly unique — a sidecar tour is one of the most special things you can do in Rhodes.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 7. Recommended Partner -->
  <section style="padding: 60px 0;">
    <div class="container">
      <div style="max-width: 700px; margin: 0 auto; text-align: center;">
        <h2 style="font-family: 'Playfair Display', serif; font-size: 1.35rem; font-weight: 700; color: #113D48; margin-bottom: 16px;" data-ani="slideinup">Recommended Sidecar Tour Operator</h2>
        <p style="font-size: 1rem; line-height: 1.75; color: #6b7c85; margin-bottom: 28px;" data-ani="fadein" data-ani-delay="0.1">
          The sidecar operator we recommend in Rhodes is <strong style="color: #113D48;">RhodesSidecarTours</strong> — a local team running vintage sidecar experiences across the island, with carefully restored bikes, professional drivers and a deep knowledge of every route.
        </p>
        <a href="https://www.rhodessidecartours.com" target="_blank" rel="noopener noreferrer" class="th-btn style3 th-icon" data-ani="slideinup" data-ani-delay="0.2">Visit RhodesSidecarTours.com <i class="fas fa-external-link-alt" style="margin-left: 6px; font-size: 0.8rem;"></i></a>
      </div>
    </div>
  </section>

  <!-- 8. Contact -->
  <section style="padding: 80px 0; background: #113D48;">
    <div class="container">
      <div style="max-width: 700px; margin: 0 auto; text-align: center;">
        <h2 style="font-family: 'Playfair Display', serif; font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 700; color: #fff; margin-bottom: 20px;" data-ani="slideinup">Ready for Something Truly Unique?</h2>
        <p style="font-size: 1rem; line-height: 1.75; color: rgba(255,255,255,0.7); margin-bottom: 36px;" data-ani="fadein" data-ani-delay="0.1">
          If you want to discover Rhodes from the side of a vintage sidecar, book directly with our recommended partner <a href="https://www.rhodessidecartours.com" target="_blank" rel="noopener noreferrer" style="color: #fff; text-decoration: underline;">RhodesSidecarTours.com</a>, or get in touch and we will help you choose the perfect route.
        </p>
        <div style="display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;" data-ani="slideinup" data-ani-delay="0.2">
          <a href="https://www.rhodessidecartours.com" target="_blank" rel="noopener noreferrer" style="display: inline-flex; align-items: center; gap: 8px; padding: 14px 28px; font-family: 'Inter', sans-serif; font-size: 0.85rem; font-weight: 600; color: #113D48; background: #fff; border-radius: 8px; text-decoration: none; transition: all 0.3s ease;"><i class="fas fa-motorcycle"></i> Book Your Sidecar Tour</a>
          <a href="/contact" class="th-btn style3 th-icon">Contact Us</a>
          <a href="https://wa.me/306951666454" target="_blank" rel="noopener" style="display: inline-flex; align-items: center; gap: 8px; padding: 14px 28px; font-family: 'Inter', sans-serif; font-size: 0.85rem; font-weight: 600; color: #fff; border: 1.5px solid rgba(255,255,255,0.3); border-radius: 8px; text-decoration: none; transition: all 0.3s ease;"><i class="fab fa-whatsapp"></i> WhatsApp</a>
        </div>
      </div>
    </div>
  </section>

  <FooterFour />
</BaseLayout>

<script>
  document.getElementById('header-one')?.classList.add('header-transparent');
</script>

<style>
  .sc-flow {
    font-family: 'Inter', sans-serif;
    font-size: 1.02rem;
    line-height: 1.8;
    color: #4a5568;
  }
  .sc-flow p { margin-bottom: 16px; }

  @media (max-width: 991px) {
    .sc-intro-grid { grid-template-columns: 1fr !important; gap: 0 !important; }
    .sc-list-grid { grid-template-columns: 1fr !important; }
  }
</style>
