---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../sections/home-one/Section1-Header.astro';
import FooterFour from '../../sections/shared/FooterFour.astro';
import ServiceHeroFullwidth from '../../sections/service/ServiceHeroFullwidth.astro';
---

<BaseLayout title="Rhodes MICE & Incentive Services — Corporate Events | Rhodes Boat Tours" description="MICE travel, incentive trips, corporate events and group experiences in Rhodes. Boat events, yacht charters, team building and event planning through our local network.">
  <Header />

  <!-- 1. Hero -->
  <ServiceHeroFullwidth
    title="Rhodes MICE & Incentive Services"
    subtitle="Corporate Events, Incentive Trips and Group Experiences"
    backgroundImage="/assets/img/gallery/yacht/yacht-luxury-1.jpg"
    heroVideo="/assets/img/hero/services/mise.mp4"
  />

  <!-- 2. Intro -->
  <section style="padding: 60px 0 40px;">
    <div class="container">
      <div style="max-width: 700px; margin: 0 auto; text-align: center; margin-bottom: 40px;">
        <p style="font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 1.2rem; line-height: 1.7; color: #1CA8CB; margin-bottom: 0;" data-ani="fadein">
          Rhodes combines coastline, history, resorts and marinas — everything needed to create complete corporate and incentive programs.
        </p>
      </div>
      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px;" class="mi-intro-grid" data-ani="slideinup" data-ani-delay="0.1">
        <div style="text-align: center; padding: 32px 24px;">
          <div style="width: 56px; height: 56px; border-radius: 14px; background: rgba(28,168,203,0.1); color: #1CA8CB; display: inline-flex; align-items: center; justify-content: center; font-size: 1.3rem; margin-bottom: 18px;">
            <i class="fas fa-building"></i>
          </div>
          <h3 style="font-family: 'Playfair Display', serif; font-size: 1rem; font-weight: 700; color: #113D48; margin-bottom: 10px;">Corporate Events</h3>
          <p style="font-size: 0.9rem; line-height: 1.65; color: #6b7c85; margin: 0;">Incentive trips, team building, conferences, product launches, VIP events and private celebrations in Rhodes.</p>
        </div>
        <div style="text-align: center; padding: 32px 24px;">
          <div style="width: 56px; height: 56px; border-radius: 14px; background: rgba(28,168,203,0.1); color: #1CA8CB; display: inline-flex; align-items: center; justify-content: center; font-size: 1.3rem; margin-bottom: 18px;">
            <i class="fas fa-ship"></i>
          </div>
          <h3 style="font-family: 'Playfair Display', serif; font-size: 1rem; font-weight: 700; color: #113D48; margin-bottom: 10px;">Boat Experiences</h3>
          <p style="font-size: 0.9rem; line-height: 1.65; color: #6b7c85; margin: 0;">Private boats, fleet events, catamaran cruises, yacht charters and sailing trips organized for groups of any size.</p>
        </div>
        <div style="text-align: center; padding: 32px 24px;">
          <div style="width: 56px; height: 56px; border-radius: 14px; background: rgba(28,168,203,0.1); color: #1CA8CB; display: inline-flex; align-items: center; justify-content: center; font-size: 1.3rem; margin-bottom: 18px;">
            <i class="fas fa-handshake"></i>
          </div>
          <h3 style="font-family: 'Playfair Display', serif; font-size: 1rem; font-weight: 700; color: #113D48; margin-bottom: 10px;">Local Network</h3>
          <p style="font-size: 0.9rem; line-height: 1.65; color: #6b7c85; margin: 0;">We connect companies and event planners with trusted local boats, venues, transfers and service providers in Rhodes.</p>
        </div>
      </div>
      <div style="text-align: center; margin-top: 28px;" data-ani="fadein" data-ani-delay="0.2">
        <p style="font-family: 'Playfair Display', serif; font-weight: 600; font-size: 0.95rem; color: #113D48; margin: 0;">
          We don't operate events or agencies. We help companies and planners connect with the right local partners in Rhodes.
        </p>
      </div>
    </div>
  </section>

  <!-- 3. MICE Opportunities -->
  <section style="padding: 40px 0 60px; background: #f8fafb;">
    <div class="container">
      <div style="max-width: 800px; margin: 0 auto;">
        <div class="mi-flow" data-ani="fadein">
          <h2 style="font-family: 'Playfair Display', serif; font-size: 1.35rem; font-weight: 700; color: #113D48; margin: 0 0 16px;">Meetings, Incentives, Conferences & Events</h2>
          <p>Rhodes offers many opportunities for corporate travel and events. Many companies choose Rhodes because it allows them to combine accommodation, sea activities, cultural visits, private events and transportation into one complete program.</p>
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 6px 24px; margin: 20px 0;" class="mi-list-grid">
            <p style="margin: 0; padding: 6px 0;"><i class="fas fa-check" style="color: #1CA8CB; margin-right: 8px; font-size: 0.8rem;"></i>Corporate incentive trips</p>
            <p style="margin: 0; padding: 6px 0;"><i class="fas fa-check" style="color: #1CA8CB; margin-right: 8px; font-size: 0.8rem;"></i>Team building activities</p>
            <p style="margin: 0; padding: 6px 0;"><i class="fas fa-check" style="color: #1CA8CB; margin-right: 8px; font-size: 0.8rem;"></i>Corporate boat events</p>
            <p style="margin: 0; padding: 6px 0;"><i class="fas fa-check" style="color: #1CA8CB; margin-right: 8px; font-size: 0.8rem;"></i>Yacht events</p>
            <p style="margin: 0; padding: 6px 0;"><i class="fas fa-check" style="color: #1CA8CB; margin-right: 8px; font-size: 0.8rem;"></i>Conferences and meetings</p>
            <p style="margin: 0; padding: 6px 0;"><i class="fas fa-check" style="color: #1CA8CB; margin-right: 8px; font-size: 0.8rem;"></i>VIP events</p>
            <p style="margin: 0; padding: 6px 0;"><i class="fas fa-check" style="color: #1CA8CB; margin-right: 8px; font-size: 0.8rem;"></i>Product launches</p>
            <p style="margin: 0; padding: 6px 0;"><i class="fas fa-check" style="color: #1CA8CB; margin-right: 8px; font-size: 0.8rem;"></i>Weddings and celebrations</p>
            <p style="margin: 0; padding: 6px 0;"><i class="fas fa-check" style="color: #1CA8CB; margin-right: 8px; font-size: 0.8rem;"></i>Fleet and regatta events</p>
            <p style="margin: 0; padding: 6px 0;"><i class="fas fa-check" style="color: #1CA8CB; margin-right: 8px; font-size: 0.8rem;"></i>Large group excursions</p>
          </div>

          <h2 style="font-family: 'Playfair Display', serif; font-size: 1.35rem; font-weight: 700; color: #113D48; margin: 32px 0 16px;">Boat Events and Sea Experiences for Groups</h2>
          <p>Boat experiences are one of the most popular activities for incentive trips and corporate events in Rhodes. Depending on the group size, it is possible to organize private boat trips, catamaran cruises, sailing trips, yacht charters, fleet events with multiple boats, sunset cruises, team building on boats and island hopping experiences.</p>

          <h2 style="font-family: 'Playfair Display', serif; font-size: 1.35rem; font-weight: 700; color: #113D48; margin: 32px 0 16px;">Event Planning Support</h2>
          <p>Organizing an event in another country requires local knowledge and reliable partners. We work with local companies and professionals in Rhodes including:</p>
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 6px 24px; margin: 20px 0;" class="mi-list-grid">
            <p style="margin: 0; padding: 6px 0;"><i class="fas fa-check" style="color: #1CA8CB; margin-right: 8px; font-size: 0.8rem;"></i>Boat owners and charter companies</p>
            <p style="margin: 0; padding: 6px 0;"><i class="fas fa-check" style="color: #1CA8CB; margin-right: 8px; font-size: 0.8rem;"></i>Transfer companies</p>
            <p style="margin: 0; padding: 6px 0;"><i class="fas fa-check" style="color: #1CA8CB; margin-right: 8px; font-size: 0.8rem;"></i>Event planners</p>
            <p style="margin: 0; padding: 6px 0;"><i class="fas fa-check" style="color: #1CA8CB; margin-right: 8px; font-size: 0.8rem;"></i>Hotels and villas</p>
            <p style="margin: 0; padding: 6px 0;"><i class="fas fa-check" style="color: #1CA8CB; margin-right: 8px; font-size: 0.8rem;"></i>Restaurants and venues</p>
            <p style="margin: 0; padding: 6px 0;"><i class="fas fa-check" style="color: #1CA8CB; margin-right: 8px; font-size: 0.8rem;"></i>Activity providers</p>
            <p style="margin: 0; padding: 6px 0;"><i class="fas fa-check" style="color: #1CA8CB; margin-right: 8px; font-size: 0.8rem;"></i>Tour guides</p>
            <p style="margin: 0; padding: 6px 0;"><i class="fas fa-check" style="color: #1CA8CB; margin-right: 8px; font-size: 0.8rem;"></i>Logistics providers</p>
          </div>

          <h2 style="font-family: 'Playfair Display', serif; font-size: 1.35rem; font-weight: 700; color: #113D48; margin: 32px 0 16px;">Large Groups, Fleet Events and Logistics</h2>
          <p>For large groups and corporate events, multiple boats, transfers, venues and activities can be organized at the same time. Fleet events, regatta style events and multi-activity programs are often organized for incentive trips and corporate groups visiting Rhodes.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. Contact -->
  <section style="padding: 80px 0; background: #113D48;">
    <div class="container">
      <div style="max-width: 700px; margin: 0 auto; text-align: center;">
        <h2 style="font-family: 'Playfair Display', serif; font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 700; color: #fff; margin-bottom: 20px;" data-ani="slideinup">Planning a Corporate Event in Rhodes?</h2>
        <p style="font-size: 1rem; line-height: 1.75; color: rgba(255,255,255,0.7); margin-bottom: 36px;" data-ani="fadein" data-ani-delay="0.1">
          If you are planning a corporate event, incentive trip, group activity or private event in Rhodes, contact us and we will help connect you with trusted local partners, boats and service providers.
        </p>
        <div style="display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;" data-ani="slideinup" data-ani-delay="0.2">
          <a href="/contact" class="th-btn style3 th-icon">Send Us a Message</a>
          <a href="https://wa.me/306951666454" style="display: inline-flex; align-items: center; gap: 8px; padding: 14px 28px; font-family: 'Inter', sans-serif; font-size: 0.85rem; font-weight: 600; color: #fff; border: 1.5px solid rgba(255,255,255,0.3); border-radius: 8px; text-decoration: none; transition: all 0.3s ease;"><i class="fab fa-whatsapp"></i> WhatsApp</a>
          <a href="mailto:info@rhodesrentaboat.com" style="display: inline-flex; align-items: center; gap: 8px; padding: 14px 28px; font-family: 'Inter', sans-serif; font-size: 0.85rem; font-weight: 600; color: #fff; border: 1.5px solid rgba(255,255,255,0.3); border-radius: 8px; text-decoration: none; transition: all 0.3s ease;"><i class="fas fa-envelope"></i> Email</a>
        </div>
      </div>
    </div>
  </section>

  <FooterFour />
</BaseLayout>

<script>
  document.getElementById('header-one')?.classList.add('header-transparent');
</script>

<style>
  .mi-flow {
    font-family: 'Inter', sans-serif;
    font-size: 1.02rem;
    line-height: 1.8;
    color: #4a5568;
  }

  .mi-flow p {
    margin-bottom: 16px;
  }

  @media (max-width: 991px) {
    .mi-intro-grid {
      grid-template-columns: 1fr !important;
      gap: 0 !important;
    }
    .mi-list-grid {
      grid-template-columns: 1fr !important;
    }
  }
</style>
