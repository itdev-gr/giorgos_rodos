---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../sections/home-one/Section1-Header.astro';
import FooterFour from '../../sections/shared/FooterFour.astro';
import ServiceHeroFullwidth from '../../sections/service/ServiceHeroFullwidth.astro';
import ServiceOverview from '../../sections/service/ServiceOverview.astro';
import ServiceVesselsShowcase from '../../sections/service/ServiceVesselsShowcase.astro';
import ServiceWhySection from '../../sections/service/ServiceWhySection.astro';
import ServiceBucketList from '../../sections/service/ServiceBucketList.astro';
import ServiceMiseChecklist from '../../sections/service/ServiceMiseChecklist.astro';
---

<BaseLayout title="Rhodes Boat Cruises - Rhodes Boat Tours">
  <Header />

  <!-- 1. Hero -->
  <ServiceHeroFullwidth
    title="Cruise the Rhodes Coastline"
    subtitle="All-inclusive day and sunset cruises. Swimming, dining, and unforgettable Aegean views."
    backgroundImage="/assets/img/cruises/greco_home1.jpg"
    heroVideo="/assets/img/hero/services/boat-cruises.mp4"
    cta1Text="Book a Cruise"
    cta2Text="View Our Cruises"
  />

  <!-- 2. Overview -->
  <ServiceOverview
    title="Your Perfect Day at Sea"
    subtitle="Overview"
    description="Three signature all-inclusive experiences along the stunning Rhodes coastline — from sun-drenched bay-hopping adventures to magical sunset voyages. Every cruise includes food, drinks, music, and multiple swimming stops in crystal-clear waters."
    features={[
      { icon: '/assets/img/icon/about_1_1.svg', title: 'All-Inclusive Experience', text: 'Food, drinks, music, and snorkeling gear — everything is included in the price. No hidden extras.' },
      { icon: '/assets/img/icon/about_1_2.svg', title: 'Stunning Swim Stops', text: 'Crystal-clear bays and secret coves along the Rhodes coastline, accessible only by boat.' },
      { icon: '/assets/img/icon/about_1_3.svg', title: 'Professional Crew', text: 'Experienced, multilingual crew dedicated to your safety, comfort, and enjoyment.' },
    ]}
    stats={[
      { value: 3, suffix: '', label: 'Cruise Experiences' },
      { value: 7, suffix: '', label: 'Days a Week' },
      { value: 15, suffix: '+', label: 'Years Experience' },
      { value: 5, suffix: '★', label: 'Guest Rating' },
    ]}
  />

  <!-- 3. Born on the Water — Image Left, Text Right -->
  <section class="about-split space">
    <div class="container">
      <div class="row align-items-center gy-40">
        <div class="col-lg-6" data-ani="slideinleft">
          <div class="about-split__img">
            <img class="global-img" src="/assets/img/cruises/greco_sunset3.jpg" alt="cruise along the Rhodes coastline" />
          </div>
        </div>
        <div class="col-lg-6" data-ani="slideinright">
          <div class="about-split__text ps-lg-4">
            <span class="about-split__accent"></span>
            <div class="title-area mb-20">
              <h2 class="sec-title">Born on the Water</h2>
            </div>
            <p class="about-split__subtitle"><em>Over fifteen years of cruising the Rhodes coastline</em></p>
            <p>
              These cruises were born from a simple love of the sea and the stunning Rhodes coastline.
              For more than fifteen years, the crew has been sharing the island's hidden bays, dramatic
              cliffs, and turquoise waters with visitors from around the world — always with warmth,
              always with a personal touch.
            </p>
            <p>
              Every route is designed with intimate knowledge of the coast — knowing exactly when to
              round a headland for the best view, which coves offer the calmest water for swimming,
              and where the sunset paints the sea gold. This isn't a tour; it's a tradition.
            </p>
            <a href="/contact" class="th-btn style3 th-icon mt-25">Get in Touch</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. All-Inclusive, All the Time — Text Left, Image Right (reversed) -->
  <section class="about-split bg-smoke space">
    <div class="container">
      <div class="row align-items-center flex-lg-row-reverse gy-40">
        <div class="col-lg-6" data-ani="slideinright">
          <div class="about-split__img">
            <img class="global-img" src="/assets/img/cruises/onboard1.jpg" alt="Onboard dining and drinks on cruise" />
          </div>
        </div>
        <div class="col-lg-6" data-ani="slideinleft">
          <div class="about-split__text pe-lg-4">
            <span class="about-split__accent"></span>
            <div class="title-area mb-20">
              <h2 class="sec-title">All-Inclusive, All the Time</h2>
            </div>
            <p class="about-split__subtitle"><em>Everything you need for a perfect day at sea</em></p>
            <p>
              When we say all-inclusive, we mean it. Fresh Mediterranean food, cold drinks, local wine,
              and music are all part of every cruise. There are no surprise extras or hidden
              charges — just step aboard and enjoy.
            </p>
            <p>
              The crew takes care of everything: comfortable spots on deck, snorkeling gear at each
              swimming stop, music and good company. Whether you want to dance, sunbathe on the bow,
              or simply watch the coastline drift by with a cold drink in hand — you choose. There is
              no schedule to follow.
            </p>
            <a href="/contact" class="th-btn style3 th-icon mt-25">Book Your Cruise</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 5. Cruise Showcase -->
  <ServiceVesselsShowcase
    title="Our Cruises"
    subtitle="Three Signature Experiences"
    vessels={[
      {
        name: 'Fun In The Sun Cruise',
        image: '/assets/img/cruises/greco_fun1.jpg',
        specs: ['Full Day Cruise', 'Swimming & Snorkeling', 'All-Inclusive Food & Drinks', 'Music & Entertainment', 'Up to 50 Guests'],
        price: 'From \u20AC55/person',
      },
      {
        name: 'All Inclusive Sunset Cruise',
        image: '/assets/img/cruises/greco_sunset1.jpg',
        specs: ['Evening Cruise', 'Sunset Views', 'All-Inclusive Drinks & Canap\u00E9s', 'Live Music', 'Up to 40 Guests'],
        price: 'From \u20AC65/person',
      },
      {
        name: 'All Inclusive Bay to Bay Cruise',
        image: '/assets/img/cruises/bay1.jpg',
        specs: ['Half Day Cruise', '3\u20134 Bay Stops', 'All-Inclusive Food & Drinks', 'Snorkeling Gear Provided', 'Up to 50 Guests'],
        price: 'From \u20AC45/person',
      },
    ]}
  />

  <!-- 6. Why Cruise with El Greco -->
  <ServiceWhySection
    layout="right"
    title="Why Cruise with Us"
    subtitle="The Rhodes Boat Tours Difference"
    description="Our cruises have been the ones locals recommend for over fifteen years. With all-inclusive pricing, expert local knowledge, and a crew that treats every guest like family, your day on the water will be the highlight of your Rhodes holiday."
    image="/assets/img/cruises/greco_home3.jpg"
    features={[
      { icon: '/assets/img/icon/about_1_1.svg', title: 'All-Inclusive Pricing', text: 'One price covers everything — food, drinks, music, and snorkeling gear. No hidden costs.' },
      { icon: '/assets/img/icon/about_1_2.svg', title: 'Local Expertise', text: '15+ years cruising the Rhodes coast — we know every bay, cove, and sunset spot.' },
      { icon: '/assets/img/icon/about_1_3.svg', title: 'Premium Comfort', text: 'Spacious vessels with shaded areas, comfortable seating, and onboard facilities.' },
    ]}
  />

  <!-- 7. Bucket List -->
  <ServiceBucketList
    title="Cruise Experiences You'll Never Forget"
    subtitle="Bucket List"
    items={[
      { title: 'Swim in Anthony Quinn Bay', description: 'Dive into the crystal-clear emerald waters of one of the most famous bays in the Mediterranean, surrounded by dramatic rocky cliffs.' },
      { title: 'Watch the Sunset from the Open Sea', description: 'See the sky turn amber and gold as the sun dips below the horizon — an unobstructed view only possible from the water.' },
      { title: 'Snorkel over Hidden Reefs', description: 'Explore vibrant underwater worlds at secret spots along the coastline, with snorkeling gear provided on every cruise.' },
      { title: 'Feast on Fresh Mediterranean Cuisine Onboard', description: 'Enjoy freshly prepared local dishes and seasonal fruits while anchored in a tranquil bay.' },
      { title: 'Dance to Live Music on Deck', description: 'Let the rhythm carry you as the crew plays music and the coastline provides the backdrop for an unforgettable party.' },
      { title: 'Discover Secret Coves Only Reachable by Boat', description: 'Visit hidden beaches and secluded swimming spots that no road can reach — exclusive access from the sea.' },
    ]}
  />

  <!-- 8. How It Works -->
  <ServiceMiseChecklist
    title="Book Your Cruise in Four Steps"
    subtitle="How It Works"
    steps={[
      { title: 'Choose Your Cruise', description: 'Pick from three signature experiences \u2014 full-day fun, sunset magic, or bay-to-bay adventure.', icon: 'fa-solid fa-ship' },
      { title: 'Pick Your Date', description: 'Daily departures from May through October. Choose the day that fits your holiday schedule.', icon: 'fa-regular fa-calendar' },
      { title: 'Book Online or Call', description: 'Reserve your spot instantly online or contact us directly. We confirm within hours.', icon: 'fa-solid fa-phone' },
      { title: 'Board & Enjoy', description: 'Meet at Mandraki Harbor, step aboard, and let the crew handle everything from there.', icon: 'fa-solid fa-anchor' },
    ]}
  />

  <!-- 10. Related Services -->
  <div class="bg-smoke space overflow-hidden">
    <div class="container">
      <div class="title-area text-center mb-50">
        <span class="sub-title style1" data-ani="slideinup">Explore More</span>
        <h2 class="sec-title" data-ani="slideinup" data-ani-delay="0.1">Our Other Services</h2>
      </div>
      <div class="row gy-30 justify-content-center">
        <div class="col-lg-6">
          <a href="/service/rhodes-boat-trips" class="related-service-card" data-ani="slideinup">
            <div class="related-service-card_img">
              <img src="/assets/img/cruises/boat1.jpg" alt="Private Boat Tours" loading="lazy" />
              <div class="related-service-card_overlay"></div>
            </div>
            <div class="related-service-card_content">
              <h4 class="related-service-card_title">Private Boat Tours</h4>
              <p class="related-service-card_text">Luxury sailing yacht charters across the Dodecanese islands with tailor-made itineraries.</p>
              <span class="th-btn style3 th-icon">Explore <i class="fas fa-arrow-right ms-2"></i></span>
            </div>
          </a>
        </div>
        <div class="col-lg-6">
          <a href="/service/rodos-boat-tours" class="related-service-card" data-ani="slideinup" data-ani-delay="0.15">
            <div class="related-service-card_img">
              <img src="/assets/img/cruises/greco_gallery2.jpg" alt="Rhodes Boat Tours" loading="lazy" />
              <div class="related-service-card_overlay"></div>
            </div>
            <div class="related-service-card_content">
              <h4 class="related-service-card_title">Rhodes Boat Tours</h4>
              <p class="related-service-card_text">Guided day trips along the stunning Rhodes coastline and nearby islands.</p>
              <span class="th-btn style3 th-icon">Explore <i class="fas fa-arrow-right ms-2"></i></span>
            </div>
          </a>
        </div>
      </div>
    </div>
  </div>

  <FooterFour />
</BaseLayout>

<style>
  /* ===== About-style Split Sections ===== */
  .about-split__img {
    border-radius: 8px;
    overflow: hidden;
  }

  .about-split__img :global(img) {
    aspect-ratio: 4 / 3;
    object-fit: cover;
    width: 100%;
    display: block;
  }

  .about-split__accent {
    display: block;
    width: 30px;
    height: 4px;
    background: var(--theme-color);
    margin-bottom: 20px;
    border-radius: 2px;
  }

  .about-split__subtitle {
    color: var(--theme-color);
    font-size: 17px;
    margin-bottom: 15px;
  }

  /* ===== Related Services Cards ===== */
  .related-service-card {
    display: block;
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    height: 350px;
    text-decoration: none;
  }
  .related-service-card_img {
    position: absolute;
    inset: 0;
  }
  .related-service-card_img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s;
  }
  .related-service-card:hover .related-service-card_img img {
    transform: scale(1.05);
  }
  .related-service-card_overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(0deg, rgba(0,0,0,0.75) 0%, rgba(0,0,0,0.15) 60%);
  }
  .related-service-card_content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 30px;
    z-index: 1;
  }
  .related-service-card_title {
    color: #fff;
    margin-bottom: 8px;
    font-size: 1.5rem;
  }
  .related-service-card_text {
    color: rgba(255,255,255,0.85);
    margin-bottom: 15px;
    font-size: 0.95rem;
  }
</style>
