---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../sections/home-one/Section1-Header.astro';
import FooterFour from '../../sections/shared/FooterFour.astro';
import ScrollToTop from '../../components/interactive/ScrollToTop';
import ServiceHeroFullwidth from '../../sections/service/ServiceHeroFullwidth.astro';
import ServiceOverview from '../../sections/service/ServiceOverview.astro';
import ServiceVesselsShowcase from '../../sections/service/ServiceVesselsShowcase.astro';
import ServiceWhySection from '../../sections/service/ServiceWhySection.astro';
import ServiceBucketList from '../../sections/service/ServiceBucketList.astro';
import ServiceMiseChecklist from '../../sections/service/ServiceMiseChecklist.astro';
---

<BaseLayout title="Speedboat Tours with Skipper in Rhodes - Rhodos Yachts">
  <Header />

  <!-- 1. Hero -->
  <ServiceHeroFullwidth
    title="Speedboat Tours with Skipper in Rhodes"
    subtitle="Explore hidden bays, swim in crystal-clear waters, and discover the Rhodes coastline aboard a high-performance RIB."
    backgroundImage="/assets/img/skipper/mako-hero.jpg"
    heroVideo="/assets/img/hero/services/skipper.mp4"
    cta1Text="View Our Tours"
    cta2Text="Contact Us"
  />

  <!-- 2. Overview -->
  <ServiceOverview
    title="The Fastest Way to See Rhodes"
    subtitle="Overview"
    description="Private speedboat experiences along the stunning east coast of Rhodes. With a professional captain at the helm, all you need to do is sit back, feel the breeze, and enjoy the ride."
    features={[
      { icon: '/assets/img/icon/about_1_1.svg', title: '4-Hour Private Cruise', text: 'Half-day adventure with swimming stops at Tsambika, Red Sand Beach, Lindos, and Navarone Bay.' },
      { icon: '/assets/img/icon/about_1_2.svg', title: '7-Hour Full-Day Cruise', text: 'Extended coastline exploration with more stops, more swimming, and a full meal on board.' },
      { icon: '/assets/img/icon/about_1_3.svg', title: 'Professional Skipper', text: 'Licensed captain with expert local knowledge — no licence needed from you.' },
    ]}
    stats={[
      { value: 3, suffix: '', label: 'Tour Experiences' },
      { value: 10, suffix: '', label: 'Max Guests' },
      { value: 1, suffix: '', label: 'Captain Included' },
      { value: 5, suffix: '★', label: 'Guest Rating' },
    ]}
  />

  <!-- 3. Our Story — Image Left, Text Right -->
  <section class="about-split space">
    <div class="container">
      <div class="row align-items-center gy-40">
        <div class="col-lg-6" data-ani="slideinleft">
          <div class="about-split__img">
            <img class="global-img" src="/assets/img/skipper/mako-boat-1.jpg" alt="RIB speedboat in Rhodes" />
          </div>
        </div>
        <div class="col-lg-6" data-ani="slideinright">
          <div class="about-split__text ps-lg-4">
            <span class="about-split__accent"></span>
            <div class="title-area mb-20">
              <h2 class="sec-title">Born on the Water</h2>
            </div>
            <p class="about-split__subtitle"><em>Born from a love of the sea and the Rhodes coastline</em></p>
            <p>
              Our skipper partner in Kolympia operates a premium 8.25m RIB, combining speed,
              comfort, and safety for an unforgettable experience along the island's east coast.
              Founded by a sea enthusiast who wanted to share the magic of Rhodes from the water,
              this is speedboat touring done right.
            </p>
            <p>
              Every trip is designed with intimate knowledge of the coastline — knowing exactly where
              the hidden bays are, which coves offer the calmest water for swimming, and how to make
              every moment on the water count.
            </p>
            <a href="#tours" class="th-btn style3 th-icon mt-25">View Our Tours</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. Your Boat, Your Captain — Text Left, Image Right (reversed) -->
  <section class="about-split bg-smoke space">
    <div class="container">
      <div class="row align-items-center flex-lg-row-reverse gy-40">
        <div class="col-lg-6" data-ani="slideinright">
          <div class="about-split__img">
            <img class="global-img" src="/assets/img/skipper/mako-boat-2.jpg" alt="The Enjoy RIB speedboat in Rhodes" />
          </div>
        </div>
        <div class="col-lg-6" data-ani="slideinleft">
          <div class="about-split__text pe-lg-4">
            <span class="about-split__accent"></span>
            <div class="title-area mb-20">
              <h2 class="sec-title">Your Boat, Your Captain</h2>
            </div>
            <p class="about-split__subtitle"><em>The "Enjoy" — an 8.25m high-performance RIB</em></p>
            <p>
              Built for speed and comfort, the Enjoy carries up to 10 guests in style. A luxury
              sunbathing deck, premium sound system with Wi-Fi, onboard shower and WC, and full
              snorkeling gear come standard on every trip. Your professional captain handles
              everything — no licence needed from you.
            </p>
            <p>
              Whether you're chasing hidden coves or anchoring in a turquoise bay, this boat was
              designed for exactly that: giving you the freedom to enjoy Rhodes from the water
              without a single worry.
            </p>
            <a href="/contact" class="th-btn style3 th-icon mt-25">Book Your Trip</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 5. Tour Showcase -->
  <div id="tours">
    <ServiceVesselsShowcase
      title="Our Tours"
      subtitle="Three Signature Experiences"
      vessels={[
        {
          name: '4-Hour Private Cruise',
          image: '/assets/img/skipper/mako-anthony-quinn.jpg',
          specs: ['4 Hours', 'Up to 10 Guests', 'Snacks & Cocktails Included', 'Stops: Tsambika · Red Sand · Lindos · Navarone'],
          price: 'From €400',
        },
        {
          name: '7-Hour Private Cruise',
          image: '/assets/img/skipper/mako-swimming.jpg',
          specs: ['7 Hours', 'Up to 10 Guests', 'Full Meal · Cocktails · Soft Drinks', 'Extended stops + more coastline'],
          price: 'From €600',
        },
        {
          name: 'Sunday BBQ Trip',
          image: '/assets/img/skipper/mako-bbq.jpg',
          specs: ['7 Hours · Every Sunday', 'Up to 10 Guests', 'Greek Souvlaki · Beer · Water', 'Destination: Red Sand Beach · Snorkeling'],
          price: '€80/person',
        },
      ]}
    />
  </div>

  <!-- 6. Explore the East Coast — Image Left, Text Right -->
  <section class="about-split space">
    <div class="container">
      <div class="row align-items-center gy-40">
        <div class="col-lg-6" data-ani="slideinleft">
          <div class="about-split__img">
            <img class="global-img" src="/assets/img/skipper/mako-lindos.jpg" alt="Lindos coastline from the sea" />
          </div>
        </div>
        <div class="col-lg-6" data-ani="slideinright">
          <div class="about-split__text ps-lg-4">
            <span class="about-split__accent"></span>
            <div class="title-area mb-20">
              <h2 class="sec-title">Explore the East Coast</h2>
            </div>
            <p class="about-split__subtitle"><em>The 4-hour cruise — your half-day escape</em></p>
            <p>
              Depart from Kolympia and head south along the stunning east coast. Visit the golden
              sands of Tsambika Beach, discover the boat-only Red Sand Beach, sail past the
              clifftop Acropolis of Lindos, and swim in the legendary Navarone Bay.
            </p>
            <p>
              Snacks, cocktails, and soft drinks are included — all you need is sunscreen and a
              sense of adventure. Your captain knows every hidden spot along this stretch of
              coastline.
            </p>
            <a href="/contact" class="th-btn style3 th-icon mt-25">Book the 4-Hour Cruise</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 7. The Full-Day Experience — Text Left, Image Right (reversed) -->
  <section class="about-split bg-smoke space">
    <div class="container">
      <div class="row align-items-center flex-lg-row-reverse gy-40">
        <div class="col-lg-6" data-ani="slideinright">
          <div class="about-split__img">
            <img class="global-img" src="/assets/img/skipper/mako-red-sand.jpg" alt="Red Sand Beach, Rhodes" />
          </div>
        </div>
        <div class="col-lg-6" data-ani="slideinleft">
          <div class="about-split__text pe-lg-4">
            <span class="about-split__accent"></span>
            <div class="title-area mb-20">
              <h2 class="sec-title">The Full-Day Experience</h2>
            </div>
            <p class="about-split__subtitle"><em>7 hours of coastline, swimming, and feasting</em></p>
            <p>
              The extended cruise takes you further along the east coast with more swimming stops,
              more hidden coves, and a complete meal on board. Visit Anthony Quinn Bay, Tsambika,
              Red Sand Beach, Lindos, Navarone Bay, and beyond.
            </p>
            <p>
              Cocktails, soft drinks, water, and a full meal are all included. This is the ultimate
              way to experience the Rhodes coastline — unhurried, with time to swim, explore, and
              soak it all in.
            </p>
            <a href="/contact" class="th-btn style3 th-icon mt-25">Book the 7-Hour Cruise</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 8. Why Book Through Rhodos Yachts -->
  <ServiceWhySection
    layout="right"
    title="Why Book Through Rhodos Yachts"
    subtitle="The Rhodos Yachts Difference"
    description="We partner directly with vetted local operators to bring you the best speedboat experience in Rhodes — no middlemen, no markups, and full concierge support from enquiry to boarding."
    image="/assets/img/skipper/mako-about.jpg"
    features={[
      { icon: '/assets/img/icon/about_1_1.svg', title: 'Vetted Local Operators', text: 'Every partner is hand-selected and regularly reviewed for quality, safety, and guest satisfaction.' },
      { icon: '/assets/img/icon/about_1_2.svg', title: 'Direct Partnerships', text: 'We work directly with trusted local operators — no middlemen, just seamless communication and a premium experience.' },
      { icon: '/assets/img/icon/about_1_3.svg', title: 'Concierge Support', text: 'From choosing the right tour to arranging transfers — we handle every detail for you.' },
    ]}
  />

  <!-- 9. Bucket List -->
  <ServiceBucketList
    title="Speedboat Experiences You'll Never Forget"
    subtitle="Bucket List"
    items={[
      { title: 'Swim at Red Sand Beach', description: 'A stunning stretch of crimson sand accessible only by boat — one of Rhodes\' best-kept secrets.' },
      { title: 'Cruise Past the Acropolis of Lindos', description: 'See the iconic clifftop ruins from the sea — a perspective most visitors never get to experience.' },
      { title: 'Snorkel in Navarone Bay', description: 'Dive into the turquoise waters of the bay made famous by the film "The Guns of Navarone."' },
      { title: 'Enjoy a Greek BBQ in a Hidden Cove', description: 'Anchor in a secluded bay and feast on a freshly prepared meal with the sea as your backdrop.' },
      { title: 'Feel the Thrill of a High-Speed RIB Ride', description: 'Experience the raw power of an 8.25m RIB cutting through the Aegean at full speed.' },
      { title: 'Dive into Anthony Quinn Bay', description: 'Plunge into the emerald waters of one of the most photographed bays in the Mediterranean.' },
    ]}
  />

  <!-- 10. How It Works -->
  <ServiceMiseChecklist
    title="Book Your Speedboat Tour in Four Steps"
    subtitle="How It Works"
    steps={[
      { title: 'Tell Us What You Want', description: 'Share your preferred dates, group size, and whether you want the 4-hour or 7-hour experience.', icon: 'fa-regular fa-envelope' },
      { title: 'Get a Tailored Recommendation', description: 'We match you with the right tour based on your interests, schedule, and group.', icon: 'fa-solid fa-compass' },
      { title: 'Confirm & Prepare', description: 'Your booking is locked in and all the details are handled — just show up and enjoy.', icon: 'fa-solid fa-circle-check' },
      { title: 'Step Aboard', description: 'Meet your captain at Kolympia, step onto the Enjoy, and set off along the Rhodes coastline.', icon: 'fa-solid fa-anchor' },
    ]}
  />

  <!-- 11. Related Services -->
  <div class="bg-smoke space overflow-hidden">
    <div class="container">
      <div class="title-area text-center mb-50">
        <span class="sub-title style1" data-ani="slideinup">Explore More</span>
        <h2 class="sec-title" data-ani="slideinup" data-ani-delay="0.1">Our Other Services</h2>
      </div>
      <div class="row gy-30 justify-content-center">
        <div class="col-lg-6">
          <a href="/service/rodos-boat-tours" class="related-service-card" data-ani="slideinup">
            <div class="related-service-card_img">
              <img src="/assets/img/tours/hero-rhodes-coast.jpg" alt="Boat Tours in Rhodes" loading="lazy" />
              <div class="related-service-card_overlay"></div>
            </div>
            <div class="related-service-card_content">
              <h4 class="related-service-card_title">Boat Tours in Rhodes</h4>
              <p class="related-service-card_text">Guided day trips along the stunning Rhodes coastline and nearby islands.</p>
              <span class="th-btn style3 th-icon">Explore <i class="fas fa-arrow-right ms-2"></i></span>
            </div>
          </a>
        </div>
        <div class="col-lg-6">
          <a href="/service/rodos-rent-boats-license-free" class="related-service-card" data-ani="slideinup" data-ani-delay="0.15">
            <div class="related-service-card_img">
              <img src="/assets/img/normal/about_3_1.jpg" alt="License-Free Boat Rental" loading="lazy" />
              <div class="related-service-card_overlay"></div>
            </div>
            <div class="related-service-card_content">
              <h4 class="related-service-card_title">License-Free Boat Rental</h4>
              <p class="related-service-card_text">No licence needed — hop on and explore the Rhodes coastline at your own pace.</p>
              <span class="th-btn style3 th-icon">Explore <i class="fas fa-arrow-right ms-2"></i></span>
            </div>
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- 12. Footer + ScrollToTop -->
  <FooterFour />
  <ScrollToTop client:load />
</BaseLayout>

<style>
  /* ===== About-style Split Sections ===== */
  .about-split__img {
    border-radius: 8px;
    overflow: hidden;
  }

  .about-split__img :global(img) {
    aspect-ratio: 4 / 3;
    object-fit: cover;
    width: 100%;
    display: block;
  }

  .about-split__accent {
    display: block;
    width: 30px;
    height: 4px;
    background: var(--theme-color);
    margin-bottom: 20px;
    border-radius: 2px;
  }

  .about-split__subtitle {
    color: var(--theme-color);
    font-size: 17px;
    margin-bottom: 15px;
  }

  /* ===== Related Services Cards ===== */
  .related-service-card {
    display: block;
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    height: 350px;
    text-decoration: none;
  }
  .related-service-card_img {
    position: absolute;
    inset: 0;
  }
  .related-service-card_img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s;
  }
  .related-service-card:hover .related-service-card_img img {
    transform: scale(1.05);
  }
  .related-service-card_overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(0deg, rgba(0,0,0,0.75) 0%, rgba(0,0,0,0.15) 60%);
  }
  .related-service-card_content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 30px;
    z-index: 1;
  }
  .related-service-card_title {
    color: #fff;
    margin-bottom: 8px;
    font-size: 1.5rem;
  }
  .related-service-card_text {
    color: rgba(255,255,255,0.85);
    margin-bottom: 15px;
    font-size: 0.95rem;
  }
</style>
