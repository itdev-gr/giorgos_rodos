---

<BaseLayout title="Premium Yacht Charter in Rhodes - Rhodes Boat Tours">
  <Header />

  <ServiceHeroFullwidth
    title="Premium Yacht Charter in Rhodes"
    subtitle="Over 80 sailing yachts and catamarans based in Rhodes and Kos. Bareboat or crewed — the entire Dodecanese is yours to explore, at your own pace."
    backgroundImage="/assets/img/fleet/oceanis-511-lupo-di-mare.jpg"
    heroVideo="/assets/img/hero/services/charter.mp4"
    cta1Text="Book a Charter"
    cta2Text="View Fleet"
  />

  <ServiceWhySection
    layout="left"
    title="Why Rhodes Is the Perfect Place to Charter"
    subtitle="The Perfect Starting Point"
    description="Rhodes sits at the crossroads of the Aegean and Mediterranean. The waters here are sheltered, the islands are close together, and the sailing season stretches from April to November. We have been chartering from this base for over fifteen years, and we still discover new favourite spots every summer."
    image="/assets/img/fleet/lagoon-42-aenaos.jpg"
    features={[
      { icon: '/assets/img/icon/about_1_1.svg', title: '300+ Days of Sunshine', text: 'Ideal sailing conditions from April through November with calm seas and steady breezes.' },
      { icon: '/assets/img/icon/about_1_2.svg', title: 'Island-Hopping Paradise', text: 'Over 15 islands within easy reach — from cosmopolitan Symi to untouched Tilos.' },
      { icon: '/assets/img/icon/about_1_3.svg', title: 'Expert Local Crews', text: 'Our captains know every hidden cove, sunset anchorage, and waterfront taverna.' },
    ]}
  />

  <ServiceSeasonInfo
    title="When to Charter"
    subtitle="Sailing Seasons"
    image="/assets/img/fleet/lagoon-46-krista.jpg"
    seasons={[
      { name: 'Spring', months: 'April – May', description: 'Mild temps, empty anchorages, wildflowers on every island. Perfect for couples and explorers.', recommended: false },
      { name: 'High Summer', months: 'June – August', description: 'Warm waters, vibrant nightlife, peak conditions for swimming and water sports.', recommended: true },
      { name: 'Golden Autumn', months: 'September – October', description: 'Warm sea, fewer crowds, golden light — the insider favorite season.', recommended: true },
      { name: 'Winter', months: 'November – March', description: 'Limited availability. Special requests for experienced sailors and coastal exploration.', recommended: false },
    ]}
  />

  <ServiceBucketList
    title="Things to Do on Your Charter"
    subtitle="Bucket List"
    items={[
      { title: 'Swim in Tsambika Bay', description: 'Anchor off one of the most beautiful sandy beaches in the Mediterranean with turquoise shallows.' },
      { title: 'Explore Symi Harbor', description: 'Cruise into the iconic pastel-painted harbor and dine on fresh seafood at waterfront tavernas.' },
      { title: 'Snorkel at Lindos', description: 'Discover underwater caves and crystal-clear waters beneath the ancient Acropolis.' },
      { title: 'Sunset at Halki', description: 'Watch the golden sunset from a remote anchorage off this car-free island paradise.' },
      { title: 'Dive in Charaki', description: 'Explore submerged rock formations and marine life in one of the best dive spots in Rhodes.' },
      { title: 'Private Beach BBQ', description: 'Your crew sets up a gourmet barbecue on a secluded beach accessible only by sea.' },
    ]}
  />

  <ServiceDiscoveryCTA
    title="Discover the Dodecanese"
    description="From the medieval walls of Rhodes Town to the volcanic shores of Nisyros — a thousand stories await on the water."
    backgroundImage="/assets/img/fleet/lagoon-55-utopia.jpg"
    ctaText="Plan Your Route"
  />

  <ServicePlanningCTA
    title="Let Us Craft Your Perfect Experience"
    description="Every charter is bespoke. Tell us your dream — island-hopping adventure, romantic getaway, corporate event, or family celebration — and our team will design a voyage to remember. From vessel selection to custom itinerary and onboard catering, we handle every detail."
    image1="/assets/img/fleet/hanse-510-sea-emerald.jpg"
    image2="/assets/img/fleet/so-479-iraklia.jpg"
    image3="/assets/img/fleet/lagoon-50-rio.jpg"
  />

  <ServiceDestinationsCarousel
    title="Charter Destinations"
    subtitle="Where to Go"
    destinations={[
      { name: 'Symi', description: 'Neoclassical harbor and pristine bays', image: 'https://images.unsplash.com/photo-1586861635167-e5223aadc9fe?w=600&h=400&fit=crop' },
      { name: 'Halki', description: 'Car-free tranquility and turquoise waters', image: 'https://images.unsplash.com/photo-1601581875309-fafbf2d3ed3a?w=600&h=400&fit=crop' },
      { name: 'Tilos', description: 'Untouched nature and hiking trails', image: 'https://images.unsplash.com/photo-1504512485720-7d83a16ee930?w=600&h=400&fit=crop' },
      { name: 'Nisyros', description: 'Volcanic landscapes and thermal springs', image: 'https://images.unsplash.com/photo-1515859005217-8a1f08870f59?w=600&h=400&fit=crop' },
      { name: 'Kastellorizo', description: 'The easternmost gem of Greece with Blue Cave', image: 'https://images.unsplash.com/photo-1580502304784-8985b7eb7260?w=600&h=400&fit=crop' },
      { name: 'Lindos Bay', description: 'Ancient acropolis meets azure waters', image: 'https://images.unsplash.com/photo-1533105079780-92b9be482077?w=600&h=400&fit=crop' },
    ]}
  />

  <ServiceVesselsShowcase
    title="Sailing Yachts"
    subtitle="Our Fleet"
    vessels={sailingYachts}
  />

  <ServiceVesselsShowcase
    title="Catamarans"
    subtitle="Our Fleet"
    vessels={catamarans}
  />

  <ServiceVesselsShowcase
    title="Motor Yachts & Special"
    subtitle="Our Fleet"
    vessels={motorYachts}
  />

  <ServiceOverview
    title="One Company, Complete Service"
    subtitle="Why Rhodes Boat Tours"
    description="From the moment you send us a message to the moment you step off the boat, our team manages everything. Vessel selection, provisioning, route planning, skipper coordination — all handled by people who know these waters personally."
    features={[
      { icon: '/assets/img/icon/about_1_1.svg', title: 'Bespoke Itineraries', text: 'Every trip is custom-designed around your preferences, pace, and interests.' },
      { icon: '/assets/img/icon/about_1_2.svg', title: 'Turnkey Experience', text: 'Crew, catering, water toys, transfers — we handle every detail.' },
      { icon: '/assets/img/icon/about_1_3.svg', title: 'Local Expertise', text: '15+ years of operating in the Dodecanese. We know every island intimately.' },
    ]}
    stats={[
      { value: 15, suffix: '+', label: 'Years Experience' },
      { value: 2000, suffix: '+', label: 'Charter Trips' },
      { value: 80, suffix: '+', label: 'Vessels' },
      { value: 5, suffix: '★', label: 'Rating' },
    ]}
