              <span class="tr-dot3" style="width: 10px; height: 10px; border-radius: 50%; background: #fff; opacity: 0.4; cursor: pointer; transition: opacity 0.3s;"></span>
              <span class="tr-dot3" style="width: 10px; height: 10px; border-radius: 50%; background: #fff; opacity: 0.4; cursor: pointer; transition: opacity 0.3s;"></span>
