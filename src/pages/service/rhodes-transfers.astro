---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../sections/home-one/Section1-Header.astro';
import FooterFour from '../../sections/shared/FooterFour.astro';
import ServiceHeroFullwidth from '../../sections/service/ServiceHeroFullwidth.astro';
---

<BaseLayout title="Rhodes Transfers — Airport, Hotel & Marina Transfers | Rhodes Boat Tours" description="Transportation services in Rhodes. Airport transfers, hotel transfers, marina transfers and private transportation. Connected with reliable local transfer providers.">
  <Header />

  <!-- 1. Hero -->
  <ServiceHeroFullwidth
    title="Rhodes Transfers"
    subtitle="Airport, Hotel and Marina Transfers"
    backgroundImage="/assets/img/transfers/rhodes-transfer-hero.jpg"
    heroVideo="/assets/img/hero/services/charter.mp4"
  />

  <!-- 2. Intro -->
  <section style="padding: 60px 0 40px;">
    <div class="container">
      <div style="max-width: 700px; margin: 0 auto; text-align: center; margin-bottom: 40px;">
        <p style="font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 1.2rem; line-height: 1.7; color: #1CA8CB; margin-bottom: 0;" data-ani="fadein">
          Getting around Rhodes should be simple. We connect you with reliable local transfer providers.
        </p>
      </div>
      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px;" class="tr-intro-grid" data-ani="slideinup" data-ani-delay="0.1">
        <div style="text-align: center; padding: 32px 24px;">
          <div style="width: 56px; height: 56px; border-radius: 14px; background: rgba(28,168,203,0.1); color: #1CA8CB; display: inline-flex; align-items: center; justify-content: center; font-size: 1.3rem; margin-bottom: 18px;">
            <i class="fas fa-plane-arrival"></i>
          </div>
          <h3 style="font-family: 'Playfair Display', serif; font-size: 1rem; font-weight: 700; color: #113D48; margin-bottom: 10px;">Airport Transfers</h3>
          <p style="font-size: 0.9rem; line-height: 1.65; color: #6b7c85; margin: 0;">Private transfers from Rhodes Airport to hotels, villas, marinas and resorts. Cars, minivans and coaches available.</p>
        </div>
        <div style="text-align: center; padding: 32px 24px;">
          <div style="width: 56px; height: 56px; border-radius: 14px; background: rgba(28,168,203,0.1); color: #1CA8CB; display: inline-flex; align-items: center; justify-content: center; font-size: 1.3rem; margin-bottom: 18px;">
            <i class="fas fa-anchor"></i>
          </div>
          <h3 style="font-family: 'Playfair Display', serif; font-size: 1rem; font-weight: 700; color: #113D48; margin-bottom: 10px;">Marina Transfers</h3>
          <p style="font-size: 0.9rem; line-height: 1.65; color: #6b7c85; margin: 0;">Transfers to Mandraki Harbour, Rhodes Marina, Faliraki, Kolymbia, Lindos and other boat departure points.</p>
        </div>
        <div style="text-align: center; padding: 32px 24px;">
          <div style="width: 56px; height: 56px; border-radius: 14px; background: rgba(28,168,203,0.1); color: #1CA8CB; display: inline-flex; align-items: center; justify-content: center; font-size: 1.3rem; margin-bottom: 18px;">
            <i class="fas fa-handshake"></i>
          </div>
          <h3 style="font-family: 'Playfair Display', serif; font-size: 1rem; font-weight: 700; color: #113D48; margin-bottom: 10px;">Local Partners</h3>
          <p style="font-size: 0.9rem; line-height: 1.65; color: #6b7c85; margin: 0;">We work with reliable local transfer companies — professional drivers, modern vehicles and trusted service.</p>
        </div>
      </div>
      <div style="text-align: center; margin-top: 28px;" data-ani="fadein" data-ani-delay="0.2">
        <p style="font-family: 'Playfair Display', serif; font-weight: 600; font-size: 0.95rem; color: #113D48; margin: 0 0 20px;">
          We recommend <a href="https://www.rhodestransfer24.com/" target="_blank" style="color: #1CA8CB; text-decoration: underline;">RhodesTransfer24</a> — a trusted local transfer company in Rhodes.
        </p>
        <a href="https://www.rhodestransfer24.com/" target="_blank" class="th-btn style3 th-icon">Book Your Transfer <i class="fas fa-external-link-alt" style="margin-left: 6px; font-size: 0.8rem;"></i></a>
      </div>
    </div>
  </section>

  <!-- 3. Split Section — Carousel Left, Text Right -->
  <section style="padding: 60px 0;">
    <div class="container">
      <div class="row align-items-center gy-40">
        <div class="col-lg-6" data-ani="slideinleft">
          <div class="tr-carousel" style="border-radius: 12px; overflow: hidden; position: relative; aspect-ratio: 4/3;">
            <div class="tr-carousel-track">
              <img src="/assets/img/transfers/tesla-exterior.jpg" alt="Tesla transfer in Rhodes" style="width: 100%; height: 100%; object-fit: cover; position: absolute; inset: 0;" />
              <img src="/assets/img/transfers/tesla-interior.jpg" alt="Tesla interior" style="width: 100%; height: 100%; object-fit: cover; position: absolute; inset: 0; opacity: 0;" />
              <img src="/assets/img/transfers/tesla-interior-2.jpg" alt="Tesla interior with Rhodes view" style="width: 100%; height: 100%; object-fit: cover; position: absolute; inset: 0; opacity: 0;" />
            </div>
            <div class="tr-carousel-dots" style="position: absolute; bottom: 14px; left: 50%; transform: translateX(-50%); display: flex; gap: 8px; z-index: 2;">
              <span class="tr-dot tr-dot--active" style="width: 10px; height: 10px; border-radius: 50%; background: #fff; cursor: pointer; transition: opacity 0.3s;"></span>
              <span class="tr-dot" style="width: 10px; height: 10px; border-radius: 50%; background: #fff; opacity: 0.4; cursor: pointer; transition: opacity 0.3s;"></span>
              <span class="tr-dot" style="width: 10px; height: 10px; border-radius: 50%; background: #fff; opacity: 0.4; cursor: pointer; transition: opacity 0.3s;"></span>
            </div>
          </div>
        </div>
        <div class="col-lg-6" data-ani="slideinright">
          <div style="padding-left: 20px;">
            <h2 style="font-family: 'Playfair Display', serif; font-size: 1.5rem; font-weight: 700; color: #113D48; margin-bottom: 16px;">Explore Rhodes Your Way</h2>
            <p style="font-size: 1rem; line-height: 1.8; color: #4a5568; margin-bottom: 16px;">
              Whether you are arriving at the airport, heading to a marina for a boat tour, or moving between resorts on the island, a private transfer makes your journey comfortable and stress-free.
            </p>
            <p style="font-size: 1rem; line-height: 1.8; color: #4a5568;">
              We work with experienced local drivers who know Rhodes inside out. Modern vehicles, professional service and punctual pick-ups — so your holiday starts the moment you land.
            </p>
            <a href="https://www.rhodestransfer24.com/" target="_blank" style="display: inline-flex; align-items: center; gap: 6px; margin-top: 16px; font-family: 'Inter', sans-serif; font-size: 0.85rem; font-weight: 600; color: #1CA8CB; text-decoration: none;">Book at RhodesTransfer24.com <i class="fas fa-arrow-right" style="font-size: 0.75rem;"></i></a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. Split Section — Text Left, Image Right (reversed) -->
  <section style="padding: 60px 0; background: #f8fafb;">
    <div class="container">
      <div class="row align-items-center flex-lg-row-reverse gy-40">
        <div class="col-lg-6" data-ani="slideinright">
          <div class="tr-carousel2" style="border-radius: 12px; overflow: hidden; position: relative; aspect-ratio: 4/3;">
            <div class="tr-carousel2-track">
              <img src="/assets/img/transfers/mercedes-sclass.jpg" alt="Mercedes S-Class transfer in Rhodes" style="width: 100%; height: 100%; object-fit: cover; position: absolute; inset: 0;" />
              <img src="/assets/img/transfers/mercedes-interior.jpg" alt="Mercedes interior" style="width: 100%; height: 100%; object-fit: cover; position: absolute; inset: 0; opacity: 0;" />
            </div>
