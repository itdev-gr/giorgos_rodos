            </p>
            <a href="https://www.rhodestransfer24.com/" target="_blank" style="display: inline-flex; align-items: center; gap: 6px; margin-top: 16px; font-family: 'Inter', sans-serif; font-size: 0.85rem; font-weight: 600; color: #1CA8CB; text-decoration: none;">Book at RhodesTransfer24.com <i class="fas fa-arrow-right" style="font-size: 0.75rem;"></i></a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 5. Group Transfers — Image Left, Text Right -->
  <section style="padding: 60px 0;">
    <div class="container">
      <div class="row align-items-center gy-40">
        <div class="col-lg-6" data-ani="slideinleft">
          <div class="tr-carousel3" style="border-radius: 12px; overflow: hidden; position: relative; aspect-ratio: 4/3;">
            <div class="tr-carousel3-track">
              <img src="/assets/img/transfers/mercedes-vans.jpg" alt="Mercedes Sprinter vans in Rhodes" style="width: 100%; height: 100%; object-fit: cover; position: absolute; inset: 0;" />
              <img src="/assets/img/transfers/van-entrance.jpg" alt="VIP minibus entrance" style="width: 100%; height: 100%; object-fit: cover; position: absolute; inset: 0; opacity: 0;" />
              <img src="/assets/img/transfers/van-front.jpg" alt="Mercedes Sprinter front" style="width: 100%; height: 100%; object-fit: cover; position: absolute; inset: 0; opacity: 0;" />
