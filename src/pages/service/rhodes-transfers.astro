              <span class="tr-dot2" style="width: 10px; height: 10px; border-radius: 50%; background: #fff; opacity: 0.4; cursor: pointer; transition: opacity 0.3s;"></span>
            </div>
          </div>
        </div>
        <div class="col-lg-6" data-ani="slideinleft">
          <div style="padding-right: 20px;">
            <h2 style="font-family: 'Playfair Display', serif; font-size: 1.5rem; font-weight: 700; color: #113D48; margin-bottom: 16px;">More Than Just a Ride</h2>
            <p style="font-size: 1rem; line-height: 1.8; color: #4a5568; margin-bottom: 16px;">
