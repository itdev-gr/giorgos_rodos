---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../sections/home-one/Section1-Header.astro';
import FooterFour from '../../sections/shared/FooterFour.astro';
import BreadcrumbSchema from '../../components/seo/BreadcrumbSchema.astro';
import FAQSchema from '../../components/seo/FAQSchema.astro';
import services from '../../data/data-service.json';
import { getMediaSlot } from '../../lib/media';
import { SITE_URL } from '../../lib/seo';

const itemListJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Boat services in Rhodes',
  numberOfItems: services.length,
  itemListElement: services.map((s: any, i: number) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: `${SITE_URL}/service/${s.slug}`,
    name: s.title,
  })),
};

const featured = services.filter((s: any) => ['rhodes-charter', 'rhodes-boat-cruises', 'rhodes-boat-trips'].includes(s.slug));
const rest = services.filter((s: any) => !['rhodes-charter', 'rhodes-boat-cruises', 'rhodes-boat-trips'].includes(s.slug));

const heroImage = await getMediaSlot('service.index.hero.image', '/assets/img/gallery/yacht/yacht-luxury-1.jpg');
const heroVideo = await getMediaSlot('service.index.hero.video', '/assets/img/hero/services/charter.mp4');

const faqItems = [
  {
    question: 'Which service should I pick — rent a boat, boat tour or yacht charter?',
    answer: 'It depends on how independent you want to be. A license-free rental is best for couples and small families who want to swim in their own bay at their own pace. A guided boat tour or cruise works for groups that prefer a captain, a planned route and lunch on board. A yacht charter is the right choice for a multi-day Dodecanese trip with a crew. If you are unsure, contact us and we will recommend the right option for your group.',
  },
  {
    question: 'What does each service typically cost?',
    answer: 'License-free rentals start at the lower end and depend on boat size and rental duration. Shared boat tours and cruises are priced per person. Private boat trips and catamaran charters are priced per boat for a half or full day. Weekly yacht charters depend on the yacht type, season and whether a skipper is included. We send a clear, written quote before any booking — no hidden fees.',
  },
  {
    question: 'Are these services run by you directly or by partners?',
    answer: 'A mix of both. Some boats and yachts are operated directly by us; others are run by trusted local captains and small family-owned operators we have worked with for years. Either way, every operator on this page is one we know personally and would put our own family on.',
  },
  {
    question: 'Can I combine multiple services on the same trip?',
    answer: 'Yes — most of our visitors combine two or three. A common pairing is a license-free rental day plus a Symi cruise the next day, or a sunset cruise paired with a sidecar tour on the island. Tell us your dates and we will suggest a balanced plan.',
  },
  {
    question: 'Do you offer transfers from my hotel to the harbour?',
    answer: 'Yes. We provide private transfers from any hotel or villa in Rhodes to Mandraki Harbour, Faliraki, Kolymbia and other departure points. See the Rhodes Transfers service for details.',
  },
  {
    question: 'Which services are available year-round?',
    answer: 'Yacht charters and private boat trips run from late April to late October. Daily cruises and group tours operate from May to mid-October, with peak availability June–September. Sidecar tours, transfers and event planning run year-round.',
  },
];
---

<BaseLayout
  title="Boat Services in Rhodes — Tours, Rentals, Cruises & Charters"
  description="All our boat services in Rhodes in one place: boat tours, license-free rentals, sailing trips, catamaran cruises, yacht charters, MICE events, transfers and tender service. Local experts since 1998."
  ogImage={heroImage}
>
  <BreadcrumbSchema items={[
    { name: 'Home', url: '/' },
    { name: 'Services', url: '/service' },
  ]} />
  <script type="application/ld+json" set:html={JSON.stringify(itemListJsonLd)} is:inline />
  <FAQSchema items={faqItems} />
  <Header />

  <!-- Hero header -->
  <section class="services-hero">
    <div class="services-hero__bg">
      <img src={heroImage} alt="Luxury yacht anchored in the clear blue waters of Rhodes, Greece" />
      <div class="services-hero__overlay"></div>
    </div>
    <video class="services-hero__video" autoplay muted loop playsinline preload="metadata">
      <source src={heroVideo} type="video/mp4" />
    </video>
    <div class="services-hero__content">
      <h1 class="services-hub-h1">Boat Services in Rhodes — Tours, Rentals, Cruises and Charters</h1>
    </div>
  </section>

  <!-- Featured services — large cards -->
  <section class="services-featured">
    <div class="services-featured__grid">
      {featured.map((data: any, i: number) => (
        <a
          href={`/service/${data.slug}`}
          class="services-card services-card--featured"
          data-ani="slideinup"
          data-ani-delay={String(i * 0.15)}
        >
          <img src={data.image} alt={data.title} loading="lazy" />
          <div class="services-card__overlay"></div>
          <div class="services-card__content">
            <h2 class="services-card__title">{data.title}</h2>
            <p class="services-card__desc">{data.item}</p>
            <span class="services-card__link">Explore <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- SEO intro: explains what's on this page and helps users choose -->
  <section class="services-intro" data-ani="fadein">
    <div class="services-intro__inner">
      <h2 class="services-intro__title">Boat Services in Rhodes — Choose the Right Experience</h2>
      <div class="services-intro__copy">
        <p>From license-free boat rentals and skippered day cruises to private yacht charters, corporate events and harbour transfers, we connect you with trusted local operators across Rhodes. Every service on this page is run by a small, family-owned team we know personally — sailors, captains and event planners who have worked these waters for years.</p>
        <p>If you are not sure which option fits your group, the simplest path is to <a href="/contact">tell us what you have in mind</a>. We will recommend the best choice without sales pressure. You can also browse the <a href="/things-to-do">full catalog of approved boat experiences</a>.</p>
      </div>

      <div class="services-intro__pillars">
        <article class="services-pillar">
          <h3 class="services-pillar__title">For independent travellers</h3>
          <p class="services-pillar__body"><a href="/service/rhodes-rent-a-boat">Rent a boat in Rhodes</a> — license-free options for couples and small families, plus skippered boats if you prefer to relax. Best for crystal bays along the east coast.</p>
        </article>
        <article class="services-pillar">
          <h3 class="services-pillar__title">For organised day trips</h3>
          <p class="services-pillar__body"><a href="/service/rhodes-boat-cruises">Boat cruises</a> and <a href="/service/rhodes-catamaran-tours">catamaran tours</a> — Symi, Lindos, Anthony Quinn Bay and sunset routes. Lunch, swimming stops and a captain included.</p>
        </article>
        <article class="services-pillar">
          <h3 class="services-pillar__title">For private occasions</h3>
          <p class="services-pillar__body"><a href="/service/rhodes-charter">Yacht charter</a> for weekly Dodecanese itineraries, plus <a href="/service/rhodes-mice-events">corporate events</a> and group experiences.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- All other services -->
  <section class="services-more">
    <div class="services-more__header" data-ani="fadein">
      <h2 class="services-more__title">More Experiences</h2>
      <p class="services-more__subtitle">Discover the full range of our maritime services</p>
    </div>
    <div class="charter-grid">
      {rest.map((data: any, i: number) => (
        <a
          href={data.externalUrl ?? `/service/${data.slug}`}
          target={data.externalUrl ? '_blank' : undefined}
          rel={data.externalUrl ? 'noopener noreferrer' : undefined}
          class={`charter-card ${i === 0 ? 'charter-card--full' : 'charter-card--half'}`}
          data-ani="slideinup"
          data-ani-delay={String(i * 0.1)}
        >
          <img src={data.image} alt={data.title} loading="lazy" />
          <div class="charter-card__content">
            <h2>{data.title}</h2>
            <p>{data.item}</p>
            <span class="charter-card__btn">Learn More</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- FAQ section: helps users choose between services + FAQPage schema for rich results -->
  <section class="services-faq" data-ani="fadein">
    <div class="services-faq__inner">
      <h2 class="services-faq__title">Frequently Asked Questions</h2>
      <p class="services-faq__intro">Common questions about choosing between our services. For booking, weather and licence details, see the <a href="/faq">full FAQ</a>.</p>
      <div class="services-faq__list">
        {faqItems.map((item) => (
          <details class="services-faq__item">
            <summary class="services-faq__q">{item.question}</summary>
            <div class="services-faq__a"><p>{item.answer}</p></div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA banner -->
  <section class="services-cta" data-ani="fadein">
    <div class="services-cta__inner">
      <h2 class="services-cta__title">Not Sure Which Experience Is Right for You?</h2>
      <p class="services-cta__text">Send us a message and tell us what you have in mind. We will suggest the best option for your group — honestly and without pressure.</p>
      <a href="/contact" class="services-cta__btn">Get in Touch</a>
    </div>
  </section>

  <FooterFour />

  <script>
  </script>
</BaseLayout>

<style>
  /* ===== Visually hidden h1 for SEO ===== */
  .services-hub-h1 {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0,0,0,0);
    white-space: nowrap; border: 0;
  }

  /* ===== Hero ===== */
  .services-hero {
    position: relative;
    height: 60vh;
    min-height: 400px;
    max-height: 600px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .services-hero__bg {
    position: absolute;
    inset: 0;
  }

  .services-hero__bg video,
  .services-hero__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .services-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0,0,0,0.4) 0%, rgba(0,0,0,0.55) 100%);
  }

  /* Video hero — mobile only */
  .services-hero__video {
    display: none;
  }

  @media (max-width: 991px) {
    .services-hero__video {
      display: block;
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      z-index: 0;
    }

    .services-hero:has(.services-hero__video) .services-hero__bg {
      display: none;
    }

    .services-hero__overlay {
      z-index: 1;
      background: none;
    }

    .services-hero {
      align-items: flex-end;
    }

    .services-hero__content {
      z-index: 2;
      padding-bottom: 5vh;
    }
  }

  .services-hero__content {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 0 20px;
    max-width: 720px;
  }

  .services-hero__accent {
    display: block;
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 1.1rem;
    font-weight: 400;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.85);
    margin-bottom: 1rem;
  }

  .services-hero__title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    font-weight: 700;
    color: #fff;
    line-height: 1.15;
    margin: 0 0 1rem;
  }

  .services-hero__subtitle {
    font-family: 'Inter', sans-serif;
    font-size: clamp(1rem, 2vw, 1.15rem);
    font-weight: 300;
    color: rgba(255,255,255,0.8);
    margin: 0;
    letter-spacing: 0.3px;
  }

  /* ===== Featured cards ===== */
  .services-featured {
    padding: 0 16px;
    margin-top: -60px;
    position: relative;
    z-index: 3;
  }

  .services-featured__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    max-width: 1400px;
    margin: 0 auto;
  }

  .services-card--featured {
    position: relative;
    display: block;
    height: 420px;
    overflow: hidden;
    text-decoration: none;
    color: #fff;
  }

  .services-card--featured img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .services-card--featured:hover img {
    transform: scale(1.06);
  }

  .services-card--featured .services-card__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.05) 55%);
    transition: background 0.5s ease;
  }

  .services-card--featured:hover .services-card__overlay {
    background: linear-gradient(to top, rgba(0,0,0,0.75) 0%, rgba(0,0,0,0.15) 60%);
  }

  .services-card__content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 32px;
    z-index: 2;
  }

  .services-card__title {
    font-family: 'Playfair Display', serif;
    font-size: 1.65rem;
    font-weight: 600;
    color: #fff;
    margin: 0 0 8px;
    line-height: 1.25;
  }

  .services-card__desc {
    font-family: 'Inter', sans-serif;
    font-size: 0.9rem;
    font-weight: 300;
    color: rgba(255,255,255,0.8);
    margin: 0 0 16px;
    line-height: 1.5;
  }

  .services-card__link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: #fff;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.4s ease, transform 0.4s ease;
  }

  .services-card:hover .services-card__link {
    opacity: 1;
    transform: translateY(0);
  }

  /* ===== More Experiences (charter-card grid) ===== */
  .services-more {
    padding: 80px 0 0;
  }

  .services-more__header {
    text-align: center;
    margin-bottom: 40px;
  }

  .services-more__title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.8rem, 3vw, 2.4rem);
    font-weight: 700;
    color: #113D48;
    margin: 0 0 12px;
  }

  .services-more__subtitle {
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
    font-weight: 300;
    color: #6E7070;
    margin: 0;
  }

  .charter-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    padding: 0 16px;
  }

  .charter-card {
    position: relative;
    overflow: hidden;
    display: block;
    text-decoration: none;
    color: #fff;
  }

  .charter-card--full {
    grid-column: 1 / -1;
    height: 500px;
  }

  .charter-card--half {
    height: 480px;
  }

  .charter-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s ease;
  }

  .charter-card:hover img {
    transform: scale(1.05);
  }

  .charter-card::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.6) 0%, transparent 60%);
    pointer-events: none;
  }

  .charter-card__content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 35px;
    z-index: 1;
  }

  .charter-card__content h2 {
    font-family: var(--title-font, 'Playfair Display', serif);
    font-size: 36px;
    font-weight: 400;
    color: #fff;
    margin: 0 0 12px;
    line-height: 1.2;
  }

  .charter-card--half .charter-card__content h2 {
    font-size: 30px;
  }

  .charter-card__content p {
    font-family: var(--body-font, 'Inter', sans-serif);
    font-size: 15px;
    line-height: 1.6;
    color: #fff;
    margin: 0 0 20px;
    max-width: 520px;
  }

  .charter-card__btn {
    display: inline-block;
    border: 1.5px solid rgba(255, 255, 255, 0.7);
    color: #fff;
    background: transparent;
    padding: 14px 32px;
    font-family: var(--body-font, 'Inter', sans-serif);
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    transition: border-color 0.3s ease, background-color 0.3s ease;
    cursor: pointer;
  }

  .charter-card:hover .charter-card__btn {
    border-color: #fff;
    background-color: rgba(255, 255, 255, 0.1);
  }

  /* ===== CTA ===== */
  .services-cta {
    padding: 0 16px 100px;
    margin-top: 80px;
    max-width: 1400px;
    margin-left: auto;
    margin-right: auto;
  }

  .services-cta__inner {
    background: #113D48;
    padding: 64px 48px;
    text-align: center;
  }

  .services-cta__title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 700;
    color: #fff;
    margin: 0 0 12px;
  }

  .services-cta__text {
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
    font-weight: 300;
    color: rgba(255,255,255,0.75);
    margin: 0 0 32px;
  }

  .services-cta__btn {
    display: inline-block;
    padding: 16px 44px;
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: #fff;
    border: 1.5px solid rgba(255,255,255,0.6);
    text-decoration: none;
    transition: all 0.4s ease;
  }

  .services-cta__btn:hover {
    background: #fff;
    color: #113D48;
    border-color: #fff;
  }

  /* ===== SEO intro ===== */
  .services-intro {
    padding: 80px 16px 0;
    max-width: 1100px;
    margin: 0 auto;
  }

  .services-intro__inner {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .services-intro__title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.8rem, 3vw, 2.4rem);
    font-weight: 700;
    color: #113D48;
    margin: 0;
    line-height: 1.2;
    text-align: center;
  }

  .services-intro__copy {
    font-family: 'Inter', sans-serif;
    font-size: 1.05rem;
    line-height: 1.75;
    color: #4a5568;
    max-width: 780px;
    margin: 0 auto;
  }

  .services-intro__copy p {
    margin: 0 0 18px;
  }

  .services-intro__copy a {
    color: #1CA8CB;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .services-intro__pillars {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    padding-top: 8px;
  }

  .services-pillar {
    background: #f8fafb;
    border-left: 3px solid #1CA8CB;
    padding: 24px 24px 22px;
  }

  .services-pillar__title {
    font-family: 'Playfair Display', serif;
    font-size: 1.15rem;
    font-weight: 600;
    color: #113D48;
    margin: 0 0 10px;
  }

  .services-pillar__body {
    font-family: 'Inter', sans-serif;
    font-size: 0.95rem;
    line-height: 1.65;
    color: #4a5568;
    margin: 0;
  }

  .services-pillar__body a {
    color: #113D48;
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .services-pillar__body a:hover {
    color: #1CA8CB;
  }

  /* ===== FAQ ===== */
  .services-faq {
    padding: 80px 16px 0;
    max-width: 880px;
    margin: 0 auto;
  }

  .services-faq__inner {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .services-faq__title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.8rem, 3vw, 2.4rem);
    font-weight: 700;
    color: #113D48;
    margin: 0;
    text-align: center;
  }

  .services-faq__intro {
    font-family: 'Inter', sans-serif;
    font-size: 0.95rem;
    color: #6E7070;
    text-align: center;
    margin: 0;
  }

  .services-faq__intro a {
    color: #1CA8CB;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .services-faq__list {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-top: 8px;
  }

  .services-faq__item {
    border-bottom: 1px solid #e5eaee;
  }

  .services-faq__item[open] {
    background: #f8fafb;
  }

  .services-faq__q {
    font-family: 'Inter', sans-serif;
    font-size: 1.02rem;
    font-weight: 600;
    color: #113D48;
    padding: 18px 44px 18px 16px;
    cursor: pointer;
    list-style: none;
    position: relative;
    transition: color 0.2s ease;
  }

  .services-faq__q::-webkit-details-marker { display: none; }

  .services-faq__q::after {
    content: '+';
    position: absolute;
    right: 16px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 1.4rem;
    font-weight: 300;
    color: #1CA8CB;
    transition: transform 0.25s ease;
  }

  .services-faq__item[open] .services-faq__q::after {
    content: '−';
  }

  .services-faq__q:hover {
    color: #1CA8CB;
  }

  .services-faq__a {
    padding: 0 16px 20px;
  }

  .services-faq__a p {
    font-family: 'Inter', sans-serif;
    font-size: 0.98rem;
    line-height: 1.7;
    color: #4a5568;
    margin: 0;
  }

  /* ===== Responsive ===== */
  @media (max-width: 991px) {
    .services-intro__pillars {
      grid-template-columns: 1fr;
    }

    .services-featured__grid {
      grid-template-columns: 1fr;
    }

    .services-featured {
      margin-top: -40px;
    }

    .services-card--featured {
      height: 340px;
    }

    .services-more {
      padding: 60px 0 0;
    }
  }

  @media (max-width: 768px) {
    .services-hero {
      height: 50vh;
      min-height: 320px;
    }

    .services-card--featured {
      height: 280px;
    }

    .services-card__content {
      padding: 24px;
    }

    .services-card__title {
      font-size: 1.35rem;
    }

    .charter-grid {
      grid-template-columns: 1fr;
    }

    .charter-card--full,
    .charter-card--half {
      height: 400px;
    }

    .charter-card__content h2 {
