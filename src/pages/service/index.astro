---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../sections/home-one/Section1-Header.astro';
import FooterFour from '../../sections/shared/FooterFour.astro';
import BreadcrumbSchema from '../../components/seo/BreadcrumbSchema.astro';
import FAQSchema from '../../components/seo/FAQSchema.astro';
import services from '../../data/data-service.json';
import { SITE_URL } from '../../lib/seo';
import { serviceHubFaq as faqItems } from '../../lib/faq';
import { SERVICE_HUB, serviceCardAbsoluteUrl } from '../../lib/service-seo';

const itemListJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Boat services in Rhodes',
  numberOfItems: services.length,
  itemListElement: services.map((s: any, i: number) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: serviceCardAbsoluteUrl(s, SITE_URL),
    name: s.title,
  })),
};
---

<BaseLayout
  title={SERVICE_HUB.metaTitle}
  description={SERVICE_HUB.metaDescription}
>
  <BreadcrumbSchema items={[
    { name: 'Home', url: '/' },
    { name: 'Services', url: '/service' },
  ]} />
  <script type="application/ld+json" set:html={JSON.stringify(itemListJsonLd)} is:inline />
  <FAQSchema items={faqItems} />
  <Header />

  <section class="svc-hero">
    <div class="container">
      <div class="svc-hero__content text-center">
        <h1 class="svc-hero__title">{SERVICE_HUB.h1}</h1>
      </div>
    </div>
  </section>

  <section class="svc-catalog">
    <div class="container">
      <div class="svc-catalog__head text-center">
        <h2 class="svc-catalog__title">All Our Services</h2>
      </div>

      <div class="svc-grid">
        {services.map((data: any, i: number) => (
          <a
            href={data.externalUrl ?? data.href ?? `/service/${data.slug}`}
            target={data.externalUrl ? '_blank' : undefined}
            rel={data.externalUrl ? 'noopener noreferrer' : undefined}
            class="svc-card"
            data-ani="slideinup"
            data-ani-delay={String((i % 3) * 0.08)}
          >
            <div class="svc-card__media">
              <img src={data.image} alt={data.title} loading="lazy" decoding="async" />
            </div>
            <div class="svc-card__body">
              <h3 class="svc-card__title">{data.title}</h3>
              <p class="svc-card__desc">{data.item}</p>
              <span class="svc-card__cta">
                {data.externalUrl ? 'Visit site' : 'Explore'}
                <i class="fa-regular fa-arrow-right" aria-hidden="true"></i>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="svc-faq">
    <div class="container">
      <div class="svc-faq__layout">
        <div class="svc-faq__head text-center">
          <h2 class="svc-faq__title">Frequently Asked Questions</h2>
          <p class="svc-faq__intro">Common questions about choosing between our services. For booking, weather and licence details, see the <a href="/faq">full FAQ</a>.</p>
        </div>
        <div class="svc-faq__list">
          {faqItems.map((item, index) => (
            <details class="svc-faq__item">
              <summary class="svc-faq__q">
                <span class="svc-faq__num">Q{index + 1}.</span>
                <span class="svc-faq__text">{item.question}</span>
                <span class="svc-faq__icon" aria-hidden="true"></span>
              </summary>
              <div class="svc-faq__a"><p>{item.answer}</p></div>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="svc-cta">
    <div class="container">
      <div class="svc-cta__inner text-center">
        <h2 class="svc-cta__title">Not Sure Which Experience Is Right for You?</h2>
        <p class="svc-cta__text">Send us a message and tell us what you have in mind. We will suggest the best option for your group, honestly and without pressure.</p>
        <a href="/contact" class="svc-cta__btn">Get in Touch</a>
      </div>
    </div>
  </section>

  <FooterFour />
</BaseLayout>

<style>
  .svc-hero {
    min-height: 320px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 140px 0 72px;
    background: linear-gradient(135deg, #1CA8CB 0%, #1489a8 35%, #113D48 100%);
  }

  .svc-hero__content {
    max-width: 720px;
    margin: 0 auto;
  }

  .svc-hero__title {
    font-size: clamp(2rem, 4.5vw, 3.25rem);
    font-weight: 800;
    line-height: 1.15;
    margin: 0;
    color: #fff;
  }

  .svc-catalog {
    padding: 64px 0 80px;
    background: #f4f8f9;
  }

  .svc-catalog__head {
    max-width: 640px;
    margin: 0 auto 44px;
  }

  .svc-catalog__title {
    font-size: clamp(1.6rem, 3vw, 2.1rem);
    font-weight: 700;
    color: #113D48;
    margin: 0;
  }

  .svc-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }

  .svc-card {
    display: flex;
    flex-direction: column;
    background: #fff;
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid #e8eef0;
    box-shadow: 0 4px 20px rgba(17, 61, 72, 0.06);
    text-decoration: none;
    color: inherit;
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
  }

  .svc-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 16px 40px rgba(28, 168, 203, 0.12);
    border-color: rgba(28, 168, 203, 0.35);
  }

  .svc-card__media {
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: #dce8ec;
  }

  .svc-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .svc-card:hover .svc-card__media img {
    transform: scale(1.05);
  }

  .svc-card__body {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: 24px 24px 26px;
  }

  .svc-card__title {
    font-size: 1.15rem;
    font-weight: 700;
    line-height: 1.35;
    color: #113D48;
    margin: 0 0 10px;
    transition: color 0.2s ease;
  }

  .svc-card:hover .svc-card__title {
    color: #1CA8CB;
  }

  .svc-card__desc {
    font-size: 0.92rem;
    line-height: 1.6;
    color: #5a6a72;
    margin: 0 0 18px;
    flex: 1;
  }

  .svc-card__cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.85rem;
    font-weight: 600;
    color: #1CA8CB;
    margin-top: auto;
    transition: gap 0.2s ease;
  }

  .svc-card:hover .svc-card__cta {
    gap: 12px;
  }

  .svc-faq {
    padding: 80px 0;
    background: #fff;
  }

  .svc-faq__layout {
    max-width: 820px;
    margin: 0 auto;
  }

  .svc-faq__head {
    margin-bottom: 36px;
  }

  .svc-faq__title {
    font-size: clamp(1.6rem, 3vw, 2.1rem);
    font-weight: 700;
    color: #113D48;
    margin: 0 0 12px;
  }

  .svc-faq__intro {
    font-size: 0.98rem;
    line-height: 1.65;
    color: #000;
    margin: 0;
  }

  .svc-faq__intro a {
    color: #1CA8CB;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .svc-faq__list {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .svc-faq__item {
    background: #fff;
    border: 1px solid #e6eef0;
    border-radius: 12px;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.04);
    overflow: hidden;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .svc-faq__item[open] {
    border-color: #1CA8CB;
    box-shadow: 0 4px 20px rgba(28, 168, 203, 0.08);
  }

  .svc-faq__q {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 22px 26px;
    font-size: 1.02rem;
    font-weight: 600;
    color: #113D48;
    line-height: 1.4;
    user-select: none;
  }

  .svc-faq__q::-webkit-details-marker { display: none; }
  .svc-faq__q::marker { content: ''; }

  .svc-faq__num {
    flex-shrink: 0;
    color: #1CA8CB;
    font-weight: 700;
  }

  .svc-faq__text {
    flex: 1;
  }

  .svc-faq__icon {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: rgba(28, 168, 203, 0.12);
    position: relative;
    transition: background 0.2s ease;
  }

  .svc-faq__icon::before,
  .svc-faq__icon::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    background: #1CA8CB;
    border-radius: 1px;
  }

  .svc-faq__icon::before {
    width: 12px;
    height: 2px;
    transform: translate(-50%, -50%);
  }

  .svc-faq__icon::after {
    width: 2px;
    height: 12px;
    transform: translate(-50%, -50%);
    transition: transform 0.25s ease, opacity 0.25s ease;
  }

  .svc-faq__item[open] .svc-faq__icon {
    background: #1CA8CB;
  }

  .svc-faq__item[open] .svc-faq__icon::before,
  .svc-faq__item[open] .svc-faq__icon::after {
    background: #fff;
  }

  .svc-faq__item[open] .svc-faq__icon::after {
    transform: translate(-50%, -50%) scaleY(0);
    opacity: 0;
  }

  .svc-faq__a {
    padding: 0 26px 24px 68px;
  }

  .svc-faq__a p {
    font-size: 0.98rem;
    line-height: 1.75;
    color: #445963;
    margin: 0;
  }

  .svc-cta {
    padding: 0 0 88px;
    background: #fff;
  }

  .svc-cta__inner {
    background: linear-gradient(135deg, #113D48 0%, #0f2f38 100%);
    border-radius: 20px;
    padding: 56px 40px;
    max-width: 900px;
    margin: 0 auto;
    box-shadow: 0 20px 50px rgba(17, 61, 72, 0.15);
  }

  .svc-cta__title {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    color: #fff;
    margin: 0 0 12px;
    line-height: 1.25;
  }

  .svc-cta__text {
    font-size: 1rem;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.85);
    margin: 0 auto 28px;
    max-width: 520px;
  }

  .svc-cta__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 32px;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #113D48;
    background: #fff;
    border-radius: 999px;
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .svc-cta__btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
  }

  @media (max-width: 991px) {
    .svc-hero {
      min-height: 280px;
      padding: 120px 0 56px;
    }

    .svc-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 22px;
    }

    .svc-faq__a {
      padding: 0 26px 24px 26px;
    }
  }

  @media (max-width: 575px) {
    .svc-hero {
      padding: 108px 0 48px;
    }

    .svc-catalog {
      padding: 48px 0 64px;
    }

    .svc-grid {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .svc-card__body {
      padding: 20px 20px 22px;
    }

    .svc-faq {
      padding: 64px 0;
    }

    .svc-faq__q {
      padding: 18px 20px;
      font-size: 0.98rem;
    }

    .svc-cta {
      padding-bottom: 64px;
    }

    .svc-cta__inner {
      padding: 40px 24px;
      border-radius: 16px;
    }
  }
</style>
