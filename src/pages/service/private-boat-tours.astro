---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../sections/home-one/Section1-Header.astro';
import FooterFour from '../../sections/shared/FooterFour.astro';
import ScrollToTop from '../../components/interactive/ScrollToTop';
import ServiceHeroFullwidth from '../../sections/service/ServiceHeroFullwidth.astro';
import ServiceOverview from '../../sections/service/ServiceOverview.astro';
import ServiceVesselsShowcase from '../../sections/service/ServiceVesselsShowcase.astro';
import ServiceWhySection from '../../sections/service/ServiceWhySection.astro';
import ServiceDestinationsCarousel from '../../sections/service/ServiceDestinationsCarousel.astro';
import ServiceBucketList from '../../sections/service/ServiceBucketList.astro';
import ServiceSeasonInfo from '../../sections/service/ServiceSeasonInfo.astro';
import ServiceMiseChecklist from '../../sections/service/ServiceMiseChecklist.astro';
---

<BaseLayout title="Luxury Sailing Yacht Charters in Rhodes - Rhodos Yachts">
  <Header />

  <!-- 1. Hero -->
  <ServiceHeroFullwidth
    title="Luxury Sailing Yacht Charters"
    subtitle="Five Bavaria sailing yachts, fourteen islands, and a crew that knows these waters like home. Tell us what kind of voyage you are dreaming of."
    backgroundImage="https://images.unsplash.com/photo-1540946485063-a40da27545f8?w=1920&h=1080&fit=crop"
    heroVideo="/assets/img/hero/services/private-tours.mp4"
    cta1Text="Charter a Yacht"
    cta2Text="View Our Fleet"
  />

  <!-- 2. Overview -->
  <ServiceOverview
    title="Sailing Excellence Since 2009"
    subtitle="Overview"
    description="We own and operate a fleet of five meticulously maintained Bavaria sailing yachts, offering bareboat and skippered charters across the entire Dodecanese archipelago. From Rhodes to Kastellorizo, every voyage is crafted with precision, local expertise, and the kind of care you only get from people who actually own and maintain the boats themselves."
    features={[
      { icon: '/assets/img/icon/about_1_1.svg', title: 'Owner-Operated Fleet', text: 'Direct owner — no brokers, no middlemen. You deal with the people who maintain and love these yachts.' },
      { icon: '/assets/img/icon/about_1_2.svg', title: 'Tailor-Made Itineraries', text: 'Every charter is custom-designed around your pace, interests, and sailing experience.' },
      { icon: '/assets/img/icon/about_1_3.svg', title: 'Complete Support', text: 'From provisioning and transfers to 24/7 on-call assistance — we handle every detail.' },
    ]}
    stats={[
      { value: 5, suffix: '', label: 'Bavaria Yachts' },
      { value: 14, suffix: '', label: 'Island Destinations' },
      { value: 15, suffix: '+', label: 'Years Experience' },
      { value: 5, suffix: '★', label: 'Guest Rating' },
    ]}
  />

  <!-- 3. Our Story — Image Left, Text Right -->
  <section class="about-split space">
    <div class="container">
      <div class="row align-items-center gy-40">
        <div class="col-lg-6" data-ani="slideinleft">
          <div class="about-split__img">
            <img class="global-img" src="/assets/img/sailing/symi.jpg" alt="Sailing in the Dodecanese" />
          </div>
        </div>
        <div class="col-lg-6" data-ani="slideinright">
          <div class="about-split__text ps-lg-4">
            <span class="about-split__accent"></span>
            <div class="title-area mb-20">
              <h2 class="sec-title">Born to Sail the Dodecanese</h2>
            </div>
            <p class="about-split__subtitle"><em>A sailing heritage spanning fifteen years</em></p>
            <p>
              The Dodecanese archipelago is one of the finest sailing grounds in the Mediterranean — blessed
              with steady summer meltemi winds, sheltered anchorages, and over 300 days of sunshine. Our team
              has spent more than fifteen years mastering these waters: every sea passage, every hidden cove,
              every sunset anchorage.
            </p>
            <p>
              Whether you are a seasoned skipper or stepping onto a yacht for the first time, we will
              match you with the perfect boat and plan a route that makes every day on the water feel
              like it was designed just for you.
            </p>
            <a href="/contact" class="th-btn style3 th-icon mt-25">Start Planning</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. Our Commitment — Text Left, Image Right (reversed) -->
  <section class="about-split bg-smoke space">
    <div class="container">
      <div class="row align-items-center flex-lg-row-reverse gy-40">
        <div class="col-lg-6" data-ani="slideinright">
          <div class="about-split__img">
            <img class="global-img" src="/assets/img/gallery/yacht/yacht-deck-1.jpg" alt="Yacht deck and maintenance" />
          </div>
        </div>
        <div class="col-lg-6" data-ani="slideinleft">
          <div class="about-split__text pe-lg-4">
            <span class="about-split__accent"></span>
            <div class="title-area mb-20">
              <h2 class="sec-title">Our Commitment to Excellence</h2>
            </div>
            <p class="about-split__subtitle"><em>Meticulous care for every voyage</em></p>
            <p>
              Every yacht in our fleet undergoes rigorous pre-season overhauls and thorough pre-charter
              inspections. Sails, rigging, engines, electronics, safety equipment — nothing is left to
              chance. We maintain our boats to a standard that exceeds industry requirements, because
              your safety and comfort are non-negotiable.
            </p>
            <p>
              Our multilingual team — fluent in English, Greek, and German — provides seamless support
              from your first enquiry through disembarkation. We're not a booking portal; we're the
              owners, and we stand behind every voyage personally.
            </p>
            <a href="/contact" class="th-btn style3 th-icon mt-25">Get in Touch</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 5. Fleet -->
  <ServiceVesselsShowcase
    title="Our Fleet"
    subtitle="Five Bavaria Yachts"
    vessels={[
      {
        name: 'Bavaria 39 Cruiser',
        image: '/assets/img/fleet/bavaria-39.jpg',
        specs: ['11.93m Length', '3.97m Beam', '3 Cabins · 6 Guests', '2 Bathrooms', 'Ideal for couples & small groups'],
        price: 'From €1,200/week',
      },
      {
        name: 'Bavaria 44',
        image: '/assets/img/fleet/bavaria-44.jpg',
        specs: ['13.60m Length', '4.20m Beam', '4 Cabins · 10 Guests', '2 Bathrooms', 'Spacious family cruiser'],
        price: 'From €1,800/week',
      },
      {
        name: 'Bavaria 46 Cruiser',
        image: '/assets/img/fleet/bavaria-46.jpg',
        specs: ['13.99m Length', '4.35m Beam', '4 Cabins · 8 Guests', '2 Bathrooms', 'Performance & comfort'],
        price: 'From €2,200/week',
      },
      {
        name: 'Bavaria 49',
        image: '/assets/img/fleet/bavaria-49.jpg',
        specs: ['14.90m Length', '4.46m Beam', '5 Cabins · 10 Guests', '3 Bathrooms', 'Premium long-range cruiser'],
        price: 'From €2,800/week',
      },
      {
        name: 'Bavaria 50 Cruiser',
        image: '/assets/img/fleet/bavaria-50.jpg',
        specs: ['14.63m Length', '4.47m Beam', '5 Cabins · 10 Guests', '3 Bathrooms', 'Our flagship yacht'],
        price: 'From €3,500/week',
      },
    ]}
  />

  <!-- 6. Why Us -->
  <ServiceWhySection
    layout="right"
    title="Why Sail with Rhodos Yachts"
    subtitle="The Rhodos Yachts Difference"
    description="We're not a booking portal — we're the owners. Every yacht in our fleet is maintained by our own team in Rhodes. When you charter with us, you get direct access to the people who know these boats inside and out, and waters that feel like home."
    image="/assets/img/sailing/halki.jpg"
    features={[
      { icon: '/assets/img/icon/about_1_1.svg', title: 'Direct Owner, No Brokers', text: 'Lower prices and faster communication — you deal directly with the fleet owner.' },
      { icon: '/assets/img/icon/about_1_2.svg', title: 'Meticulous Maintenance', text: 'Every yacht undergoes rigorous pre-season and pre-charter inspections.' },
      { icon: '/assets/img/icon/about_1_3.svg', title: 'Local Knowledge', text: '15+ years sailing the Dodecanese — we know the anchorages guidebooks don\'t mention.' },
    ]}
  />

  <!-- 9. Destinations -->
  <ServiceDestinationsCarousel
    title="The Dodecanese Islands"
    subtitle="14 Destinations"
    destinations={[
      { name: 'Rhodes', description: 'Medieval Old Town, vibrant nightlife, and endless coastline', image: '/assets/img/sailing/rhodes.jpg' },
      { name: 'Kos', description: 'Birthplace of Hippocrates with golden beaches and thermal springs', image: '/assets/img/sailing/kos.jpg' },
      { name: 'Patmos', description: 'The sacred island of the Apocalypse — serenity and spirituality', image: '/assets/img/sailing/patmos.jpg' },
      { name: 'Lipsi', description: 'Tiny, unspoiled paradise with crystalline bays and white chapels', image: '/assets/img/sailing/lipsi.jpg' },
      { name: 'Kalymnos', description: 'World-famous rock climbing and authentic sponge-diving heritage', image: '/assets/img/sailing/kalymnos.jpg' },
      { name: 'Astypalaia', description: 'Butterfly-shaped island with Cycladic charm and hidden coves', image: '/assets/img/sailing/astypalaia.jpg' },
      { name: 'Nisyros', description: 'Active volcanic crater, thermal villages, and dramatic landscapes', image: '/assets/img/sailing/nisyros.jpg' },
      { name: 'Symi', description: 'Iconic neoclassical harbor — the jewel of the Dodecanese', image: '/assets/img/sailing/symi.jpg' },
      { name: 'Tilos', description: 'Eco-island with hiking trails, medieval castles, and rare wildlife', image: '/assets/img/sailing/tilos.jpg' },
      { name: 'Halki', description: 'Car-free tranquility, turquoise waters, and time standing still', image: '/assets/img/sailing/halki.jpg' },
      { name: 'Karpathos', description: 'Wild beauty, traditional mountain villages, and windsurfing paradise', image: '/assets/img/sailing/karpathos.jpg' },
      { name: 'Kasos', description: 'Greece\'s most remote inhabited island — raw and untouched', image: '/assets/img/sailing/kasos.jpg' },
      { name: 'Kastellorizo', description: 'The easternmost gem with the legendary Blue Cave', image: '/assets/img/sailing/kastellorizo.jpg' },
      { name: 'Leros', description: 'Art deco architecture, calm bays, and authentic island life', image: '/assets/img/sailing/leros.jpg' },
    ]}
  />

  <!-- 10. Bucket List -->
  <ServiceBucketList
    title="Sailing Experiences You'll Never Forget"
    subtitle="Bucket List"
    items={[
      { title: 'Sail into Symi Harbor at Dawn', description: 'Watch the pastel-painted neoclassical mansions glow gold as you glide into one of the most beautiful harbors in the Mediterranean.' },
      { title: 'Anchor in a Private Cove', description: 'Drop anchor in a hidden bay accessible only by sea — swim, snorkel, and have the world entirely to yourself.' },
      { title: 'Sunset Cocktails on Deck', description: 'Mix sundowners in the cockpit as the Aegean sky turns amber and the islands silhouette against the horizon.' },
      { title: 'Walk the Nisyros Volcano', description: 'Moor in Mandraki and hike into the caldera of an active volcano — a surreal moonscape surrounded by sea.' },
      { title: 'Feast on Halki Seafood', description: 'Tie up at the tiny harbor and feast on the day\'s catch at a waterfront taverna where the fisherman is also the chef.' },
      { title: 'Explore the Kastellorizo Blue Cave', description: 'Swim into a sea cave illuminated by an otherworldly blue light — a natural wonder at Greece\'s easternmost point.' },
    ]}
  />

  <!-- 11. Seasons -->
  <ServiceSeasonInfo
    title="When to Charter"
    subtitle="Sailing Seasons"
    image="/assets/img/sailing/karpathos.jpg"
    seasons={[
      { name: 'Spring Sailing', months: 'April – May', description: 'Mild temperatures, empty anchorages, wildflowers on every island. Perfect for couples and explorers seeking solitude.', recommended: false },
      { name: 'Peak Season', months: 'June – August', description: 'Warm waters, steady meltemi winds, longest days, and vibrant island nightlife. The quintessential Greek sailing experience.', recommended: true },
      { name: 'Golden Autumn', months: 'September – October', description: 'Warm sea, fewer crowds, golden light, and calmer winds — the insider\'s favorite season for a relaxed cruise.', recommended: true },
      { name: 'Off-Season', months: 'November – March', description: 'Fleet in winter maintenance. Special arrangements possible for experienced sailors on request.', recommended: false },
    ]}
  />

  <!-- 12. How It Works -->
  <ServiceMiseChecklist
    title="Your Charter in Five Steps"
    subtitle="How It Works"
    steps={[
      { title: 'Inquire', description: 'Tell us your dates, group size, and sailing experience. We respond within 24 hours with availability and recommendations.', icon: 'fa-regular fa-envelope' },
      { title: 'Yacht Selection', description: 'Choose from five Bavaria yachts — we help you pick the perfect match for your crew and voyage style.', icon: 'fa-solid fa-sailboat' },
      { title: 'Itinerary Design', description: 'We craft a bespoke route through the Dodecanese based on your preferences, with insider tips at every stop.', icon: 'fa-solid fa-map-location-dot' },
      { title: 'Provisioning', description: 'Pre-stock your yacht with groceries, drinks, and special requests — everything is ready when you arrive.', icon: 'fa-solid fa-basket-shopping' },
      { title: 'Set Sail', description: 'Board at Rhodes Mandraki Harbor, complete your briefing, and cast off into the Aegean. Your adventure begins.', icon: 'fa-solid fa-anchor' },
    ]}
  />

  <!-- Related Services -->
  <div class="bg-smoke space overflow-hidden">
    <div class="container">
      <div class="title-area text-center mb-50">
        <span class="sub-title style1" data-ani="slideinup">Explore More</span>
        <h2 class="sec-title" data-ani="slideinup" data-ani-delay="0.1">Our Other Services</h2>
      </div>
      <div class="row gy-30 justify-content-center">
        <div class="col-lg-6">
          <a href="/service/rodos-boat-tours" class="related-service-card" data-ani="slideinup">
            <div class="related-service-card_img">
              <img src="/assets/img/gallery/yacht/greek-coast-1.jpg" alt="Rhodos Boat Tours" loading="lazy" />
              <div class="related-service-card_overlay"></div>
            </div>
            <div class="related-service-card_content">
              <h4 class="related-service-card_title">Rhodos Boat Tours</h4>
              <p class="related-service-card_text">Guided day trips along the stunning Rhodes coastline and nearby islands.</p>
              <span class="th-btn style3 th-icon">Explore <i class="fas fa-arrow-right ms-2"></i></span>
            </div>
          </a>
        </div>
        <div class="col-lg-6">
          <a href="/service/rodos-boat-cruises" class="related-service-card" data-ani="slideinup" data-ani-delay="0.15">
            <div class="related-service-card_img">
              <img src="/assets/img/gallery/yacht/sunset-cruise-1.jpg" alt="Rhodos Boat Cruises" loading="lazy" />
              <div class="related-service-card_overlay"></div>
            </div>
            <div class="related-service-card_content">
              <h4 class="related-service-card_title">Rhodos Boat Cruises</h4>
              <p class="related-service-card_text">Luxury sunset and full-day cruises with onboard dining and swimming stops.</p>
              <span class="th-btn style3 th-icon">Explore <i class="fas fa-arrow-right ms-2"></i></span>
            </div>
          </a>
        </div>
      </div>
    </div>
  </div>

  <FooterFour />
  <ScrollToTop client:load />
</BaseLayout>

<style>
  /* ===== About-style Split Sections ===== */
  .about-split__img {
    border-radius: 8px;
    overflow: hidden;
  }

  .about-split__img :global(img) {
    aspect-ratio: 4 / 3;
    object-fit: cover;
    width: 100%;
    display: block;
  }

  .about-split__accent {
    display: block;
    width: 30px;
    height: 4px;
    background: var(--theme-color);
    margin-bottom: 20px;
    border-radius: 2px;
  }

  .about-split__subtitle {
    color: var(--theme-color);
    font-size: 17px;
    margin-bottom: 15px;
  }

  /* ===== Related Services Cards ===== */
  .related-service-card {
    display: block;
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    height: 350px;
    text-decoration: none;
  }
  .related-service-card_img {
    position: absolute;
    inset: 0;
  }
  .related-service-card_img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s;
  }
  .related-service-card:hover .related-service-card_img img {
    transform: scale(1.05);
  }
  .related-service-card_overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(0deg, rgba(0,0,0,0.75) 0%, rgba(0,0,0,0.15) 60%);
  }
  .related-service-card_content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 30px;
    z-index: 1;
  }
  .related-service-card_title {
    color: #fff;
    margin-bottom: 8px;
    font-size: 1.5rem;
  }
  .related-service-card_text {
    color: rgba(255,255,255,0.85);
    margin-bottom: 15px;
    font-size: 0.95rem;
  }

</style>
