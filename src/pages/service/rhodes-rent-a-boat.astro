---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../sections/home-one/Section1-Header.astro';
import FooterFour from '../../sections/shared/FooterFour.astro';
import ServiceHeroFullwidth from '../../sections/service/ServiceHeroFullwidth.astro';
import ServiceSchema from '../../components/seo/ServiceSchema.astro';
import BreadcrumbSchema from '../../components/seo/BreadcrumbSchema.astro';
import FAQSchema from '../../components/seo/FAQSchema.astro';
import { getMediaSlot, imgUrl, imgSrcset } from '../../lib/media';
import { tourCardAlt } from '../../lib/tour-alt';
import { createPublicClient } from '../../lib/supabase';
import { rentABoatFaq } from '../../lib/faq';

const heroVideo = await getMediaSlot('service.rent-a-boat.hero.video', '/assets/img/hero/services/license-free.mp4');
const heroImage = await getMediaSlot('service.rent-a-boat.hero.image', '/assets/img/gallery/yacht/crystal-water-1.jpg');

// Fetch approved tours from Supabase
let dbCards: any[] = [];
try {
  const supabase = createPublicClient();
  if (supabase) {
    const { data } = await supabase
      .from('tours')
      .select('*')
      .or('service_page.eq.rhodes-rent-a-boat,is_global.eq.true')
      .eq('status', 'approved')
      .order('is_global', { ascending: false })
      .order('created_at', { ascending: false });
    dbCards = (data || []).map((t: any) => ({
      title: t.title,
      description: t.description,
      image: t.image_url || t.images?.[0] || '/assets/img/gallery/yacht/crystal-water-1.jpg',
      duration: t.duration || '',
      guests: t.guests || '',
      type: t.badge_label || '',
      price: t.price || '',
      href: `/tour-detail/${t.slug || t.id}`,
      imageAlt: tourCardAlt(t.title, t.badge_label),
    }));
  }
} catch (e) {
  console.error("Supabase error:", e); // Supabase unavailable — show demo data only
}

const boats = dbCards;
---

<BaseLayout title="Rent a Boat in Rhodes — License Free & With Skipper" description="Rent a boat in Rhodes without a licence. Self-drive boats from 30hp to 150hp departing daily from Rhodes Town." ogImage={heroImage}>
  <ServiceSchema
    name="Rhodes Rent a Boat"
    description="License-free boat rentals and small boats with skipper along the Rhodes coast. Explore bays, swim and enjoy the sea at your own pace."
    serviceType="Boat Rental"
    image={heroImage}
    url="/service/rhodes-rent-a-boat"
    lowPrice="130"
    highPrice="380"
    offerCount="5"
  />
  <BreadcrumbSchema items={[
    { name: 'Home', url: '/' },
    { name: 'Services', url: '/service' },
    { name: 'Rhodes Rent a Boat', url: '/service/rhodes-rent-a-boat' },
  ]} />
  <FAQSchema items={rentABoatFaq} />
  <Header />

  <!-- 1. Hero -->
  <ServiceHeroFullwidth
    title="Rhodes Rent a Boat"
    subtitle="License Free Boats and Boats with Skipper"
    backgroundImage={heroImage}
    heroVideo={heroVideo}
  />

  <!-- 2. Intro -->
  <section style="padding: 60px 0 40px;">
    <div class="container">
      <div style="max-width: 700px; margin: 0 auto; text-align: center; margin-bottom: 40px;">
        <p style="font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 1.2rem; line-height: 1.7; color: #107184; margin-bottom: 0;" data-ani="fadein">
          Renting a boat is the most independent way to explore the Rhodes coastline at your own pace.
        </p>
      </div>
      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px;" class="rb-intro-grid" data-ani="slideinup" data-ani-delay="0.1">
        <div style="text-align: center; padding: 32px 24px;">
          <div style="width: 56px; height: 56px; border-radius: 14px; background: rgba(28,168,203,0.1); color: #1CA8CB; display: inline-flex; align-items: center; justify-content: center; font-size: 1.3rem; margin-bottom: 18px;">
            <i class="fas fa-key"></i>
          </div>
          <h2 style="font-family: 'Playfair Display', serif; font-size: 1rem; font-weight: 700; color: #113D48; margin-bottom: 10px;">License Free Boats</h2>
          <p style="font-size: 0.9rem; line-height: 1.65; color: #56646b; margin: 0;">Small motorboats you can drive yourself — no license needed. Easy to operate, safe and ideal for a few hours on the water.</p>
        </div>
        <div style="text-align: center; padding: 32px 24px;">
          <div style="width: 56px; height: 56px; border-radius: 14px; background: rgba(28,168,203,0.1); color: #1CA8CB; display: inline-flex; align-items: center; justify-content: center; font-size: 1.3rem; margin-bottom: 18px;">
            <i class="fas fa-user-shield"></i>
          </div>
          <h2 style="font-family: 'Playfair Display', serif; font-size: 1rem; font-weight: 700; color: #113D48; margin-bottom: 10px;">Rent with Skipper</h2>
          <p style="font-size: 0.9rem; line-height: 1.65; color: #56646b; margin: 0;">Prefer someone else to drive? Rent a small boat with an experienced local skipper who knows the best spots.</p>
        </div>
        <div style="text-align: center; padding: 32px 24px;">
          <div style="width: 56px; height: 56px; border-radius: 14px; background: rgba(28,168,203,0.1); color: #1CA8CB; display: inline-flex; align-items: center; justify-content: center; font-size: 1.3rem; margin-bottom: 18px;">
            <i class="fas fa-map-marked-alt"></i>
          </div>
          <h2 style="font-family: 'Playfair Display', serif; font-size: 1rem; font-weight: 700; color: #113D48; margin-bottom: 10px;">Local Guidance</h2>
          <p style="font-size: 0.9rem; line-height: 1.65; color: #56646b; margin: 0;">We help you pick license-free or skippered, and the boat size that matches your coastal plans and group.</p>
        </div>
      </div>
      <div style="text-align: center; margin-top: 28px;" data-ani="fadein" data-ani-delay="0.2">
        <p style="font-family: 'Playfair Display', serif; font-weight: 600; font-size: 0.95rem; color: #113D48; margin: 0;">
          We don't rent boats. We help you choose the right sea experience in Rhodes. Prefer a skipper and a planned route? See our <a href="/service/rhodes-boat-trips">private boat trips</a>.
        </p>
      </div>
    </div>
  </section>

  <!-- 3. Boats Grid -->
  <section style="padding: 80px 0; background: #f8fafb;">
    <div class="container">
      <div class="title-area text-center" style="margin-bottom: 50px;">
        <h2 class="sec-title" data-ani="slideinup">What Are Your Options for Renting a Boat in Rhodes?</h2>
      </div>
      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px;" class="rb-boats-grid">
        {boats.map((boat, i) => (
          <a href={boat.href || '/contact'} class="rb-boat-card" data-ani="slideinup" data-ani-delay={`${0.1 + i * 0.06}`} style="display: flex; flex-direction: column; text-decoration: none; color: inherit; background: #fff; border-radius: 14px; overflow: hidden; box-shadow: 0 4px 24px rgba(0,0,0,0.06); transition: transform 0.3s ease, box-shadow 0.3s ease;">
            <div style="height: 220px; overflow: hidden; position: relative;">
              <img src={imgUrl(boat.image, 600, { quality: 75 })} srcset={imgSrcset(boat.image, [400, 600, 800])} sizes="(max-width: 575px) 100vw, (max-width: 991px) 50vw, 33vw" width="600" height="450" alt={boat.imageAlt} loading="lazy" style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease;" />
              <span style="position: absolute; top: 14px; right: 14px; background: rgba(17,61,72,0.85); color: #fff; font-family: 'Inter', sans-serif; font-size: 0.75rem; font-weight: 600; padding: 5px 12px; border-radius: 6px; backdrop-filter: blur(4px);">{boat.type}</span>
            </div>
            <div style="padding: 24px; display: flex; flex-direction: column; flex: 1;">
              <h3 style="font-family: 'Playfair Display', serif; font-size: 1.1rem; font-weight: 700; color: #113D48; margin-bottom: 8px;">{boat.title}</h3>
              <p style="font-size: 0.88rem; line-height: 1.6; color: #56646b; margin-bottom: 14px;">{boat.description}</p>
              <div style="display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 16px;">
                <span style="display: inline-flex; align-items: center; gap: 4px; font-size: 0.75rem; color: #5a6a72; background: #f0f4f5; padding: 4px 10px; border-radius: 20px;"><i class="far fa-clock" style="font-size: 0.7rem; color: #1CA8CB;"></i> {boat.duration}</span>
                <span style="display: inline-flex; align-items: center; gap: 4px; font-size: 0.75rem; color: #5a6a72; background: #f0f4f5; padding: 4px 10px; border-radius: 20px;"><i class="far fa-user" style="font-size: 0.7rem; color: #1CA8CB;"></i> {boat.guests}</span>
              </div>
              <div style="display: flex; justify-content: space-between; align-items: center; margin-top: auto; padding-top: 14px; border-top: 1px solid #f0f0f0;">
                <span style="font-family: 'Playfair Display', serif; font-size: 1.05rem; font-weight: 700; color: #1CA8CB;">{boat.price}</span>
                <span style="font-size: 0.78rem; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; color: #113D48;">Enquire <i class="fa-regular fa-arrow-right" style="margin-left: 4px;"></i></span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- 4. No-licence vs Skipper comparison — decision content for visitors -->
  <section class="rb-compare" data-ani="fadein">
    <div class="container">
      <div class="rb-compare__header">
        <h2 class="rb-compare__title">No Licence vs With Skipper — Which Is Right for You?</h2>
        <p class="rb-compare__intro">Both options are popular and both are safe. The right pick depends on how independent you want to be, your group, and how confident you feel on the water. Here is the honest breakdown.</p>
      </div>
      <div class="rb-compare__grid">
        <article class="rb-compare__card">
          <header class="rb-compare__card-head">
            <i class="fas fa-key" aria-hidden="true"></i>
            <h3>License-Free Self-Drive</h3>
          </header>
          <ul class="rb-compare__list">
            <li><strong>Best for:</strong> couples and small families who want full independence</li>
            <li><strong>Boat size:</strong> small motorboats up to 30 hp (4–6 guests)</li>
            <li><strong>Range:</strong> coastal cruising — typically the east coast bays</li>
            <li><strong>Driving:</strong> you steer; 15-minute safety briefing before departure</li>
            <li><strong>Required:</strong> 18+, valid ID or passport, no licence needed</li>
            <li><strong>Typical day:</strong> swim stops in 2–3 secluded coves, lunch ashore</li>
          </ul>
          <a href="/contact" class="rb-compare__cta">Ask about license-free rental</a>
        </article>
        <article class="rb-compare__card rb-compare__card--accent">
          <header class="rb-compare__card-head">
            <i class="fas fa-user-shield" aria-hidden="true"></i>
            <h3>Boat with Skipper</h3>
          </header>
          <ul class="rb-compare__list">
            <li><strong>Best for:</strong> families with kids, longer trips, or full-day exploration</li>
            <li><strong>Boat size:</strong> small to mid-size boats (4–10 guests)</li>
            <li><strong>Range:</strong> wider — Lindos, secluded south-coast bays, sunset routes</li>
            <li><strong>Driving:</strong> experienced local skipper handles the boat</li>
            <li><strong>Required:</strong> nothing — just show up at the harbour</li>
            <li><strong>Typical day:</strong> custom route based on your interests and the weather</li>
          </ul>
          <a href="/contact" class="rb-compare__cta">Ask about boat with skipper</a>
        </article>
      </div>
      <p class="rb-compare__note"><i class="fas fa-info-circle" aria-hidden="true"></i> <strong>Safety note:</strong> all boats carry full safety equipment (life jackets, first-aid kit, anchor, marine map). We monitor the official sea-state forecast every morning and will reschedule or refund if conditions are not safe. Children's life jackets are provided free of charge.</p>
    </div>
  </section>

  <!-- 5. FAQ — long-tail SEO + decision support -->
  <section class="rb-faq" data-ani="fadein">
    <div class="container">
      <div class="rb-faq__header">
        <h2 class="rb-faq__title">Rent a Boat in Rhodes — FAQ</h2>
        <p class="rb-faq__intro">Common questions from first-time renters. For booking, pricing or anything specific, <a href="/contact">send us a message</a>.</p>
      </div>
      <div class="rb-faq__list">
        {rentABoatFaq.map((item) => (
          <details class="rb-faq__item">
            <summary class="rb-faq__q">{item.question}</summary>
            <div class="rb-faq__a"><p>{item.answer}</p></div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- 6. Contact -->
  <section style="padding: 80px 0; background: #113D48;">
    <div class="container">
      <div style="max-width: 700px; margin: 0 auto; text-align: center;">
        <h2 style="font-family: 'Playfair Display', serif; font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 700; color: #fff; margin-bottom: 20px;" data-ani="slideinup">Need Help Choosing Between Boat Tour, Boat Trip or Rent a Boat?</h2>
        <p style="font-size: 1rem; line-height: 1.75; color: rgba(255,255,255,0.7); margin-bottom: 36px;" data-ani="fadein" data-ani-delay="0.1">
          If you are not sure which option is the best for you, contact us and we will help you choose the right sea experience depending on your group, how many hours you want and what type of experience you prefer.
        </p>
        <div style="display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;" data-ani="slideinup" data-ani-delay="0.2">
          <a href="/contact" class="th-btn style3 th-icon">Send Us a Message</a>
          <a href="https://wa.me/306951666454" style="display: inline-flex; align-items: center; gap: 8px; padding: 14px 28px; font-family: 'Inter', sans-serif; font-size: 0.85rem; font-weight: 600; color: #fff; border: 1.5px solid rgba(255,255,255,0.3); border-radius: 8px; text-decoration: none; transition: all 0.3s ease;"><i class="fab fa-whatsapp"></i> WhatsApp</a>
          <a href="tel:+306951666454" style="display: inline-flex; align-items: center; gap: 8px; padding: 14px 28px; font-family: 'Inter', sans-serif; font-size: 0.85rem; font-weight: 600; color: #fff; border: 1.5px solid rgba(255,255,255,0.3); border-radius: 8px; text-decoration: none; transition: all 0.3s ease;"><i class="fas fa-phone"></i> +30 695 166 6454</a>
        </div>
      </div>
    </div>
  </section>

  <FooterFour />
</BaseLayout>

<script>
</script>

<style>
  .rb-boat-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(0,0,0,0.1) !important;
  }

  .rb-boat-card:hover img {
    transform: scale(1.05);
  }

  /* ===== Comparison block ===== */
  .rb-compare {
    padding: 80px 0;
    background: #fff;
  }

  .rb-compare__header {
    max-width: 760px;
    margin: 0 auto 40px;
    text-align: center;
  }

  .rb-compare__title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 700;
    color: #113D48;
    margin: 0 0 14px;
    line-height: 1.25;
  }

  .rb-compare__intro {
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
    line-height: 1.7;
    color: #5a6a72;
    margin: 0;
  }

  .rb-compare__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    max-width: 1100px;
    margin: 0 auto;
  }

  .rb-compare__card {
    background: #f8fafb;
    border: 1px solid #e5eaee;
    border-radius: 14px;
    padding: 28px 28px 24px;
    display: flex;
    flex-direction: column;
  }

  .rb-compare__card--accent {
    background: #113D48;
    border-color: #113D48;
    color: #fff;
  }

  .rb-compare__card-head {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 18px;
    padding-bottom: 16px;
    border-bottom: 1px solid #e5eaee;
  }

  .rb-compare__card--accent .rb-compare__card-head {
    border-bottom-color: rgba(255,255,255,0.15);
  }

  .rb-compare__card-head i {
    width: 44px;
    height: 44px;
    border-radius: 10px;
    background: rgba(28,168,203,0.12);
    color: #1CA8CB;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 1.05rem;
    flex-shrink: 0;
  }

  .rb-compare__card--accent .rb-compare__card-head i {
    background: rgba(255,255,255,0.12);
    color: #fff;
  }

  .rb-compare__card-head h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: #113D48;
    margin: 0;
  }

  .rb-compare__card--accent .rb-compare__card-head h3 {
    color: #fff;
  }

  .rb-compare__list {
    list-style: none;
    padding: 0;
    margin: 0 0 22px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .rb-compare__list li {
    font-family: 'Inter', sans-serif;
    font-size: 0.93rem;
    line-height: 1.6;
    color: #4a5568;
    padding-left: 22px;
    position: relative;
  }

  .rb-compare__list li::before {
    content: '✓';
    position: absolute;
    left: 0;
    top: 0;
    color: #1CA8CB;
    font-weight: 700;
  }

  .rb-compare__card--accent .rb-compare__list li {
    color: rgba(255,255,255,0.85);
  }

  .rb-compare__card--accent .rb-compare__list li::before {
    color: #5fd0eb;
  }

  .rb-compare__list strong {
    color: #113D48;
  }

  .rb-compare__card--accent .rb-compare__list strong {
    color: #fff;
  }

  .rb-compare__cta {
    margin-top: auto;
    align-self: flex-start;
    display: inline-block;
    padding: 11px 22px;
    font-family: 'Inter', sans-serif;
    font-size: 0.82rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1.2px;
    color: #1CA8CB;
    border: 1.5px solid #1CA8CB;
    border-radius: 8px;
    text-decoration: none;
    transition: all 0.25s ease;
  }

  .rb-compare__cta:hover {
    background: #1CA8CB;
    color: #fff;
  }

  .rb-compare__card--accent .rb-compare__cta {
    color: #fff;
    border-color: rgba(255,255,255,0.5);
  }

  .rb-compare__card--accent .rb-compare__cta:hover {
    background: #fff;
    color: #113D48;
    border-color: #fff;
  }

  .rb-compare__note {
    max-width: 1100px;
    margin: 28px auto 0;
    padding: 16px 18px;
    background: #fff7e6;
    border-left: 3px solid #F59E0B;
    border-radius: 6px;
    font-family: 'Inter', sans-serif;
    font-size: 0.9rem;
    line-height: 1.65;
    color: #5a4a1f;
  }

  .rb-compare__note i {
    color: #F59E0B;
    margin-right: 6px;
  }

  /* ===== FAQ ===== */
  .rb-faq {
    padding: 80px 0;
    background: #f8fafb;
  }

  .rb-faq__header {
    max-width: 760px;
    margin: 0 auto 32px;
    text-align: center;
  }

  .rb-faq__title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 700;
    color: #113D48;
    margin: 0 0 12px;
  }

  .rb-faq__intro {
    font-family: 'Inter', sans-serif;
    font-size: 0.95rem;
    line-height: 1.65;
    color: #5a6a72;
    margin: 0;
  }

  .rb-faq__intro a {
    color: #1CA8CB;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .rb-faq__list {
    max-width: 880px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .rb-faq__item {
    background: #fff;
    border: 1px solid #e5eaee;
    border-radius: 10px;
  }

  .rb-faq__item[open] {
    border-color: #1CA8CB;
  }

  .rb-faq__q {
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    color: #113D48;
    padding: 16px 44px 16px 18px;
    cursor: pointer;
    list-style: none;
    position: relative;
  }

  .rb-faq__q::-webkit-details-marker { display: none; }

  .rb-faq__q::after {
    content: '+';
    position: absolute;
    right: 18px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 1.4rem;
    font-weight: 300;
    color: #1CA8CB;
  }

  .rb-faq__item[open] .rb-faq__q::after { content: '−'; }

  .rb-faq__a {
    padding: 0 18px 18px;
  }

  .rb-faq__a p {
    font-family: 'Inter', sans-serif;
    font-size: 0.95rem;
    line-height: 1.7;
    color: #4a5568;
    margin: 0;
  }

  @media (max-width: 991px) {
    .rb-intro-grid {
      grid-template-columns: 1fr !important;
      gap: 0 !important;
    }
    .rb-boats-grid {
      grid-template-columns: repeat(2, 1fr) !important;
    }
    .rb-compare__grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 575px) {
    .rb-boats-grid {
      grid-template-columns: 1fr !important;
    }
    .rb-compare__card {
      padding: 22px 22px 20px;
    }
    .rb-compare__note {
      margin: 22px 16px 0;
    }
  }
</style>
