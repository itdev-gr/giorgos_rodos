---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../sections/home-one/Section1-Header.astro';
import FooterFour from '../sections/shared/FooterFour.astro';
import BreadcrumbSchema from '../components/seo/BreadcrumbSchema.astro';
import { getMediaSlot } from '../lib/media';
import { SITE_URL, SITE_NAME } from '../lib/seo';

const aboutPageJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  '@id': `${SITE_URL}/about#aboutpage`,
  url: `${SITE_URL}/about`,
  name: `About ${SITE_NAME}`,
  description: 'Meet the local team behind Rhodes Rent a Boat — sailors, captains and guides based in Mandraki Harbour since 1998.',
  inLanguage: 'en-US',
  isPartOf: { '@id': `${SITE_URL}#website` },
  about: { '@id': `${SITE_URL}#organization` },
  mainEntity: { '@id': `${SITE_URL}#organization` },
};

const heroBg = await getMediaSlot('about.hero.bg', '/assets/img/about/about-hero-boy-sailboat.jpg');
const storyImg = await getMediaSlot('about.story.img', '/assets/img/gallery/yacht/greek-island-1.jpg');
const safetyImg = await getMediaSlot('about.safety.img', '/assets/img/gallery/yacht/yacht-interior-1.jpg');
const differenceImg = await getMediaSlot('about.difference.img', '/assets/img/gallery/yacht/yacht-deck-1.jpg');
const ctaCharterBg = await getMediaSlot('about.cta.charter.bg', '/assets/img/gallery/yacht/yacht-luxury-1.jpg');
const ctaToursBg = await getMediaSlot('about.cta.tours.bg', '/assets/img/gallery/yacht/greek-coast-1.jpg');
const expSunset = await getMediaSlot('about.experience.sunset.img', '/assets/img/gallery/yacht/sunset-cruise-1.jpg');
const expHopping = await getMediaSlot('about.experience.hopping.img', '/assets/img/gallery/yacht/crystal-water-1.jpg');
const expCharter = await getMediaSlot('about.experience.charter.img', '/assets/img/gallery/yacht/yacht-sailing-1.jpg');
const expAdventures = await getMediaSlot('about.experience.adventures.img', '/assets/img/gallery/yacht/yacht-luxury-1.jpg');

const experienceImages: Record<string, string> = {
  'sunset-cruise-1.jpg': expSunset,
  'crystal-water-1.jpg': expHopping,
  'yacht-sailing-1.jpg': expCharter,
  'yacht-luxury-1.jpg': expAdventures,
};
---

<BaseLayout
  title="About Rhodes Rent a Boat — Local Experts in Mandraki Harbour"
  description="Meet the local team behind Rhodes Rent a Boat. Sailors, captains and guides based in Mandraki Harbour since 1998 — not a marketplace."
  ogImage={heroBg}
>
  <BreadcrumbSchema items={[
    { name: 'Home', url: '/' },
    { name: 'About', url: '/about' },
  ]} />
  <script type="application/ld+json" set:html={JSON.stringify(aboutPageJsonLd)} is:inline />
  <Header />

  <!-- ============== Section 1: Full-Bleed Hero ============== -->
  <div class="about-hero" style={`background-image: url(${heroBg});`}>
    <div class="about-hero__overlay"></div>
    <div class="container about-hero__content">
      <span class="about-hero__breadcrumb">Rhodes Rent a Boat &nbsp;|&nbsp; About Us</span>
      <h1 class="about-hero__title" data-ani="slideinup">We Are Rhodes Rent a Boat</h1>
      <p class="about-hero__desc" data-ani="slideinup" data-ani-delay="0.15">
        A family of sailors, local guides, and sea lovers. We have been sharing the waters around Rhodes with visitors since 1998 — always directly, always personally.
      </p>
    </div>
  </div>

  <!-- ============== Section 2: Our Philosophy ============== -->
  <section style="padding: 80px 0;">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-lg-8">
          <div class="title-area text-center mb-20" data-ani="slideinup">
            <h2 class="sec-title">Our Philosophy</h2>
          </div>
          <div class="about-philosophy" data-ani="fadein" data-ani-delay="0.1">
            <p style="font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 1.25rem; line-height: 1.8; color: #1CA8CB; text-align: center; margin-bottom: 32px;">
              Rhodes is not a place you experience through a booking platform.<br />
              Rhodes is a place you experience through people.
            </p>
            <p>This website was created by local professionals who have spent many years working at sea and in tourism on the island. We know the boats, the routes, the crews and the people behind each experience.</p>
            <p>Our goal is not to become a large booking platform. Our goal is to help visitors understand their options and connect directly with the right local providers.</p>
            <p>We believe that small local businesses, family boats and experienced crews offer some of the best experiences on the island. For this reason, we carefully select the experiences and partners that appear on this website.</p>
            <p>This platform is not based on algorithms, advertisements or sponsored listings. It is based on local knowledge, real experience and personal recommendations.</p>
            <p style="font-family: 'Playfair Display', serif; font-weight: 600; font-size: 1.1rem; color: #113D48; text-align: center; margin-top: 32px; line-height: 1.7;">
              We don't try to sell you the most expensive tour.<br />
              We try to help you choose the right experience for you.
            </p>
          </div>
          <div style="display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; margin-top: 36px;" data-ani="slideinup" data-ani-delay="0.2">
            <a href="/service" class="th-btn style3 th-icon">Our Services</a>
            <a href="/contact" class="th-btn style-outline th-icon">Contact Us</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============== Section 2b: Our Story Text ============== -->
  <section style="padding: 0 0 80px;">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-lg-8">
          <div class="about-philosophy" data-ani="fadein">
            <p>This website was created by people who live and work in Rhodes and spend most of their lives at sea.</p>
            <p>After many years working in tourism and boating on the island, we realized that many visitors find it difficult to understand the difference between the many boat tours, boat trips and sea experiences available in Rhodes. Many experiences look similar online, but in reality they can be very different.</p>
            <p>For this reason, we decided to create a website where visitors can find clear information about sea experiences in Rhodes and discover selected boats, tours and local businesses that we believe offer a very good overall experience.</p>
            <p style="font-family: 'Playfair Display', serif; font-weight: 600; color: #113D48;">This is not a large booking platform and not a marketplace.</p>
            <p>Our goal is not to sell as many tours as possible. Our goal is to help visitors find the right experience for them and connect directly with local people who love what they do.</p>
            <p style="font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 1.15rem; color: #1CA8CB; text-align: center; margin-top: 28px; line-height: 1.7;">
              Rhodes is a place that you experience from the sea, and we hope this website helps you discover that side of the island.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============== Section 3: Our Story (Image Left + Text Right) ============== -->
  <section class="about-split space">
    <div class="container">
      <div class="row align-items-center gy-40">
        <div class="col-lg-6" data-ani="slideinleft">
          <div class="about-split__img">
            <img class="global-img" src={storyImg} alt="Greek island coastline" />
          </div>
        </div>
        <div class="col-lg-6" data-ani="slideinright">
          <div class="about-split__text ps-lg-4">
            <span class="about-split__accent"></span>
            <div class="title-area mb-20">
              <h2 class="sec-title">Our Story</h2>
            </div>
            <p class="about-split__subtitle"><em>A local story, told on the water</em></p>
            <p>
              What started as a single sailboat and a passion for the Dodecanese has grown into a full maritime operation — yacht charters, day cruises, speedboat tours, license-free rentals, and professional marine support. But no matter how much we have grown, the philosophy has stayed the same: talk to people first, understand what they want, and then make it happen on the sea.
            </p>
            <p>
              Our skippers know every hidden bay between Rhodes and Kastellorizo. Our team knows the best tavernas, the quietest anchorages, and the perfect time of day to visit each spot. That knowledge does not come from a guidebook — it comes from a lifetime spent here.
            </p>
            <a href="/service" class="th-btn style3 th-icon mt-25">Learn More</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============== Section 4: Our Commitment (Text Left + Image Right — Reversed) ============== -->
  <section class="about-split bg-smoke space">
    <div class="container">
      <div class="row align-items-center flex-lg-row-reverse gy-40">
        <div class="col-lg-6" data-ani="slideinright">
          <div class="about-split__img">
            <img class="global-img" src={safetyImg} alt="Luxury yacht interior" />
          </div>
        </div>
        <div class="col-lg-6" data-ani="slideinleft">
          <div class="about-split__text pe-lg-4">
            <span class="about-split__accent"></span>
            <div class="title-area mb-20">
              <h2 class="sec-title">Safety and Honesty Come First</h2>
            </div>
            <p class="about-split__subtitle"><em>We would rather lose a booking than put you on the wrong boat</em></p>
            <p>
              Every vessel we operate or recommend is regularly inspected and fully equipped with modern safety gear. Our skippers hold professional maritime licenses and are trained for all sea conditions. When you step aboard, you can relax knowing that everything has been checked, double-checked, and prepared with care.
            </p>
            <p>
              We also believe in transparent pricing. The price we quote is the price you pay — no hidden fees, no surprise extras at the dock. If something is not included, we will tell you upfront. That honesty is the foundation of every relationship we build.
            </p>
            <a href="/contact" class="th-btn style3 th-icon mt-25">Get in Touch</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============== Section 5: The Rhodes Rent a Boat Difference (Image Left + Text Right) ============== -->
  <section class="about-split space">
    <div class="container">
      <div class="row align-items-center gy-40">
        <div class="col-lg-6" data-ani="slideinleft">
          <div class="about-split__img">
            <img class="global-img" src={differenceImg} alt="Yacht deck view" />
          </div>
        </div>
        <div class="col-lg-6" data-ani="slideinright">
          <div class="about-split__text ps-lg-4">
            <span class="about-split__accent"></span>
            <div class="title-area mb-20">
              <h2 class="sec-title">What Makes Us Different</h2>
            </div>
            <p class="about-split__subtitle"><em>Direct, personal, and always available</em></p>
            <p>
              When you book through us, you are dealing with the people who actually run the boats. There are no call centers, no middlemen, no booking portals between you and us. You send a message, we reply. You have a question at the harbour, we are a phone call away. That directness is rare in this industry, and our guests notice it immediately.
            </p>
            <p>
              We also do not believe in one-size-fits-all. A couple looking for a quiet sunset cruise needs a completely different experience from a family with young children or a group of friends wanting to explore hidden beaches. We listen, we suggest, and we make sure the experience matches the people.
            </p>
            <a href="/service" class="th-btn style3 th-icon mt-25">Explore Services</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============== Section 6: Featured Experiences ============== -->
  <section class="about-experiences bg-smoke space">
    <div class="container">
      <div class="title-area text-center" data-ani="slideinup">
        <span class="sub-title">There Is More Where This Came From</span>
        <h2 class="sec-title">A Few of the Things We Do</h2>
      </div>
      <div class="row gy-30">
        {[
          {
            img: 'sunset-cruise-1.jpg',
            title: 'Sunset Cruises',
            desc: 'The Rhodes coastline at golden hour — drinks on deck, the sky on fire, and nothing to do but enjoy the moment.',
          },
          {
            img: 'crystal-water-1.jpg',
            title: 'Island Hopping',
            desc: 'Sail from Rhodes to Symi, Halki, or Tilos. Each island has its own character, and we know them all by heart.',
          },
          {
            img: 'yacht-sailing-1.jpg',
            title: 'Private Charters',
            desc: 'Your own yacht, your own skipper, your own schedule. The most personal way to experience the Dodecanese.',
          },
          {
            img: 'yacht-luxury-1.jpg',
            title: 'Sea Adventures',
            desc: 'Snorkel over hidden reefs, swim in bays with no road access, or simply float in water so clear it does not look real.',
          },
        ].map((item, i) => (
          <div class="col-xl-3 col-lg-6 col-md-6" data-ani="slideinup" data-ani-delay={`${i * 0.1}`}>
            <div class="about-exp-card">
              <div class="about-exp-card__img global-img">
                <img src={experienceImages[item.img] || `/assets/img/gallery/yacht/${item.img}`} alt={item.title} />
              </div>
              <div class="about-exp-card__body">
                <h3 class="box-title">{item.title}</h3>
                <p>{item.desc}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============== Section 7: Two Large CTA Cards ============== -->
  <section class="about-cta">
    <div class="container-fluid p-0">
      <div class="row g-0">
        <div class="col-lg-6" data-ani="slideinleft">
          <a href="/service/rodos-charter" class="about-cta__card">
            <img class="about-cta__bg" src={ctaCharterBg} alt="Private Charters" />
            <div class="about-cta__overlay"></div>
            <div class="about-cta__content">
              <h2 class="about-cta__title">Private Charters</h2>
              <p class="about-cta__desc">Your own yacht, your own route, your own pace. Tell us what you want and we will make it happen.</p>
              <span class="th-btn style2 th-icon">Discover More</span>
            </div>
          </a>
        </div>
        <div class="col-lg-6" data-ani="slideinright">
          <a href="/service/rodos-boat-tours" class="about-cta__card">
            <img class="about-cta__bg" src={ctaToursBg} alt="Boat Tours" />
            <div class="about-cta__overlay"></div>
            <div class="about-cta__content">
              <h2 class="about-cta__title">Boat Tours</h2>
              <p class="about-cta__desc">Join a day cruise, rent a speedboat, or hire a boat with a skipper. We have options for every kind of sea lover.</p>
              <span class="th-btn style2 th-icon">Discover More</span>
            </div>
          </a>
        </div>
      </div>
    </div>
  </section>

  <FooterFour />
</BaseLayout>

<script>
  function initAboutHero() {
    document.getElementById('header-one')?.classList.add('header-transparent');
  }
  document.addEventListener('DOMContentLoaded', initAboutHero);
  document.addEventListener('astro:page-load', initAboutHero);
</script>

<style>
  /* ===== Section 1: Hero ===== */
  .about-hero {
    position: relative;
    min-height: 75vh;
    display: flex;
    align-items: flex-end;
    background-color: #0b2f38;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    overflow: hidden;
  }

  .about-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0.15) 0%,
      rgba(17, 61, 72, 0.7) 100%
    );
    z-index: 1;
  }

  .about-hero__content {
    position: relative;
    z-index: 2;
    padding-bottom: 80px;
    color: var(--white-color);
  }

  .about-hero__breadcrumb {
    display: inline-block;
    text-transform: uppercase;
    font-size: 18px;
    letter-spacing: 3px;
    margin-bottom: 20px;
    opacity: 0.85;
  }

  .about-hero__title {
    font-size: 56px;
    font-weight: 700;
    line-height: 1.15;
    margin-bottom: 20px;
    max-width: 650px;
    color: var(--white-color);
  }

  .about-hero__desc {
    font-size: 18px;
    line-height: 1.7;
    max-width: 550px;
    opacity: 0.9;
    margin-bottom: 0;
    color: #fff;
  }

  @media (max-width: 991px) {
    .about-hero {
      min-height: 60vh;
    }
    .about-hero__title {
      font-size: 38px;
    }
    .about-hero__content {
      padding-bottom: 50px;
    }
  }

  @media (max-width: 575px) {
    .about-hero {
      min-height: 55vh;
    }
    .about-hero__title {
      font-size: 30px;
    }
    .about-hero__desc {
      font-size: 16px;
    }
  }

  /* ===== Section 2: Philosophy ===== */
  .about-philosophy {
    font-family: 'Inter', sans-serif;
    font-size: 1.05rem;
    line-height: 1.85;
    color: #4a5568;
  }

  .about-philosophy p {
    margin-bottom: 18px;
  }

  :global(.th-btn.style-outline) {
    background: transparent;
    color: var(--title-color);
    border: 1px solid var(--title-color);
    box-shadow: none;
  }

  :global(.th-btn.style-outline::before) {
    background-color: var(--theme-color);
  }

  :global(.th-btn.style-outline:hover) {
    color: var(--white-color);
    border-color: var(--theme-color);
  }

  /* ===== Sections 3-5: Split Sections ===== */
  .about-split__img {
    border-radius: 8px;
    overflow: hidden;
  }

  .about-split__img :global(img) {
    aspect-ratio: 4 / 3;
    object-fit: cover;
    width: 100%;
    display: block;
  }

  .about-split__accent {
    display: block;
    width: 30px;
    height: 4px;
    background: var(--theme-color);
    margin-bottom: 20px;
    border-radius: 2px;
  }

  .about-split__subtitle {
    color: var(--theme-color);
    font-size: 17px;
    margin-bottom: 15px;
  }

  /* ===== Section 6: Featured Experiences ===== */
  .about-exp-card {
    background: var(--white-color);
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    height: 100%;
  }

  .about-exp-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.12);
  }

  .about-exp-card__img {
    overflow: hidden;
    aspect-ratio: 4 / 3;
  }

  .about-exp-card__img :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .about-exp-card:hover .about-exp-card__img :global(img) {
    transform: scale(1.07);
  }

  .about-exp-card__body {
    padding: 24px;
  }

  .about-exp-card__body :global(.box-title) {
    margin-bottom: 10px;
  }

  .about-exp-card__body p {
    font-size: 15px;
    line-height: 1.6;
    margin-bottom: 0;
  }

  /* ===== Section 7: CTA Cards ===== */
  .about-cta__card {
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    position: relative;
    min-height: 450px;
    overflow: hidden;
    text-decoration: none;
  }

  .about-cta__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .about-cta__card:hover .about-cta__bg {
    transform: scale(1.05);
  }

  .about-cta__overlay {
    position: absolute;
    inset: 0;
    background: rgba(17, 61, 72, 0.65);
    transition: background 0.3s ease;
  }

  .about-cta__card:hover .about-cta__overlay {
    background: rgba(17, 61, 72, 0.75);
  }

  .about-cta__content {
    position: relative;
    z-index: 2;
    color: var(--white-color);
    padding: 40px 20px;
  }

  .about-cta__title {
    font-size: 36px;
    font-weight: 700;
    margin-bottom: 12px;
    color: var(--white-color);
  }

  .about-cta__desc {
    font-size: 17px;
    color: #fff;
    opacity: 1;
    margin-bottom: 28px;
    max-width: 380px;
    margin-left: auto;
    margin-right: auto;
  }

  @media (max-width: 991px) {
    .about-cta__card {
      min-height: 350px;
    }
    .about-cta__title {
      font-size: 28px;
    }
  }

  @media (max-width: 575px) {
    .about-cta__card {
      min-height: 300px;
    }
  }
</style>
