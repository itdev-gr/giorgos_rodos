---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../sections/home-one/Section1-Header.astro';
import FooterFour from '../sections/shared/FooterFour.astro';
import BreadcrumbSchema from '../components/seo/BreadcrumbSchema.astro';
import { getMediaSlot } from '../lib/media';
import { SITE_URL, SITE_NAME } from '../lib/seo';
import { resolveLocale } from '../i18n/context';
import { getMessages } from '../i18n';
import { localizedPath } from '../i18n/routing';
import { SCHEMA_LANGUAGE } from '../i18n/locales';

import { getPageContent } from '../i18n/page-content';

const locale = resolveLocale(Astro.locals, Astro.url.pathname);
const messages = getMessages(locale);
const pc = getPageContent(locale).about;
const serviceHref = localizedPath('/service', locale);
const contactHref = localizedPath('/contact', locale);
const charterHref = localizedPath('/service/rhodes-charter', locale);
const toursHref = localizedPath('/service/rhodes-boat-tours', locale);

const aboutPageJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  '@id': `${SITE_URL}/about#aboutpage`,
  url: `${SITE_URL}${localizedPath('/about', locale)}`,
  name: messages.meta.about.title,
  description: messages.meta.about.description,
  inLanguage: SCHEMA_LANGUAGE[locale],
  isPartOf: { '@id': `${SITE_URL}#website` },
  about: { '@id': `${SITE_URL}#organization` },
  mainEntity: { '@id': `${SITE_URL}#organization` },
};

const heroBg = await getMediaSlot('about.hero.bg', '/assets/img/pages/about/about-hero-boy-sailboat.jpg');
const storyImg = await getMediaSlot('about.story.img', '/assets/img/gallery/yacht/greek-island-1.jpg');
const safetyImg = await getMediaSlot('about.safety.img', '/assets/img/gallery/yacht/yacht-interior-1.jpg');
const differenceImg = await getMediaSlot('about.difference.img', '/assets/img/gallery/yacht/yacht-deck-1.jpg');
const ctaCharterBg = await getMediaSlot('about.cta.charter.bg', '/assets/img/gallery/yacht/yacht-luxury-1.jpg');
const ctaToursBg = await getMediaSlot('about.cta.tours.bg', '/assets/img/gallery/yacht/greek-coast-1.jpg');
const expSunset = await getMediaSlot('about.experience.sunset.img', '/assets/img/gallery/yacht/sunset-cruise-1.jpg');
const expHopping = await getMediaSlot('about.experience.hopping.img', '/assets/img/gallery/yacht/crystal-water-1.jpg');
const expCharter = await getMediaSlot('about.experience.charter.img', '/assets/img/gallery/yacht/yacht-sailing-1.jpg');
const expAdventures = await getMediaSlot('about.experience.adventures.img', '/assets/img/gallery/yacht/yacht-luxury-1.jpg');

const experienceImages: Record<string, string> = {
  'sunset-cruise-1.jpg': expSunset,
  'crystal-water-1.jpg': expHopping,
  'yacht-sailing-1.jpg': expCharter,
  'yacht-luxury-1.jpg': expAdventures,
};
---

<BaseLayout
  title={messages.meta.about.title}
  description={messages.meta.about.description}
  ogImage={heroBg}
>
  <BreadcrumbSchema items={[
    { name: messages.breadcrumbs.home, url: localizedPath('/', locale) },
    { name: messages.breadcrumbs.about, url: localizedPath('/about', locale) },
  ]} />
  <script type="application/ld+json" set:html={JSON.stringify(aboutPageJsonLd)} is:inline />
  <Header />

  <!-- ============== Section 1: Hero ============== -->
  <section class="about-hero">
    <div class="container">
      <div class="about-hero__content text-center">
        <h1 class="about-hero__title">{pc.h1}</h1>
      </div>
    </div>
  </section>

  <!-- ============== Section 2: Meet the Founder ============== -->
  <section class="about-panel">
    <div class="container">
      <div class="row align-items-center gy-40">
        <div class="col-lg-6" data-ani="slideinleft">
          <div class="about-panel__media">
            <img src={heroBg} alt="Giorgos R., Captain and Founder of Rhodes Rent a Boat" loading="lazy" decoding="async" />
          </div>
        </div>
        <div class="col-lg-6" data-ani="slideinright">
          <div class="about-panel__body">
            <span class="about-panel__eyebrow">{pc.founder.eyebrow}</span>
            <h2 class="about-panel__title">{pc.founder.title}</h2>
            <p class="about-panel__lead"><em>{pc.founder.lead}</em></p>
            <p>{pc.founder.paragraphs[0]}</p>
            <p>{pc.founder.paragraphs[1]}</p>
            <div class="about-panel__note">
              {pc.founder.note}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============== Section 3: Our Philosophy ============== -->
  <section class="about-panel about-panel--muted about-panel--reverse">
    <div class="container">
      <div class="row align-items-center flex-lg-row-reverse gy-40">
        <div class="col-lg-6" data-ani="slideinright">
          <div class="about-panel__media">
            <img src={expCharter} alt="Sailing yacht charter in the Dodecanese" loading="lazy" decoding="async" />
          </div>
        </div>
        <div class="col-lg-6" data-ani="slideinleft">
          <div class="about-panel__body about-panel__body--pad-right">
            <span class="about-panel__eyebrow">{pc.philosophy.eyebrow}</span>
            <h2 class="about-panel__title">{pc.philosophy.title}</h2>
            <p class="about-panel__quote">
              {pc.philosophy.quote}
            </p>
            <p>{pc.philosophy.paragraphs[0]}</p>
            <p>{pc.philosophy.paragraphs[1]}</p>
            <p>{pc.philosophy.paragraphs[2]}</p>
            <p class="about-panel__highlight">
              {pc.philosophy.highlight}
            </p>
            <div class="about-panel__actions">
              <a href={serviceHref} class="th-btn style3 th-icon">{pc.philosophy.ctaServices}</a>
              <a href={contactHref} class="th-btn style-outline th-icon">{pc.philosophy.ctaContact}</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============== Section 4: Why We Built This ============== -->
  <section class="about-panel">
    <div class="container">
      <div class="row align-items-center gy-40">
        <div class="col-lg-6" data-ani="slideinleft">
          <div class="about-panel__media">
            <img src={expHopping} alt="Crystal clear waters around Rhodes" loading="lazy" decoding="async" />
          </div>
        </div>
        <div class="col-lg-6" data-ani="slideinright">
          <div class="about-panel__body">
            <span class="about-panel__eyebrow">{pc.whyBuilt.eyebrow}</span>
            <h2 class="about-panel__title">{pc.whyBuilt.title}</h2>
            <p>{pc.whyBuilt.paragraphs[0]}</p>
            <p>{pc.whyBuilt.paragraphs[1]}</p>
            <p>{pc.whyBuilt.paragraphs[2]}</p>
            <p>{pc.whyBuilt.paragraphs[3]}</p>
            <p class="about-panel__quote about-panel__quote--inline">
              {pc.whyBuilt.quote}
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============== Section 5: Our Story (Image Left + Text Right) ============== -->
  <section class="about-split space">
    <div class="container">
      <div class="row align-items-center gy-40">
        <div class="col-lg-6" data-ani="slideinleft">
          <div class="about-split__img">
            <img class="global-img" src={storyImg} alt="Greek island coastline" />
          </div>
        </div>
        <div class="col-lg-6" data-ani="slideinright">
          <div class="about-split__text ps-lg-4">
            <span class="about-split__accent"></span>
            <div class="title-area mb-20">
              <h2 class="sec-title">{pc.story.title}</h2>
            </div>
            <p class="about-split__subtitle"><em>{pc.story.subtitle}</em></p>
            <p>
              {pc.story.paragraphs[0]}
            </p>
            <p>
              {pc.story.paragraphs[1]}
            </p>
            <a href={serviceHref} class="th-btn style3 th-icon mt-25">{pc.story.cta}</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============== Section 6: Safety (Text Left + Image Right, Reversed) ============== -->
  <section class="about-split bg-smoke space">
    <div class="container">
      <div class="row align-items-center flex-lg-row-reverse gy-40">
        <div class="col-lg-6" data-ani="slideinright">
          <div class="about-split__img">
            <img class="global-img" src={safetyImg} alt="Luxury yacht interior" />
          </div>
        </div>
        <div class="col-lg-6" data-ani="slideinleft">
          <div class="about-split__text pe-lg-4">
            <span class="about-split__accent"></span>
            <div class="title-area mb-20">
              <h2 class="sec-title">{pc.safety.title}</h2>
            </div>
            <p class="about-split__subtitle"><em>{pc.safety.subtitle}</em></p>
            <p>
              {pc.safety.paragraphs[0]}
            </p>
            <p>
              {pc.safety.paragraphs[1]}
            </p>
            <a href={contactHref} class="th-btn style3 th-icon mt-25">{pc.safety.cta}</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============== Section 7: The Difference (Image Left + Text Right) ============== -->
  <section class="about-split space">
    <div class="container">
      <div class="row align-items-center gy-40">
        <div class="col-lg-6" data-ani="slideinleft">
          <div class="about-split__img">
            <img class="global-img" src={differenceImg} alt="Yacht deck view" />
          </div>
        </div>
        <div class="col-lg-6" data-ani="slideinright">
          <div class="about-split__text ps-lg-4">
            <span class="about-split__accent"></span>
            <div class="title-area mb-20">
              <h2 class="sec-title">{pc.difference.title}</h2>
            </div>
            <p class="about-split__subtitle"><em>{pc.difference.subtitle}</em></p>
            <p>
              {pc.difference.paragraphs[0]}
            </p>
            <p>
              {pc.difference.paragraphs[1]}
            </p>
            <a href={serviceHref} class="th-btn style3 th-icon mt-25">{pc.difference.cta}</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============== Section 6: Featured Experiences ============== -->
  <section class="about-experiences bg-smoke space">
    <div class="container">
      <div class="title-area text-center" data-ani="slideinup">
        <h2 class="sec-title">{pc.experiences.title}</h2>
      </div>
      <div class="row gy-30">
        {[
          { img: 'sunset-cruise-1.jpg', ...pc.experiences.items[0] },
          { img: 'crystal-water-1.jpg', ...pc.experiences.items[1] },
          { img: 'yacht-sailing-1.jpg', ...pc.experiences.items[2] },
          { img: 'yacht-luxury-1.jpg', ...pc.experiences.items[3] },
        ].map((item, i) => (
          <div class="col-xl-3 col-lg-6 col-md-6" data-ani="slideinup" data-ani-delay={`${i * 0.1}`}>
            <div class="about-exp-card">
              <div class="about-exp-card__img global-img">
                <img src={experienceImages[item.img] || `/assets/img/gallery/yacht/${item.img}`} alt={item.title} />
              </div>
              <div class="about-exp-card__body">
                <h3 class="box-title">{item.title}</h3>
                <p>{item.desc}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============== Section 7: Two Large CTA Cards ============== -->
  <section class="about-cta">
    <div class="container-fluid p-0">
      <div class="row g-0">
        <div class="col-lg-6" data-ani="slideinleft">
          <a href={charterHref} class="about-cta__card">
            <img class="about-cta__bg" src={ctaCharterBg} alt={pc.ctaCards.charter.title} />
            <div class="about-cta__overlay"></div>
            <div class="about-cta__content">
              <h2 class="about-cta__title">{pc.ctaCards.charter.title}</h2>
              <p class="about-cta__desc">{pc.ctaCards.charter.desc}</p>
              <span class="th-btn style2 th-icon">{pc.ctaCards.charter.cta}</span>
            </div>
          </a>
        </div>
        <div class="col-lg-6" data-ani="slideinright">
          <a href={toursHref} class="about-cta__card">
            <img class="about-cta__bg" src={ctaToursBg} alt={pc.ctaCards.tours.title} />
            <div class="about-cta__overlay"></div>
            <div class="about-cta__content">
              <h2 class="about-cta__title">{pc.ctaCards.tours.title}</h2>
              <p class="about-cta__desc">{pc.ctaCards.tours.desc}</p>
              <span class="th-btn style2 th-icon">{pc.ctaCards.tours.cta}</span>
            </div>
          </a>
        </div>
      </div>
    </div>
  </section>

  <FooterFour />
</BaseLayout>

<style>
  /* ===== Section 1: Hero ===== */
  .about-hero {
    min-height: 320px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 140px 0 72px;
    background: linear-gradient(135deg, #1CA8CB 0%, #1489a8 35%, #113D48 100%);
  }

  .about-hero__content {
    max-width: 760px;
    margin: 0 auto;
  }

  .about-hero__title {
    font-size: clamp(2rem, 4.5vw, 3.25rem);
    font-weight: 800;
    line-height: 1.15;
    margin: 0;
    color: #fff;
  }

  @media (max-width: 991px) {
    .about-hero {
      min-height: 280px;
      padding: 120px 0 52px;
    }
  }

  @media (max-width: 575px) {
    .about-hero {
      padding: 108px 0 44px;
    }
  }

  /* ===== Sections 2–4: Alternating panels ===== */
  .about-panel {
    padding: 88px 0;
    background: #fff;
  }

  .about-panel--muted {
    background: #f8fafb;
  }

  .about-panel__media {
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 16px 48px rgba(17, 61, 72, 0.12);
    position: relative;
  }

  .about-panel__media::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 55%, rgba(17, 61, 72, 0.18) 100%);
    pointer-events: none;
  }

  .about-panel__media img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .about-panel:hover .about-panel__media img {
    transform: scale(1.03);
  }

  .about-panel__body {
    max-width: 560px;
  }

  .about-panel__body--pad-right {
    margin-left: auto;
  }

  .about-panel--reverse .about-panel__body {
    margin-left: 0;
    margin-right: auto;
  }

  .about-panel__eyebrow {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #1CA8CB;
    margin-bottom: 10px;
  }

  .about-panel__title {
    font-size: clamp(1.85rem, 3vw, 2.4rem);
    font-weight: 700;
    color: #113D48;
    line-height: 1.25;
    margin: 0 0 18px;
    text-transform: none !important;
  }

  .about-panel__title::first-letter {
    text-transform: uppercase !important;
  }

  .about-panel__lead {
    font-size: 1.05rem;
    font-weight: 600;
    font-style: italic;
    color: #1CA8CB;
    margin: 0 0 18px;
  }

  .about-panel__body p {
    font-size: 1rem;
    line-height: 1.75;
    color: #4a5568;
    margin: 0 0 14px;
  }

  .about-panel__note {
    margin-top: 10px;
    padding: 16px 18px;
    border-left: 3px solid #1CA8CB;
    background: rgba(28, 168, 203, 0.08);
    border-radius: 0 10px 10px 0;
    font-size: 0.95rem;
    line-height: 1.65;
    color: #113D48;
    font-weight: 500;
  }

  .about-panel__quote {
    margin: 0 0 20px;
    padding: 18px 20px;
    border: 0;
    border-left: 3px solid #1CA8CB;
    border-radius: 0 12px 12px 0;
    background: rgba(28, 168, 203, 0.07);
    font-style: italic;
    font-size: 1.05rem;
    line-height: 1.65;
    color: #0e6f87;
  }

  .about-panel__quote--inline {
    margin-top: 6px;
    margin-bottom: 0;
  }

  .about-panel__highlight {
    font-weight: 600 !important;
    font-size: 1.08rem !important;
    color: #113D48 !important;
    line-height: 1.6 !important;
    margin-top: 8px !important;
    margin-bottom: 0 !important;
  }

  .about-panel__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 24px;
  }

  .about-panel__actions :global(.th-btn) {
    font-size: 0.88rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    text-transform: none;
    padding: 12px 22px;
    border-radius: 8px;
  }

  @media (max-width: 991px) {
    .about-panel {
      padding: 64px 0;
    }

    .about-panel__body,
    .about-panel__body--pad-right,
    .about-panel--reverse .about-panel__body {
      max-width: none;
      margin: 0;
    }
  }

  @media (max-width: 575px) {
    .about-panel {
      padding: 48px 0;
    }

    .about-panel__actions {
      flex-direction: column;
    }

    .about-panel__actions :global(.th-btn) {
      width: 100%;
      justify-content: center;
    }
  }

  :global(.th-btn.style-outline) {
    background: transparent;
    color: var(--title-color);
    border: 1px solid var(--title-color);
    box-shadow: none;
  }

  :global(.th-btn.style-outline::before) {
    background-color: var(--theme-color);
  }

  :global(.th-btn.style-outline:hover) {
    color: var(--white-color);
    border-color: var(--theme-color);
  }

  /* ===== Sections 3-5: Split Sections ===== */
  .about-split :global(h2.sec-title) {text-transform: none !important;
    line-height: 1.25;
  }

  .about-split :global(h2.sec-title)::first-letter {
    text-transform: uppercase !important;
  }

  .about-split__text p {font-size: 1rem;
    line-height: 1.75;
    color: #4a5568;
  }

  .about-split__subtitle {font-size: 1rem;
    font-weight: 500;
    font-style: italic;
    color: #1CA8CB;
    margin-bottom: 16px;
  }

  .about-split__img {
    border-radius: 8px;
    overflow: hidden;
  }

  .about-split__img :global(img) {
    aspect-ratio: 4 / 3;
    object-fit: cover;
    width: 100%;
    display: block;
  }

  .about-split__accent {
    display: block;
    width: 30px;
    height: 4px;
    background: var(--theme-color);
    margin-bottom: 20px;
    border-radius: 2px;
  }

  .about-experiences :global(h2.sec-title),
  .about-experiences :global(.sub-title) {text-transform: none !important;
  }

  .about-experiences :global(h2.sec-title)::first-letter,
  .about-experiences :global(.sub-title)::first-letter {
    text-transform: uppercase !important;
  }

  /* ===== Section 6: Featured Experiences ===== */
  .about-exp-card {
    background: var(--white-color);
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    height: 100%;
  }

  .about-exp-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.12);
  }

  .about-exp-card__img {
    overflow: hidden;
    aspect-ratio: 4 / 3;
  }

  .about-exp-card__img :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .about-exp-card:hover .about-exp-card__img :global(img) {
    transform: scale(1.07);
  }

  .about-exp-card__body {
    padding: 24px;
  }

  .about-exp-card__body :global(.box-title) {
    margin-bottom: 10px;
  }

  .about-exp-card__body p {
    font-size: 15px;
    line-height: 1.6;
    margin-bottom: 0;
  }

  /* ===== Section 7: CTA Cards ===== */
  .about-cta__card {
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    position: relative;
    min-height: 450px;
    overflow: hidden;
    text-decoration: none;
  }

  .about-cta__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .about-cta__card:hover .about-cta__bg {
    transform: scale(1.05);
  }

  .about-cta__overlay {
    position: absolute;
    inset: 0;
    background: rgba(17, 61, 72, 0.65);
    transition: background 0.3s ease;
  }

  .about-cta__card:hover .about-cta__overlay {
    background: rgba(17, 61, 72, 0.75);
  }

  .about-cta__content {
    position: relative;
    z-index: 2;
    color: var(--white-color);
    padding: 40px 20px;
  }

  .about-cta__title {
    font-size: 36px;
    font-weight: 700;
    margin-bottom: 12px;
    color: var(--white-color);
  }

  .about-cta__desc {
    font-size: 17px;
    color: #fff;
    opacity: 1;
    margin-bottom: 28px;
    max-width: 380px;
    margin-left: auto;
    margin-right: auto;
  }

  @media (max-width: 991px) {
    .about-cta__card {
      min-height: 350px;
    }
    .about-cta__title {
      font-size: 28px;
    }
  }

  @media (max-width: 575px) {
    .about-cta__card {
      min-height: 300px;
    }
  }
</style>
