---
export const prerender = false;

import LoginForm from '../components/auth/LoginForm';

// If already logged in, redirect to dashboard
const accessToken = Astro.cookies.get('sb-access-token')?.value;
if (accessToken) {
  return Astro.redirect('/dashboard');
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Secure login for Rhodes Rent a Boat partners and tour operators — manage listings, bookings and calendar from the dashboard." />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="googlebot" content="noindex, nofollow" />
    <link rel="canonical" href="https://rhodesrentaboat.com/login" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="stylesheet" href="/assets/css/site-fonts.css" />
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body { font-family: Helvetica, "Helvetica Neue", Arial, sans-serif; background: #f8fafb; min-height: 100vh; display: flex; align-items: center; justify-content: center; }
      input:focus { border-color: #1CA8CB !important; box-shadow: 0 0 0 3px rgba(28,168,203,0.1); }
      button:hover:not(:disabled) { background: #178da8 !important; }
    </style>
  </head>
  <body>
    <LoginForm client:load />
  </body>
</html>
