---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../sections/home-one/Section1-Header.astro';
import FooterFour from '../sections/shared/FooterFour.astro';
import ContactPanel from '../components/ContactPanel.astro';
import BreadcrumbSchema from '../components/seo/BreadcrumbSchema.astro';
import { getMediaSlot } from '../lib/media';
import { SITE_URL } from '../lib/seo';
import { resolveLocale } from '../i18n/context';
import { getMessages } from '../i18n';
import { localizedPath } from '../i18n/routing';
import { getPageContent } from '../i18n/page-content';
import { getContactFormLabels } from '../i18n/ui-labels';
import { SCHEMA_LANGUAGE } from '../i18n/locales';

const locale = resolveLocale(Astro.locals, Astro.url.pathname);
const messages = getMessages(locale);
const contact = getPageContent(locale).contact;
const formLabels = getContactFormLabels(locale);
const contactPath = localizedPath('/contact', locale);

const heroBg = await getMediaSlot('contact.hero.bg', '/assets/img/gallery/yacht/crystal-water-1.jpg');

const contactPageJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  '@id': `${SITE_URL}${contactPath === '/' ? '' : contactPath}#contactpage`,
  url: `${SITE_URL}${contactPath === '/' ? '' : contactPath}`,
  name: messages.meta.contact.title,
  description: messages.meta.contact.description,
  inLanguage: SCHEMA_LANGUAGE[locale],
  isPartOf: { '@id': `${SITE_URL}#website` },
  about: { '@id': `${SITE_URL}#organization` },
};
---

<BaseLayout
  title={messages.meta.contact.title}
  description={messages.meta.contact.description}
  ogImage={heroBg}
>
  <BreadcrumbSchema items={[
    { name: messages.breadcrumbs.home, url: localizedPath('/', locale) },
    { name: messages.breadcrumbs.contact, url: localizedPath('/contact', locale) },
  ]} />
  <script type="application/ld+json" set:html={JSON.stringify(contactPageJsonLd)} is:inline />
  <Header />

  <section class="contact-hero">
    <div class="container">
      <div class="contact-hero__content text-center">
        <h1 class="contact-hero__title">{messages.contact.h1}</h1>
      </div>
    </div>
  </section>

  <ContactPanel
    class="contact-page__panel"
    formIdPrefix="pg"
    formIntro={contact.formIntro}
    infoIntro={contact.infoIntro}
    labels={formLabels}
  />

  <section class="contact-location">
    <div class="container">
      <div class="contact-location__grid">
        <div class="contact-location__content">
          <span class="contact-location__eyebrow">{contact.location.eyebrow}</span>
          <h2 class="contact-location__title">{contact.location.title}</h2>
          <p class="contact-location__text">
            {contact.location.text}
          </p>
          <ul class="contact-location__list">
            {contact.location.listItems.map((item) => (
              <li set:html={item} />
            ))}
          </ul>
        </div>

        <aside class="contact-location__card" aria-label={contact.location.card.businessName}>
          <h3 class="contact-location__card-title">{contact.location.card.businessName}</h3>
          <dl class="contact-location__card-list">
            <dt>{contact.location.card.labels.address}</dt>
            <dd>Ionos Dragoumi 39<br />Rhodes 851 00, Greece</dd>
            <dt>{contact.location.card.labels.phone}</dt>
            <dd><a href="tel:+306951666454">+30 695 166 6454</a></dd>
            <dt>{contact.location.card.labels.whatsapp}</dt>
            <dd><a href="https://wa.me/306951666454" target="_blank" rel="noopener">+30 695 166 6454</a></dd>
            <dt>{contact.location.card.labels.email}</dt>
            <dd><a href="mailto:rhodessailingtours2023@gmail.com">rhodessailingtours2023@gmail.com</a></dd>
            <dt>{contact.location.card.labels.hours}</dt>
            <dd>{contact.location.card.hoursValue}</dd>
          </dl>
          <a href="https://maps.app.goo.gl/2KSkGvEyWXBu83SVA" target="_blank" rel="noopener" class="contact-location__maps-link">
            {contact.location.card.mapsLink}
            <i class="fa-regular fa-arrow-right" aria-hidden="true"></i>
          </a>
        </aside>
      </div>

      <div class="contact-location__map">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3231.5!2d28.2197904!3d36.4497769!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x1495612e417eb653%3A0x90a1e588da06a420!2sRhodes+Rent+a+Boat!5e0!3m2!1sen!2sgr!4v1715072400000!5m2!1sen!2sgr"
          allowfullscreen
          loading="lazy"
          title={contact.location.mapTitle}
        ></iframe>
      </div>
    </div>
  </section>

  <FooterFour />
</BaseLayout>

<style>
  .contact-hero {
    min-height: 280px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 140px 0 56px;
    background: linear-gradient(135deg, #1CA8CB 0%, #1489a8 35%, #113D48 100%);
  }

  .contact-hero__content {
    max-width: 680px;
    margin: 0 auto;
  }

  .contact-hero__title {
    font-size: clamp(2rem, 4.5vw, 3rem);
    font-weight: 800;
    line-height: 1.15;
    margin: 0;
    color: #fff;
  }

  .contact-page__panel {
    padding-top: 64px;
    padding-bottom: 64px;
    background: #fff;
  }

  .contact-location {
    padding: 0 0 88px;
    background: #f4f8f9;
  }

  .contact-location__grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 32px;
    align-items: start;
    margin-bottom: 36px;
  }

  .contact-location__eyebrow {
    display: block;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #1CA8CB;
    margin-bottom: 10px;
  }

  .contact-location__title {
    font-size: clamp(1.5rem, 2.8vw, 2rem);
    font-weight: 700;
    color: #113D48;
    margin: 0 0 14px;
    line-height: 1.25;
  }

  .contact-location__text {
    font-size: 0.98rem;
    line-height: 1.75;
    color: #000;
    margin: 0 0 22px;
  }

  .contact-location__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .contact-location__list li {
    font-size: 0.94rem;
    line-height: 1.65;
    color: #000;
    padding-left: 20px;
    position: relative;
  }

  .contact-location__list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #1CA8CB;
  }

  .contact-location__list strong {
    color: #000;
  }

  .contact-location__list a {
    color: #1CA8CB;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .contact-location__card {
    background: #fff;
    border-radius: 16px;
    padding: 28px;
    box-shadow: 0 12px 40px rgba(17, 61, 72, 0.08);
    border: 1px solid #e8eef0;
  }

  .contact-location__card-title {
    font-size: 1.2rem;
    font-weight: 700;
    color: #113D48;
    margin: 0 0 18px;
    padding-bottom: 14px;
    border-bottom: 1px solid #e8eef0;
  }

  .contact-location__card-list {
    margin: 0;
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: 8px 16px;
  }

  .contact-location__card-list dt {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #1CA8CB;
    align-self: start;
    padding-top: 2px;
  }

  .contact-location__card-list dd {
    font-size: 0.92rem;
    line-height: 1.55;
    color: #000;
    margin: 0;
  }

  .contact-location__card-list a {
    color: #000;
    transition: color 0.2s ease;
  }

  .contact-location__card-list a:hover {
    color: #1CA8CB;
  }

  .contact-location__maps-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 22px;
    font-size: 0.85rem;
    font-weight: 600;
    color: #1CA8CB;
    text-decoration: none;
  }

  .contact-location__maps-link:hover {
    color: #178fa8;
  }

  .contact-location__map {
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 12px 40px rgba(17, 61, 72, 0.1);
    border: 1px solid #e8eef0;
  }

  .contact-location__map iframe {
    display: block;
    width: 100%;
    height: 420px;
    border: 0;
  }

  @media (max-width: 991px) {
    .contact-hero {
      min-height: 240px;
      padding: 120px 0 44px;
    }

    .contact-page__panel {
      padding-top: 48px;
      padding-bottom: 48px;
    }

    .contact-location__grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 575px) {
    .contact-hero {
      padding: 108px 0 36px;
    }

    .contact-location {
      padding-bottom: 64px;
    }

    .contact-location__map iframe {
      height: 320px;
    }
  }
</style>
