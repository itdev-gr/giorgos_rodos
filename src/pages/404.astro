---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../sections/home-one/Section1-Header.astro';
import Breadcrumb from '../components/ui/Breadcrumb.astro';
import FooterFour from '../sections/shared/FooterFour.astro';
import { resolveLocale } from '../i18n/context';
import { getMessages } from '../i18n';
import { localizedPath } from '../i18n/routing';

const locale = resolveLocale(Astro.locals, Astro.url.pathname);
const messages = getMessages(locale);
const homeHref = localizedPath('/', locale);
---

<BaseLayout
  title={messages.meta.notFound.title}
  description={messages.meta.notFound.description}
  noindex={true}
>
  <Header />
  <Breadcrumb title={messages.notFound.breadcrumb} homeHref={homeHref} homeLabel={messages.breadcrumbs.home} />
  <section class="space bg-smoke">
    <div class="container">
      <div class="row flex-row-reverse align-items-center">
        <div class="col-lg-6">
          <div class="error-img">
            <img src="/assets/img/ui/theme/error.svg" alt="404" />
          </div>
        </div>
        <div class="col-lg-6">
          <div class="error-content">
            <h2 class="error-title">{messages.notFound.title}</h2>
            <h4 class="error-subtitle">{messages.notFound.subtitle}</h4>
            <p class="error-text">{messages.notFound.text}</p>
            <a href={homeHref} class="th-btn style3">
              <img src="/assets/img/ui/icons/right-arrow2.svg" alt="" aria-hidden="true" />
              {messages.notFound.cta}
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
  <FooterFour />
</BaseLayout>
