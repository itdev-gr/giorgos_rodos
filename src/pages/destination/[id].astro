---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../sections/home-one/Section1-Header.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import FooterFour from '../../sections/shared/FooterFour.astro';
import ScrollToTop from '../../components/interactive/ScrollToTop';
import destinations from '../../data/data-destination.json';

export function getStaticPaths() {
  return destinations.map((dest: any) => ({
    params: { id: String(dest.id) },
    props: { destination: dest },
  }));
}

const { destination } = Astro.props;
