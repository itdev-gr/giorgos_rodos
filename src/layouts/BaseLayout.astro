---
import Seo from '../components/seo/Seo.astro';
import OrganizationSchema from '../components/seo/OrganizationSchema.astro';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  articleAuthor?: string;
  articlePublishedTime?: string;
  noindex?: boolean;
}

const {
  title = 'Rhodes Boat Tours | Boat Trips, Cruises & Rentals',
  description = 'Boat tours, rentals and yacht charters in Rhodes, Greece. Local experts in Mandraki Harbour since 2009.',
  canonical,
  ogImage,
  ogType,
  articleAuthor,
  articlePublishedTime,
  noindex,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/assets/img/favicon.svg" />
    <Seo
      title={title}
      description={description}
      canonical={canonical}
      ogImage={ogImage}
      ogType={ogType}
      articleAuthor={articleAuthor}
      articlePublishedTime={articlePublishedTime}
      noindex={noindex}
    />
    <OrganizationSchema />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Manrope:wght@300;400;500;600;700;800&family=Playfair+Display:wght@400;500;600;700;800;900&family=Allura&display=swap"
      rel="stylesheet"
    />

    <!-- Bootstrap -->
    <link rel="stylesheet" href="/assets/css/bootstrap.min.css" />
    <!-- FontAwesome -->
    <link rel="stylesheet" href="/assets/css/fontawesome.min.css" />
    <!-- Magnific Popup -->
    <link rel="stylesheet" href="/assets/css/magnific-popup.min.css" />
    <!-- Swiper -->
    <link rel="stylesheet" href="/assets/css/swiper-bundle.min.css" />
    <!-- Theme CSS (must be AFTER Bootstrap) -->
    <link rel="stylesheet" href="/assets/css/style.css" />
    <style>
      html, body {
        overflow-x: hidden !important;
        max-width: 100vw !important;
        width: 100% !important;
      }
      *, *::before, *::after {
        max-width: 100vw;
      }
    </style>
  </head>
  <body>
    <slot />

    <a
      href="https://wa.me/306951666454"
      target="_blank"
      rel="noopener"
      aria-label="Chat on WhatsApp — Let us help you"
      class="wa-float-btn"
    >
      <span class="wa-float-btn__label">Let us help you</span>
      <span class="wa-float-btn__icon"><i class="fab fa-whatsapp"></i></span>
    </a>
    <style>
      .wa-float-btn {
        position: fixed;
        right: 20px;
        bottom: 20px;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 8px 8px 8px 18px;
        background: #25D366;
        color: #fff;
        border-radius: 999px;
        text-decoration: none;
        box-shadow: 0 6px 20px rgba(0, 0, 0, 0.2);
        z-index: 9999;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
      }
      .wa-float-btn:hover {
        transform: scale(1.04);
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.28);
        color: #fff;
      }
      .wa-float-btn__label {
        font-family: 'Inter', sans-serif;
        font-size: 0.9rem;
        font-weight: 600;
        letter-spacing: 0.2px;
        white-space: nowrap;
      }
      .wa-float-btn__icon {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.15);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
      }
      @media (max-width: 767px) {
        .wa-float-btn {
          right: 16px;
          bottom: 16px;
          padding: 6px 6px 6px 14px;
          gap: 8px;
        }
        .wa-float-btn__label {
          font-size: 0.85rem;
        }
        .wa-float-btn__icon {
          width: 36px;
          height: 36px;
          font-size: 20px;
        }
      }
    </style>

    <!-- GSAP -->
    <script>
      import { gsap } from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      gsap.registerPlugin(ScrollTrigger);

      // Make gsap available globally for components
      window.gsap = gsap;
      window.ScrollTrigger = ScrollTrigger;

      // Initialize scroll animations for elements with data-animate attribute
      function initAnimations() {
        // Slide in up animations
        gsap.utils.toArray('[data-ani="slideinup"]').forEach((el) => {
          const delay = parseFloat(el.getAttribute('data-ani-delay') || '0');
          gsap.from(el, {
            y: 60,
            opacity: 0,
            duration: 0.8,
            delay: delay,
            ease: 'power2.out',
            scrollTrigger: {
              trigger: el,
              start: 'top 90%',
              toggleActions: 'play none none none',
            },
          });
        });

        // Fade in left
        gsap.utils.toArray('[data-ani="slideinleft"]').forEach((el) => {
          const delay = parseFloat(el.getAttribute('data-ani-delay') || '0');
          gsap.from(el, {
            x: -60,
            opacity: 0,
            duration: 0.8,
            delay: delay,
            ease: 'power2.out',
            scrollTrigger: {
              trigger: el,
              start: 'top 90%',
              toggleActions: 'play none none none',
            },
          });
        });

        // Fade in right
        gsap.utils.toArray('[data-ani="slideinright"]').forEach((el) => {
          const delay = parseFloat(el.getAttribute('data-ani-delay') || '0');
          gsap.from(el, {
            x: 60,
            opacity: 0,
            duration: 0.8,
            delay: delay,
            ease: 'power2.out',
            scrollTrigger: {
              trigger: el,
              start: 'top 90%',
              toggleActions: 'play none none none',
            },
          });
        });

        // Fade in down
        gsap.utils.toArray('[data-ani="slideindown"]').forEach((el) => {
          const delay = parseFloat(el.getAttribute('data-ani-delay') || '0');
          gsap.from(el, {
            y: -60,
            opacity: 0,
            duration: 0.8,
            delay: delay,
            ease: 'power2.out',
            scrollTrigger: {
              trigger: el,
              start: 'top 90%',
              toggleActions: 'play none none none',
            },
          });
        });

        // Fade in
        gsap.utils.toArray('[data-ani="fadein"]').forEach((el) => {
          const delay = parseFloat(el.getAttribute('data-ani-delay') || '0');
          gsap.from(el, {
            opacity: 0,
            duration: 0.8,
            delay: delay,
            scrollTrigger: {
              trigger: el,
              start: 'top 90%',
              toggleActions: 'play none none none',
            },
          });
        });

        // Zoom in
        gsap.utils.toArray('[data-ani="zoomIn"]').forEach((el) => {
          const delay = parseFloat(el.getAttribute('data-ani-delay') || '0');
          gsap.from(el, {
            scale: 0.5,
            opacity: 0,
            duration: 0.8,
            delay: delay,
            ease: 'power2.out',
            scrollTrigger: {
              trigger: el,
              start: 'top 90%',
              toggleActions: 'play none none none',
            },
          });
        });

        // Floating/decorative animations
        gsap.utils.toArray('.jump, .jumpAni').forEach((el) => {
          gsap.to(el, {
            y: -15,
            repeat: -1,
            yoyo: true,
            duration: 2,
            ease: 'sine.inOut',
          });
        });

        gsap.utils.toArray('.movingX').forEach((el) => {
          gsap.to(el, {
            x: 20,
            repeat: -1,
            yoyo: true,
            duration: 3,
            ease: 'sine.inOut',
          });
        });

        gsap.utils.toArray('.moving').forEach((el) => {
          gsap.to(el, {
            y: 15,
            x: 10,
            repeat: -1,
            yoyo: true,
            duration: 4,
            ease: 'sine.inOut',
          });
        });

        gsap.utils.toArray('.spin').forEach((el) => {
          gsap.to(el, {
            rotation: 360,
            repeat: -1,
            duration: 10,
            ease: 'none',
          });
        });
      }

      // Run on page load
      document.addEventListener('DOMContentLoaded', initAnimations);
      // Also run on Astro page transitions
      document.addEventListener('astro:page-load', initAnimations);

      // Global contact form handler
      function initContactForms() {
        document.querySelectorAll('.ajax-contact').forEach(form => {
          if ((form as HTMLElement).dataset.wired) return;
          (form as HTMLElement).dataset.wired = 'true';
          form.addEventListener('submit', async (e) => {
            e.preventDefault();
            const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
            const orig = btn.innerHTML;
            btn.disabled = true;
            btn.textContent = 'Sending...';
            const fd = new FormData(form as HTMLFormElement);
            try {
              const res = await fetch('/api/contact', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(Object.fromEntries(fd)),
              });
              if (res.ok) {
                btn.textContent = 'Message Sent!';
                btn.style.background = '#10B981';
                (form as HTMLFormElement).reset();
                setTimeout(() => { btn.innerHTML = orig; btn.style.background = ''; btn.disabled = false; }, 3000);
              } else {
                alert('Failed to send. Please try again.');
                btn.innerHTML = orig; btn.disabled = false;
              }
            } catch {
              alert('Network error. Please try again.');
              btn.innerHTML = orig; btn.disabled = false;
            }
          });
        });
      }
      document.addEventListener('DOMContentLoaded', initContactForms);
      document.addEventListener('astro:page-load', initContactForms);
    </script>
  </body>
</html>
