---
import Seo from '../components/seo/Seo.astro';
import OrganizationSchema from '../components/seo/OrganizationSchema.astro';
import WebsiteSchema from '../components/seo/WebsiteSchema.astro';
import { buildCanonical, SITE_URL } from '../lib/seo';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  ogImageAlt?: string;
  ogType?: 'website' | 'article';
  articleAuthor?: string;
  articlePublishedTime?: string;
  articleModifiedTime?: string;
  articleSection?: string;
  articleTags?: string[];
  noindex?: boolean;
  keywords?: string;
}

const {
  title = 'Rhodes Boat Tours | Boat Trips, Cruises & Rentals',
  description = 'Boat tours, rentals and yacht charters in Rhodes, Greece. Local experts in Mandraki Harbour since 2009.',
  canonical,
  ogImage,
  ogImageAlt,
  ogType,
  articleAuthor,
  articlePublishedTime,
  articleModifiedTime,
  articleSection,
  articleTags,
  noindex,
  keywords,
} = Astro.props;

const finalCanonical = canonical ?? buildCanonical(Astro.url.pathname);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta http-equiv="x-dns-prefetch-control" content="on" />
    <link rel="icon" type="image/svg+xml" href="/assets/img/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/assets/img/favicon.svg" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="alternate" hreflang="en" href={finalCanonical} />
    <link rel="alternate" hreflang="x-default" href={finalCanonical} />
    <Seo
      title={title}
      description={description}
      canonical={canonical}
      ogImage={ogImage}
      ogImageAlt={ogImageAlt}
      ogType={ogType}
      articleAuthor={articleAuthor}
      articlePublishedTime={articlePublishedTime}
      articleModifiedTime={articleModifiedTime}
      articleSection={articleSection}
      articleTags={articleTags}
      noindex={noindex}
      keywords={keywords}
    />
    <OrganizationSchema />
    <WebsiteSchema />

    <!-- DNS prefetch / preconnect to third-party origins -->
    <link rel="dns-prefetch" href="https://iuidzdvrrrsxevvkbxam.supabase.co" />
    <link rel="preconnect" href="https://iuidzdvrrrsxevvkbxam.supabase.co" crossorigin />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Manrope:wght@300;400;500;600;700;800&family=Playfair+Display:wght@400;500;600;700;800;900&family=Allura&display=swap"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Manrope:wght@300;400;500;600;700;800&family=Playfair+Display:wght@400;500;600;700;800;900&family=Allura&display=swap"
      rel="stylesheet"
    />

    <!-- Bootstrap -->
    <link rel="stylesheet" href="/assets/css/bootstrap.min.css" />
    <!-- FontAwesome -->
    <link rel="stylesheet" href="/assets/css/fontawesome.min.css" />
    <!-- Magnific Popup -->
    <link rel="stylesheet" href="/assets/css/magnific-popup.min.css" />
    <!-- Swiper -->
    <link rel="stylesheet" href="/assets/css/swiper-bundle.min.css" />
    <!-- Theme CSS (must be AFTER Bootstrap) -->
    <link rel="stylesheet" href="/assets/css/style.css" />
    <style>
      html, body {
        overflow-x: hidden !important;
        max-width: 100vw !important;
        width: 100% !important;
      }
      *, *::before, *::after {
        max-width: 100vw;
      }
      html:not(.has-gsap) [data-ani] {
        opacity: 1 !important;
        transform: none !important;
      }
      @media (max-width: 575px) {
        :global(body) { font-size: 15px; line-height: 1.55; }
        :global(small), :global(.small), :global(.meta),
        :global(.blog-card_meta), :global(.blog-card_tag),
        :global(.blog-card__tag), :global(.footer-copyright) {
          font-size: 13px !important;
        }
      }
    </style>
  </head>
  <body>
    <slot />

    <a
      href="https://wa.me/306951666454"
      target="_blank"
      rel="noopener"
      aria-label="Chat on WhatsApp — Let us help you"
      class="wa-float-btn"
    >
      <span class="wa-float-btn__label">Let us help you</span>
      <span class="wa-float-btn__icon"><i class="fab fa-whatsapp"></i></span>
    </a>
    <style>
      .wa-float-btn {
        position: fixed;
        right: 20px;
        bottom: 20px;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 8px 8px 8px 18px;
        background: #25D366;
        color: #fff;
        border-radius: 999px;
        text-decoration: none;
        box-shadow: 0 6px 20px rgba(0, 0, 0, 0.2);
        z-index: 9999;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
      }
      .wa-float-btn:hover {
        transform: scale(1.04);
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.28);
        color: #fff;
      }
      .wa-float-btn__label {
        font-family: 'Inter', sans-serif;
        font-size: 0.9rem;
        font-weight: 600;
        letter-spacing: 0.2px;
        white-space: nowrap;
      }
      .wa-float-btn__icon {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.15);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
      }
      @media (max-width: 767px) {
        .wa-float-btn {
          right: 16px;
          bottom: 16px;
          padding: 6px 6px 6px 14px;
          gap: 8px;
        }
        .wa-float-btn__label {
          font-size: 0.85rem;
        }
        .wa-float-btn__icon {
          width: 36px;
          height: 36px;
          font-size: 20px;
        }
      }
    </style>

    <!-- GSAP -->
    <script>
      import { gsap } from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      gsap.registerPlugin(ScrollTrigger);

      document.documentElement.classList.add('has-gsap');

      // Make gsap available globally for components
      window.gsap = gsap;
      window.ScrollTrigger = ScrollTrigger;

      // Initialize scroll animations for elements with data-animate attribute
      function initAnimations() {
        const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        const animate = (sel: string, fromVars: gsap.TweenVars) => {
          gsap.utils.toArray<HTMLElement>(sel).forEach((el) => {
            const delay = parseFloat(el.getAttribute('data-ani-delay') || '0');

            if (reduce) {
              gsap.set(el, { opacity: 1, x: 0, y: 0, scale: 1, clearProps: 'all' });
              return;
            }

            const rect = el.getBoundingClientRect();
            const inView = rect.top < window.innerHeight && rect.bottom > 0;

            const tween = {
              ...fromVars,
              delay,
              duration: 0.8,
              ease: 'power2.out',
              clearProps: 'transform,opacity',
            };

            if (inView) {
              gsap.from(el, tween);
            } else {
              gsap.from(el, {
                ...tween,
                scrollTrigger: {
                  trigger: el,
                  start: 'top 95%',
                  toggleActions: 'play none none none',
                  once: true,
                },
              });
            }
          });
        };

        animate('[data-ani="slideinup"]',    { y: 60, opacity: 0 });
        animate('[data-ani="slideinleft"]',  { x: -60, opacity: 0 });
        animate('[data-ani="slideinright"]', { x: 60, opacity: 0 });
        animate('[data-ani="slideindown"]',  { y: -60, opacity: 0 });
        animate('[data-ani="fadein"]',       { opacity: 0 });
        animate('[data-ani="zoomIn"]',       { scale: 0.5, opacity: 0 });

        if (reduce) return;

        gsap.utils.toArray<HTMLElement>('.jump, .jumpAni').forEach((el) =>
          gsap.to(el, { y: -15, repeat: -1, yoyo: true, duration: 2, ease: 'sine.inOut' })
        );
        gsap.utils.toArray<HTMLElement>('.movingX').forEach((el) =>
          gsap.to(el, { x: 20, repeat: -1, yoyo: true, duration: 3, ease: 'sine.inOut' })
        );
        gsap.utils.toArray<HTMLElement>('.moving').forEach((el) =>
          gsap.to(el, { y: 15, x: 10, repeat: -1, yoyo: true, duration: 4, ease: 'sine.inOut' })
        );
        gsap.utils.toArray<HTMLElement>('.spin').forEach((el) =>
          gsap.to(el, { rotation: 360, repeat: -1, duration: 10, ease: 'none' })
        );

        ScrollTrigger.refresh();
      }

      // Run on page load
      document.addEventListener('DOMContentLoaded', initAnimations);
      // Also run on Astro page transitions
      document.addEventListener('astro:page-load', initAnimations);

      // Global contact form handler
      function initContactForms() {
        document.querySelectorAll('.ajax-contact').forEach(form => {
          if ((form as HTMLElement).dataset.wired) return;
          (form as HTMLElement).dataset.wired = 'true';
          form.addEventListener('submit', async (e) => {
            e.preventDefault();
            const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
            const orig = btn.innerHTML;
            btn.disabled = true;
            btn.textContent = 'Sending...';
            const fd = new FormData(form as HTMLFormElement);
            try {
              const res = await fetch('/api/contact', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(Object.fromEntries(fd)),
              });
              if (res.ok) {
                btn.textContent = 'Message Sent!';
                btn.style.background = '#10B981';
                (form as HTMLFormElement).reset();
                setTimeout(() => { btn.innerHTML = orig; btn.style.background = ''; btn.disabled = false; }, 3000);
              } else {
                alert('Failed to send. Please try again.');
                btn.innerHTML = orig; btn.disabled = false;
              }
            } catch {
              alert('Network error. Please try again.');
              btn.innerHTML = orig; btn.disabled = false;
            }
          });
        });
      }
      document.addEventListener('DOMContentLoaded', initContactForms);
      document.addEventListener('astro:page-load', initContactForms);
    </script>
  </body>
</html>
