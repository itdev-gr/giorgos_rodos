---
import Seo from '../components/seo/Seo.astro';
import OrganizationSchema from '../components/seo/OrganizationSchema.astro';
import WebsiteSchema from '../components/seo/WebsiteSchema.astro';
import { buildCanonical, SITE_URL } from '../lib/seo';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  ogImageAlt?: string;
  ogType?: 'website' | 'article' | 'product';
  articleAuthor?: string;
  articlePublishedTime?: string;
  articleModifiedTime?: string;
  articleSection?: string;
  articleTags?: string[];
  noindex?: boolean;
  noindexFollow?: boolean;
  keywords?: string;
}

const {
  title = 'Rhodes Rent a Boat | Boat Tours, Cruises & License-Free Rentals',
  description = 'Boat tours, rentals and yacht charters in Rhodes, Greece. Local experts on Ionos Dragoumi 39, Rhodes Town, since 1998.',
  canonical,
  ogImage,
  ogImageAlt,
  ogType: ogTypeProp,
  articleAuthor,
  articlePublishedTime,
  articleModifiedTime,
  articleSection,
  articleTags,
  noindex,
  noindexFollow,
  keywords,
} = Astro.props;

const finalCanonical = canonical ?? buildCanonical(Astro.url.pathname);
const isServiceDetail =
  Astro.url.pathname.startsWith('/service/') && Astro.url.pathname !== '/service/';
const ogType = ogTypeProp ?? (isServiceDetail ? 'product' : 'website');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta http-equiv="x-dns-prefetch-control" content="on" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="alternate" hreflang="en" href={finalCanonical} />
    <link rel="alternate" hreflang="x-default" href={finalCanonical} />
    <Seo
      title={title}
      description={description}
      canonical={canonical}
      ogImage={ogImage}
      ogImageAlt={ogImageAlt}
      ogType={ogType}
      articleAuthor={articleAuthor}
      articlePublishedTime={articlePublishedTime}
      articleModifiedTime={articleModifiedTime}
      articleSection={articleSection}
      articleTags={articleTags}
      noindex={noindex}
      noindexFollow={noindexFollow}
      keywords={keywords}
    />
    <OrganizationSchema />
    <WebsiteSchema />

    <!-- GA4 stub — script loads after page is interactive (see body) -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
    </script>

    <!-- Page-specific <head> additions (preload, page-scoped meta, etc.) -->
    <slot name="head" />

    <!-- DNS prefetch / preconnect to third-party origins -->
    <link rel="dns-prefetch" href="https://iuidzdvrrrsxevvkbxam.supabase.co" />
    <link rel="preconnect" href="https://iuidzdvrrrsxevvkbxam.supabase.co" crossorigin />

    <!-- Critical CSS inlined: covers above-the-fold (header, hero, base layout)
         so the page paints immediately while Bootstrap + theme load async below. -->
    <style>
      /* Reset + base layout — keeps everything in place pre-Bootstrap */
      *, *::before, *::after { box-sizing: border-box; }
      html { -webkit-text-size-adjust: 100%; }
      body {
        margin: 0;
        font-family: Helvetica, "Helvetica Neue", Arial, sans-serif;
        font-size: 16px;
        line-height: 1.6;
        color: #113D48;
        background: #fff;
        -webkit-font-smoothing: antialiased;
      }
      img, video { max-width: 100%; height: auto; display: block; }
      a { color: inherit; text-decoration: none; }

      /* Bootstrap grid — inlined so header/hero don't reflow when bootstrap.min.css arrives */
      .row {
        --bs-gutter-x: 1.5rem;
        --bs-gutter-y: 0;
        display: flex;
        flex-wrap: wrap;
        margin-top: calc(-1 * var(--bs-gutter-y));
        margin-right: calc(-0.5 * var(--bs-gutter-x));
        margin-left: calc(-0.5 * var(--bs-gutter-x));
      }
      .row > * {
        flex-shrink: 0;
        width: 100%;
        max-width: 100%;
        padding-right: calc(var(--bs-gutter-x) * 0.5);
        padding-left: calc(var(--bs-gutter-x) * 0.5);
        margin-top: var(--bs-gutter-y);
      }
      .col { flex: 1 0 0%; }
      .col-auto { flex: 0 0 auto; width: auto; }
      .d-none { display: none !important; }
      .d-block { display: block !important; }
      .d-lg-none { display: block !important; }
      .d-lg-flex { display: none !important; }
      .d-lg-block { display: none !important; }
      @media (min-width: 992px) {
        .d-lg-none { display: none !important; }
        .d-lg-flex { display: flex !important; }
        .d-lg-block { display: block !important; }
      }
      .ms-auto { margin-left: auto !important; }
      .align-items-center { align-items: center !important; }
      .justify-content-center { justify-content: center !important; }
      .text-center { text-align: center !important; }

      .container {
        width: 100%;
        max-width: 1320px;
        margin: 0 auto;
        padding: 0 16px;
      }
      @media (min-width: 576px) { .container { max-width: 540px; } }
      @media (min-width: 768px) { .container { max-width: 720px; } }
      @media (min-width: 992px) { .container { max-width: 960px; } }
      @media (min-width: 1200px) { .container { max-width: 1140px; } }
      @media (min-width: 1400px) { .container { max-width: 1320px; } }

      /* Header — transparent over hero by default, sticky-wrapper reserves
         a fixed height so the layout doesn't shift when the sticky class
         activates on scroll. Both states have the same physical footprint. */
      header { position: relative; z-index: 100; }
      .th-header.header-transparent .sticky-wrapper:not(.sticky) {
        position: absolute; top: 0; left: 0; right: 0; z-index: 100;
      }
      .sticky-wrapper { min-height: 90px; }
      @media (max-width: 991px) { .sticky-wrapper { min-height: 70px; } }
      .header-logo img {
        max-height: 140px;
        width: auto;
        display: block;
      }
      @media (max-width: 991px) {
        .header-logo img { max-height: 100px; }
      }
      #header-one .main-menu > ul {
        display: flex;
        align-items: center;
        list-style: none;
        margin: 0;
        padding: 0;
        gap: 24px;
      }
      #header-one .main-menu > ul > li > a {
        font-size: 13px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        padding: 32px 0;
        white-space: nowrap;
      }

      /* Hero — full structure reserved before style.css loads */
      .th-hero-wrapper {
        position: relative;
        z-index: 1;
        overflow: hidden;
      }
      .hero-inner {
        position: relative;
        height: 100%;
        width: 100%;
      }
      .th-hero-bg {
        position: absolute;
        inset: 0;
        overflow: hidden;
        z-index: 0;
      }
      .th-hero-bg video,
      .th-hero-bg img {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        max-width: none;
        object-fit: cover;
      }
      .hero-fullscreen, .th-hero-wrapper {
        position: relative; min-height: 600px; height: 100vh;
        background-color: #0b2f38; overflow: hidden;
      }
      .service-hero-fullwidth, .services-hero, .about-hero, .contact-hero, .rab-hero {
        position: relative; min-height: 100vh;
        background-color: #0b2f38; overflow: hidden;
      }
      @media (max-width: 991px) {
        .service-hero-fullwidth { min-height: 380px; height: 75vh; }
        .services-hero { min-height: 50vh; }
        .about-hero, .contact-hero, .rab-hero { min-height: 75vh; }
      }
      @media (max-width: 767px) {
        .service-hero-fullwidth { min-height: 360px; }
      }

      /* Tour-detail gallery wrapper — main image is 16/7. Reserving the
         aspect prevents the section from collapsing pre-CSS. */
      .td-gallery { aspect-ratio: 16 / 7; }
      @media (max-width: 991px) { .td-gallery { aspect-ratio: 4 / 3; } }

      /* Stop horizontal scroll the moment the page paints */
      html, body {
        overflow-x: hidden;
        max-width: 100vw;
      }

      /* Swiper pagination bullets — bump touch target to ≥24px each
         (WCAG 2.5.8 Target Size minimum is 24×24, recommended 44×44 with
         spacing). Visual dot stays the same; padding makes the hit area
         bigger. */
      .swiper-pagination-bullet {
        width: 12px !important;
        height: 12px !important;
        margin: 0 6px !important;
        padding: 6px;
        background-clip: content-box !important;
      }
    </style>

    <!-- Bootstrap + theme — single fetch via preload-as-stylesheet (no duplicate preload + link) -->
    <link rel="preload" href="/assets/css/bootstrap.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'" />
    <link rel="preload" href="/assets/css/style.css" as="style" onload="this.onload=null;this.rel='stylesheet'" />
    <link rel="stylesheet" href="/assets/css/site-fonts.css" />
    <noscript>
      <link rel="stylesheet" href="/assets/css/bootstrap.min.css" />
      <link rel="stylesheet" href="/assets/css/style.css" />
      <link rel="stylesheet" href="/assets/css/site-fonts.css" />
    </noscript>

    <!-- Non-critical CSS — async via media-print swap -->
    <link rel="stylesheet" href="/assets/css/fontawesome.min.css" media="print" onload="this.media='all'" />
    <link rel="stylesheet" href="/assets/css/magnific-popup.min.css" media="print" onload="this.media='all'" />
    <link rel="stylesheet" href="/assets/css/swiper-bundle.min.css" media="print" onload="this.media='all'" />
    <noscript>
      <link rel="stylesheet" href="/assets/css/fontawesome.min.css" />
      <link rel="stylesheet" href="/assets/css/magnific-popup.min.css" />
      <link rel="stylesheet" href="/assets/css/swiper-bundle.min.css" />
    </noscript>
    <!-- Fallback for browsers that don't fire onload on preload-as-stylesheet -->
    <script is:inline>
      !function(e){"use strict";var t=function(t,n,o){var r,i=e.document,a=i.createElement("link");if(n)r=n;else{var l=(i.body||i.getElementsByTagName("head")[0]).childNodes;r=l[l.length-1]}var d=i.styleSheets;a.rel="stylesheet",a.href=t,a.media="only x",function e(t){if(i.body)return t();setTimeout(function(){e(t)})}(function(){r.parentNode.insertBefore(a,n?r:r.nextSibling)});var f=function(e){for(var t=a.href,n=d.length;n--;)if(d[n].href===t)return e();setTimeout(function(){f(e)})};return a.addEventListener&&a.addEventListener("load",function(){this.media=o||"all"}),a.onloadcssdefined=f,f(function(){a.media=o||"all"}),a};"undefined"!=typeof exports?exports.loadCSS=t:e.loadCSS=t}("undefined"!=typeof global?global:this);
    </script>
    <style>
      html, body {
        overflow-x: hidden !important;
        max-width: 100vw !important;
        width: 100% !important;
      }
      *, *::before, *::after {
        max-width: 100vw;
      }
      html:not(.has-gsap) [data-ani],
      html.has-gsap [data-ani] {
        opacity: 1 !important;
        transform: none !important;
      }
      /* Logo touch target — WCAG 2.5.8 minimum 48×48px */
      :global(.header-logo a), :global(.navbar-brand) {
        display: inline-flex;
        align-items: center;
        min-height: 48px;
        padding: 8px 0;
      }
      @media (max-width: 575px) {
        :global(body) { font-size: 16px; line-height: 1.6; }
        :global(small), :global(.small), :global(.meta),
        :global(.blog-card_meta), :global(.blog-card_tag),
        :global(.blog-card__tag), :global(.footer-copyright) {
          font-size: 13px !important;
        }
      }
    </style>
  </head>
  <body>
    <main id="main-content">
      <slot />
    </main>

    <a
      href="https://wa.me/306951666454"
      target="_blank"
      rel="noopener"
      aria-label="Chat on WhatsApp — Let us help you"
      class="wa-float-btn"
    >
      <span class="wa-float-btn__label">Let us help you</span>
      <span class="wa-float-btn__icon"><i class="fab fa-whatsapp"></i></span>
    </a>
    <style>
      .wa-float-btn {
        position: fixed;
        right: 20px;
        bottom: 20px;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 8px 8px 8px 18px;
        background: #075E54;
        color: #fff;
        border-radius: 999px;
        text-decoration: none;
        box-shadow: 0 6px 20px rgba(0, 0, 0, 0.2);
        z-index: 9999;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
      }
      .wa-float-btn:hover {
        transform: scale(1.04);
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.28);
        color: #fff;
      }
      .wa-float-btn__label {
        font-family: Helvetica, "Helvetica Neue", Arial, sans-serif;
        font-size: 0.9rem;
        font-weight: 600;
        letter-spacing: 0.2px;
        white-space: nowrap;
      }
      .wa-float-btn__icon {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.15);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
      }
      @media (max-width: 767px) {
        .wa-float-btn {
          right: 16px;
          bottom: 80px;
          padding: 0;
          gap: 0;
          width: 56px;
          height: 56px;
          border-radius: 50%;
          display: flex;
          align-items: center;
          justify-content: center;
        }
        .wa-float-btn__label {
          display: none;
        }
        .wa-float-btn__icon {
          width: 40px;
          height: 40px;
          font-size: 22px;
          background: transparent;
        }
      }
    </style>

    <!-- GSAP — lazy-loaded only when the page uses scroll animations or hero parallax -->
    <script>
      let gsapBootPromise: Promise<void> | null = null;

      function needsGsap() {
        return document.querySelector(
          '.jump, .jumpAni, .movingX, .moving, .spin, #service-hero .service-hero-bg'
        );
      }

      async function bootGsap() {
        if (!needsGsap()) return;
        if (!gsapBootPromise) {
          gsapBootPromise = (async () => {
            const { gsap } = await import('gsap');
            const { ScrollTrigger } = await import('gsap/ScrollTrigger');
            gsap.registerPlugin(ScrollTrigger);
            document.documentElement.classList.add('has-gsap');
            window.gsap = gsap;
            window.ScrollTrigger = ScrollTrigger;
          })();
        }
        await gsapBootPromise;
      }

      async function initAnimations() {
        await bootGsap();
        if (!window.gsap || !window.ScrollTrigger) return;

        const gsap = window.gsap;
        const ScrollTrigger = window.ScrollTrigger;
        const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (reduce) return;

        // Decorative loops only — scroll entrance animations disabled to prevent CLS
        gsap.utils.toArray<HTMLElement>('.jump, .jumpAni').forEach((el) =>
          gsap.to(el, { y: -15, repeat: -1, yoyo: true, duration: 2, ease: 'sine.inOut' })
        );
        gsap.utils.toArray<HTMLElement>('.movingX').forEach((el) =>
          gsap.to(el, { x: 20, repeat: -1, yoyo: true, duration: 3, ease: 'sine.inOut' })
        );
        gsap.utils.toArray<HTMLElement>('.moving').forEach((el) =>
          gsap.to(el, { y: 15, x: 10, repeat: -1, yoyo: true, duration: 4, ease: 'sine.inOut' })
        );
        gsap.utils.toArray<HTMLElement>('.spin').forEach((el) =>
          gsap.to(el, { rotation: 360, repeat: -1, duration: 10, ease: 'none' })
        );

        ScrollTrigger.refresh();
      }

      function scheduleAnimations() {
        const run = () => { void initAnimations(); };
        if ('requestIdleCallback' in window) {
          requestIdleCallback(run, { timeout: 2000 });
        } else {
          setTimeout(run, 1);
        }
      }

      document.addEventListener('DOMContentLoaded', scheduleAnimations);
      document.addEventListener('astro:page-load', scheduleAnimations);

      // Global contact form handler
      function initContactForms() {
        document.querySelectorAll('.ajax-contact').forEach(form => {
          if ((form as HTMLElement).dataset.wired) return;
          (form as HTMLElement).dataset.wired = 'true';
          form.addEventListener('submit', async (e) => {
            e.preventDefault();
            const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
            const orig = btn.innerHTML;
            btn.disabled = true;
            btn.textContent = 'Sending...';
            const fd = new FormData(form as HTMLFormElement);
            try {
              const res = await fetch('/api/contact', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(Object.fromEntries(fd)),
              });
              if (res.ok) {
                btn.textContent = 'Message Sent!';
                btn.style.background = '#10B981';
                (form as HTMLFormElement).reset();
                setTimeout(() => { btn.innerHTML = orig; btn.style.background = ''; btn.disabled = false; }, 3000);
              } else {
                alert('Failed to send. Please try again.');
                btn.innerHTML = orig; btn.disabled = false;
              }
            } catch {
              alert('Network error. Please try again.');
              btn.innerHTML = orig; btn.disabled = false;
            }
          });
        });
      }
      document.addEventListener('DOMContentLoaded', initContactForms);
      document.addEventListener('astro:page-load', initContactForms);
    </script>

    <!-- GA4 — deferred until after first paint -->
    <script is:inline>
      (function () {
        function loadGa4() {
          var s = document.createElement('script');
          s.src = 'https://www.googletagmanager.com/gtag/js?id=G-3YCY0C2ZXF';
          s.async = true;
          document.head.appendChild(s);
          s.onload = function () {
            gtag('js', new Date());
            gtag('config', 'G-3YCY0C2ZXF');
          };
        }
        if ('requestIdleCallback' in window) {
          requestIdleCallback(loadGa4, { timeout: 3000 });
        } else {
          window.addEventListener('load', loadGa4);
        }
      })();
    </script>
  </body>
</html>
