    </a>
    <style>
      .wa-float-btn {
        position: fixed;
        right: 20px;
        bottom: 20px;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 8px 8px 8px 18px;
        background: #075E54;
        color: #fff;
        border-radius: 999px;
        text-decoration: none;
        box-shadow: 0 6px 20px rgba(0, 0, 0, 0.2);
        z-index: 9999;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
      }
      .wa-float-btn:hover {
        transform: scale(1.04);
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.28);
        color: #fff;
      }
      .wa-float-btn__label {
        font-family: Helvetica, "Helvetica Neue", Arial, sans-serif;
        font-size: 0.9rem;
        font-weight: 600;
        letter-spacing: 0.2px;
        white-space: nowrap;
      }
      .wa-float-btn__icon {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.15);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
      }
      @media (max-width: 767px) {
        .wa-float-btn {
          right: 16px;
          bottom: 80px;
          padding: 0;
          gap: 0;
          width: 56px;
          height: 56px;
          border-radius: 50%;
          display: flex;
          align-items: center;
          justify-content: center;
        }
        .wa-float-btn__label {
          display: none;
        }
        .wa-float-btn__icon {
          width: 40px;
          height: 40px;
          font-size: 22px;
          background: transparent;
        }
      }
    </style>

    <!-- GSAP, lazy-loaded only when the page uses scroll animations or hero parallax -->
    <script>
      let gsapBootPromise: Promise<void> | null = null;

      function needsGsap() {
        return document.querySelector(
          '.jump, .jumpAni, .movingX, .moving, .spin, #service-hero .service-hero-bg'
        );
      }

      async function bootGsap() {
        if (!needsGsap()) return;
        if (!gsapBootPromise) {
          gsapBootPromise = (async () => {
            const { gsap } = await import('gsap');
            const { ScrollTrigger } = await import('gsap/ScrollTrigger');
            gsap.registerPlugin(ScrollTrigger);
            document.documentElement.classList.add('has-gsap');
            window.gsap = gsap;
            window.ScrollTrigger = ScrollTrigger;
          })();
        }
        await gsapBootPromise;
      }

      async function initAnimations() {
        await bootGsap();
        if (!window.gsap || !window.ScrollTrigger) return;

        const gsap = window.gsap;
        const ScrollTrigger = window.ScrollTrigger;
        const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (reduce) return;

        // Decorative loops only, scroll entrance animations disabled to prevent CLS
        gsap.utils.toArray<HTMLElement>('.jump, .jumpAni').forEach((el) =>
          gsap.to(el, { y: -15, repeat: -1, yoyo: true, duration: 2, ease: 'sine.inOut' })
        );
        gsap.utils.toArray<HTMLElement>('.movingX').forEach((el) =>
          gsap.to(el, { x: 20, repeat: -1, yoyo: true, duration: 3, ease: 'sine.inOut' })
        );
        gsap.utils.toArray<HTMLElement>('.moving').forEach((el) =>
          gsap.to(el, { y: 15, x: 10, repeat: -1, yoyo: true, duration: 4, ease: 'sine.inOut' })
        );
        gsap.utils.toArray<HTMLElement>('.spin').forEach((el) =>
          gsap.to(el, { rotation: 360, repeat: -1, duration: 10, ease: 'none' })
        );

        ScrollTrigger.refresh();
      }

      function scheduleAnimations() {
        const run = () => { void initAnimations(); };
        if ('requestIdleCallback' in window) {
          requestIdleCallback(run, { timeout: 2000 });
        } else {
          setTimeout(run, 1);
        }
      }

      document.addEventListener('DOMContentLoaded', scheduleAnimations);
      document.addEventListener('astro:page-load', scheduleAnimations);

      // Global contact form handler
      function initContactForms() {
        document.querySelectorAll('.ajax-contact').forEach(form => {
          if ((form as HTMLElement).dataset.wired) return;
          (form as HTMLElement).dataset.wired = 'true';
          form.addEventListener('submit', async (e) => {
            e.preventDefault();
            const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
            const orig = btn.innerHTML;
            btn.disabled = true;
            btn.textContent = 'Sending...';
            const fd = new FormData(form as HTMLFormElement);
            const data = Object.fromEntries(fd) as Record<string, string>;
            if (data.firstName || data.lastName) {
              data.name = [data.firstName, data.lastName].filter(Boolean).join(' ').trim();
              delete data.firstName;
              delete data.lastName;
            }
            try {
              const res = await fetch('/api/contact', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data),
              });
              if (res.ok) {
                btn.textContent = 'Message Sent!';
                btn.style.background = '#10B981';
                (form as HTMLFormElement).reset();
                setTimeout(() => { btn.innerHTML = orig; btn.style.background = ''; btn.disabled = false; }, 3000);
              } else {
                alert('Failed to send. Please try again.');
                btn.innerHTML = orig; btn.disabled = false;
              }
            } catch {
              alert('Network error. Please try again.');
              btn.innerHTML = orig; btn.disabled = false;
            }
          });
        });
      }
      document.addEventListener('DOMContentLoaded', initContactForms);
      document.addEventListener('astro:page-load', initContactForms);
    </script>

    <!-- GA4, deferred until after first paint -->
    <script is:inline>
      (function () {
        function loadGa4() {
          var s = document.createElement('script');
          s.src = 'https://www.googletagmanager.com/gtag/js?id=G-3YCY0C2ZXF';
          s.async = true;
          document.head.appendChild(s);
          s.onload = function () {
            gtag('js', new Date());
            gtag('config', 'G-3YCY0C2ZXF');
          };
        }
        if ('requestIdleCallback' in window) {
          requestIdleCallback(loadGa4, { timeout: 5000 });
        } else {
          window.addEventListener('load', function () { setTimeout(loadGa4, 2500); });
        }
      })();
    </script>
    {isHome && (
      <script is:inline>
        (function () {
          function loadHomeIcons() {
            var l = document.createElement('link');
            l.rel = 'stylesheet';
            l.href = '/assets/css/fontawesome.min.css';
            document.head.appendChild(l);
          }
          if ('requestIdleCallback' in window) {
            requestIdleCallback(loadHomeIcons, { timeout: 6000 });
          } else {
            window.addEventListener('load', function () { setTimeout(loadHomeIcons, 3000); });
          }
        })();
      </script>
    )}
  </body>
