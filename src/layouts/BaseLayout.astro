---
import Seo from '../components/seo/Seo.astro';
import OrganizationSchema from '../components/seo/OrganizationSchema.astro';
import WebsiteSchema from '../components/seo/WebsiteSchema.astro';
import { buildCanonical, SITE_URL } from '../lib/seo';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  ogImageAlt?: string;
  ogType?: 'website' | 'article';
  articleAuthor?: string;
  articlePublishedTime?: string;
  articleModifiedTime?: string;
  articleSection?: string;
  articleTags?: string[];
  noindex?: boolean;
  keywords?: string;
}

const {
  title = 'Rhodes Rent a Boat | Boat Tours, Cruises & License-Free Rentals',
  description = 'Boat tours, rentals and yacht charters in Rhodes, Greece. Local experts on Ionos Dragoumi 39, Rhodes Town, since 1998.',
  canonical,
  ogImage,
  ogImageAlt,
  ogType,
  articleAuthor,
  articlePublishedTime,
  articleModifiedTime,
  articleSection,
  articleTags,
  noindex,
  keywords,
} = Astro.props;

const finalCanonical = canonical ?? buildCanonical(Astro.url.pathname);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta http-equiv="x-dns-prefetch-control" content="on" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="alternate" hreflang="en" href={finalCanonical} />
    <link rel="alternate" hreflang="x-default" href={finalCanonical} />
    <Seo
      title={title}
      description={description}
      canonical={canonical}
      ogImage={ogImage}
      ogImageAlt={ogImageAlt}
      ogType={ogType}
      articleAuthor={articleAuthor}
      articlePublishedTime={articlePublishedTime}
      articleModifiedTime={articleModifiedTime}
      articleSection={articleSection}
      articleTags={articleTags}
      noindex={noindex}
      keywords={keywords}
    />
    <OrganizationSchema />
    <WebsiteSchema />

    <!-- Page-specific <head> additions (preload, page-scoped meta, etc.) -->
    <slot name="head" />

    <!-- DNS prefetch / preconnect to third-party origins -->
    <link rel="dns-prefetch" href="https://iuidzdvrrrsxevvkbxam.supabase.co" />
    <link rel="preconnect" href="https://iuidzdvrrrsxevvkbxam.supabase.co" crossorigin />

    <!-- Google Fonts — load non-blocking via media-print swap (one network request) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Manrope:wght@300;400;500;600;700;800&family=Playfair+Display:wght@400;500;600;700;800;900&family=Allura&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Manrope:wght@300;400;500;600;700;800&family=Playfair+Display:wght@400;500;600;700;800;900&family=Allura&display=swap"
      />
    </noscript>

    <!-- Critical CSS inlined: covers above-the-fold (header, hero, base layout)
         so the page paints immediately while Bootstrap + theme load async below. -->
    <style>
      /* Reset + base layout — keeps everything in place pre-Bootstrap */
      *, *::before, *::after { box-sizing: border-box; }
      html { -webkit-text-size-adjust: 100%; }
      body {
        margin: 0;
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        font-size: 16px;
        line-height: 1.6;
        color: #113D48;
        background: #fff;
        -webkit-font-smoothing: antialiased;
      }
      img, video { max-width: 100%; height: auto; display: block; }
      a { color: inherit; text-decoration: none; }
      .container {
        width: 100%;
        max-width: 1320px;
        margin: 0 auto;
        padding: 0 16px;
      }
      @media (min-width: 576px) { .container { max-width: 540px; } }
      @media (min-width: 768px) { .container { max-width: 720px; } }
      @media (min-width: 992px) { .container { max-width: 960px; } }
      @media (min-width: 1200px) { .container { max-width: 1140px; } }
      @media (min-width: 1400px) { .container { max-width: 1320px; } }

      /* Header — transparent over hero by default, sticky-wrapper reserves
         a fixed height so the layout doesn't shift when the sticky class
         activates on scroll. Both states have the same physical footprint. */
      header { position: relative; z-index: 100; }
      .th-header.header-transparent .sticky-wrapper:not(.sticky) {
        position: absolute; top: 0; left: 0; right: 0; z-index: 100;
      }
      .sticky-wrapper { min-height: 90px; }
      @media (max-width: 991px) { .sticky-wrapper { min-height: 70px; } }

      /* Hero containers — reserve their final height now so the deferred
         theme CSS doesn't trigger a 1.0+ CLS when it eventually applies. */
      .hero-fullscreen, .th-hero-wrapper {
        position: relative; min-height: 600px; height: 100vh;
        background-color: #0b2f38; overflow: hidden;
      }
      .service-hero-fullwidth, .services-hero, .about-hero, .contact-hero, .rab-hero {
        position: relative; min-height: 100vh;
        background-color: #0b2f38; overflow: hidden;
      }
      @media (max-width: 991px) {
        .service-hero-fullwidth { min-height: 380px; height: 75vh; }
        .services-hero { min-height: 50vh; }
        .about-hero, .contact-hero, .rab-hero { min-height: 75vh; }
      }
      @media (max-width: 767px) {
        .service-hero-fullwidth { min-height: 360px; }
      }

      /* Tour-detail gallery wrapper — main image is 16/7. Reserving the
         aspect prevents the section from collapsing pre-CSS. */
      .td-gallery { aspect-ratio: 16 / 7; }
      @media (max-width: 991px) { .td-gallery { aspect-ratio: 4 / 3; } }

      /* Stop horizontal scroll the moment the page paints */
      html, body {
        overflow-x: hidden;
        max-width: 100vw;
      }
    </style>

    <!-- Bootstrap + theme — load async via print-onload swap; noscript fallback -->
    <link rel="preload" href="/assets/css/bootstrap.min.css" as="style" />
    <link rel="preload" href="/assets/css/style.css" as="style" />
    <link rel="stylesheet" href="/assets/css/bootstrap.min.css" media="print" onload="this.media='all'" />
    <link rel="stylesheet" href="/assets/css/style.css" media="print" onload="this.media='all'" />

    <!-- Non-critical CSS — async via media-print swap -->
    <link rel="stylesheet" href="/assets/css/fontawesome.min.css" media="print" onload="this.media='all'" />
    <link rel="stylesheet" href="/assets/css/magnific-popup.min.css" media="print" onload="this.media='all'" />
    <link rel="stylesheet" href="/assets/css/swiper-bundle.min.css" media="print" onload="this.media='all'" />
    <noscript>
      <link rel="stylesheet" href="/assets/css/bootstrap.min.css" />
      <link rel="stylesheet" href="/assets/css/style.css" />
      <link rel="stylesheet" href="/assets/css/fontawesome.min.css" />
      <link rel="stylesheet" href="/assets/css/magnific-popup.min.css" />
      <link rel="stylesheet" href="/assets/css/swiper-bundle.min.css" />
    </noscript>
    <style>
      html, body {
        overflow-x: hidden !important;
        max-width: 100vw !important;
        width: 100% !important;
      }
      *, *::before, *::after {
        max-width: 100vw;
      }
      html:not(.has-gsap) [data-ani] {
        opacity: 1 !important;
        transform: none !important;
      }
      @media (max-width: 575px) {
        :global(body) { font-size: 15px; line-height: 1.55; }
        :global(small), :global(.small), :global(.meta),
        :global(.blog-card_meta), :global(.blog-card_tag),
        :global(.blog-card__tag), :global(.footer-copyright) {
          font-size: 13px !important;
        }
      }
    </style>
  </head>
  <body>
    <main id="main-content">
      <slot />
    </main>

    <a
      href="https://wa.me/306951666454"
      target="_blank"
      rel="noopener"
      aria-label="Chat on WhatsApp — Let us help you"
      class="wa-float-btn"
    >
      <span class="wa-float-btn__label">Let us help you</span>
      <span class="wa-float-btn__icon"><i class="fab fa-whatsapp"></i></span>
    </a>
    <style>
      .wa-float-btn {
        position: fixed;
        right: 20px;
        bottom: 20px;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 8px 8px 8px 18px;
        background: #128C7E;
        color: #fff;
        border-radius: 999px;
        text-decoration: none;
        box-shadow: 0 6px 20px rgba(0, 0, 0, 0.2);
        z-index: 9999;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
      }
      .wa-float-btn:hover {
        transform: scale(1.04);
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.28);
        color: #fff;
      }
      .wa-float-btn__label {
        font-family: 'Inter', sans-serif;
        font-size: 0.9rem;
        font-weight: 600;
        letter-spacing: 0.2px;
        white-space: nowrap;
      }
      .wa-float-btn__icon {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.15);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
      }
      @media (max-width: 767px) {
        .wa-float-btn {
          right: 16px;
          bottom: 16px;
          padding: 6px 6px 6px 14px;
          gap: 8px;
        }
        .wa-float-btn__label {
          font-size: 0.85rem;
        }
        .wa-float-btn__icon {
          width: 36px;
          height: 36px;
          font-size: 20px;
        }
      }
    </style>

    <!-- GSAP -->
    <script>
      import { gsap } from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      gsap.registerPlugin(ScrollTrigger);

      document.documentElement.classList.add('has-gsap');

      // Make gsap available globally for components
      window.gsap = gsap;
      window.ScrollTrigger = ScrollTrigger;

      // Initialize scroll animations for elements with data-animate attribute
      function initAnimations() {
        const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        const animate = (sel: string, fromVars: gsap.TweenVars) => {
          gsap.utils.toArray<HTMLElement>(sel).forEach((el) => {
            const delay = parseFloat(el.getAttribute('data-ani-delay') || '0');

            if (reduce) {
              gsap.set(el, { opacity: 1, x: 0, y: 0, scale: 1, clearProps: 'all' });
              return;
            }

            const rect = el.getBoundingClientRect();
            const inView = rect.top < window.innerHeight && rect.bottom > 0;

            const tween = {
              ...fromVars,
              delay,
              duration: 0.8,
              ease: 'power2.out',
              clearProps: 'transform,opacity',
            };

            if (inView) {
              gsap.from(el, tween);
            } else {
              gsap.from(el, {
                ...tween,
                scrollTrigger: {
                  trigger: el,
                  start: 'top 95%',
                  toggleActions: 'play none none none',
                  once: true,
                },
              });
            }
          });
        };

        animate('[data-ani="slideinup"]',    { y: 60, opacity: 0 });
        animate('[data-ani="slideinleft"]',  { x: -60, opacity: 0 });
        animate('[data-ani="slideinright"]', { x: 60, opacity: 0 });
        animate('[data-ani="slideindown"]',  { y: -60, opacity: 0 });
        animate('[data-ani="fadein"]',       { opacity: 0 });
        animate('[data-ani="zoomIn"]',       { scale: 0.5, opacity: 0 });

        if (reduce) return;

        gsap.utils.toArray<HTMLElement>('.jump, .jumpAni').forEach((el) =>
          gsap.to(el, { y: -15, repeat: -1, yoyo: true, duration: 2, ease: 'sine.inOut' })
        );
        gsap.utils.toArray<HTMLElement>('.movingX').forEach((el) =>
          gsap.to(el, { x: 20, repeat: -1, yoyo: true, duration: 3, ease: 'sine.inOut' })
        );
        gsap.utils.toArray<HTMLElement>('.moving').forEach((el) =>
          gsap.to(el, { y: 15, x: 10, repeat: -1, yoyo: true, duration: 4, ease: 'sine.inOut' })
        );
        gsap.utils.toArray<HTMLElement>('.spin').forEach((el) =>
          gsap.to(el, { rotation: 360, repeat: -1, duration: 10, ease: 'none' })
        );

        ScrollTrigger.refresh();
      }

      // Run on page load
      document.addEventListener('DOMContentLoaded', initAnimations);
      // Also run on Astro page transitions
      document.addEventListener('astro:page-load', initAnimations);

      // Global contact form handler
      function initContactForms() {
        document.querySelectorAll('.ajax-contact').forEach(form => {
          if ((form as HTMLElement).dataset.wired) return;
          (form as HTMLElement).dataset.wired = 'true';
          form.addEventListener('submit', async (e) => {
            e.preventDefault();
            const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
            const orig = btn.innerHTML;
            btn.disabled = true;
            btn.textContent = 'Sending...';
            const fd = new FormData(form as HTMLFormElement);
            try {
              const res = await fetch('/api/contact', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(Object.fromEntries(fd)),
              });
              if (res.ok) {
                btn.textContent = 'Message Sent!';
                btn.style.background = '#10B981';
                (form as HTMLFormElement).reset();
                setTimeout(() => { btn.innerHTML = orig; btn.style.background = ''; btn.disabled = false; }, 3000);
              } else {
                alert('Failed to send. Please try again.');
                btn.innerHTML = orig; btn.disabled = false;
              }
            } catch {
              alert('Network error. Please try again.');
              btn.innerHTML = orig; btn.disabled = false;
            }
          });
        });
      }
      document.addEventListener('DOMContentLoaded', initContactForms);
      document.addEventListener('astro:page-load', initContactForms);
    </script>
  </body>
</html>
