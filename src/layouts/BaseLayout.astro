---
import Seo from '../components/seo/Seo.astro';
import OrganizationSchema from '../components/seo/OrganizationSchema.astro';
import WebsiteSchema from '../components/seo/WebsiteSchema.astro';
import { buildCanonical, SITE_URL } from '../lib/seo';
import { resolveLocale, logicalPath, isPageLocalizable } from '../i18n/context';
import { getHreflangAlternates } from '../i18n/routing';
import { isRtlLocale } from '../i18n/locales';
import { getMessages } from '../i18n';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  ogImageAlt?: string;
  ogType?: 'website' | 'article' | 'product';
  articleAuthor?: string;
  articlePublishedTime?: string;
  articleModifiedTime?: string;
  articleSection?: string;
  articleTags?: string[];
  noindex?: boolean;
  noindexFollow?: boolean;
  keywords?: string;
  loadMagnific?: boolean;
}

const locale = resolveLocale(Astro.locals, Astro.url.pathname);
const logical = logicalPath(Astro.url.pathname);
const messages = getMessages(locale);

const {
  title = messages.meta.home.title,
  description = messages.meta.home.description,
  canonical,
  ogImage,
  ogImageAlt,
  ogType: ogTypeProp,
  articleAuthor,
  articlePublishedTime,
  articleModifiedTime,
  articleSection,
  articleTags,
  noindex,
  noindexFollow,
  keywords,
  loadMagnific = logical !== '/',
} = Astro.props;

const finalCanonical = canonical ?? buildCanonical(Astro.url.pathname);
const hreflangAlternates = isPageLocalizable(Astro.url.pathname)
  ? getHreflangAlternates(logical)
  : [{ hreflang: 'en', href: finalCanonical }, { hreflang: 'x-default', href: finalCanonical }];
const isServiceDetail =
  logical.startsWith('/service/') && logical !== '/service/';
const isServiceRoute =
  logical === '/service' || logical.startsWith('/service/');
const ogType = ogTypeProp ?? (isServiceDetail ? 'product' : 'website');
const isHome = logical === '/';
const htmlDir = isRtlLocale(locale) ? 'rtl' : 'ltr';
---

<!doctype html>
<html lang={locale} dir={htmlDir}>
  <head>
    <meta charset="UTF-8" />
    <script is:inline>
      document.documentElement.classList.remove('nav-hover-ready');
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta http-equiv="x-dns-prefetch-control" content="on" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    {hreflangAlternates.map((alt) => (
      <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />
    ))}
    <Seo
      title={title}
      description={description}
      canonical={finalCanonical}
      ogImage={ogImage}
      ogImageAlt={ogImageAlt}
      ogType={ogType}
      locale={locale}
      articleAuthor={articleAuthor}
      articlePublishedTime={articlePublishedTime}
      articleModifiedTime={articleModifiedTime}
      articleSection={articleSection}
      articleTags={articleTags}
      noindex={noindex}
      noindexFollow={noindexFollow}
      keywords={keywords}
      addBrandSuffix={!isServiceRoute}
    />
    <OrganizationSchema locale={locale} />
    <WebsiteSchema locale={locale} />

    <!-- GA4 stub, script loads after page is interactive (see body) -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
    </script>

    <!-- Page-specific <head> additions (preload, page-scoped meta, etc.) -->
    <slot name="head" />

    <!-- DNS prefetch / preconnect to third-party origins -->
    {!isHome && (
      <>
        <link rel="dns-prefetch" href="https://iuidzdvrrrsxevvkbxam.supabase.co" />
        <link rel="preconnect" href="https://iuidzdvrrrsxevvkbxam.supabase.co" crossorigin />
      </>
    )}

    <!-- Critical CSS inlined: covers above-the-fold (header, hero, base layout)
         so the page paints immediately while Bootstrap + theme load async below. -->
    <style>
      /* Reset + base layout, keeps everything in place pre-Bootstrap */
      *, *::before, *::after { box-sizing: border-box; }
      html { -webkit-text-size-adjust: 100%; }
      body {
        margin: 0;
        font-family: Helvetica, "Helvetica Neue", Arial, sans-serif;
        font-size: 16px;
        line-height: 1.6;
        color: #113D48;
        background: #fff;
        -webkit-font-smoothing: antialiased;
      }
      img, video { max-width: 100%; height: auto; display: block; }
      a { color: inherit; text-decoration: none; }

      /* Bootstrap grid, inlined so header/hero don't reflow when bootstrap.min.css arrives */
      .row {
        --bs-gutter-x: 1.5rem;
        --bs-gutter-y: 0;
        display: flex;
        flex-wrap: wrap;
        margin-top: calc(-1 * var(--bs-gutter-y));
        margin-right: calc(-0.5 * var(--bs-gutter-x));
        margin-left: calc(-0.5 * var(--bs-gutter-x));
      }
      .row > * {
        flex-shrink: 0;
        width: 100%;
        max-width: 100%;
        padding-right: calc(var(--bs-gutter-x) * 0.5);
        padding-left: calc(var(--bs-gutter-x) * 0.5);
        margin-top: var(--bs-gutter-y);
      }
      .col { flex: 1 0 0%; }
      .col-auto { flex: 0 0 auto; width: auto; }
      .d-none { display: none !important; }
      .d-block { display: block !important; }
      .d-lg-none { display: block !important; }
      .d-lg-flex { display: none !important; }
      .d-lg-block { display: none !important; }
      @media (min-width: 992px) {
        .d-lg-none { display: none !important; }
        .d-lg-flex { display: flex !important; }
        .d-lg-block { display: block !important; }
      }
      .ms-auto { margin-left: auto !important; }
      .align-items-center { align-items: center !important; }
      .justify-content-center { justify-content: center !important; }
      .text-center { text-align: center !important; }

      .container {
        width: 100%;
        max-width: 1320px;
        margin: 0 auto;
        padding: 0 16px;
      }
      @media (min-width: 576px) { .container { max-width: 540px; } }
      @media (min-width: 768px) { .container { max-width: 720px; } }
      @media (min-width: 992px) { .container { max-width: 960px; } }
      @media (min-width: 1200px) { .container { max-width: 1140px; } }
      @media (min-width: 1400px) { .container { max-width: 1320px; } }

      /* Header, transparent over hero by default, sticky-wrapper reserves
         a fixed height so the layout doesn't shift when the sticky class
         activates on scroll. Both states have the same physical footprint. */
      header { position: relative; z-index: 100; }
      .th-header.header-transparent .sticky-wrapper:not(.sticky) {
        position: absolute; top: 0; left: 0; right: 0; z-index: 100;
      }
      .sticky-wrapper { min-height: 90px; }
      @media (max-width: 991px) { .sticky-wrapper { min-height: 70px; } }
      .header-logo img {
        max-height: 140px;
        width: auto;
        display: block;
      }
      @media (max-width: 991px) {
        .header-logo img { max-height: 100px; }
      }

      /* Extra space below transparent header on inner pages */
      :root {
        --page-header-gap: 28px;
        --page-hero-padding-top: calc(140px + var(--page-header-gap));
        --page-hero-padding-top-md: calc(120px + var(--page-header-gap));
        --page-hero-padding-top-sm: calc(108px + var(--page-header-gap));
      }

      :global(.faq-hero),
      :global(.blog-hero),
      :global(.contact-hero),
      :global(.things-hero),
      :global(.about-hero),
      :global(.legal-hero),
      :global(.breadcumb-wrapper) {
        padding-top: var(--page-hero-padding-top) !important;
      }

      :global(.service-hero-content) {
        padding-top: calc(160px + var(--page-header-gap)) !important;
      }

      :global(.services-hero),
      :global(.service-hero-fullwidth),
      :global(.rab-hero) {
        padding-top: var(--page-header-gap);
        box-sizing: border-box;
      }

      :global(.td-page-start) {
        padding-top: 32px !important;
        background: #f8fafc;
      }

      @media (max-width: 991px) {
        :global(.td-page-start) {
          padding-top: 24px !important;
        }
      }

      @media (max-width: 991px) {
        :root {
          --page-header-gap: 24px;
        }

        :global(.faq-hero),
        :global(.blog-hero),
        :global(.contact-hero),
        :global(.things-hero),
        :global(.about-hero),
        :global(.legal-hero),
        :global(.breadcumb-wrapper) {
          padding-top: var(--page-hero-padding-top-md) !important;
        }

        :global(.service-hero-content) {
          padding-top: calc(140px + var(--page-header-gap)) !important;
        }
      }

      @media (max-width: 575px) {
        :root {
          --page-header-gap: 20px;
        }

        :global(.faq-hero),
        :global(.blog-hero),
        :global(.contact-hero),
        :global(.things-hero),
        :global(.about-hero) {
          padding-top: var(--page-hero-padding-top-sm) !important;
        }
      }

      #header-one .main-menu > ul {
        display: flex;
        align-items: center;
        list-style: none;
        margin: 0;
        padding: 0;
        gap: 24px;
      }
      #header-one .main-menu > ul > li > a {
        font-size: 13px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        padding: 32px 0;
        white-space: nowrap;
      }
      /* Prevent Service dropdown flash on refresh (hover blocked until user moves mouse) */
      #header-one .main-menu ul.sub-menu {
        display: none !important;
        visibility: hidden !important;
        opacity: 0 !important;
        pointer-events: none !important;
        transform: scaleY(0);
      }
      @media (min-width: 992px) {
        html.nav-hover-ready #header-one .main-menu li.menu-item-has-children:hover > ul.sub-menu,
        #header-one .main-menu li.menu-item-has-children:focus-within > ul.sub-menu {
          display: block !important;
          visibility: visible !important;
          opacity: 1 !important;
          pointer-events: auto !important;
          transform: scaleY(1);
        }
      }
      .th-menu-wrapper:not(.th-body-visible) {
        opacity: 0 !important;
        visibility: hidden !important;
        pointer-events: none !important;
      }

      /* Hero, full structure reserved before style.css loads */
      .th-hero-wrapper {
        position: relative;
        z-index: 1;
        overflow: hidden;
      }
      .hero-inner {
        position: relative;
        height: 100%;
        width: 100%;
      }
      .th-hero-bg {
        position: absolute;
        inset: 0;
        overflow: hidden;
        z-index: 0;
      }
      .th-hero-bg video,
      .th-hero-bg img {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        max-width: none;
        object-fit: cover;
      }
      .hero-fullscreen, .th-hero-wrapper {
        position: relative; min-height: 600px; height: 100vh;
        background-color: #0b2f38; overflow: hidden;
      }
      @media (max-width: 991px) {
        .hero-fullscreen, .th-hero-wrapper { min-height: 380px; height: 75vh; }
      }
      @media (max-width: 767px) {
        .hero-fullscreen, .th-hero-wrapper { min-height: 360px; }
      }

      /* Services grid — reserve card shape before experience-cards.css loads */
      .exp-grid, .exp-grid--4 {
        display: grid;
        gap: 18px;
      }
      .exp-card {
        position: relative;
        display: block;
        border-radius: 16px;
        overflow: hidden;
        aspect-ratio: 4 / 5;
        min-height: 380px;
      }
      @media (max-width: 991px) {
        .exp-grid, .exp-grid--4 { grid-template-columns: 1fr; }
        .exp-card { aspect-ratio: 4 / 5; min-height: 0; }
      }
      .service-hero-fullwidth, .services-hero, .rab-hero {
        position: relative; min-height: 100vh;
        background-color: #0b2f38; overflow: hidden;
      }
      @media (max-width: 991px) {
        .service-hero-fullwidth { min-height: 380px; height: 75vh; }
        .services-hero { min-height: 50vh; }
        .rab-hero { min-height: 75vh; }
      }
      @media (max-width: 767px) {
        .service-hero-fullwidth { min-height: 360px; }
      }

      /* Tour-detail gallery wrapper, main image is 16/7. Reserving the
         aspect prevents the section from collapsing pre-CSS. */
      .td-gallery { aspect-ratio: 16 / 7; }
      @media (max-width: 991px) { .td-gallery { aspect-ratio: 4 / 3; } }

      /* Stop horizontal scroll the moment the page paints */
      html, body {
        overflow-x: hidden;
        max-width: 100%;
      }

      /* Swiper pagination bullets, bump touch target to ≥24px each
         (WCAG 2.5.8 Target Size minimum is 24×24, recommended 44×44 with
         spacing). Visual dot stays the same; padding makes the hit area
         bigger. */
      .swiper-pagination-bullet {
        width: 12px !important;
        height: 12px !important;
        margin: 0 6px !important;
        padding: 6px;
        background-clip: content-box !important;
      }
    </style>

    {isHome ? (
      <>
        <link rel="preload" href="/assets/css/bootstrap.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'" />
        <link rel="preload" href="/assets/css/style.css" as="style" onload="this.onload=null;this.rel='stylesheet'" />
        <link rel="preload" href="/assets/css/experience-cards.css" as="style" onload="this.onload=null;this.rel='stylesheet'" />
        <link rel="preload" href="/assets/css/home-contact.css" as="style" onload="this.onload=null;this.rel='stylesheet'" />
        <link rel="preload" href="/assets/css/site-fonts.css" as="style" onload="this.onload=null;this.rel='stylesheet'" />
      </>
    ) : (
      <>
        <link rel="preload" href="/assets/css/bootstrap.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'" />
        <link rel="preload" href="/assets/css/style.css" as="style" onload="this.onload=null;this.rel='stylesheet'" />
        <link rel="stylesheet" href="/assets/css/site-fonts.css" />
        <link rel="stylesheet" href="/assets/css/home-contact.css" />
        <link rel="stylesheet" href="/assets/css/experience-cards.css" />
      </>
    )}
    <noscript>
      <link rel="stylesheet" href="/assets/css/bootstrap.min.css" />
      <link rel="stylesheet" href="/assets/css/style.css" />
      <link rel="stylesheet" href="/assets/css/site-fonts.css" />
      <link rel="stylesheet" href="/assets/css/home-contact.css" />
      <link rel="stylesheet" href="/assets/css/experience-cards.css" />
    </noscript>

    <!-- Non-critical CSS, async via media-print swap -->
    {!isHome && (
      <link rel="stylesheet" href="/assets/css/fontawesome.min.css" media="print" onload="this.media='all'" />
    )}
    {loadMagnific && (
      <link rel="stylesheet" href="/assets/css/magnific-popup.min.css" media="print" onload="this.media='all'" />
    )}
    {!isHome && (
      <link rel="stylesheet" href="/assets/css/swiper-bundle.min.css" media="print" onload="this.media='all'" />
    )}
    <noscript>
      {!isHome && <link rel="stylesheet" href="/assets/css/fontawesome.min.css" />}
      {loadMagnific && <link rel="stylesheet" href="/assets/css/magnific-popup.min.css" />}
      {!isHome && <link rel="stylesheet" href="/assets/css/swiper-bundle.min.css" />}
    </noscript>
    <!-- Fallback for browsers that don't fire onload on preload-as-stylesheet -->
    <script is:inline>
      !function(e){"use strict";var t=function(t,n,o){var r,i=e.document,a=i.createElement("link");if(n)r=n;else{var l=(i.body||i.getElementsByTagName("head")[0]).childNodes;r=l[l.length-1]}var d=i.styleSheets;a.rel="stylesheet",a.href=t,a.media="only x",function e(t){if(i.body)return t();setTimeout(function(){e(t)})}(function(){r.parentNode.insertBefore(a,n?r:r.nextSibling)});var f=function(e){for(var t=a.href,n=d.length;n--;)if(d[n].href===t)return e();setTimeout(function(){f(e)})};return a.addEventListener&&a.addEventListener("load",function(){this.media=o||"all"}),a.onloadcssdefined=f,f(function(){a.media=o||"all"}),a};"undefined"!=typeof exports?exports.loadCSS=t:e.loadCSS=t}("undefined"!=typeof global?global:this);
    </script>
    <style>
      html, body {
        overflow-x: hidden !important;
        max-width: 100% !important;
        width: 100% !important;
      }
      html:not(.has-gsap) [data-ani],
      html.has-gsap [data-ani] {
        opacity: 1 !important;
        transform: none !important;
      }
      /* Logo touch target, WCAG 2.5.8 minimum 48×48px */
      :global(.header-logo a), :global(.navbar-brand) {
        display: inline-flex;
        align-items: center;
        min-height: 48px;
        padding: 8px 0;
      }
      @media (max-width: 575px) {
        :global(body) { font-size: 16px; line-height: 1.6; }
        :global(small), :global(.small), :global(.meta),
        :global(.blog-card_meta), :global(.blog-card_tag),
        :global(.blog-card__tag), :global(.footer-copyright) {
          font-size: 13px !important;
        }
      }

      /* Headings: sentence case (only first letter capital) */
      :global(h1),
      :global(h2),
      :global(h3),
      :global(h4),
      :global(h5),
      :global(h6),
      :global(.sec-title),
      :global(.sub-title),
      :global(.intro-heading),
      :global(.rab-subheading),
      :global(.rab-title),
      :global(.hero-heading),
      :global(.box-title),
      :global(.box-title2),
      :global(.service-hero-title),
      :global(.services-hero__title),
      :global(.things-hero__title),
      :global(.about-hero__title),
      :global(.contact-hero__title),
      :global(.blog-card__title),
      :global(.exp-card__title),
      :global(.why-title) {
        text-transform: lowercase !important;
      }
      :global(h1)::first-letter,
      :global(h2)::first-letter,
      :global(h3)::first-letter,
      :global(h4)::first-letter,
      :global(h5)::first-letter,
      :global(h6)::first-letter,
      :global(.sec-title)::first-letter,
      :global(.sub-title)::first-letter,
      :global(.intro-heading)::first-letter,
      :global(.rab-subheading)::first-letter,
      :global(.rab-title)::first-letter,
      :global(.hero-heading)::first-letter,
      :global(.box-title)::first-letter,
      :global(.box-title2)::first-letter,
      :global(.service-hero-title)::first-letter,
      :global(.services-hero__title)::first-letter,
      :global(.things-hero__title)::first-letter,
      :global(.about-hero__title)::first-letter,
      :global(.contact-hero__title)::first-letter,
      :global(.blog-card__title)::first-letter,
      :global(.exp-card__title)::first-letter,
      :global(.why-title)::first-letter {
        text-transform: uppercase !important;
      }

      /* Mobile heading scale */
      @media (max-width: 991px) {
        :global(.sec-title),
        :global(.title-area .sec-title) {
          font-size: 26px !important;
          line-height: 1.3 !important;
        }
        :global(.sub-title) {
          font-size: 22px !important;
          line-height: 1.2 !important;
        }
        :global(.breadcumb-title),
        :global(.hero-title) {
          font-size: 32px !important;
          line-height: 1.2 !important;
        }
        :global(.box-title) {
          font-size: 20px !important;
          line-height: 1.35 !important;
        }
        :global(.box-title2) {
          font-size: 17px !important;
        }
        :global(.hero-heading) {
          font-size: 32px !important;
          line-height: 1.15 !important;
          color: #fff !important;
          font-weight: 700 !important;
        }
        :global(.intro-heading) {
          font-size: 1.35rem !important;
          line-height: 1.25 !important;
        }
        :global(.hero-accent) {
          font-size: 0.85rem !important;
          color: #fff !important;
          font-weight: 700 !important;
        }
        :global(.service-hero-title),
        :global(.services-hero__title),
        :global(.things-hero__title),
        :global(.about-hero__title),
        :global(.contact-hero__title),
        :global(.legal-hero__title),
        :global(.rab-hero__title),
        :global(.blog-hero__title),
        :global(.faq-hero__title) {
          font-size: 1.75rem !important;
          line-height: 1.2 !important;
        }
        :global(.contact-find__title),
        :global(.contact-services__title),
        :global(.services-intro__title),
        :global(.services-more__title),
        :global(.services-faq__title),
        :global(.services-cta__title),
        :global(.rb-compare__title),
        :global(.rb-faq__title),
        :global(.about-cta__title),
        :global(.rab-subheading),
        :global(.rab-services__title),
        :global(.rab-related__title) {
          font-size: 1.35rem !important;
          line-height: 1.3 !important;
        }
        :global(main h2[style*="clamp"]) {
          font-size: 1.25rem !important;
          line-height: 1.3 !important;
        }
      }

      @media (max-width: 575px) {
        :global(.sec-title),
        :global(.title-area .sec-title) {
          font-size: 22px !important;
        }
        :global(.breadcumb-title),
        :global(.hero-title) {
          font-size: 28px !important;
        }
        :global(.sub-title) {
          font-size: 20px !important;
        }
        :global(.hero-heading) {
          font-size: 32px !important;
          line-height: 1.15 !important;
          color: #fff !important;
          font-weight: 700 !important;
        }
        :global(.service-hero-title),
        :global(.services-hero__title),
        :global(.things-hero__title),
        :global(.about-hero__title),
        :global(.contact-hero__title),
        :global(.legal-hero__title),
        :global(.rab-hero__title),
        :global(.blog-hero__title),
        :global(.faq-hero__title) {
          font-size: 1.5rem !important;
        }
        :global(main h2[style*="clamp"]) {
          font-size: 1.15rem !important;
        }
      }
    </style>
  </head>
  <body>
    <main id="main-content">
      <slot />
    </main>

    <a
      href="https://wa.me/306951666454"
      target="_blank"
      rel="noopener"
      aria-label="Chat on WhatsApp, Let us help you"
      class="wa-float-btn"
    >
      <span class="wa-float-btn__label">Let us help you</span>
      <span class="wa-float-btn__icon" aria-hidden="true">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
