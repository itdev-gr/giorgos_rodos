---
import type { ServiceFeature } from '../../lib/service-content';

interface Props {
  quote: string;
  features: ServiceFeature[];
  footnote?: string;
}

const { quote, features, footnote } = Astro.props;
---

<section class="sp-features">
  <div class="sp-features__lead-band">
    <div class="container">
      <div class="sp-features__lead-wrap" data-ani="fadein">
        <span class="sp-features__lead-accent" aria-hidden="true"></span>
        <p class="sp-features__lead">{quote}</p>
      </div>
    </div>
  </div>

  <div class="container sp-features__body">
    <div class="sp-features__grid" data-ani="slideinup" data-ani-delay="0.08">
      {features.map((feature) => (
        <article class="sp-feature-card">
          <div class="sp-feature-card__icon" aria-hidden="true">
            <i class={feature.icon}></i>
          </div>
          <h2 class="sp-feature-card__title">{feature.title}</h2>
          <p class="sp-feature-card__text">{feature.text}</p>
        </article>
      ))}
    </div>

    {footnote && (
      <p class="sp-features__footnote" data-ani="fadein" data-ani-delay="0.15" set:html={footnote} />
    )}
  </div>
</section>

<style>
  .sp-features {
    background: #fff;
  }

  .sp-features__lead-band {
    padding: 48px 0;
    background: #f4f8f9;
    border-bottom: 1px solid #e8eef0;
  }

  .sp-features__lead-wrap {
    max-width: 760px;
    margin: 0 auto;
    display: flex;
    align-items: flex-start;
    gap: 20px;
  }

  .sp-features__lead-accent {
    flex-shrink: 0;
    width: 4px;
    min-height: 100%;
    align-self: stretch;
    background: #1CA8CB;
    border-radius: 4px;
    margin-top: 4px;
    min-height: 48px;
  }

  .sp-features__lead {
    margin: 0;
    font-size: clamp(1.12rem, 2.2vw, 1.38rem);
    line-height: 1.65;
    font-weight: 500;
    color: #000;
    font-style: normal;
    letter-spacing: -0.01em;
  }

  .sp-features__body {
    padding: 56px 0 64px;
  }

  .sp-features__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .sp-feature-card {
    background: #fff;
    border: 1px solid #e8eef0;
    border-radius: 16px;
    padding: 32px 26px;
    text-align: left;
    height: 100%;
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
  }

  .sp-feature-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 36px rgba(17, 61, 72, 0.08);
    border-color: rgba(28, 168, 203, 0.3);
  }

  .sp-feature-card__icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: rgba(28, 168, 203, 0.1);
    color: #1CA8CB;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 1.15rem;
    margin-bottom: 18px;
  }

  .sp-feature-card__title {
    font-size: 1.05rem;
    font-weight: 700;
    color: #113D48;
    margin: 0 0 10px;
    line-height: 1.3;
  }

  .sp-feature-card__text {
    font-size: 0.95rem;
    line-height: 1.65;
    color: #000;
    margin: 0;
  }

  .sp-features__footnote {
    max-width: 720px;
    margin: 36px auto 0;
    text-align: center;
    font-size: 0.98rem;
    font-weight: 600;
    line-height: 1.65;
    color: #113D48;
  }

  .sp-features__footnote :global(a) {
    color: #1CA8CB;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .sp-features__footnote :global(a:hover) {
    color: #178fa8;
  }

  @media (max-width: 991px) {
    .sp-features__lead-band {
      padding: 36px 0;
    }

    .sp-features__body {
      padding: 40px 0 48px;
    }

    .sp-features__grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }
  }

  @media (max-width: 575px) {
    .sp-features__lead-wrap {
      gap: 14px;
    }

    .sp-features__lead {
      font-size: 1.05rem;
    }
  }
</style>
