---
interface Props {
  title: string;
  subtitle?: string;
  backgroundImage?: string;
}

const { title, subtitle, backgroundImage } = Astro.props;
---

<section class="sp-hero" style={backgroundImage ? `--sp-hero-img: url(${backgroundImage})` : undefined}>
  <div class="container">
    <div class="sp-hero__inner text-center" data-ani="fadein">
      <h1 class="sp-hero__title">{title}</h1>
      {subtitle && <p class="sp-hero__subtitle">{subtitle}</p>}
    </div>
  </div>
</section>

<style>
  .sp-hero {
    min-height: 320px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 140px 0 72px;
    background: linear-gradient(135deg, #1CA8CB 0%, #1489a8 35%, #113D48 100%);
    position: relative;
    overflow: hidden;
  }

  .sp-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: var(--sp-hero-img);
    background-size: cover;
    background-position: center;
    opacity: 0.14;
    pointer-events: none;
  }

  .sp-hero__inner {
    position: relative;
    z-index: 1;
    max-width: 760px;
    margin: 0 auto;
  }

  .sp-hero__title {
    font-size: clamp(2rem, 4.5vw, 3.25rem);
    font-weight: 800;
    line-height: 1.15;
    margin: 0 0 14px;
    color: #fff;
  }

  .sp-hero__subtitle {
    font-size: clamp(1rem, 2vw, 1.2rem);
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.92);
    margin: 0;
    max-width: 560px;
    margin-inline: auto;
  }

  @media (max-width: 991px) {
    .sp-hero {
      min-height: 280px;
      padding: 120px 0 52px;
    }
  }

  @media (max-width: 575px) {
    .sp-hero {
      padding: 108px 0 44px;
    }
  }
</style>
