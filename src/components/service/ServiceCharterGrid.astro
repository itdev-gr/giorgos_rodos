---
import ExperienceCard from '../ExperienceCard.astro';

interface CharterItem {
  title: string;
  description: string;
  image: string;
  imageAlt?: string;
  duration?: string;
  guests?: string;
  type?: string;
  price?: string;
  href: string;
}

interface Props {
  items: CharterItem[];
}

const { items } = Astro.props;
---

<div class="exp-grid exp-grid--catalog">
  {items.map((charter, i) => (
    <div data-ani="slideinup" data-ani-delay={`${0.08 + i * 0.06}`}>
      <ExperienceCard
        href={charter.href || '/contact'}
        title={charter.title}
        description={charter.description}
        image={charter.image}
        imageAlt={charter.imageAlt}
        badge={charter.type || charter.duration}
        price={charter.price}
        duration={charter.duration}
        guests={charter.guests}
      />
    </div>
  ))}
</div>
