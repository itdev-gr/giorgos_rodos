---
import { resolveLocale } from '../../i18n/context';
import { getPageContent } from '../../i18n/page-content';
import { localizeHtmlLinks } from '../../i18n/localize-links';
import { localizedPath } from '../../i18n/routing';

const locale = resolveLocale(Astro.locals, Astro.url.pathname);
const intro = getPageContent(locale).boatTripsIntro;
const lede = localizeHtmlLinks(intro.ledeHtml, locale);
const cruisesHref = localizedPath('/service/rhodes-boat-cruises', locale);
---

<section class="sp-boat-intro" aria-labelledby="sp-boat-intro-title">
  <div class="container">
    <div class="sp-boat-intro__inner">
      <h2 id="sp-boat-intro-title" class="visually-hidden">{intro.hiddenTitle}</h2>
      <p class="sp-boat-intro__lede" set:html={lede} />

      <div class="sp-boat-intro__table-wrap">
        <table class="sp-boat-intro__table">
          <caption>{intro.table.caption}</caption>
          <thead>
            <tr>
              <th scope="col">{intro.table.columns.type}</th>
              <th scope="col">{intro.table.columns.bestFor}</th>
              <th scope="col">{intro.table.columns.price}</th>
              <th scope="col">{intro.table.columns.book}</th>
            </tr>
          </thead>
          <tbody>
            {intro.table.rows.map((row) => (
              <tr>
                <td>{row.type}</td>
                <td>{row.bestFor}</td>
                <td>{row.price}</td>
                <td set:html={localizeHtmlLinks(row.bookHtml.replace('/service/rhodes-boat-cruises', cruisesHref), locale)} />
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>

<style>
  .sp-boat-intro {
    padding: 48px 0 64px;
    background: #fff;
  }

  .sp-boat-intro__inner {
    max-width: 760px;
    margin: 0 auto;
    text-align: center;
  }

  .sp-boat-intro__lede {
    margin: 0 0 40px;
    padding: 0 12px;
    font-size: 1.08rem;
    line-height: 1.8;
    color: #475569;
  }

  .sp-boat-intro__lede :global(a) {
    color: #1CA8CB;
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .sp-boat-intro__table-wrap {
    overflow-x: auto;
    text-align: left;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    background: #f8fafb;
  }

  .sp-boat-intro__table {
    width: 100%;
    min-width: 560px;
    border-collapse: collapse;
    font-size: 0.95rem;
  }

  .sp-boat-intro__table caption {
    padding: 14px 16px 0;
    font-weight: 700;
    color: #113D48;
    text-align: left;
  }

  .sp-boat-intro__table th,
  .sp-boat-intro__table td {
    padding: 14px 16px;
    border-top: 1px solid #e2e8f0;
    vertical-align: top;
  }

  .sp-boat-intro__table th {
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #64748b;
    background: #f1f5f7;
  }

  .sp-boat-intro__table td {
    color: #334155;
  }

  .sp-boat-intro__table :global(a) {
    color: #1CA8CB;
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
