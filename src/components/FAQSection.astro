---
// Page-level FAQ block: renders visible accordion + FAQPage JSON-LD schema.
// Answers may contain inline HTML (anchors, <strong>), we use set:html so
// internal links inside answers work.

import FAQSchema from './seo/FAQSchema.astro';

interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  items: FaqItem[];
  title?: string;
  titleHtml?: string;
  intro?: string;
  background?: 'light' | 'white';
}

const { items, title = 'Frequently Asked Questions', titleHtml, intro, background = 'light' } = Astro.props;
---

<FAQSchema items={items} />

<section class:list={['faq-section', background === 'white' && 'faq-section--white']} aria-labelledby="faq-section-title">
  <div class="container">
    <div class="faq-section__header" data-ani="fadein">
      {titleHtml ? (
        <h2 id="faq-section-title" class="faq-section__title" set:html={titleHtml}></h2>
      ) : (
        <h2 id="faq-section-title" class="faq-section__title">{title}</h2>
      )}
      {intro && <p class="faq-section__intro" set:html={intro}></p>}
    </div>
    <div class="faq-section__list">
      {items.map((item) => (
        <details class="faq-section__item">
          <summary class="faq-section__q">{item.question}</summary>
          <div class="faq-section__a"><p set:html={item.answer}></p></div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .faq-section {
    padding: 88px 0;
    background: linear-gradient(180deg, #eef6f8 0%, #f8fafb 100%);
  }
  .faq-section--white {
    background: #fff;
  }
  .faq-section__header {
    max-width: 720px;
    margin: 0 auto 40px;
    text-align: center;
  }
  .faq-section__title {font-size: clamp(1.65rem, 3.2vw, 2.35rem);
    font-weight: 700;
    color: #113D48;
    margin: 0 0 14px;
    line-height: 1.25;
  }
  .faq-section__title :global(.faq-title-accent) {
    color: #1CA8CB;
  }
  .faq-section__intro {font-size: 1rem;
    line-height: 1.65;
    color: #56646b;
    margin: 0;
  }
  .faq-section__intro a {
    color: #1CA8CB;
    font-weight: 600;
    text-decoration: none;
    border-bottom: 1px solid rgba(28, 168, 203, 0.35);
  }
  .faq-section__intro a:hover {
    color: #178fa8;
    border-bottom-color: #178fa8;
  }
  .faq-section__list {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .faq-section__item {
    background: #fff;
    border: 1px solid rgba(28, 168, 203, 0.12);
    border-radius: 14px;
    border-left: 4px solid rgba(28, 168, 203, 0.25);
    box-shadow: 0 4px 18px rgba(17, 61, 72, 0.05);
    overflow: hidden;
    transition: border-color 0.25s ease, box-shadow 0.25s ease, background-color 0.25s ease;
  }
  .faq-section--white .faq-section__item {
    background: #f8fafb;
  }
  .faq-section__item[open] {
    border-color: rgba(28, 168, 203, 0.35);
    border-left-color: #1CA8CB;
    background: linear-gradient(90deg, rgba(28, 168, 203, 0.1) 0%, #fff 28%);
    box-shadow: 0 10px 32px rgba(28, 168, 203, 0.14);
  }
  .faq-section__q {font-size: 1.15rem;
    font-weight: 600;
    color: #113D48;
    padding: 20px 68px 20px 22px;
    cursor: pointer;
    list-style: none;
    position: relative;
    transition: color 0.2s ease;
    line-height: 1.45;
  }
  .faq-section__item[open] .faq-section__q {
    color: #0e5668;
  }
  .faq-section__q::-webkit-details-marker { display: none; }
  .faq-section__q::after {
    content: '+';
    position: absolute;
    right: 18px;
    top: 50%;
    transform: translateY(-50%);
    width: 34px;
    height: 34px;
    line-height: 34px;
    text-align: center;
    font-size: 1.15rem;
    font-weight: 600;
    color: #1CA8CB;
    background: rgba(28, 168, 203, 0.12);
    border-radius: 50%;
    transition: background-color 0.2s ease, color 0.2s ease;
  }
  .faq-section__item[open] .faq-section__q::after {
    content: '−';
    background: #1CA8CB;
    color: #fff;
  }
  .faq-section__a {
    padding: 0 20px 20px;
    border-top: 1px solid rgba(28, 168, 203, 0.12);
    margin-top: 0;
  }
  .faq-section__item:not([open]) .faq-section__a {
    border-top-color: transparent;
  }
  .faq-section__a p {font-size: 1.08rem;
    line-height: 1.65;
    color: #000;
    margin: 18px 0 0;
  }
  .faq-section__a a {
    color: #1CA8CB;
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  @media (max-width: 575px) {
    .faq-section__q {
      font-size: 1.05rem;
      padding: 18px 60px 18px 18px;
    }

    .faq-section__a p {
      font-size: 1rem;
    }
  }
</style>
