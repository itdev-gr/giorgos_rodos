---
// Page-level FAQ block: renders visible accordion + FAQPage JSON-LD schema.
// Answers may contain inline HTML (anchors, <strong>) — we use set:html so
// internal links inside answers work.

import FAQSchema from './seo/FAQSchema.astro';

interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  items: FaqItem[];
  title?: string;
  intro?: string;
  background?: 'light' | 'white';
}

const { items, title = 'Frequently Asked Questions', intro, background = 'light' } = Astro.props;
---

<FAQSchema items={items} />

<section class:list={['faq-section', background === 'white' && 'faq-section--white']} aria-labelledby="faq-section-title">
  <div class="container">
    <div class="faq-section__header" data-ani="fadein">
      <h2 id="faq-section-title" class="faq-section__title">{title}</h2>
      {intro && <p class="faq-section__intro" set:html={intro}></p>}
    </div>
    <div class="faq-section__list">
      {items.map((item) => (
        <details class="faq-section__item">
          <summary class="faq-section__q">{item.question}</summary>
          <div class="faq-section__a"><p set:html={item.answer}></p></div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .faq-section {
    padding: 80px 0;
    background: #f8fafb;
  }
  .faq-section--white {
    background: #fff;
  }
  .faq-section__header {
    max-width: 760px;
    margin: 0 auto 32px;
    text-align: center;
  }
  .faq-section__title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 700;
    color: #113D48;
    margin: 0 0 12px;
  }
  .faq-section__intro {
    font-family: 'Inter', sans-serif;
    font-size: 0.95rem;
    line-height: 1.65;
    color: #56646b;
    margin: 0;
  }
  .faq-section__intro a {
    color: #1CA8CB;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .faq-section__list {
    max-width: 880px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .faq-section__item {
    background: #fff;
    border: 1px solid #e5eaee;
    border-radius: 10px;
  }
  .faq-section--white .faq-section__item {
    background: #f8fafb;
  }
  .faq-section__item[open] {
    border-color: #1CA8CB;
  }
  .faq-section__q {
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    color: #113D48;
    padding: 16px 44px 16px 18px;
    cursor: pointer;
    list-style: none;
    position: relative;
  }
  .faq-section__q::-webkit-details-marker { display: none; }
  .faq-section__q::after {
    content: '+';
    position: absolute;
    right: 18px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 1.4rem;
    font-weight: 300;
    color: #1CA8CB;
  }
  .faq-section__item[open] .faq-section__q::after {
    content: '−';
  }
  .faq-section__a {
    padding: 0 18px 18px;
  }
  .faq-section__a p {
    font-family: 'Inter', sans-serif;
    font-size: 0.95rem;
    line-height: 1.7;
    color: #4a5568;
    margin: 0;
  }
  .faq-section__a a {
    color: #1CA8CB;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
</style>
