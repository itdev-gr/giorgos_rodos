---
import { THINGS_TO_DO_SERVICE_LINKS } from '../../lib/internal-links';
---

<section class="ttd-svc-links" aria-labelledby="ttd-svc-links-title">
  <div class="container">
    <h2 id="ttd-svc-links-title" class="ttd-svc-links__title">Explore by Service Type</h2>
    <p class="ttd-svc-links__intro">
      Every listing on this page is handpicked. Start with the service that matches what you want — then compare individual experiences below.
    </p>
    <ul class="ttd-svc-links__grid">
      {THINGS_TO_DO_SERVICE_LINKS.map((link) => (
        <li>
          <a href={link.url} class="ttd-svc-links__card">
            <span class="ttd-svc-links__card-name">{link.name}</span>
            <span class="ttd-svc-links__card-blurb">{link.blurb}</span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .ttd-svc-links {
    padding: 48px 0 24px;
    background: #fff;
  }

  .ttd-svc-links__title {
    font-size: clamp(1.35rem, 2.5vw, 1.65rem);
    font-weight: 700;
    color: #113D48;
    margin: 0 0 10px;
    text-align: center;
  }

  .ttd-svc-links__intro {
    max-width: 640px;
    margin: 0 auto 28px;
    text-align: center;
    font-size: 0.98rem;
    line-height: 1.65;
    color: #475569;
  }

  .ttd-svc-links__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .ttd-svc-links__card {
    display: flex;
    flex-direction: column;
    gap: 6px;
    height: 100%;
    padding: 18px 16px;
    background: #f8fafb;
    border: 1px solid #e8eef0;
    border-radius: 12px;
    text-decoration: none;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .ttd-svc-links__card:hover {
    border-color: rgba(28, 168, 203, 0.45);
    transform: translateY(-2px);
  }

  .ttd-svc-links__card-name {
    font-size: 0.95rem;
    font-weight: 700;
    color: #113D48;
    line-height: 1.3;
  }

  .ttd-svc-links__card-blurb {
    font-size: 0.82rem;
    line-height: 1.5;
    color: #64748b;
  }

  @media (max-width: 991px) {
    .ttd-svc-links__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 575px) {
    .ttd-svc-links__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
