---
interface Props {
  id?: string;
  class?: string;
  formIntro?: string;
  infoIntro?: string;
  showSubject?: boolean;
  formIdPrefix?: string;
}

const {
  id,
  class: className,
  formIntro = 'For any question or info about our services, please fill out the form below and we\'ll get back to you as soon as possible.',
  infoIntro = 'Our team is available every day, by phone, WhatsApp, or email. We answer personally with clear advice, fair prices, and boats we know well.',
  showSubject = false,
  formIdPrefix = 'cp',
} = Astro.props;

const phone = '+30 695 166 6454';
const phoneHref = 'tel:+306951666454';
const email = 'info@rhodesrentaboat.com';
const address = 'Ionos Dragoumi 39, Rhodes (85100) Greece';

const contactDetails = [
  {
    icon: 'fas fa-map-marker-alt',
    title: 'Office Address',
    text: address,
    href: 'https://maps.app.goo.gl/2KSkGvEyWXBu83SVA',
    external: true,
  },
  {
    icon: 'fas fa-anchor',
    title: 'Boat Pickup Location',
    text: 'Mandraki Harbour & Rhodes marinas',
    href: 'https://maps.app.goo.gl/2KSkGvEyWXBu83SVA',
    external: true,
  },
  {
    icon: 'fas fa-phone',
    title: 'Call Us',
    text: phone,
    href: phoneHref,
  },
  {
    icon: 'fas fa-envelope',
    title: 'Email Us',
    text: email,
    href: `mailto:${email}`,
  },
];

---

<section class:list={['home-cta-contact', className]} id={id}>
  <div class="container">
    <div class="home-cta-contact__grid">
      <div class="home-cta-contact__form-box">
        <h3>Send us a message</h3>
        {formIntro && <p class="home-cta-contact__form-intro">{formIntro}</p>}

        <form class="ajax-contact home-cta-contact__form">
          <div class="home-cta-contact__row home-cta-contact__row--2">
            <div class="home-cta-contact__field">
              <label for={`${formIdPrefix}-first`}>First Name *</label>
              <input
                id={`${formIdPrefix}-first`}
                type="text"
                name="firstName"
                required
                autocomplete="given-name"
              />
            </div>
            <div class="home-cta-contact__field">
              <label for={`${formIdPrefix}-last`}>Last Name *</label>
              <input
                id={`${formIdPrefix}-last`}
                type="text"
                name="lastName"
                required
                autocomplete="family-name"
              />
            </div>
          </div>

          <div class="home-cta-contact__field">
            <label for={`${formIdPrefix}-phone`}>Phone Number</label>
            <input
              id={`${formIdPrefix}-phone`}
              type="tel"
              name="phone"
              autocomplete="tel"
            />
          </div>

          <div class="home-cta-contact__field">
            <label for={`${formIdPrefix}-email`}>Email *</label>
            <input
              id={`${formIdPrefix}-email`}
              type="email"
              name="email"
              required
              autocomplete="email"
            />
          </div>

          {showSubject && (
            <div class="home-cta-contact__field">
              <label for={`${formIdPrefix}-subject`}>I'm interested in</label>
              <select id={`${formIdPrefix}-subject`} name="subject">
                <option value="" disabled selected>Select an option</option>
                <option value="Private Yacht Charter">Private Yacht Charter</option>
                <option value="Boat Tour / Cruise">Boat Tour / Cruise</option>
                <option value="Boat Rental">Boat Rental</option>
                <option value="Special Event">Special Event</option>
                <option value="Something Else">Something Else</option>
              </select>
            </div>
          )}

          <div class="home-cta-contact__field">
            <label for={`${formIdPrefix}-message`}>Write a message *</label>
            <textarea
              id={`${formIdPrefix}-message`}
              name="message"
              required
            ></textarea>
          </div>

          <button type="submit" class="home-cta-contact__submit">
            Send Message
            <i class="fa-regular fa-arrow-right" aria-hidden="true"></i>
          </button>
        </form>
      </div>

      <div class="home-cta-contact__info">
        <span class="home-cta-contact__eyebrow">Contact Us</span>
        <h2>Get In Touch</h2>
        <p>{infoIntro}</p>

        <ul class="home-cta-contact__details">
          {contactDetails.map((item) => (
            <li>
              <a
                href={item.href}
                class="home-cta-contact__detail"
                {...(item.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
              >
                <span class="home-cta-contact__detail-icon" aria-hidden="true">
                  <i class={item.icon}></i>
                </span>
                <span class="home-cta-contact__detail-copy">
                  <span class="home-cta-contact__detail-title">{item.title}</span>
                  <span class="home-cta-contact__detail-text">{item.text}</span>
                </span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
