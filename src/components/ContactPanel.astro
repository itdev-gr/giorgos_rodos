---
import type { ContactFormLabels } from '../../i18n/ui-labels';

interface Props {
  id?: string;
  class?: string;
  formIntro?: string;
  infoIntro?: string;
  showSubject?: boolean;
  formIdPrefix?: string;
  labels: ContactFormLabels;
}

const {
  id,
  class: className,
  formIntro,
  infoIntro,
  showSubject = false,
  formIdPrefix = 'cp',
  labels,
} = Astro.props;

const phone = '+30 695 166 6454';
const phoneHref = 'tel:+306951666454';
const email = 'rhodessailingtours2023@gmail.com';
const address = 'Ionos Dragoumi 39, Rhodes (85100) Greece';

const contactDetails = [
  {
    icon: 'fas fa-map-marker-alt',
    title: labels.officeAddress,
    text: address,
    href: 'https://maps.app.goo.gl/2KSkGvEyWXBu83SVA',
    external: true,
  },
  {
    icon: 'fas fa-anchor',
    title: labels.boatPickup,
    text: labels.boatPickupText,
    href: 'https://maps.app.goo.gl/2KSkGvEyWXBu83SVA',
    external: true,
  },
  {
    icon: 'fas fa-phone',
    title: labels.callUs,
    text: phone,
    href: phoneHref,
  },
  {
    icon: 'fas fa-envelope',
    title: labels.emailUs,
    text: email,
    href: `mailto:${email}`,
  },
];

const subjectOptions = [
  { value: labels.subjects.charter, label: labels.subjects.charter },
  { value: labels.subjects.tour, label: labels.subjects.tour },
  { value: labels.subjects.rental, label: labels.subjects.rental },
  { value: labels.subjects.event, label: labels.subjects.event },
  { value: labels.subjects.other, label: labels.subjects.other },
];
---

<section class:list={['home-cta-contact', className]} id={id}>
  <div class="container">
    <div class="home-cta-contact__grid">
      <div class="home-cta-contact__form-box">
        <h3>{labels.title}</h3>
        {formIntro && <p class="home-cta-contact__form-intro">{formIntro}</p>}

        <form class="ajax-contact home-cta-contact__form">
          <div class="home-cta-contact__row home-cta-contact__row--2">
            <div class="home-cta-contact__field">
              <label for={`${formIdPrefix}-first`}>{labels.firstName}</label>
              <input
                id={`${formIdPrefix}-first`}
                type="text"
                name="firstName"
                required
                autocomplete="given-name"
              />
            </div>
            <div class="home-cta-contact__field">
              <label for={`${formIdPrefix}-last`}>{labels.lastName}</label>
              <input
                id={`${formIdPrefix}-last`}
                type="text"
                name="lastName"
                required
                autocomplete="family-name"
              />
            </div>
          </div>

          <div class="home-cta-contact__field">
            <label for={`${formIdPrefix}-phone`}>{labels.phone}</label>
            <input
              id={`${formIdPrefix}-phone`}
              type="tel"
              name="phone"
              autocomplete="tel"
            />
          </div>

          <div class="home-cta-contact__field">
            <label for={`${formIdPrefix}-email`}>{labels.email}</label>
            <input
              id={`${formIdPrefix}-email`}
              type="email"
              name="email"
              required
              autocomplete="email"
            />
          </div>

          {showSubject && (
            <div class="home-cta-contact__field">
              <label for={`${formIdPrefix}-subject`}>{labels.subjectLabel}</label>
              <select id={`${formIdPrefix}-subject`} name="subject">
                <option value="" disabled selected>{labels.subjectPlaceholder}</option>
                {subjectOptions.map((opt) => (
                  <option value={opt.value}>{opt.label}</option>
                ))}
              </select>
            </div>
          )}

          <div class="home-cta-contact__field">
            <label for={`${formIdPrefix}-message`}>{labels.message}</label>
            <textarea
              id={`${formIdPrefix}-message`}
              name="message"
              required
            ></textarea>
          </div>

          <button type="submit" class="home-cta-contact__submit">
            {labels.submit}
            <i class="fa-regular fa-arrow-right" aria-hidden="true"></i>
          </button>
        </form>
      </div>

      <div class="home-cta-contact__info">
        <span class="home-cta-contact__eyebrow">{labels.eyebrow}</span>
        <h2>{labels.sideTitle}</h2>
        <p>{infoIntro}</p>

        <ul class="home-cta-contact__details">
          {contactDetails.map((item) => (
            <li>
              <a
                href={item.href}
                class="home-cta-contact__detail"
                {...(item.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
              >
                <span class="home-cta-contact__detail-icon" aria-hidden="true">
                  <i class={item.icon}></i>
                </span>
                <span class="home-cta-contact__detail-copy">
                  <span class="home-cta-contact__detail-title">{item.title}</span>
                  <span class="home-cta-contact__detail-text">{item.text}</span>
                </span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
