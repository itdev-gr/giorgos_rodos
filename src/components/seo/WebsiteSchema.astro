---
import { SITE_URL, SITE_NAME, SITE_ALTERNATE_NAME, FOUNDING_YEAR } from '../../lib/seo';
import { SCHEMA_LANGUAGE, type Locale } from '../../i18n/locales';
import { getMessages } from '../../i18n';
import { localizedPath } from '../../i18n/routing';

interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;
const messages = getMessages(locale);

const data = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${SITE_URL}#website`,
  url: SITE_URL,
  name: SITE_NAME,
  alternateName: SITE_ALTERNATE_NAME,
  description: messages.schema.websiteDescription,
  inLanguage: SCHEMA_LANGUAGE[locale],
  publisher: { '@id': `${SITE_URL}#organization` },
  potentialAction: {
    '@type': 'SearchAction',
    target: {
      '@type': 'EntryPoint',
      urlTemplate: `${SITE_URL}${localizedPath('/things-to-do', locale)}?q={search_term_string}`,
    },
    'query-input': 'required name=search_term_string',
  },
};
---
<script type="application/ld+json" set:html={JSON.stringify(data)} is:inline />
