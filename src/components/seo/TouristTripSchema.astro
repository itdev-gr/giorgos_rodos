---
import { SITE_URL } from '../../lib/seo';

interface Props {
  tour: {
    title: string;
    description?: string | null;
    slug?: string | null;
    id: string;
    duration?: string | number | null;
    meeting_point?: string | null;
    guests?: string | number | null;
    price?: string | null;
    badge_label?: string | null;
    status?: string;
    images?: string[] | null;
    image_url?: string | null;
    highlights?: string[] | null;
  };
  displayDescription: string;
  isPublished: boolean;
}

const { tour, displayDescription, isPublished } = Astro.props;

const images = tour.images?.length
  ? tour.images
  : tour.image_url
    ? [tour.image_url]
    : ['/assets/img/gallery/yacht/crystal-water-1.jpg'];

const tourPathSegment = tour.slug || tour.id;
const tourCanonical = `${SITE_URL}/tour-detail/${tourPathSegment}`;
const priceValidUntil = `${new Date().getFullYear() + 1}-12-31`;
const highlights = tour.highlights || [];

// Convert a free-text duration to a valid ISO 8601 period, detecting the unit.
// Returns undefined when it can't be parsed, so we omit `duration` rather than
// emit an invalid value (e.g. "Full day") or the wrong unit (7 days as PT7H).
const toISO8601Duration = (raw: string | number): string | undefined => {
  const s = String(raw).trim();
  if (/^P/i.test(s)) return s; // already an ISO 8601 period (PT4H, P7D, ...)
  const lower = s.toLowerCase();
  const num = parseFloat(lower.replace(/[^\d.]/g, ''));
  const hoursToISO = (hrs: number) => {
    const h = Math.floor(hrs);
    const m = Math.round((hrs - h) * 60);
    return `PT${h}H${m > 0 ? `${m}M` : ''}`;
  };
  if (/day/.test(lower)) return isNaN(num) ? undefined : `P${Math.round(num)}D`;
  if (/hour|hr|\bh\b/.test(lower)) return isNaN(num) ? undefined : hoursToISO(num);
  if (/min/.test(lower)) return isNaN(num) ? undefined : `PT${Math.round(num)}M`;
  // Bare number with no unit → assume hours; anything else can't be parsed.
  if (!isNaN(num) && lower === String(num)) return hoursToISO(num);
  return undefined;
};

// Extract a single clean numeric price. Takes the FIRST number in the string
// (so ranges like "€1,500 - €3,000" don't concatenate into "15003000") and
// strips thousands separators — prices here are whole euros.
const parsePrice = (raw: string): string | undefined => {
  const token = String(raw).match(/\d[\d.,]*/)?.[0];
  if (!token) return undefined;
  const digits = token.replace(/[.,]/g, '');
  return digits || undefined;
};

const data: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'TouristTrip',
  '@id': `${tourCanonical}#trip`,
  name: tour.title,
  description: displayDescription,
  url: tourCanonical,
  mainEntityOfPage: { '@type': 'WebPage', '@id': tourCanonical },
  image: images.map((img: string) => (img.startsWith('http') ? img : `${SITE_URL}${img}`)),
  touristType: tour.badge_label || 'Boat experience',
  inLanguage: 'en-US',
  provider: { '@id': `${SITE_URL}#organization` },
};

if (highlights.length) {
  data.itinerary = {
    '@type': 'ItemList',
    itemListElement: highlights.map((h: string, i: number) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: h,
    })),
  };
}

if (tour.duration) {
  const iso = toISO8601Duration(tour.duration);
  if (iso) data.duration = iso;
}

if (tour.meeting_point) {
  data.departureLocation = {
    '@type': 'Place',
    name: tour.meeting_point,
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Rhodes',
      addressRegion: 'South Aegean',
      addressCountry: 'GR',
    },
  };
}

if (tour.guests) {
  data.audience = {
    '@type': 'PeopleAudience',
    suggestedMinAge: 0,
    name: String(tour.guests),
  };
}

if (tour.price) {
  const numericPrice = parsePrice(tour.price);
  data.offers = [{
    '@type': 'Offer',
    price: numericPrice || undefined,
    priceCurrency: 'EUR',
    availability: isPublished ? 'https://schema.org/InStock' : 'https://schema.org/OutOfStock',
    url: tourCanonical,
    priceValidUntil,
    seller: { '@id': `${SITE_URL}#organization` },
    category: tour.badge_label || 'Boat experience',
  }];
}
---
<script type="application/ld+json" set:html={JSON.stringify(data)} is:inline />
