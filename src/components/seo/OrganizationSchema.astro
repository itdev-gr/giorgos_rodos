---
import { SITE_URL, SITE_NAME, FOUNDING_YEAR } from '../../lib/seo';

const data = {
  '@context': 'https://schema.org',
  '@type': ['TravelAgency', 'LocalBusiness'],
  '@id': `${SITE_URL}#organization`,
  name: SITE_NAME,
  url: SITE_URL,
  logo: {
    '@type': 'ImageObject',
    url: `${SITE_URL}/assets/img/logo2.svg`,
    width: 200,
    height: 60,
  },
  image: `${SITE_URL}/assets/img/hero/hero_bg_1_1.jpg`,
  description: `Local-led boat tours, license-free rentals, sailing trips and yacht charters in Rhodes, Greece. Operating from our office on Ionos Dragoumi 39, Rhodes Town, since ${FOUNDING_YEAR}.`,
  telephone: '+306951666454',
  email: 'info@rhodesrentaboat.com',
  priceRange: '€€',
  currenciesAccepted: 'EUR',
  paymentAccepted: 'Cash, Credit Card, Bank Transfer',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Ionos Dragoumi 39',
    addressLocality: 'Rhodes Town',
    addressRegion: 'South Aegean',
    postalCode: '85100',
    addressCountry: 'GR',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 36.4497769,
    longitude: 28.2197904,
  },
  areaServed: [
    { '@type': 'Place', name: 'Rhodes, Greece' },
    { '@type': 'Place', name: 'Symi, Greece' },
    { '@type': 'Place', name: 'Lindos, Greece' },
    { '@type': 'Place', name: 'Dodecanese, Greece' },
  ],
  hasMap: 'https://www.google.com/maps/place/Rhodes+Rent+a+Boat/@36.4497769,28.2197904,17z',
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'],
      opens: '09:00',
      closes: '20:00',
      validFrom: '--05-01',
      validThrough: '--10-31',
    },
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'],
      opens: '00:00',
      closes: '00:00',
      validFrom: '--11-01',
      validThrough: '--04-30',
    },
  ],
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.9',
    reviewCount: '6',
    bestRating: '5',
    worstRating: '1',
  },
  sameAs: [
    'https://www.facebook.com/RhodosYachts',
    'https://www.instagram.com/rhodos_yachts/',
    'https://www.google.com/maps/place/Rhodes+Rent+a+Boat/@36.4497769,28.2197904,17z',
  ],
  foundingDate: FOUNDING_YEAR,
  knowsLanguage: ['en', 'el', 'de', 'it', 'fr'],
  contactPoint: [
    {
      '@type': 'ContactPoint',
      telephone: '+306951666454',
      contactType: 'customer service',
      areaServed: 'GR',
      availableLanguage: ['English', 'Greek', 'German', 'Italian', 'French'],
    },
  ],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Boat Experiences in Rhodes',
    itemListElement: [
      { '@type': 'Offer', url: `${SITE_URL}/service/rhodes-boat-tours`, itemOffered: { '@type': 'TouristTrip', name: 'Rhodes Boat Tours', description: 'Guided sailing tours along the Rhodes coastline', url: `${SITE_URL}/service/rhodes-boat-tours`, image: `${SITE_URL}/assets/img/tours/hero-rhodes-coast.jpg` }},
      { '@type': 'Offer', url: `${SITE_URL}/service/rhodes-boat-trips`, itemOffered: { '@type': 'TouristTrip', name: 'Rhodes Private Boat Trips', description: 'Private skippered boat trips with flexible routes', url: `${SITE_URL}/service/rhodes-boat-trips`, image: `${SITE_URL}/assets/img/hero/hero_bg_1_1.jpg` }},
      { '@type': 'Offer', url: `${SITE_URL}/service/rhodes-charter`, itemOffered: { '@type': 'TouristTrip', name: 'Rhodes Yacht Charter', description: 'Bareboat and crewed yacht charters in the Dodecanese', url: `${SITE_URL}/service/rhodes-charter`, image: `${SITE_URL}/assets/img/hero/hero_bg_1_1.jpg` }},
      { '@type': 'Offer', url: `${SITE_URL}/service/rhodes-rent-a-boat`, itemOffered: { '@type': 'TouristTrip', name: 'Rhodes Rent a Boat', description: 'License-free boat rentals along the Rhodes coast', url: `${SITE_URL}/service/rhodes-rent-a-boat`, image: `${SITE_URL}/assets/img/hero/hero_bg_1_1.jpg` }},
      { '@type': 'Offer', url: `${SITE_URL}/service/rhodes-catamaran-tours`, itemOffered: { '@type': 'TouristTrip', name: 'Rhodes Catamaran Tours', description: 'Day and sunset catamaran experiences', url: `${SITE_URL}/service/rhodes-catamaran-tours`, image: `${SITE_URL}/assets/img/hero/hero_bg_1_1.jpg` }},
      { '@type': 'Offer', url: `${SITE_URL}/service/rhodes-sailing-trips`, itemOffered: { '@type': 'TouristTrip', name: 'Rhodes Sailing Trips', description: 'Shared and private sailing experiences', url: `${SITE_URL}/service/rhodes-sailing-trips`, image: `${SITE_URL}/assets/img/hero/hero_bg_1_1.jpg` }},
    ],
  },
  review: [
    {
      '@type': 'Review',
      itemReviewed: { '@id': `${SITE_URL}#organization` },
      reviewRating: { '@type': 'Rating', ratingValue: '5', bestRating: '5' },
      author: { '@type': 'Person', name: 'Sarah & Tom W.' },
      reviewBody: 'We contacted Rhodes Rent a Boat before our trip and they helped us pick the perfect boat tour for our family. The advice was honest, the captain was fantastic, and the hidden bays we visited were absolutely stunning. Best day of our holiday.',
      datePublished: '2025-09-12',
    },
    {
      '@type': 'Review',
      itemReviewed: { '@id': `${SITE_URL}#organization` },
      reviewRating: { '@type': 'Rating', ratingValue: '5', bestRating: '5' },
      author: { '@type': 'Person', name: 'Marco & Giulia B.' },
      reviewBody: 'We chartered a sailing yacht for a week around the Dodecanese. The team arranged everything — from provisioning to the route. Symi, Halki, Tilos — every island was a new discovery. Truly a local team that knows these waters.',
      datePublished: '2025-08-05',
    },
    {
      '@type': 'Review',
      itemReviewed: { '@id': `${SITE_URL}#organization` },
      reviewRating: { '@type': 'Rating', ratingValue: '5', bestRating: '5' },
      author: { '@type': 'Person', name: 'The Peterson Family' },
      reviewBody: 'Travelling with three kids, we were not sure which cruise to choose. The team recommended the all-inclusive day cruise and it was perfect. The children loved swimming in Anthony Quinn Bay and the food onboard was delicious.',
      datePublished: '2025-07-18',
    },
    {
      '@type': 'Review',
      itemReviewed: { '@id': `${SITE_URL}#organization` },
      reviewRating: { '@type': 'Rating', ratingValue: '5', bestRating: '5' },
      author: { '@type': 'Person', name: 'Anna & David K.' },
      reviewBody: 'The speedboat trip with skipper was the highlight of our Rhodes holiday. We visited beaches that are impossible to reach by car. The skipper knew every hidden spot along the coastline. Cannot recommend this enough.',
      datePublished: '2025-06-24',
    },
    {
      '@type': 'Review',
      itemReviewed: { '@id': `${SITE_URL}#organization` },
      reviewRating: { '@type': 'Rating', ratingValue: '5', bestRating: '5' },
      author: { '@type': 'Person', name: 'Christine L.' },
      reviewBody: 'Renting a license-free boat was so easy. The team explained everything clearly and gave us a map with the best spots. We spent the whole day exploring the southeast coast on our own. Pure freedom.',
      datePublished: '2025-08-30',
    },
    {
      '@type': 'Review',
      itemReviewed: { '@id': `${SITE_URL}#organization` },
      reviewRating: { '@type': 'Rating', ratingValue: '5', bestRating: '5' },
      author: { '@type': 'Person', name: 'Michael & Petra S.' },
      reviewBody: 'The sunset cruise was magical. Watching the sun go down from the water with a glass of wine, surrounded by the Rhodes coastline — it was one of those moments you never forget. Thank you for making it so special.',
      datePublished: '2025-06-08',
    },
  ],
};
---
<script type="application/ld+json" set:html={JSON.stringify(data)} is:inline />
