---
import { SITE_URL, SITE_NAME, FOUNDING_YEAR } from '../../lib/seo';
import { LOCALES, SCHEMA_LANGUAGE, type Locale } from '../../i18n/locales';
import { getMessages } from '../../i18n';
import { localizedPath } from '../../i18n/routing';

interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;
const messages = getMessages(locale);
const schemaLang = SCHEMA_LANGUAGE[locale];

const data = {
  '@context': 'https://schema.org',
  '@type': ['TravelAgency', 'LocalBusiness'],
  '@id': `${SITE_URL}#organization`,
  name: SITE_NAME,
  url: SITE_URL,
  inLanguage: schemaLang,
  logo: {
    '@type': 'ImageObject',
    url: `${SITE_URL}/assets/img/brand/logos/logo2.svg`,
    width: 200,
    height: 60,
  },
  image: `${SITE_URL}/assets/img/heroes/hero_bg_1_1.jpg`,
  description: messages.schema.organizationDescription,
  telephone: '+306951666454',
  email: 'rhodessailingtours2023@gmail.com',
  priceRange: '€€',
  currenciesAccepted: 'EUR',
  paymentAccepted: 'Cash, Credit Card, Bank Transfer',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Ionos Dragoumi 39',
    addressLocality: 'Rhodes Town',
    addressRegion: 'South Aegean',
    postalCode: '85100',
    addressCountry: 'GR',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 36.4497769,
    longitude: 28.2197904,
  },
  areaServed: [
    { '@type': 'Place', name: 'Rhodes, Greece' },
    { '@type': 'Place', name: 'Symi, Greece' },
    { '@type': 'Place', name: 'Lindos, Greece' },
    { '@type': 'Place', name: 'Dodecanese, Greece' },
  ],
  hasMap: 'https://www.google.com/maps/place/Rhodes+Rent+a+Boat/@36.4497769,28.2197904,17z',
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'],
      opens: '09:00',
      closes: '20:00',
      validFrom: '--05-01',
      validThrough: '--10-31',
    },
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'],
      opens: '00:00',
      closes: '00:00',
      validFrom: '--11-01',
      validThrough: '--04-30',
    },
  ],
  sameAs: [
    'https://www.facebook.com/RhodosYachts',
    'https://www.instagram.com/rhodos_yachts/',
    'https://www.google.com/maps/place/Rhodes+Rent+a+Boat/@36.4497769,28.2197904,17z',
  ],
  foundingDate: FOUNDING_YEAR,
  knowsLanguage: [...LOCALES],
  contactPoint: [
    {
      '@type': 'ContactPoint',
      telephone: '+306951666454',
      contactType: 'customer service',
      areaServed: 'GR',
      availableLanguage: ['English', 'German', 'Italian', 'French', 'Russian', 'Hebrew', 'Dutch', 'Polish', 'Ukrainian'],
    },
  ],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: messages.schema.offerCatalogName,
    itemListElement: [
      { '@type': 'Offer', url: `${SITE_URL}${localizedPath('/service/rhodes-boat-tours', locale)}`, itemOffered: { '@type': 'TouristTrip', name: messages.services['rhodes-boat-tours']?.name ?? 'Rhodes Boat Tours', description: messages.services['rhodes-boat-tours']?.schemaDescription ?? '', url: `${SITE_URL}${localizedPath('/service/rhodes-boat-tours', locale)}`, image: `${SITE_URL}/assets/img/tours/hero-rhodes-coast.jpg` }},
      { '@type': 'Offer', url: `${SITE_URL}${localizedPath('/service/rhodes-boat-trips', locale)}`, itemOffered: { '@type': 'TouristTrip', name: messages.services['rhodes-boat-trips']?.name ?? 'Rhodes Boat Trips', description: messages.services['rhodes-boat-trips']?.schemaDescription ?? '', url: `${SITE_URL}${localizedPath('/service/rhodes-boat-trips', locale)}`, image: `${SITE_URL}/assets/img/heroes/hero_bg_1_1.jpg` }},
      { '@type': 'Offer', url: `${SITE_URL}${localizedPath('/service/rhodes-charter', locale)}`, itemOffered: { '@type': 'TouristTrip', name: messages.services['rhodes-charter']?.name ?? 'Rhodes Yacht Charter', description: messages.services['rhodes-charter']?.schemaDescription ?? '', url: `${SITE_URL}${localizedPath('/service/rhodes-charter', locale)}`, image: `${SITE_URL}/assets/img/heroes/hero_bg_1_1.jpg` }},
      { '@type': 'Offer', url: `${SITE_URL}${localizedPath('/', locale)}#rent-a-boat`, itemOffered: { '@type': 'TouristTrip', name: messages.services['rhodes-rent-a-boat']?.name ?? 'Rhodes Rent a Boat', description: messages.services['rhodes-rent-a-boat']?.schemaDescription ?? '', url: `${SITE_URL}${localizedPath('/', locale)}#rent-a-boat`, image: `${SITE_URL}/assets/img/heroes/hero_bg_1_1.jpg` }},
      { '@type': 'Offer', url: `${SITE_URL}${localizedPath('/service/rhodes-catamaran-tours', locale)}`, itemOffered: { '@type': 'TouristTrip', name: messages.services['rhodes-catamaran-tours']?.name ?? 'Rhodes Catamaran Tours', description: messages.services['rhodes-catamaran-tours']?.schemaDescription ?? '', url: `${SITE_URL}${localizedPath('/service/rhodes-catamaran-tours', locale)}`, image: `${SITE_URL}/assets/img/heroes/hero_bg_1_1.jpg` }},
      { '@type': 'Offer', url: `${SITE_URL}${localizedPath('/service/rhodes-sailing-trips', locale)}`, itemOffered: { '@type': 'TouristTrip', name: messages.services['rhodes-sailing-trips']?.name ?? 'Rhodes Sailing Trips', description: messages.services['rhodes-sailing-trips']?.schemaDescription ?? '', url: `${SITE_URL}${localizedPath('/service/rhodes-sailing-trips', locale)}`, image: `${SITE_URL}/assets/img/heroes/hero_bg_1_1.jpg` }},
    ],
  },
  // NOTE: No aggregateRating/review here. Google prohibits self-serving review
  // markup (reviews about the entity that hosts them) and can issue a manual
  // action for it. If real, verifiable reviews are collected, mark them up on
  // the specific product/tour being reviewed — not on the Organization itself.
};
---
<script type="application/ld+json" set:html={JSON.stringify(data)} is:inline />
