# ─────────────────────────────────────────────────────────────────────────────
# Environment variables for tourm-astro (Rhodes Rent a Boat)
#
# Copy this file to `.env` and fill in real values:  cp .env.example .env
# `.env` and `.env.production` are gitignored — never commit real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (required for tours, bookings, auth, dashboard) ──────────────────
# Without these the public pages still render, but tour catalogs are empty and
# /tour-detail/* pages 404. Found in your Supabase project: Settings → API.

# Public project URL and anon key are exposed to the browser (PUBLIC_ prefix).
PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service-role key — SERVER ONLY, bypasses row-level security. Never expose it
# to the browser. Use SUPABASE_SERVICE_ROLE_KEY; the code also accepts the
# Supabase-Vercel-integration alias SUPABASE_SERVICE_ROLE as a fallback, but
# prefer the _KEY form to avoid ambiguity.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Web3Forms (required for the contact + booking forms to send email) ────────
# Get a key at https://web3forms.com. There is no committed fallback: if this
# is unset, form submissions return an error instead of silently failing.
WEB3FORMS_ACCESS_KEY=your-web3forms-access-key

# ── Seed / admin scripts only (scripts/*.mjs) ────────────────────────────────
# Password used when the seed scripts create vendor/admin accounts. Required by
# the scripts (they refuse to run without it). Use a strong value.
SEED_USER_PASSWORD=change-me-to-a-strong-password
