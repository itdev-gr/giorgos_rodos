{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, s-maxage=3600, stale-while-revalidate=86400"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), interest-cohort=()"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self' data:; connect-src 'self' https://*.supabase.co https://www.googletagmanager.com https://www.google-analytics.com https://*.google-analytics.com https://*.analytics.google.com; media-src 'self' https://*.supabase.co; frame-src 'self' https://www.google.com https://www.facebook.com https://www.instagram.com https://www.youtube.com; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'self'; upgrade-insecure-requests"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/favicon.ico",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/favicon-:size(\\d+).png",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/apple-touch-icon.png",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/android-chrome-:size(\\d+).png",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.rhodesrentaboat.com" }],
      "destination": "https://rhodesrentaboat.com/:path*",
      "permanent": true
    },
    {
      "source": "/service/rodos-boat-tours",
      "destination": "/service/rhodes-boat-tours",
      "permanent": true
    },
    {
      "source": "/service/rodos-boat-trips",
      "destination": "/service/rhodes-boat-trips",
      "permanent": true
    },
    {
      "source": "/service/rodos-sailing-trips",
      "destination": "/service/rhodes-sailing-trips",
      "permanent": true
    },
    {
      "source": "/service/rodos-catamaran-tours",
      "destination": "/service/rhodes-catamaran-tours",
      "permanent": true
    },
    {
      "source": "/service/rodos-charter",
      "destination": "/service/rhodes-charter",
      "permanent": true
    },
    {
      "source": "/service/rodos-rent-a-boat",
      "destination": "/service/rhodes-rent-a-boat",
      "permanent": true
    },
    {
      "source": "/tour-detail/all-inclusive-sunset-cruise-a-sunset-remedy",
      "destination": "/tour-detail/sunset-cruise-lindos-calypso",
      "permanent": true
    },
    {
      "source": "/service/rodos-boat-cruises",
      "destination": "/service/rhodes-boat-cruises",
      "permanent": true
    },
    {
      "source": "/blog/rhodes-rent-a-boat",
      "destination": "/blog/rent-a-boat-rhodes-first-timers-guide",
      "permanent": true
    },
    {
      "source": "/things-to-do/rhodes-sidecar-tours",
      "destination": "https://rhodessidecartours.com/",
      "permanent": true
    },
    {
      "source": "/service/rhodes-sidecar-tours",
      "destination": "https://rhodessidecartours.com/",
      "permanent": true
    },
    {
      "source": "/service/rhodes-transfers",
      "destination": "https://www.rhodestransfer24.com/",
      "permanent": true
    },
    {
      "source": "/assets/img/hero/:path*",
      "destination": "/assets/img/heroes/:path*",
      "permanent": true
    },
    {
      "source": "/assets/img/about/:path*",
      "destination": "/assets/img/pages/about/:path*",
      "permanent": true
    }
  ]
}
