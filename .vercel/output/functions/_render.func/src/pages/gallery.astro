---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../sections/home-one/Section1-Header.astro';
import Breadcrumb from '../components/ui/Breadcrumb.astro';
import FooterFour from '../sections/shared/FooterFour.astro';
import GalleryGrid from '../components/interactive/GalleryGrid';

const galleryImages = [
  { src: '/assets/img/gallery/yacht/yacht-exterior-1.jpg', alt: 'Luxury yacht on open water' },
  { src: '/assets/img/gallery/yacht/yacht-interior-1.jpg', alt: 'Elegant yacht interior' },
  { src: '/assets/img/gallery/yacht/sailing-sunset-1.jpg', alt: 'Sailing at sunset' },
  { src: '/assets/img/gallery/yacht/greek-island-1.jpg', alt: 'Greek island coastline' },
  { src: '/assets/img/gallery/yacht/yacht-luxury-1.jpg', alt: 'Luxury yacht in Rhodes' },
  { src: '/assets/img/gallery/yacht/crystal-water-1.jpg', alt: 'Crystal clear waters' },
  { src: '/assets/img/gallery/yacht/yacht-deck-1.jpg', alt: 'Yacht deck view' },
  { src: '/assets/img/gallery/yacht/sunset-cruise-1.jpg', alt: 'Sunset cruise' },
  { src: '/assets/img/gallery/yacht/greek-coast-1.jpg', alt: 'Greek coastline' },
  { src: '/assets/img/gallery/yacht/yacht-sailing-1.jpg', alt: 'Yacht under sail' },
  { src: '/assets/img/cruises/greco_sunset3.jpg', alt: 'Sunset cruise in Rhodes' },
  { src: '/assets/img/gallery/yacht/yacht-luxury-1.jpg', alt: 'Luxury yacht experience' },
];
---

<BaseLayout title="Gallery - Rhodes Boat Tours">
  <Header />
  <Breadcrumb title="Gallery" />

  <section class="gallery-intro">
    <div class="container text-center">
      <h2 class="sec-title">Moments from the Water</h2>
      <p class="gallery-intro__text">A glimpse of what a day with Rhodes Boat Tours looks like — the coastlines, the boats, the light, and the sea.</p>
    </div>
  </section>

  <section class="gallery-section">
    <div class="gallery-wide-container">
      <GalleryGrid images={galleryImages} client:load />
    </div>
  </section>

  <FooterFour />
</BaseLayout>

<style>
  .gallery-intro {
    padding: 60px 0 20px;
  }

  .gallery-intro__text {
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--body-color, #6e7070);
    max-width: 580px;
    margin: 0 auto;
  }

  .gallery-section {
    padding: 20px 0 100px;
    background: #fff;
  }

  .gallery-wide-container {
    max-width: 1600px;
    margin: 0 auto;
    padding: 0 40px;
  }

  /* Mosaic Grid */
  :global(.gallery-mosaic) {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 6px;
    grid-auto-rows: 220px;
  }

  :global(.gallery-mosaic-item) {
    position: relative;
    overflow: hidden;
    cursor: pointer;
  }

  :global(.gallery-mosaic-item img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  :global(.gallery-mosaic-item:hover img) {
    transform: scale(1.03);
  }

  :global(.gallery-mosaic-item::after) {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0);
    transition: background 0.4s ease;
    pointer-events: none;
  }

  :global(.gallery-mosaic-item:hover::after) {
    background: rgba(0, 0, 0, 0.15);
  }

  /* Responsive */
  @media (max-width: 991px) {
    .gallery-wide-container {
      padding: 0 20px;
    }

    :global(.gallery-mosaic) {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: 200px;
    }

    /* Simplify spans on tablet: max 2 cols */
    :global(.gallery-mosaic-item) {
      grid-column: span 1 !important;
      grid-row: span 1 !important;
    }

    /* Let every other image span 2 cols for visual variety */
    :global(.gallery-mosaic-item:nth-child(5)),
    :global(.gallery-mosaic-item:nth-child(8)),
    :global(.gallery-mosaic-item:nth-child(10)) {
      grid-column: span 2 !important;
      grid-row: span 1 !important;
    }

    .gallery-section {
      padding: 15px 0 80px;
    }
  }

  @media (max-width: 575px) {
    .gallery-wide-container {
      padding: 0 12px;
    }

    :global(.gallery-mosaic) {
      grid-template-columns: 1fr;
      grid-auto-rows: 220px;
      gap: 4px;
    }

    :global(.gallery-mosaic-item) {
      grid-column: span 1 !important;
      grid-row: span 1 !important;
    }

    .gallery-section {
      padding: 10px 0 60px;
    }
  }
</style>
